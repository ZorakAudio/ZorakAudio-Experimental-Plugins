desc:Hyperreal 3D Panner V6.2.1 (Perceptual Position + Visual Cues + Tooltip Alignment Fix)

// #HELP: Headphone-focused 3D panner using softened perceptual placement, microdelay, head shadow, pinna cues, distance loss, occlusion, and room cues.
// #HELP: Drag the orange source in the stage canvas. X = Lateral, Y = Front/Rear. Mouse wheel changes Distance.
// #HELP: Spatial Throw controls how strongly the placement asserts itself without changing output gain.
// #HELP: Solid orange = visual object position. Ghost orange = effective cue position after Throw / Cue Curve compression.
// #HELP: Cyan wall markers are EARLY BOUNCES: first reflection hits used for out-of-head placement.
// #HELP: Automation Safe caps aggressive throw and lengthens smoothing for drawn automation.
// #HELP: Visual cues: Size = orange halo/cloud, Distance = grey range rings/dashes, Push Out = listener shell, Room = cyan bounces/wall glow, Motion = green trail.
// #HELP: Hover any canvas cue, snap chip, Automation Safe button, or quick-control lane for inline guidance. Tooltips use exact hit zones and dock away from controls.
// #TOOLTIP: Perceptual object panner. Place the object visually, then scale how hard the cue stack fires.

options:want_all_kb
options:gfx_hz=60

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

// POSITION
// #TOOLTIP: Left/right object placement. Negative = left, positive = right.
slider1:0<-1,1,0.001>-Lateral
// #TOOLTIP: Physical distance throw. V6 uses a shorter, higher-resolution stage range than V5.
slider2:0.25<0,1,0.001>-Distance
// #TOOLTIP: Front/rear object placement. +1 = front wall, 0 = side plane, -1 = rear wall.
slider3:0.82<-1,1,0.001>-Depth Front/Rear

// FEEL
// #TOOLTIP: Spatial cue intensity. Higher = stronger ITD/head-shadow/pinna/side cues. Does not change loudness.
slider4:0.58<0,1,0.001>-Spatial Throw
// #TOOLTIP: Apparent source size. Lower = tighter point source; higher = wider / more diffuse image.
slider5:0.10<0,1,0.001>-Size
// #TOOLTIP: Out-of-head realism cue strength. Formerly Externalize.
slider6:0.42<0,1,0.001>-Push Out
// #TOOLTIP: Early reflection amount. Higher = more room cue and more externalization, less surgical precision.
slider7:0.30<0,1,0.001>-Room

// MATERIAL / MOTION
// #TOOLTIP: How blocked or hidden the source is. Higher = more muffled direct sound and more reflection dominance.
slider8:0<0,1,0.001>-Occlusion
// #TOOLTIP: Tiny motion added to keep static sources from collapsing inward on headphones.
slider9:0.04<0,1,0.001>-Micro Motion
// #TOOLTIP: Final output trim after spatial processing.
slider10:0<-18,12,0.1>-Output Trim (dB)

// AUTOMATION / ADVANCED
// #TOOLTIP: Caps aggressive spatial throw and uses safer smoothing for automation curves.
slider11:1<0,1,1>-Automation Safe
// #TOOLTIP: Perceptual compression curve. Higher values make moderate visual angles less extreme.
slider12:2.00<1,3,0.01>-Cue Curve
// #TOOLTIP: Movement smoothing in milliseconds. Automation Safe enforces a higher minimum.
slider13:90<5,250,1>-Motion Smooth (ms)
// #TOOLTIP: Geometric room scale for the bounce model. Higher = larger room and longer early reflection timing.
slider14:0.55<0,1,0.001>-Room Size

// V6 control model:
//   Lateral + Depth Front/Rear = visual object coordinate.
//   Distance                  = near/far physical distance.
//   Spatial Throw             = strength of the directional cue stack.
//   Push Out                  = outside-head realism / pinna-room emphasis.
//   Cue Curve                 = how much mid-angle positions are softened.

@init
// --- delay buffers ---
er_bufsize = 32768;
er_mask = er_bufsize - 1;
er_wpos = 0;

itd_bufsize = 4096;
itd_mask = itd_bufsize - 1;
itd_wpos = 0;

loop_cnt = 0;
loop(er_bufsize,
  erbuf[loop_cnt] = 0;
  loop_cnt += 1;
);

loop_cnt = 0;
loop(itd_bufsize,
  itdbuf[loop_cnt] = 0;
  loop_cnt += 1;
);

// --- smoothing ---
// V6 recalculates smooth_k / coeff_k from the Motion Smooth slider in @block.
smooth_k = 1 - exp(-1/(0.090*srate));
coeff_k  = 1 - exp(-1/(0.140*srate));
meter_k  = 1 - exp(-1/(0.050*srate));

// --- filters / splits ---
split_fc = 1000;
split_a = exp(-2*$pi*split_fc/srate);

occ_split_fc = 650;
occ_split_a = exp(-2*$pi*occ_split_fc/srate);

band1_fc = 320;
band2_fc = 1800;
band1_a = exp(-2*$pi*band1_fc/srate);
band2_a = exp(-2*$pi*band2_fc/srate);

// --- reflection defaults ---
er_a1 = exp(-2*$pi*12500/srate);
er_a2 = exp(-2*$pi*9800/srate);
er_a3 = exp(-2*$pi*8000/srate);
er_a4 = exp(-2*$pi*6400/srate);
er_a5 = exp(-2*$pi*5200/srate);
er_a6 = exp(-2*$pi*4200/srate);
er_a7 = exp(-2*$pi*3200/srate);
er_a8 = exp(-2*$pi*2600/srate);

// --- smoothed params ---
// sm_az is the softened/cue-scaled azimuth, not the visual placement angle.
sm_az = 0;
sm_depth = 0.25;
sm_width = 0.10;
sm_ext = 0.42;
sm_room = 0.30;
sm_rsize = 0.55;
sm_occ = 0;
sm_motion = 0.04;
sm_trim = 1;

// --- smoothed derived ---
sm_direct_g = 1;
sm_er_g = 0;
sm_air_a = 0.2;
sm_occ_a = 0.5;

sm_er1_d = 250;
sm_er2_d = 420;
sm_er3_d = 620;
sm_er4_d = 920;
sm_er5_d = 1300;
sm_er6_d = 1800;
sm_er7_d = 2450;
sm_er8_d = 3300;

// --- states ---
air_state = 0;
occ_lp = 0;
occ_low_mem = 0;
occ_ap_x1 = 0;
occ_ap_y1 = 0;

// head-shadow split states
l_low = 0;
r_low = 0;

// perceptual band split states
l_band1 = 0;
l_band2 = 0;
r_band1 = 0;
r_band2 = 0;

// ER filter states
er_lp1 = 0;
er_lp2 = 0;
er_lp3 = 0;
er_lp4 = 0;
er_lp5 = 0;
er_lp6 = 0;
er_lp7 = 0;
er_lp8 = 0;

// ER decorrelation allpass (per channel)
er_ap_x1_l = 0; er_ap_y1_l = 0;
er_ap_x1_r = 0; er_ap_y1_r = 0;

// Pinna (biquad) states
pn_x1_l = 0; pn_x2_l = 0; pn_y1_l = 0; pn_y2_l = 0;
pn_x1_r = 0; pn_x2_r = 0; pn_y1_r = 0; pn_y2_r = 0;

// Pinna coeffs (smoothed)
pn_b0_l = 1; pn_b1_l = 0; pn_b2_l = 0; pn_a1_l = 0; pn_a2_l = 0;
pn_b0_r = 1; pn_b1_r = 0; pn_b2_r = 0; pn_a1_r = 0; pn_a2_r = 0;

// Pinna coeff targets
pn_t_b0_l = 1; pn_t_b1_l = 0; pn_t_b2_l = 0; pn_t_a1_l = 0; pn_t_a2_l = 0;
pn_t_b0_r = 1; pn_t_b1_r = 0; pn_t_b2_r = 0; pn_t_a1_r = 0; pn_t_a2_r = 0;

// Rear tint (very mild)
rear_lp_l = 0;
rear_lp_r = 0;
rear_a = exp(-2*$pi*18000/srate);
rear_t_a = rear_a;
rear_mix = 0;
rear_t_mix = 0;

// Motion LFO
ph1 = 0;
ph2 = 0;

// meters / readouts
meter_direct = 0;
meter_er = 0;
last_itd_ms = 0;
last_air_fc = 18000;
last_dist_m = 0.3;
last_ext_db = 0;
last_rear = 0;
last_focus = 1;
last_shadow = 0;
last_front = 1;
last_side = 0;
last_back = 0;
last_room_w = 4.8;
last_room_d = 5.6;

// V6 perceptual placement readouts
last_visual_az = 0;
last_cue_az = 0;
last_throw = 0.58;
last_throw_dsp = 0.58;
last_lat = 0;
last_fb = 0.82;
last_smooth_ms = 90;
last_cue_curve_eff = 1;
last_automation_safe = 1;

// UI interaction
ui_mode = 0;
ui_prev_l = 0;
ui_prev_r = 0;
ui_drag_start_x = 0;
ui_drag_start_y = 0;
ui_drag_start_v1 = 0;
ui_drag_start_v2 = 0;
ui_drag_bar = 0;


@block
// V6 perceptual-position mapping.
// User-facing position is a stage coordinate; DSP receives a softened cue azimuth.

// --- raw UI targets ---
tgt_lat = slider1;
tgt_lat < -1 ? tgt_lat = -1;
tgt_lat > 1 ? tgt_lat = 1;

tgt_dist_n = slider2;
tgt_dist_n < 0 ? tgt_dist_n = 0;
tgt_dist_n > 1 ? tgt_dist_n = 1;

tgt_fb = slider3;
tgt_fb < -1 ? tgt_fb = -1;
tgt_fb > 1 ? tgt_fb = 1;

tgt_throw = slider4;
tgt_throw < 0 ? tgt_throw = 0;
tgt_throw > 1 ? tgt_throw = 1;

tgt_width = slider5;
tgt_width < 0 ? tgt_width = 0;
tgt_width > 1 ? tgt_width = 1;

tgt_ext = slider6;
tgt_ext < 0 ? tgt_ext = 0;
tgt_ext > 1 ? tgt_ext = 1;

tgt_room = slider7;
tgt_room < 0 ? tgt_room = 0;
tgt_room > 1 ? tgt_room = 1;

tgt_occ = slider8;
tgt_occ < 0 ? tgt_occ = 0;
tgt_occ > 1 ? tgt_occ = 1;

tgt_motion = slider9;
tgt_motion < 0 ? tgt_motion = 0;
tgt_motion > 1 ? tgt_motion = 1;

tgt_trim = 10^(slider10/20);

auto_safe = slider11 >= 0.5 ? 1 : 0;
last_automation_safe = auto_safe;

cue_curve_user = slider12;
cue_curve_user < 1 ? cue_curve_user = 1;
cue_curve_user > 3 ? cue_curve_user = 3;

smooth_ms = slider13;
smooth_ms < 5 ? smooth_ms = 5;
auto_safe && smooth_ms < 90 ? smooth_ms = 90;
last_smooth_ms = smooth_ms;
smooth_k = 1 - exp(-1/((smooth_ms*0.001)*srate));
coeff_ms = smooth_ms * 1.55;
coeff_ms < 15 ? coeff_ms = 15;
coeff_k = 1 - exp(-1/((coeff_ms*0.001)*srate));
meter_k  = 1 - exp(-1/(0.050*srate));

tgt_rsize = slider14;
tgt_rsize < 0 ? tgt_rsize = 0;
tgt_rsize > 1 ? tgt_rsize = 1;

// --- visual coordinate normalization ---
pos_r = sqrt(tgt_lat*tgt_lat + tgt_fb*tgt_fb);
(pos_r > 1) ? (
  vis_lat = tgt_lat / pos_r;
  vis_fb = tgt_fb / pos_r;
  pos_r = 1;
) : (
  vis_lat = tgt_lat;
  vis_fb = tgt_fb;
);

// If object is dead-center, treat it as front-center so cue math stays stable.
pos_r < 0.0001 ? (
  raw_side = 0;
  raw_front = 1;
) : (
  raw_side = vis_lat / pos_r;
  raw_front = vis_fb / pos_r;
);

// Visual angle readout, preserving V5 convention: negative = left, positive = right.
vis_ang = atan(raw_side / (abs(raw_front) + 0.000000000000000001)) * 180 / $pi;
(raw_front < 0) ? (
  raw_side >= 0 ? vis_ang = 180 - vis_ang : vis_ang = -180 - vis_ang;
);
last_visual_az = vis_ang;
last_lat = vis_lat;
last_fb = vis_fb;

// Spatial Throw becomes the cue-stack intensity. Automation Safe caps it.
throw_dsp = tgt_throw;
auto_safe && throw_dsp > 0.72 ? throw_dsp = 0.72;
last_throw = tgt_throw;
last_throw_dsp = throw_dsp;

// Perceptual compression: 45 degrees visual no longer equals 70% max side cue by default.
// Throw 100% returns to raw/V5-like side cueing. Lower throw both compresses and scales.
curve_eff = 1 + (1 - throw_dsp) * (cue_curve_user - 1);
last_cue_curve_eff = curve_eff;
side_abs = abs(raw_side);
cue_side = side_abs^curve_eff;
raw_side < 0 ? cue_side = -cue_side;
cue_side *= 0.50 + 0.50*throw_dsp;
cue_side > 0.999 ? cue_side = 0.999;
cue_side < -0.999 ? cue_side = -0.999;
cue_front_abs = sqrt(1 - cue_side*cue_side);
cue_front = raw_front < 0 ? -cue_front_abs : cue_front_abs;

cue_ang = atan(cue_side / (abs(cue_front) + 0.000000000000000001)) * 180 / $pi;
(cue_front < 0) ? (
  cue_side >= 0 ? cue_ang = 180 - cue_ang : cue_ang = -180 - cue_ang;
);
tgt_az = cue_ang;
last_cue_az = cue_ang;

// Distance mapping: V6 trades V5's huge 22m reach for faster, higher-resolution stage placement.
_depth2 = tgt_dist_n*tgt_dist_n;
_depth3 = _depth2*tgt_dist_n;
tgt_depth = tgt_dist_n;
dist_m = 0.18 + 8.82*(0.72*_depth2 + 0.28*_depth3);
last_dist_m = dist_m;

// Direct gain vs distance/occlusion
_direct_g = 1 / (1 + 0.26*dist_m);
_direct_g *= 1 - 0.28*tgt_occ;
_direct_g < 0.11 ? _direct_g = 0.11;
tgt_direct_g = _direct_g;

// Room gain vs distance + occlusion
_er_g = tgt_room * (0.035 + 0.16*tgt_depth + 0.11*_depth2);
_er_g *= 1 + 0.85*tgt_occ;
tgt_er_g = _er_g;

// Air absorption cutoff (distance + occlusion)
air_fc = 19000 / (1 + 0.20*dist_m + 1.7*tgt_occ);
air_fc < 1700 ? air_fc = 1700;
air_fc > 19000 ? air_fc = 19000;
last_air_fc = air_fc;
tgt_air_a = exp(-2*$pi*air_fc/srate);

// Occlusion cutoff
occ_fc = 13000 / (1 + 18*tgt_occ*tgt_occ);
occ_fc < 450 ? occ_fc = 450;
occ_fc > 13000 ? occ_fc = 13000;
tgt_occ_a = exp(-2*$pi*occ_fc/srate);

// Room geometry (for early reflections + UI readout)
room_curve = tgt_rsize*tgt_rsize*(0.72 + 0.28*tgt_rsize);
room_w = 2.8 + 9.8*room_curve;
room_d = 3.3 + 12.2*room_curve;
last_room_w = room_w;
last_room_d = room_d;

// Reflection delays from a simple image-source style room.
// Uses visual object coordinate, not compressed cue angle, so the room picture remains honest.
src_nx = 0.74 * vis_lat;
src_ny = 0.74 * vis_fb;

hw = room_w * 0.5;
hd = room_d * 0.5;

direct_geom = sqrt((src_nx*hw)*(src_nx*hw) + (src_ny*hd)*(src_ny*hd));
direct_geom < 0.08 ? direct_geom = 0.08;

len_l  = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + ((src_ny)*hd)*((src_ny)*hd));
len_r  = sqrt((( (2 - src_nx)*hw))*(((2 - src_nx)*hw)) + ((src_ny)*hd)*((src_ny)*hd));
len_f  = sqrt(((src_nx*hw)*(src_nx*hw)) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_b  = sqrt(((src_nx*hw)*(src_nx*hw)) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));
len_fl = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_fr = sqrt((((2 - src_nx)*hw))*(((2 - src_nx)*hw)) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_bl = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));
len_br = sqrt((((2 - src_nx)*hw))*(((2 - src_nx)*hw)) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));

ms_scale = 1000/343;
base_ms = 0.8 + 1.5*tgt_depth + 0.6*tgt_room;

d1 = base_ms + max(1.0, (len_l  - direct_geom) * ms_scale);
d2 = base_ms + max(1.0, (len_r  - direct_geom) * ms_scale);
d3 = base_ms + max(1.0, (len_f  - direct_geom) * ms_scale);
d4 = base_ms + max(1.2, (len_b  - direct_geom) * ms_scale);
d5 = base_ms + max(1.5, (len_fl - direct_geom) * ms_scale);
d6 = base_ms + max(1.5, (len_fr - direct_geom) * ms_scale);
d7 = base_ms + max(1.8, (len_bl - direct_geom) * ms_scale);
d8 = base_ms + max(1.8, (len_br - direct_geom) * ms_scale);

tgt_er1_d = d1 * srate * 0.001;
tgt_er2_d = d2 * srate * 0.001;
tgt_er3_d = d3 * srate * 0.001;
tgt_er4_d = d4 * srate * 0.001;
tgt_er5_d = d5 * srate * 0.001;
tgt_er6_d = d6 * srate * 0.001;
tgt_er7_d = d7 * srate * 0.001;
tgt_er8_d = d8 * srate * 0.001;

// Reflection LPFs get darker with distance + occlusion + rear bias
hf_scale = 1 / (1 + 0.14*dist_m + 1.1*tgt_occ);

c1 = 11800*hf_scale; c2 = 11800*hf_scale; c3 = 10200*hf_scale; c4 = 7200*hf_scale;
c5 = 7600*hf_scale;  c6 = 7600*hf_scale;  c7 = 5200*hf_scale; c8 = 5200*hf_scale;

c1 < 1500 ? c1=1500; c2 < 1500 ? c2=1500; c3 < 1500 ? c3=1500; c4 < 1500 ? c4=1500;
c5 < 1500 ? c5=1500; c6 < 1500 ? c6=1500; c7 < 1500 ? c7=1500; c8 < 1500 ? c8=1500;

c1 > 18000 ? c1=18000; c2 > 18000 ? c2=18000; c3 > 18000 ? c3=18000; c4 > 18000 ? c4=18000;
c5 > 18000 ? c5=18000; c6 > 18000 ? c6=18000; c7 > 18000 ? c7=18000; c8 > 18000 ? c8=18000;

er_a1 = exp(-2*$pi*c1/srate);
er_a2 = exp(-2*$pi*c2/srate);
er_a3 = exp(-2*$pi*c3/srate);
er_a4 = exp(-2*$pi*c4/srate);
er_a5 = exp(-2*$pi*c5/srate);
er_a6 = exp(-2*$pi*c6/srate);
er_a7 = exp(-2*$pi*c7/srate);
er_a8 = exp(-2*$pi*c8/srate);

// --- Pinna externalize biquad (negative peaking EQ = notch hint) ---
az_rad = tgt_az * $pi / 180;
az_s = sin(az_rad);
az_c = cos(az_rad);
az_abs = abs(az_s);
front = max(0, az_c);
rear = max(0, -az_c);
side = 1 - abs(az_c);
side < 0 ? side = 0;
last_rear = rear;
last_front = front;
last_side = side;
last_back = rear;

focus = 1 - 0.74*tgt_width;
focus < 0.18 ? focus = 0.18;
last_focus = focus;
last_shadow = az_abs * focus;

// semantic zone weighting:
// front = cleaner / tighter
// side  = stronger lateral lock
// back  = darker / more notch / wider reflections
zone_notch = 0.70 + 0.55*side + 0.85*rear;
notch_db = -6.8 * tgt_ext * (0.18 + 0.82*az_abs) * zone_notch * focus;
last_ext_db = notch_db;

Q = 3.0 + 2.6*tgt_ext;

base_fc = 7150 + 220*front - 650*side - 1250*rear;
span_fc = (1700 + 450*side + 250*rear) * focus;

fc_l = base_fc - span_fc*az_s;
fc_r = base_fc + span_fc*az_s;

fc_l < 2200 ? fc_l = 2200; fc_l > 11200 ? fc_l = 11200;
fc_r < 2200 ? fc_r = 2200; fc_r > 11200 ? fc_r = 11200;

abs(notch_db) < 0.001 ? (
  pn_t_b0_l = 1; pn_t_b1_l = 0; pn_t_b2_l = 0; pn_t_a1_l = 0; pn_t_a2_l = 0;
  pn_t_b0_r = 1; pn_t_b1_r = 0; pn_t_b2_r = 0; pn_t_a1_r = 0; pn_t_a2_r = 0;
) : (
  A = 10^(notch_db/40);

  // Left
  w0 = 2*$pi*fc_l/srate;
  cs = cos(w0);
  sn = sin(w0);
  alpha = sn/(2*Q);
  b0 = 1 + alpha*A;
  b1 = -2*cs;
  b2 = 1 - alpha*A;
  a0 = 1 + alpha/A;
  a1 = -2*cs;
  a2 = 1 - alpha/A;
  b0 /= a0; b1 /= a0; b2 /= a0; a1 /= a0; a2 /= a0;
  pn_t_b0_l = b0; pn_t_b1_l = b1; pn_t_b2_l = b2; pn_t_a1_l = a1; pn_t_a2_l = a2;

  // Right
  w0 = 2*$pi*fc_r/srate;
  cs = cos(w0);
  sn = sin(w0);
  alpha = sn/(2*Q);
  b0 = 1 + alpha*A;
  b1 = -2*cs;
  b2 = 1 - alpha*A;
  a0 = 1 + alpha/A;
  a1 = -2*cs;
  a2 = 1 - alpha/A;
  b0 /= a0; b1 /= a0; b2 /= a0; a1 /= a0; a2 /= a0;
  pn_t_b0_r = b0; pn_t_b1_r = b1; pn_t_b2_r = b2; pn_t_a1_r = a1; pn_t_a2_r = a2;
);

// Rear tint targets (very gentle, only when push out is up)
rear_t_mix = (0.08*side + 0.34*rear) * tgt_ext;
rear_fc = 18000 / (1 + 1.2*side*tgt_ext + 2.8*rear*tgt_ext);
rear_fc < 2300 ? rear_fc = 2300;
rear_fc > 18000 ? rear_fc = 18000;
rear_t_a = exp(-2*$pi*rear_fc/srate);

@sample
// --- input to mono ---
mono_in = (spl0 + spl1) * 0.5;

// --- smooth user params ---
sm_az     += (tgt_az     - sm_az)     * smooth_k;
sm_depth  += (tgt_depth  - sm_depth)  * smooth_k;
sm_width  += (tgt_width  - sm_width)  * smooth_k;
sm_ext    += (tgt_ext    - sm_ext)    * smooth_k;
sm_room   += (tgt_room   - sm_room)   * smooth_k;
sm_rsize  += (tgt_rsize  - sm_rsize)  * smooth_k;
sm_occ    += (tgt_occ    - sm_occ)    * smooth_k;
sm_motion += (tgt_motion - sm_motion) * smooth_k;
sm_trim   += (tgt_trim   - sm_trim)   * smooth_k;

// --- smooth derived ---
sm_direct_g += (tgt_direct_g - sm_direct_g) * smooth_k;
sm_er_g     += (tgt_er_g     - sm_er_g)     * smooth_k;
sm_air_a    += (tgt_air_a    - sm_air_a)    * coeff_k;
sm_occ_a    += (tgt_occ_a    - sm_occ_a)    * coeff_k;

sm_er1_d += (tgt_er1_d - sm_er1_d) * smooth_k;
sm_er2_d += (tgt_er2_d - sm_er2_d) * smooth_k;
sm_er3_d += (tgt_er3_d - sm_er3_d) * smooth_k;
sm_er4_d += (tgt_er4_d - sm_er4_d) * smooth_k;
sm_er5_d += (tgt_er5_d - sm_er5_d) * smooth_k;
sm_er6_d += (tgt_er6_d - sm_er6_d) * smooth_k;
sm_er7_d += (tgt_er7_d - sm_er7_d) * smooth_k;
sm_er8_d += (tgt_er8_d - sm_er8_d) * smooth_k;

// Smooth pinna biquad coefficients
pn_b0_l += (pn_t_b0_l - pn_b0_l) * coeff_k;
pn_b1_l += (pn_t_b1_l - pn_b1_l) * coeff_k;
pn_b2_l += (pn_t_b2_l - pn_b2_l) * coeff_k;
pn_a1_l += (pn_t_a1_l - pn_a1_l) * coeff_k;
pn_a2_l += (pn_t_a2_l - pn_a2_l) * coeff_k;

pn_b0_r += (pn_t_b0_r - pn_b0_r) * coeff_k;
pn_b1_r += (pn_t_b1_r - pn_b1_r) * coeff_k;
pn_b2_r += (pn_t_b2_r - pn_b2_r) * coeff_k;
pn_a1_r += (pn_t_a1_r - pn_a1_r) * coeff_k;
pn_a2_r += (pn_t_a2_r - pn_a2_r) * coeff_k;

rear_a   += (rear_t_a   - rear_a)   * coeff_k;
rear_mix += (rear_t_mix - rear_mix) * coeff_k;

// --- optional micro motion ---
ph1 += (2*$pi*(0.12 + 0.08*sm_motion))/srate;
ph2 += (2*$pi*(0.20 + 0.10*sm_motion))/srate;
(ph1 > 2*$pi) ? ph1 -= 2*$pi;
(ph2 > 2*$pi) ? ph2 -= 2*$pi;

mot_deg = 2.3 * sm_motion;
az_eff = sm_az + mot_deg*(sin(ph1) + 0.55*sin(ph2));
az_eff > 180 ? az_eff = 180;
az_eff < -180 ? az_eff = -180;

// --- distance / air absorption ---
air_state = (1-sm_air_a)*mono_in + sm_air_a*air_state;

// --- improved occlusion ---
occ_lp = (1-sm_occ_a)*air_state + sm_occ_a*occ_lp;
occ_low_mem = (1-occ_split_a)*occ_lp + occ_split_a*occ_low_mem;
occ_high = occ_lp - occ_low_mem;

occ_low_g  = 1 + 0.30*sm_occ;
occ_high_g = 1 - 0.90*sm_occ;
occ_high_g < 0.08 ? occ_high_g = 0.08;
occ_sig = occ_low_mem*occ_low_g + occ_high*occ_high_g;

// phase smear
ap_a = 0.56 + 0.30*sm_occ;
ap_y = -ap_a*occ_sig + occ_ap_x1 + ap_a*occ_ap_y1;
occ_ap_x1 = occ_sig;
occ_ap_y1 = ap_y;
occ_sig = ap_y;

// direct path mixes around occlusion; reflections are less occluded
direct_feed = air_state*(1-sm_occ) + occ_sig*sm_occ;
er_feed = air_state*(1 - 0.32*sm_occ) + occ_sig*(0.32*sm_occ);

// --- ITD delay line ---
itdbuf[itd_wpos] = direct_feed;

az_rad = az_eff * $pi / 180;
az_sin = sin(az_rad);
az_cos = cos(az_rad);
az_abs = abs(az_sin);
az_sign = az_eff >= 0 ? 1 : -1;

focus = 1 - 0.74*sm_width;
focus < 0.18 ? focus = 0.18;

itd_ms = 0.68 * az_sin * focus;
last_itd_ms = itd_ms;
itd_spl = abs(itd_ms) * 0.001 * srate;
itd_i = floor(itd_spl);
itd_f = itd_spl - itd_i;
idx0 = (itd_wpos - itd_i) & itd_mask;
idx1 = (itd_wpos - itd_i - 1) & itd_mask;
far_sig = itdbuf[idx0]*(1-itd_f) + itdbuf[idx1]*itd_f;

az_eff < 0 ? (
  sig_l = direct_feed;
  sig_r = far_sig;
) : (
  sig_l = far_sig;
  sig_r = direct_feed;
);

itd_wpos = (itd_wpos + 1) & itd_mask;

// --- perceptual band split (rough critical-band inspired weighting) ---
l_band1 = (1-band1_a)*sig_l + band1_a*l_band1;
l_rem1 = sig_l - l_band1;
l_band2 = (1-band2_a)*l_rem1 + band2_a*l_band2;
l_lowb = l_band1;
l_midb = l_band2;
l_hib = l_rem1 - l_band2;

r_band1 = (1-band1_a)*sig_r + band1_a*r_band1;
r_rem1 = sig_r - r_band1;
r_band2 = (1-band2_a)*r_rem1 + band2_a*r_band2;
r_lowb = r_band1;
r_midb = r_band2;
r_hib = r_rem1 - r_band2;

// --- frequency-shaped directional weighting ---
front = max(0, az_cos);
rear = max(0, -az_cos);
side = 1 - abs(az_cos);
side < 0 ? side = 0;
shadow = az_abs * focus;
nearfield = 1 - sm_depth;
nearfield < 0 ? nearfield = 0;

// semantic field zones
front_tight = 1 + 0.12*front;
side_lock   = 1 + 0.28*side;
rear_diff   = 1 + 0.30*rear;

// low band = mostly ITD, mild level asymmetry
low_near_g = 1 + 0.03*shadow;
low_far_g  = 1 - 0.10*shadow;
low_far_g < 0.84 ? low_far_g = 0.84;

// mid band = stronger direction + slight proximity push
mid_shape = (1 + 0.10*sm_ext*front - 0.16*sm_ext*rear) * (1 + 0.10*side);
mid_near_g = (1 + 0.10*shadow*side_lock + 0.05*nearfield) * mid_shape;
mid_far_g  = (1 - 0.36*shadow*side_lock - 0.05*rear) * (1 - 0.05*sm_ext*rear);
mid_far_g < 0.30 ? mid_far_g = 0.30;

// high band = strongest head shadow + front/back character
hi_shape = (1 + 0.08*sm_ext*front - 0.24*sm_ext*rear) * (1 + 0.08*side);
hi_near_g = (1 + 0.18*shadow*side_lock + 0.05*nearfield + 0.05*sm_ext*front) * hi_shape;
hi_far_g  = (1 - 0.92*shadow*side_lock - 0.22*sm_ext*rear);
hi_far_g < 0.08 ? hi_far_g = 0.08;

az_eff < 0 ? (
  dir_l = l_lowb*low_near_g + l_midb*mid_near_g + l_hib*hi_near_g;
  dir_r = r_lowb*low_far_g  + r_midb*mid_far_g  + r_hib*hi_far_g;
) : (
  dir_l = l_lowb*low_far_g  + l_midb*mid_far_g  + l_hib*hi_far_g;
  dir_r = r_lowb*low_near_g + r_midb*mid_near_g + r_hib*hi_near_g;
);

// Additional broad-band split for a gentle low/high pan contour
l_low = (1-split_a)*dir_l + split_a*l_low;
r_low = (1-split_a)*dir_r + split_a*r_low;
l_high = dir_l - l_low;
r_high = dir_r - r_low;

shadow_h = shadow;
shadow_l = shadow * 0.25;

near_low_g = 1 + 0.03*shadow_l;
far_low_g  = 1 - 0.14*shadow_l;
near_hi_g  = 1 + 0.06*shadow_h;
far_hi_g   = 1 - 0.28*shadow_h;
far_hi_g < 0.70 ? far_hi_g = 0.70;

az_eff < 0 ? (
  dir_l = l_low*near_low_g + l_high*near_hi_g;
  dir_r = r_low*far_low_g  + r_high*far_hi_g;
) : (
  dir_l = l_low*far_low_g  + l_high*far_hi_g;
  dir_r = r_low*near_low_g + r_high*near_hi_g;
);

// Width = blur toward center, more at distance
center_blend = sm_width * (0.22 + 0.10*sm_depth + 0.10*rear);
center_blend > 0.45 ? center_blend = 0.45;
dir_l = dir_l*(1-center_blend) + direct_feed*center_blend;
dir_r = dir_r*(1-center_blend) + direct_feed*center_blend;

// --- pinna externalize hint ---
pn_y = pn_b0_l*dir_l + pn_b1_l*pn_x1_l + pn_b2_l*pn_x2_l - pn_a1_l*pn_y1_l - pn_a2_l*pn_y2_l;
pn_x2_l = pn_x1_l; pn_x1_l = dir_l;
pn_y2_l = pn_y1_l; pn_y1_l = pn_y;
dir_l = pn_y;

pn_y = pn_b0_r*dir_r + pn_b1_r*pn_x1_r + pn_b2_r*pn_x2_r - pn_a1_r*pn_y1_r - pn_a2_r*pn_y2_r;
pn_x2_r = pn_x1_r; pn_x1_r = dir_r;
pn_y2_r = pn_y1_r; pn_y1_r = pn_y;
dir_r = pn_y;

// --- rear tint ---
rear_lp_l = (1-rear_a)*dir_l + rear_a*rear_lp_l;
rear_lp_r = (1-rear_a)*dir_r + rear_a*rear_lp_r;
dir_l = dir_l*(1-rear_mix) + rear_lp_l*rear_mix;
dir_r = dir_r*(1-rear_mix) + rear_lp_r*rear_mix;
dir_l *= front_tight;
dir_r *= front_tight;
rear_scale = 1 - 0.05*rear;
dir_l *= rear_scale + 0.05*front;
dir_r *= rear_scale + 0.05*front;

// apply distance gain after spectral cues
dir_l *= sm_direct_g;
dir_r *= sm_direct_g;

// --- Early reflections buffer ---
erbuf[er_wpos] = er_feed;

er_l = 0;
er_r = 0;
rear_wide = 1 + 0.32*rear;
front_focus = 1 - 0.20*front;
side_wide = 1 + 0.18*side;

// Tap 1: left wall
rd = sm_er1_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp1 = (1-er_a1)*tap + er_a1*er_lp1;
er_l += er_lp1 * 0.45 * 1.22 * front_focus;
er_r += er_lp1 * 0.45 * 0.74 * front_focus;

// Tap 2: right wall
rd = sm_er2_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp2 = (1-er_a2)*tap + er_a2*er_lp2;
er_l += er_lp2 * 0.45 * 0.74 * front_focus;
er_r += er_lp2 * 0.45 * 1.22 * front_focus;

// Tap 3: front wall
rd = sm_er3_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp3 = (1-er_a3)*tap + er_a3*er_lp3;
er_l += er_lp3 * 0.34 * (0.98 + 0.05*side);
er_r += er_lp3 * 0.34 * (0.98 + 0.05*side);

// Tap 4: back wall
rd = sm_er4_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp4 = (1-er_a4)*tap + er_a4*er_lp4;
er_l += er_lp4 * 0.26 * rear_wide * 1.04;
er_r += er_lp4 * 0.26 * rear_wide * 1.04;

// Tap 5: front-left corner
rd = sm_er5_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp5 = (1-er_a5)*tap + er_a5*er_lp5;
er_l += er_lp5 * 0.20 * 1.16;
er_r += er_lp5 * 0.20 * 0.86;

// Tap 6: front-right corner
rd = sm_er6_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp6 = (1-er_a6)*tap + er_a6*er_lp6;
er_l += er_lp6 * 0.20 * 0.86;
er_r += er_lp6 * 0.20 * 1.16;

// Tap 7: back-left corner
rd = sm_er7_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp7 = (1-er_a7)*tap + er_a7*er_lp7;
er_l += er_lp7 * 0.13 * 1.14 * rear_wide;
er_r += er_lp7 * 0.13 * 0.82 * rear_wide;

// Tap 8: back-right corner
rd = sm_er8_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp8 = (1-er_a8)*tap + er_a8*er_lp8;
er_l += er_lp8 * 0.13 * 0.82 * rear_wide;
er_r += er_lp8 * 0.13 * 1.14 * rear_wide;

// ER decorrelation
apL = 0.53;
apR = 0.69;

er_ap_y = -apL*er_l + er_ap_x1_l + apL*er_ap_y1_l;
er_ap_x1_l = er_l;
er_ap_y1_l = er_ap_y;
er_l = er_ap_y;

er_ap_y = -apR*er_r + er_ap_x1_r + apR*er_ap_y1_r;
er_ap_x1_r = er_r;
er_ap_y1_r = er_ap_y;
er_r = er_ap_y;

// Distance / occlusion push more energy into the room
er_push = 0.70 + 0.72*sm_depth + 0.55*sm_occ + 0.12*side + 0.18*rear;
er_l *= sm_er_g * er_push;
er_r *= sm_er_g * er_push;

// Mix out
out_l = (dir_l + er_l) * sm_trim;
out_r = (dir_r + er_r) * sm_trim;

spl0 = out_l;
spl1 = out_r;
// advance ER buffer
er_wpos = (er_wpos + 1) & er_mask;

// meters
meter_direct += (max(abs(dir_l), abs(dir_r)) - meter_direct) * meter_k;
meter_er     += (max(abs(er_l),  abs(er_r))  - meter_er)     * meter_k;


@gfx 820 500
// V6.1 perceptual-position UI: stage canvas, visual-vs-cue ghosting, automation-safe controls, distinct visual nouns.

winflags = gfx_getchar(65536);

// --- layout ---
base_w = 820; base_h = 500;
ui_s = min(gfx_w/base_w, gfx_h/base_h);
ui_s < 0.56 ? ui_s = 0.56;
ui_s > 1.85 ? ui_s = 1.85;

pad = 16*ui_s;
pad < 10 ? pad = 10;
title_h = 48*ui_s;
title_h < 36 ? title_h = 36;
foot_h = 34*ui_s;
foot_h < 28 ? foot_h = 28;

right_w = gfx_w * 0.34;
right_w < 250*ui_s ? right_w = 250*ui_s;
right_w > gfx_w*0.42 ? right_w = gfx_w*0.42;

left_w = gfx_w - right_w - pad*3;
left_w < 265*ui_s ? (
  right_w = gfx_w*0.36;
  left_w = gfx_w - right_w - pad*3;
);
left_w < 245*ui_s ? left_w = 245*ui_s;

field_h = gfx_h - title_h - foot_h - pad*2;
field_h < 230*ui_s ? field_h = 230*ui_s;

canvas_x = pad;
canvas_y = title_h + pad;
canvas_w = left_w;
canvas_h = field_h;

rx = canvas_x + canvas_w + pad;
ry = canvas_y;
rw = gfx_w - rx - pad;
rw < 230*ui_s ? rw = 230*ui_s;
rh = field_h;

cx = canvas_x + canvas_w*0.50;
cy = canvas_y + canvas_h*0.52;

room_hw = canvas_w * 0.39;
room_hd = canvas_h * 0.31;
room_hw < 86*ui_s ? room_hw = 86*ui_s;
room_hd < 70*ui_s ? room_hd = 70*ui_s;
room_hw *= 0.88 + 0.12*slider14;
room_hd *= 0.86 + 0.14*slider14;

room_l = cx - room_hw;
room_r = cx + room_hw;
room_t = cy - room_hd;
room_b = cy + room_hd;

// --- sliders / readouts ---
ui_lat = slider1;
ui_dist = slider2;
ui_fb = slider3;
ui_throw = slider4;
ui_size = slider5;
ui_push = slider6;
ui_room = slider7;
ui_occ = slider8;
ui_motion = slider9;
ui_trim = slider10;
ui_safe = slider11 >= 0.5 ? 1 : 0;
ui_curve = slider12;
ui_smooth = slider13;
ui_rsize = slider14;

pos_r = sqrt(ui_lat*ui_lat + ui_fb*ui_fb);
pos_r > 1 ? (
  draw_lat = ui_lat / pos_r;
  draw_fb = ui_fb / pos_r;
  draw_r = 1;
) : (
  draw_lat = ui_lat;
  draw_fb = ui_fb;
  draw_r = pos_r;
);

sx = cx + draw_lat * room_hw * 0.82;
sy = cy - draw_fb  * room_hd * 0.82;

dot_r = 8.5*ui_s + 4.5*ui_s*ui_size;
// Tooltip hit-tests need these before the drawing pass.
ghost_r = dot_r*0.72;
head_r = 17*ui_s;

cue_rad = last_cue_az * $pi/180;
ghost_x = sin(cue_rad) * draw_r;
ghost_y = cos(cue_rad) * draw_r;
gsx = cx + ghost_x * room_hw * 0.82;
gsy = cy - ghost_y * room_hd * 0.82;

frontness = max(0, draw_fb / (draw_r + 0.000000000000000001));
backness = max(0, -draw_fb / (draw_r + 0.000000000000000001));
sideness = abs(draw_lat / (draw_r + 0.000000000000000001));
draw_r < 0.0001 ? (frontness = 1; backness = 0; sideness = 0;);

// Precompute bounce points before mouse hit-testing so Room tooltips align this frame.
src_nx = draw_lat * 0.82;
src_ny = draw_fb * 0.82;
tL = (-1 - src_nx) / (-2 - src_nx + 0.000000000000000001);
bLx = -1;
bLy = src_ny + tL * (0 - src_ny);
tR = (1 - src_nx) / (2 - src_nx + 0.000000000000000001);
bRx = 1;
bRy = src_ny + tR * (0 - src_ny);
tF = (1 - src_ny) / (2 - src_ny + 0.000000000000000001);
bFx = src_nx + tF * (0 - src_nx);
bFy = 1;
tB = (-1 - src_ny) / (-2 - src_ny + 0.000000000000000001);
bBx = src_nx + tB * (0 - src_nx);
bBy = -1;
bpLx = cx + bLx * room_hw; bpLy = cy - bLy * room_hd;
bpRx = cx + bRx * room_hw; bpRy = cy - bRy * room_hd;
bpFx = cx + bFx * room_hw; bpFy = cy - bFy * room_hd;
bpBx = cx + bBx * room_hw; bpBy = cy - bBy * room_hd;

// --- cards / bars ---
card_gap = 10*ui_s;
card_gap < 6 ? card_gap = 6;

card1_h = rh * 0.23;
card2_h = rh * 0.57;
min_c1 = 88*ui_s;
min_c2 = 218*ui_s;
min_c3 = 76*ui_s;
card1_h < min_c1 ? card1_h = min_c1;
card2_h < min_c2 ? card2_h = min_c2;
card3_h = rh - card1_h - card2_h - card_gap*2;
card3_h < min_c3 ? (
  deficit = min_c3 - card3_h;
  card2_h -= deficit;
  card2_h < 188*ui_s ? card2_h = 188*ui_s;
  card3_h = rh - card1_h - card2_h - card_gap*2;
);
card3_h < 58*ui_s ? card3_h = 58*ui_s;

c1x = rx; c1y = ry; c1w = rw; c1h = card1_h;
c2x = rx; c2y = c1y + c1h + card_gap; c2w = rw; c2h = card2_h;
c3x = rx; c3y = c2y + c2h + card_gap; c3w = rw; c3h = card3_h;

bar_pad_x = 14*ui_s;
value_gutter = 62*ui_s;
value_gutter < 48 ? value_gutter = 48;
barx = c2x + bar_pad_x;
barw = c2w - bar_pad_x*2 - value_gutter;
barw < 96*ui_s ? barw = 96*ui_s;
valx = barx + barw + 8*ui_s;

bars_top = c2y + 39*ui_s;
bars_bottom = c2y + c2h - 12*ui_s;
row_h = (bars_bottom - bars_top) / 10;
row_h < 15*ui_s ? row_h = 15*ui_s;
barh = row_h * 0.42;
barh > 13*ui_s ? barh = 13*ui_s;
barh < 8*ui_s ? barh = 8*ui_s;
label_lift = barh + 4*ui_s;

b1y = bars_top + row_h*0.50 - barh*0.50;
b2y = bars_top + row_h*1.50 - barh*0.50;
b3y = bars_top + row_h*2.50 - barh*0.50;
b4y = bars_top + row_h*3.50 - barh*0.50;
b5y = bars_top + row_h*4.50 - barh*0.50;
b6y = bars_top + row_h*5.50 - barh*0.50;
b7y = bars_top + row_h*6.50 - barh*0.50;
b8y = bars_top + row_h*7.50 - barh*0.50;
b9y = bars_top + row_h*8.50 - barh*0.50;
b10y = bars_top + row_h*9.50 - barh*0.50;

// --- mouse / hover ---
mouse_l = mouse_cap & 1;
mouse_r = mouse_cap & 2;
mouse_shift = mouse_cap & 8;
mouse_ctrl = mouse_cap & 4;
mouse_alt = mouse_cap & 16;

inside_canvas = mouse_x >= canvas_x && mouse_x <= canvas_x + canvas_w && mouse_y >= canvas_y && mouse_y <= canvas_y + canvas_h;
inside_room = mouse_x >= room_l && mouse_x <= room_r && mouse_y >= room_t && mouse_y <= room_b;
near_src = ((mouse_x-sx)*(mouse_x-sx) + (mouse_y-sy)*(mouse_y-sy)) <= ((dot_r+8*ui_s)*(dot_r+8*ui_s));

hover_bar = 0;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b1y && mouse_y <= b1y+barh) ? hover_bar = 1;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b2y && mouse_y <= b2y+barh) ? hover_bar = 2;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b3y && mouse_y <= b3y+barh) ? hover_bar = 3;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b4y && mouse_y <= b4y+barh) ? hover_bar = 4;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b5y && mouse_y <= b5y+barh) ? hover_bar = 5;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b6y && mouse_y <= b6y+barh) ? hover_bar = 6;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b7y && mouse_y <= b7y+barh) ? hover_bar = 7;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b8y && mouse_y <= b8y+barh) ? hover_bar = 8;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b9y && mouse_y <= b9y+barh) ? hover_bar = 9;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b10y && mouse_y <= b10y+barh) ? hover_bar = 10;

// Tooltip lane targeting must match the actual slider hitbox exactly.
// V6.2 used widened row hitboxes, which made help trigger above the visible bar
// and made the slider feel visually offset. Keep tooltip hover tied to hover_bar.
hover_tip_bar = hover_bar;

safe_x = c1x + c1w - 112*ui_s;
safe_y = c1y + 10*ui_s;
safe_w = 96*ui_s;
safe_h = 22*ui_s;
hover_safe = mouse_x >= safe_x && mouse_x <= safe_x+safe_w && mouse_y >= safe_y && mouse_y <= safe_y+safe_h;

// Snap chips
chip_h = 22*ui_s;
chip_y = canvas_y + canvas_h - chip_h - 11*ui_s;
chip_gap = 6*ui_s;
chip_x = canvas_x + 14*ui_s;
chip_w = (canvas_w - 28*ui_s - chip_gap*7) / 8;
chip_w > 54*ui_s ? chip_w = 54*ui_s;
chip_w < 34*ui_s ? chip_w = 34*ui_s;
chip1x = chip_x;
chip2x = chip1x + chip_w + chip_gap;
chip3x = chip2x + chip_w + chip_gap;
chip4x = chip3x + chip_w + chip_gap;
chip5x = chip4x + chip_w + chip_gap;
chip6x = chip5x + chip_w + chip_gap;
chip7x = chip6x + chip_w + chip_gap;
chip8x = chip7x + chip_w + chip_gap;

hover_chip = 0;
(mouse_y >= chip_y && mouse_y <= chip_y+chip_h) ? (
  mouse_x >= chip1x && mouse_x <= chip1x+chip_w ? hover_chip = 1;
  mouse_x >= chip2x && mouse_x <= chip2x+chip_w ? hover_chip = 2;
  mouse_x >= chip3x && mouse_x <= chip3x+chip_w ? hover_chip = 3;
  mouse_x >= chip4x && mouse_x <= chip4x+chip_w ? hover_chip = 4;
  mouse_x >= chip5x && mouse_x <= chip5x+chip_w ? hover_chip = 5;
  mouse_x >= chip6x && mouse_x <= chip6x+chip_w ? hover_chip = 6;
  mouse_x >= chip7x && mouse_x <= chip7x+chip_w ? hover_chip = 7;
  mouse_x >= chip8x && mouse_x <= chip8x+chip_w ? hover_chip = 8;
);

// --- tooltip target routing ---
// Numeric IDs keep this JSFX-safe:
// 20s canvas/visual cues, 30 Auto Safe, 40s snap chips, 100s lanes.
tip_id = 0;
tip_hot = (!mouse_l && !mouse_r && ui_mode == 0);

tip_hot ? (
  hover_tip_bar > 0 ? tip_id = 100 + hover_tip_bar;
  hover_safe ? tip_id = 30;
  hover_chip > 0 ? tip_id = 40 + hover_chip;

  // Recompute visible-cue hit zones from the current object/canvas geometry.
  src_dx = mouse_x - sx;
  src_dy = mouse_y - sy;
  src_d2 = src_dx*src_dx + src_dy*src_dy;
  near_src = src_d2 <= ((dot_r+8*ui_s)*(dot_r+8*ui_s));

  ghost_dx = mouse_x - gsx;
  ghost_dy = mouse_y - gsy;
  near_ghost = (ghost_dx*ghost_dx + ghost_dy*ghost_dy) <= ((ghost_r+9*ui_s)*(ghost_r+9*ui_s));

  mouse_rad = sqrt((mouse_x-cx)*(mouse_x-cx) + (mouse_y-cy)*(mouse_y-cy));
  room_edge_hot = inside_canvas && (abs(mouse_x-room_l) < 8*ui_s || abs(mouse_x-room_r) < 8*ui_s || abs(mouse_y-room_t) < 8*ui_s || abs(mouse_y-room_b) < 8*ui_s);
  listener_shell_r = head_r + (10 + 52*ui_push)*ui_s;
  shell_hot = inside_room && ui_push > 0.04 && abs(mouse_rad - listener_shell_r) <= 10*ui_s;

  size_hot_r = dot_r + (8 + 46*(ui_size^0.72))*ui_s;
  size_hot = inside_room && ui_size > 0.06 && !near_src && src_d2 <= size_hot_r*size_hot_r;

  range_min_tip = min(room_hw, room_hd);
  range_active_tip = range_min_tip * (0.18 + 0.70*ui_dist);
  range_hot = inside_room && abs(mouse_rad - range_active_tip) <= 9*ui_s;

  motion_hot_r = (4 + 28*ui_motion)*ui_s + 8*ui_s;
  motion_hot = inside_room && ui_motion > 0.04 && !near_src && src_d2 <= motion_hot_r*motion_hot_r;

  occ_tip_x = cx + (sx-cx)*0.46;
  occ_tip_y = cy + (sy-cy)*0.46;
  occ_hot_r = 18*ui_s + 26*ui_s*ui_occ;
  occ_hot = inside_room && ui_occ > 0.04 && ((mouse_x-occ_tip_x)*(mouse_x-occ_tip_x) + (mouse_y-occ_tip_y)*(mouse_y-occ_tip_y)) <= occ_hot_r*occ_hot_r;

  bounce_hot_r = 2.5*ui_s + 5.2*ui_s*ui_room + 8*ui_s;
  bounce_hot = ui_room > 0.035 && (
    ((mouse_x-bpLx)*(mouse_x-bpLx) + (mouse_y-bpLy)*(mouse_y-bpLy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpRx)*(mouse_x-bpRx) + (mouse_y-bpRy)*(mouse_y-bpRy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpFx)*(mouse_x-bpFx) + (mouse_y-bpFy)*(mouse_y-bpFy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpBx)*(mouse_x-bpBx) + (mouse_y-bpBy)*(mouse_y-bpBy)) <= bounce_hot_r*bounce_hot_r
  );

  head_hot = ((mouse_x-cx)*(mouse_x-cx) + (mouse_y-cy)*(mouse_y-cy)) <= ((head_r+11*ui_s)*(head_r+11*ui_s));

  tip_id == 0 && near_src ? tip_id = 20;
  tip_id == 0 && near_ghost ? tip_id = 21;
  tip_id == 0 && occ_hot ? tip_id = 29;
  tip_id == 0 && bounce_hot ? tip_id = 22;
  tip_id == 0 && shell_hot ? tip_id = 23;
  tip_id == 0 && size_hot ? tip_id = 26;
  tip_id == 0 && motion_hot ? tip_id = 28;
  tip_id == 0 && range_hot ? tip_id = 27;
  tip_id == 0 && room_edge_hot ? tip_id = 22;
  tip_id == 0 && head_hot ? tip_id = 24;
  tip_id == 0 && inside_room ? tip_id = 24;
  tip_id == 0 && inside_canvas ? tip_id = 25;
);

// Small hover delay: prevents flashing while passing over dense controls.
tip_id == tooltip_last_id ? (
  tooltip_frames += 1;
) : (
  tooltip_last_id = tip_id;
  tooltip_frames = 0;
);
tooltip_show = tip_id > 0 && tooltip_frames >= 8;

// --- wheel controls ---
mouse_wheel != 0 ? (
  wstep = mouse_wheel / 120;
  wheel_scale = mouse_shift ? 0.25 : 1.0;

  hover_bar == 1 ? (
    slider1 += wstep * 0.045 * wheel_scale;
    slider1 < -1 ? slider1 = -1; slider1 > 1 ? slider1 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 2 ? (
    slider3 += wstep * 0.045 * wheel_scale;
    slider3 < -1 ? slider3 = -1; slider3 > 1 ? slider3 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 3 ? (
    slider2 += wstep * 0.035 * wheel_scale;
    slider2 < 0 ? slider2 = 0; slider2 > 1 ? slider2 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 4 ? (
    slider4 += wstep * 0.035 * wheel_scale;
    slider4 < 0 ? slider4 = 0; slider4 > 1 ? slider4 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 5 ? (
    slider5 += wstep * 0.030 * wheel_scale;
    slider5 < 0 ? slider5 = 0; slider5 > 1 ? slider5 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 6 ? (
    slider6 += wstep * 0.035 * wheel_scale;
    slider6 < 0 ? slider6 = 0; slider6 > 1 ? slider6 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 7 ? (
    slider7 += wstep * 0.035 * wheel_scale;
    slider7 < 0 ? slider7 = 0; slider7 > 1 ? slider7 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 8 ? (
    slider8 += wstep * 0.035 * wheel_scale;
    slider8 < 0 ? slider8 = 0; slider8 > 1 ? slider8 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 9 ? (
    slider9 += wstep * 0.030 * wheel_scale;
    slider9 < 0 ? slider9 = 0; slider9 > 1 ? slider9 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 10 ? (
    slider10 += wstep * 0.4 * wheel_scale;
    slider10 < -18 ? slider10 = -18; slider10 > 12 ? slider10 = 12;
    sliderchange(-1.0);
  ) : inside_canvas ? (
    mouse_ctrl ? (
      slider4 += wstep * 0.035 * wheel_scale;
      slider4 < 0 ? slider4 = 0; slider4 > 1 ? slider4 = 1;
    ) : mouse_alt ? (
      slider6 += wstep * 0.035 * wheel_scale;
      slider6 < 0 ? slider6 = 0; slider6 > 1 ? slider6 = 1;
    ) : (
      slider2 += wstep * 0.035 * wheel_scale;
      slider2 < 0 ? slider2 = 0; slider2 > 1 ? slider2 = 1;
    );
    sliderchange(-1.0);
  );
  mouse_wheel = 0;
);

// --- press actions ---
(!ui_prev_r && mouse_r) ? (
  inside_canvas ? (
    slider1 = 0;
    slider2 = 0.25;
    slider3 = 0.82;
    sliderchange(-1.0);
  ) : hover_bar == 1 ? (slider1 = 0; sliderchange(-1.0);) :
  hover_bar == 2 ? (slider3 = 0.82; sliderchange(-1.0);) :
  hover_bar == 3 ? (slider2 = 0.25; sliderchange(-1.0);) :
  hover_bar == 4 ? (slider4 = 0.58; sliderchange(-1.0);) :
  hover_bar == 5 ? (slider5 = 0.10; sliderchange(-1.0);) :
  hover_bar == 6 ? (slider6 = 0.42; sliderchange(-1.0);) :
  hover_bar == 7 ? (slider7 = 0.30; sliderchange(-1.0);) :
  hover_bar == 8 ? (slider8 = 0.00; sliderchange(-1.0);) :
  hover_bar == 9 ? (slider9 = 0.04; sliderchange(-1.0);) :
  hover_bar == 10 ? (slider10 = 0.0; sliderchange(-1.0););
);

(!ui_prev_l && mouse_l) ? (
  hover_safe ? (
    slider11 = 1 - slider11;
    sliderchange(-1.0);
  ) : hover_chip > 0 ? (
    snap_r = 0.78;
    hover_chip == 1 ? (slider1 = 0; slider3 = 0.82;) :
    hover_chip == 2 ? (a = -30*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
    hover_chip == 3 ? (a = -45*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
    hover_chip == 4 ? (a = -60*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
    hover_chip == 5 ? (a = 30*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
    hover_chip == 6 ? (a = 45*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
    hover_chip == 7 ? (a = 60*$pi/180; slider1 = sin(a)*snap_r; slider3 = cos(a)*snap_r;) :
                         (slider1 = 0; slider3 = -0.82;);
    sliderchange(-1.0);
  ) : (near_src || inside_room) ? (
    ui_mode = 1;
    ui_drag_start_x = mouse_x;
    ui_drag_start_y = mouse_y;
    ui_drag_start_v1 = slider1;
    ui_drag_start_v2 = slider3;
    ui_drag_start_v3 = slider2;
  ) : hover_bar > 0 ? (
    ui_mode = 100 + hover_bar;
    ui_drag_bar = hover_bar;
    ui_drag_start_x = mouse_x;
    ui_drag_start_y = mouse_y;
    ui_drag_start_v1 =
      hover_bar == 1 ? slider1 :
      hover_bar == 2 ? slider3 :
      hover_bar == 3 ? slider2 :
      hover_bar == 4 ? slider4 :
      hover_bar == 5 ? slider5 :
      hover_bar == 6 ? slider6 :
      hover_bar == 7 ? slider7 :
      hover_bar == 8 ? slider8 :
      hover_bar == 9 ? slider9 : slider10;
  );
);

// --- drag actions ---
(mouse_l && ui_mode == 1) ? (
  mouse_alt ? (
    slider2 = ui_drag_start_v3 - (mouse_y - ui_drag_start_y) * 0.0028 / ui_s;
    slider2 < 0 ? slider2 = 0;
    slider2 > 1 ? slider2 = 1;
  ) : mouse_ctrl ? (
    slider1 = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) * 0.0040 / ui_s;
    slider1 < -1 ? slider1 = -1;
    slider1 > 1 ? slider1 = 1;
  ) : mouse_shift ? (
    slider1 = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) * 0.00135 / ui_s;
    slider3 = ui_drag_start_v2 - (mouse_y - ui_drag_start_y) * 0.00135 / ui_s;
    slider1 < -1 ? slider1 = -1; slider1 > 1 ? slider1 = 1;
    slider3 < -1 ? slider3 = -1; slider3 > 1 ? slider3 = 1;
    rr = sqrt(slider1*slider1 + slider3*slider3);
    rr > 1 ? (slider1 /= rr; slider3 /= rr;);
  ) : (
    dxn = (mouse_x - cx) / (room_hw*0.82);
