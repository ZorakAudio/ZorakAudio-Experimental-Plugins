);

// finalize drag
(!mouse_l && ui_prev_l && ui_mode) ? (
  ui_mode = 0;
  ui_drag_bar = 0;
  sliderchange(-1.0);
);

ui_prev_l = mouse_l;
ui_prev_r = mouse_r;

// refresh for drawing after interaction
ui_lat = slider1;
ui_dist = slider2;
ui_fb = slider3;
ui_throw = slider4;
ui_size = slider5;
ui_push = slider6;
ui_room = slider7;
ui_occ = slider8;
ui_motion = slider9;
ui_trim = slider10;
ui_safe = slider11 >= 0.5 ? 1 : 0;
ui_curve = slider12;
ui_smooth = slider13;
ui_rsize = slider14;

pos_r = sqrt(ui_lat*ui_lat + ui_fb*ui_fb);
pos_r > 1 ? (
  draw_lat = ui_lat / pos_r;
  draw_fb = ui_fb / pos_r;
  draw_r = 1;
) : (
  draw_lat = ui_lat;
  draw_fb = ui_fb;
  draw_r = pos_r;
);
sx = cx + draw_lat * room_hw * 0.82;
sy = cy - draw_fb  * room_hd * 0.82;
cue_rad = last_cue_az * $pi/180;
ghost_x = sin(cue_rad) * draw_r;
ghost_y = cos(cue_rad) * draw_r;
gsx = cx + ghost_x * room_hw * 0.82;
gsy = cy - ghost_y * room_hd * 0.82;

// bounce points on room walls, visual coordinate
src_nx = draw_lat * 0.82;
src_ny = draw_fb * 0.82;

tL = (-1 - src_nx) / (-2 - src_nx + 0.000000000000000001);
bLx = -1;
bLy = src_ny + tL * (0 - src_ny);

tR = (1 - src_nx) / (2 - src_nx + 0.000000000000000001);
bRx = 1;
bRy = src_ny + tR * (0 - src_ny);

tF = (1 - src_ny) / (2 - src_ny + 0.000000000000000001);
bFx = src_nx + tF * (0 - src_nx);
bFy = 1;

tB = (-1 - src_ny) / (-2 - src_ny + 0.000000000000000001);
bBx = src_nx + tB * (0 - src_nx);
bBy = -1;

bpLx = cx + bLx * room_hw; bpLy = cy - bLy * room_hd;
bpRx = cx + bRx * room_hw; bpRy = cy - bRy * room_hd;
bpFx = cx + bFx * room_hw; bpFy = cy - bFy * room_hd;
bpBx = cx + bBx * room_hw; bpBy = cy - bBy * room_hd;

// --- colors ---
bg_r=0.056; bg_g=0.064; bg_b=0.078;
panel_r=0.100; panel_g=0.112; panel_b=0.140;
card_r=0.126; card_g=0.140; card_b=0.174;
line_r=0.235; line_g=0.260; line_b=0.320;
txt_r=0.94; txt_g=0.95; txt_b=0.98;
mut_r=0.56; mut_g=0.61; mut_b=0.69;
src_cr=0.97; src_cg=0.67; src_cb=0.16;
bounce_r=0.33; bounce_g=0.80; bounce_b=0.98;
occ_cr=0.83; occ_cg=0.38; occ_cb=0.96;
ok_r=0.58; ok_g=0.78; ok_b=0.51;
warn_r=0.96; warn_g=0.48; warn_b=0.18;

// --- background ---
gfx_set(bg_r,bg_g,bg_b,1); gfx_rect(0,0,gfx_w,gfx_h,1);

// fonts
fs1 = floor(18*ui_s); fs2 = floor(12*ui_s); fs3 = floor(10*ui_s); fs4 = floor(9*ui_s);
fs1 < 12 ? fs1 = 12; fs2 < 10 ? fs2 = 10; fs3 < 9 ? fs3 = 9; fs4 < 8 ? fs4 = 8;

// title
gfx_setfont(1,"Arial",fs1,'b');
gfx_set(txt_r,txt_g,txt_b,1);
gfx_x = pad; gfx_y = pad*0.45; gfx_printf("Hyperreal 3D Panner V6.2.1");

gfx_setfont(2,"Arial",fs2);
gfx_set(mut_r,mut_g,mut_b,1);
gfx_x = pad; gfx_y = pad*0.45 + fs1 + 1*ui_s;
gfx_printf("Perceptual Position | visual cues | aligned hover help | automation-safe spatial throw");

// main surfaces
gfx_set(panel_r,panel_g,panel_b,1);
gfx_rect(canvas_x, canvas_y, canvas_w, canvas_h);
gfx_roundrect(canvas_x, canvas_y, canvas_w, canvas_h, 14*ui_s, 1);
gfx_rect(c1x, c1y, c1w, c1h);
gfx_roundrect(c1x, c1y, c1w, c1h, 12*ui_s, 1);
gfx_rect(c2x, c2y, c2w, c2h);
gfx_roundrect(c2x, c2y, c2w, c2h, 12*ui_s, 1);
gfx_rect(c3x, c3y, c3w, c3h);
gfx_roundrect(c3x, c3y, c3w, c3h, 12*ui_s, 1);

// canvas inner
gfx_set(0.082,0.090,0.112,1);
gfx_rect(canvas_x+8*ui_s, canvas_y+8*ui_s, canvas_w-16*ui_s, canvas_h-16*ui_s);
gfx_roundrect(canvas_x+8*ui_s, canvas_y+8*ui_s, canvas_w-16*ui_s, canvas_h-16*ui_s, 12*ui_s, 1);

// stage room
gfx_set(0.112,0.124,0.158,1);
gfx_rect(room_l, room_t, room_hw*2, room_hd*2);
gfx_roundrect(room_l, room_t, room_hw*2, room_hd*2, 10*ui_s, 1);
gfx_set(0.38,0.43,0.52,0.95);
gfx_roundrect(room_l, room_t, room_hw*2, room_hd*2, 10*ui_s, 0);

// grid
gfx_set(0.23,0.26,0.33,0.55);
gfx_line(cx-room_hw, cy, cx+room_hw, cy);
gfx_line(cx, cy-room_hd, cx, cy+room_hd);
gfx_line(cx-room_hw*0.5, room_t, cx-room_hw*0.5, room_b);
gfx_line(cx+room_hw*0.5, room_t, cx+room_hw*0.5, room_b);
gfx_line(room_l, cy-room_hd*0.5, room_r, cy-room_hd*0.5);
gfx_line(room_l, cy+room_hd*0.5, room_r, cy+room_hd*0.5);

// snap rays
gfx_set(0.30,0.34,0.42,0.35);
a=-60*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=-45*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=-30*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=30*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=45*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=60*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);

// room labels
gfx_setfont(3,"Arial",fs3,'b');
gfx_set(0.73,0.79,0.87,0.95);
gfx_x = cx - 30*ui_s; gfx_y = room_t - 16*ui_s; gfx_printf("FRONT");
gfx_x = room_l - 18*ui_s; gfx_y = cy - 5*ui_s; gfx_printf("L");
gfx_x = room_r + 10*ui_s; gfx_y = cy - 5*ui_s; gfx_printf("R");
gfx_set(0.70,0.58,0.85,0.95);
gfx_x = cx - 24*ui_s; gfx_y = room_b + 5*ui_s; gfx_printf("REAR");

// --- visual cue: Distance = range rings + air dashes, not a bigger source ---
range_min = min(room_hw, room_hd);
range_r1 = range_min * 0.25;
range_r2 = range_min * 0.50;
range_r3 = range_min * 0.75;
range_active = range_min * (0.18 + 0.70*ui_dist);

// static reference rings
gfx_set(0.70,0.74,0.84,0.10); gfx_circle(cx,cy,range_r1,0,1);
gfx_set(0.70,0.74,0.84,0.08); gfx_circle(cx,cy,range_r2,0,1);
gfx_set(0.70,0.74,0.84,0.06); gfx_circle(cx,cy,range_r3,0,1);

// active distance ring brightens and expands with Distance
gfx_set(0.78,0.82,0.92,0.13 + 0.14*ui_dist);
gfx_circle(cx,cy,range_active,0,1);

// small distance tick marks along the placement ray
seg_n = 5;
seg_i = 1;
loop(seg_n,
  seg_t = seg_i / (seg_n + 1);
  seg_x = cx + (sx-cx) * seg_t;
  seg_y = cy + (sy-cy) * seg_t;
  seg_a = (0.05 + 0.18*ui_dist) * seg_t;
  gfx_set(0.78,0.82,0.92,seg_a);
  gfx_circle(seg_x, seg_y, (1.5 + 2.8*ui_dist)*ui_s, 1, 1);
  seg_i += 1;
);

gfx_setfont(4,"Arial",fs4);
gfx_set(0.70,0.74,0.84,0.48);
gfx_x = room_l + 8*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("CLOSE");
gfx_x = cx - 10*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("MID");
gfx_x = room_r - 28*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("FAR");

// --- visual cue: Room = wall glow strength ---
(ui_room > 0.001) ? (
  glow_i = 0;
  loop(3,
    glow_o = (glow_i + 1) * 2.0*ui_s;
    glow_a = ui_room * (0.20 - glow_i*0.045);
    gfx_set(bounce_r,bounce_g,bounce_b,glow_a);
    gfx_roundrect(room_l-glow_o, room_t-glow_o, room_hw*2+glow_o*2, room_hd*2+glow_o*2, 10*ui_s+glow_o, 0);
    glow_i += 1;
  );
);

// direct visual path
gfx_set(src_cr,src_cg,src_cb,0.58 + 0.20*(1-ui_dist));
gfx_line(cx, cy, sx, sy);

// cue ghost path
gfx_set(src_cr,src_cg,src_cb,0.22 + 0.12*ui_throw);
gfx_line(cx, cy, gsx, gsy);

// --- visual cue: Room = cyan early-bounce paths and wall-hit markers ---
bounce_a = 0.04 + 0.72*ui_room;
gfx_set(bounce_r,bounce_g,bounce_b,bounce_a);
gfx_line(sx, sy, bpLx, bpLy); gfx_line(bpLx, bpLy, cx, cy);
gfx_line(sx, sy, bpRx, bpRy); gfx_line(bpRx, bpRy, cx, cy);
gfx_line(sx, sy, bpFx, bpFy); gfx_line(bpFx, bpFy, cx, cy);
gfx_line(sx, sy, bpBx, bpBy); gfx_line(bpBx, bpBy, cx, cy);

// secondary stronger trace at high Room, gives a thicker-looking reflection web
(ui_room > 0.55) ? (
  gfx_set(bounce_r,bounce_g,bounce_b,(ui_room-0.55)*0.55);
  gfx_line(sx+1*ui_s, sy, bpLx+1*ui_s, bpLy); gfx_line(bpLx+1*ui_s, bpLy, cx+1*ui_s, cy);
  gfx_line(sx-1*ui_s, sy, bpRx-1*ui_s, bpRy); gfx_line(bpRx-1*ui_s, bpRy, cx-1*ui_s, cy);
  gfx_line(sx, sy+1*ui_s, bpFx, bpFy+1*ui_s); gfx_line(bpFx, bpFy+1*ui_s, cx, cy+1*ui_s);
  gfx_line(sx, sy-1*ui_s, bpBx, bpBy-1*ui_s); gfx_line(bpBx, bpBy-1*ui_s, cx, cy-1*ui_s);
);

// bounce markers fade down when Room is low; they no longer imply reflections are active at 0
bm_r = 2.5*ui_s + 5.2*ui_s*ui_room;
bm_a = 0.16 + 0.82*ui_room;
gfx_set(bounce_r,bounce_g,bounce_b,bm_a);
gfx_circle(bpLx, bpLy, bm_r, 1, 1);
gfx_circle(bpRx, bpRy, bm_r, 1, 1);
gfx_circle(bpFx, bpFy, bm_r, 1, 1);
gfx_circle(bpBx, bpBy, bm_r, 1, 1);

(ui_room > 0.30) ? (
  gfx_set(bounce_r,bounce_g,bounce_b,0.12 + 0.24*ui_room);
  gfx_circle(bpLx, bpLy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpRx, bpRy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpFx, bpFy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpBx, bpBy, bm_r + 4.0*ui_s*ui_room, 0, 1);
);

// occlusion wedge
(ui_occ > 0.001) ? (
  bx = cx + (sx-cx)*0.56;
  by = cy + (sy-cy)*0.56;
  wx = (sy-cy) * 0.09 * ui_occ;
  wy = -(sx-cx) * 0.09 * ui_occ;
  ax = cx + (sx-cx)*0.23;
  ay = cy + (sy-cy)*0.23;
  gfx_set(occ_cr,occ_cg,occ_cb,0.48 + 0.22*ui_occ);
  gfx_triangle(ax,ay, bx+wx,by+wy, bx-wx,by-wy);
);

// --- visual cue: Push Out = listener externalization shell, not distance ---
head_r = 17*ui_s;
(ui_push > 0.001) ? (
  shell_r = head_r + (10 + 52*ui_push)*ui_s;
  shell_a = 0.06 + 0.22*ui_push;
  gfx_set(src_cr,src_cg,src_cb,shell_a);
  gfx_circle(cx, cy, shell_r, 0, 1);
  gfx_set(bounce_r,bounce_g,bounce_b,0.04 + 0.16*ui_push);
  gfx_circle(cx, cy, shell_r + 8*ui_s, 0, 1);

  // faint ear-to-source separation rays appear only as Push Out rises
  ear_a = 0.05 + 0.16*ui_push;
  gfx_set(src_cr,src_cg,src_cb,ear_a);
  gfx_line(cx-21*ui_s, cy, sx, sy);
  gfx_line(cx+21*ui_s, cy, sx, sy);
);

// cue ghost = effective DSP position after Spatial Throw/Cue Curve compression
ghost_r = dot_r*0.72;
gfx_set(src_cr,src_cg,src_cb,0.12 + 0.20*ui_throw);
gfx_circle(gsx, gsy, ghost_r, 1, 1);
gfx_set(src_cr,src_cg,src_cb,0.45 + 0.35*ui_throw);
gfx_circle(gsx, gsy, ghost_r + 3*ui_s, 0, 1);

// --- visual cue: Motion = green fading trail around source ---
(ui_motion > 0.002) ? (
  trail_n = 11;
  trail_i = 0;
  trail_amp = (4 + 28*ui_motion)*ui_s;
  trail_phase = ph1*0.70 + ph2*0.33;
  loop(trail_n,
    trail_t = trail_i / (trail_n - 1);
    trail_a = trail_phase - trail_t*(1.45 + 2.20*ui_motion)*$pi;
    trail_rr = trail_amp * (0.35 + 0.65*trail_t);
    tx = sx + cos(trail_a) * trail_rr;
    ty = sy + sin(trail_a) * trail_rr * 0.58;
    ta = (0.06 + 0.30*ui_motion) * (1 - trail_t);
    gfx_set(ok_r,ok_g,ok_b,ta);
    gfx_circle(tx, ty, (1.2 + 2.4*ui_motion)*ui_s, 1, 1);
    trail_i += 1;
  );
  gfx_set(ok_r,ok_g,ok_b,0.08 + 0.18*ui_motion);
  gfx_circle(sx, sy, trail_amp, 0, 1);
);

// --- visual cue: Size = orange source extent / diffusion ---
size_pow = ui_size^0.72;
halo_r = dot_r + (8 + 46*size_pow)*ui_s;
halo_a = 0.05 + 0.24*ui_size;
gfx_set(src_cr,src_cg,src_cb,halo_a);
gfx_circle(sx, sy, halo_r, 0, 1);
gfx_set(src_cr,src_cg,src_cb,0.04 + 0.14*ui_size);
gfx_circle(sx, sy, halo_r*0.58, 0, 1);

(ui_size > 0.12) ? (
  cloud_n = floor(4 + 14*ui_size);
  cloud_i = 0;
  loop(cloud_n,
    cloud_t = cloud_i / (cloud_n + 0.000001);
    ca = cloud_t*2*$pi + 0.55;
    cr = halo_r * (0.24 + 0.58*(cloud_i + 1)/(cloud_n + 1));
    px = sx + cos(ca)*cr;
    py = sy + sin(ca)*cr*0.68;
    pa = (0.06 + 0.20*ui_size) * (0.55 + 0.45*(cloud_n - cloud_i)/(cloud_n + 1));
    gfx_set(src_cr,src_cg,src_cb,pa);
    gfx_circle(px, py, (1.2 + 2.5*ui_size)*ui_s, 1, 1);
    cloud_i += 1;
  );
);

// focus crosshair fades out as Size becomes diffuse
focus_a_ui = 0.62 * (1 - ui_size);
(focus_a_ui > 0.02) ? (
  gfx_set(1,1,1,focus_a_ui);
  gfx_line(sx-13*ui_s, sy, sx+13*ui_s, sy);
  gfx_line(sx, sy-13*ui_s, sx, sy+13*ui_s);
);

// main source orb: size changes mildly; distance only dims the edge, avoiding size/distance confusion
core_a = 1 - 0.16*ui_dist;
gfx_set(src_cr,src_cg,src_cb,core_a);
gfx_circle(sx, sy, dot_r, 1, 1);
gfx_set(1,0.88,0.55,0.35 + 0.20*(1-ui_dist));
gfx_circle(sx, sy, dot_r + 1.8*ui_s, 0, 1);
gfx_set(0.12,0.12,0.13,1); gfx_circle(sx, sy, 2.6*ui_s, 1, 1);

// listener
gfx_set(0.60,0.66,0.76,1);
gfx_circle(cx, cy, head_r, 0, 1);
gfx_circle(cx-21*ui_s, cy, 5.1*ui_s, 0, 1);
gfx_circle(cx+21*ui_s, cy, 5.1*ui_s, 0, 1);
gfx_line(cx, cy-head_r, cx, cy-(head_r+9*ui_s));

// legend / readout on canvas
gfx_setfont(4,"Arial",fs4);
gfx_set(bounce_r,bounce_g,bounce_b,0.95);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s; gfx_printf("cyan = Room bounces");
gfx_set(src_cr,src_cg,src_cb,0.95);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + fs4 + 4*ui_s; gfx_printf("orange halo = Size | ghost = cue");
gfx_set(0.78,0.82,0.92,0.82);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + (fs4 + 4*ui_s)*2; gfx_printf("rings = Distance | shell = Push Out");
gfx_set(ok_r,ok_g,ok_b,0.82);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + (fs4 + 4*ui_s)*3; gfx_printf("green trail = Motion");

// chips
gfx_setfont(4,"Arial",fs4,'b');

active = hover_chip==1;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip1x,chip_y,chip_w,chip_h); gfx_roundrect(chip1x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip1x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("Center");

active = hover_chip==2;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip2x,chip_y,chip_w,chip_h); gfx_roundrect(chip2x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip2x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("30L");

active = hover_chip==3;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip3x,chip_y,chip_w,chip_h); gfx_roundrect(chip3x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip3x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("45L");

active = hover_chip==4;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip4x,chip_y,chip_w,chip_h); gfx_roundrect(chip4x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip4x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("60L");

active = hover_chip==5;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip5x,chip_y,chip_w,chip_h); gfx_roundrect(chip5x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip5x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("30R");

active = hover_chip==6;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip6x,chip_y,chip_w,chip_h); gfx_roundrect(chip6x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip6x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("45R");

active = hover_chip==7;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip7x,chip_y,chip_w,chip_h); gfx_roundrect(chip7x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip7x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("60R");

active = hover_chip==8;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip8x,chip_y,chip_w,chip_h); gfx_roundrect(chip8x,chip_y,chip_w,chip_h,7*ui_s,1);
gfx_set(active ? src_cr : mut_r, active ? src_cg : mut_g, active ? src_cb : mut_b, 1);
gfx_x = chip8x + 7*ui_s; gfx_y = chip_y + 5*ui_s; gfx_printf("Rear");

// --- right card 1: summary ---
gfx_setfont(2,"Arial",fs2,'b');
gfx_set(txt_r,txt_g,txt_b,1);
gfx_x = c1x + 14*ui_s; gfx_y = c1y + 10*ui_s; gfx_printf("Position");

// safe toggle
gfx_set(ui_safe ? ok_r : warn_r, ui_safe ? ok_g : warn_g, ui_safe ? ok_b : warn_b, hover_safe ? 0.95 : 0.75);
gfx_rect(safe_x,safe_y,safe_w,safe_h);
gfx_roundrect(safe_x,safe_y,safe_w,safe_h,8*ui_s,1);
gfx_set(0.08,0.09,0.11,1);
gfx_setfont(4,"Arial",fs4,'b');
gfx_x = safe_x + 9*ui_s; gfx_y = safe_y + 6*ui_s; ui_safe ? gfx_printf("AUTO SAFE") : gfx_printf("PERFORM");

gfx_setfont(3,"Arial",fs3);
gfx_set(0.88,0.91,0.96,1);
gfx_x = c1x + 14*ui_s; gfx_y = c1y + 34*ui_s; gfx_printf("Visual %+.1f deg", last_visual_az);
gfx_x = c1x + 14*ui_s; gfx_y = c1y + 51*ui_s; gfx_printf("Cue    %+.1f deg", last_cue_az);
gfx_x = c1x + c1w*0.55; gfx_y = c1y + 34*ui_s; gfx_printf("%.2f m", last_dist_m);
gfx_x = c1x + c1w*0.55; gfx_y = c1y + 51*ui_s;
frontness >= sideness && frontness >= backness ? gfx_printf("Zone FRONT") : sideness >= backness ? gfx_printf("Zone SIDE") : gfx_printf("Zone BACK");

gfx_setfont(4,"Arial",fs4);
gfx_set(mut_r,mut_g,mut_b,1);
gfx_x = c1x + 14*ui_s; gfx_y = c1y + 70*ui_s;
gfx_printf("Throw %.0f%% -> DSP %.0f%% | Smooth %.0f ms", ui_throw*100, last_throw_dsp*100, last_smooth_ms);

// --- right card 2: control lanes ---
gfx_setfont(2,"Arial",fs2,'b');
gfx_set(txt_r,txt_g,txt_b,1);
gfx_x = c2x + 14*ui_s; gfx_y = c2y + 10*ui_s; gfx_printf("Quick Controls");

gfx_setfont(4,"Arial",fs4);

// bar drawing repeated
lat_n = (ui_lat + 1)*0.5;
fb_n = (ui_fb + 1)*0.5;
trim_n = (ui_trim + 18) / 30;

// 1 Lateral
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b1y-label_lift; gfx_printf("Lateral");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b1y,barw,barh); gfx_roundrect(barx,b1y,barw,barh,6*ui_s,1);
gfx_set(src_cr,src_cg,src_cb,1); gfx_rect(barx,b1y,barw*lat_n,barh);
gfx_set(0.08,0.08,0.10,0.65); gfx_line(barx+barw*0.5,b1y,barx+barw*0.5,b1y+barh);
gfx_set(1,1,1, hover_bar==1 ? 0.95 : 0.70); gfx_circle(barx + barw*lat_n, b1y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b1y-1*ui_s; gfx_printf("%+.2f", ui_lat);

// 2 Front/rear
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b2y-label_lift; gfx_printf("Front / Rear");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b2y,barw,barh); gfx_roundrect(barx,b2y,barw,barh,6*ui_s,1);
gfx_set(0.70,0.58,0.85,1); gfx_rect(barx,b2y,barw*fb_n,barh);
gfx_set(0.08,0.08,0.10,0.65); gfx_line(barx+barw*0.5,b2y,barx+barw*0.5,b2y+barh);
gfx_set(1,1,1, hover_bar==2 ? 0.95 : 0.70); gfx_circle(barx + barw*fb_n, b2y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b2y-1*ui_s; gfx_printf("%+.2f", ui_fb);

// 3 Distance
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b3y-label_lift; gfx_printf("Distance");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b3y,barw,barh); gfx_roundrect(barx,b3y,barw,barh,6*ui_s,1);
gfx_set(0.78,0.81,0.90,1); gfx_rect(barx,b3y,barw*ui_dist,barh);
gfx_set(1,1,1, hover_bar==3 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_dist, b3y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b3y-1*ui_s; gfx_printf("%.2fm", last_dist_m);

// 4 Throw
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b4y-label_lift; gfx_printf("Spatial Throw");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b4y,barw,barh); gfx_roundrect(barx,b4y,barw,barh,6*ui_s,1);
gfx_set(src_cr,src_cg,src_cb,1); gfx_rect(barx,b4y,barw*ui_throw,barh);
gfx_set(1,1,1, hover_bar==4 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_throw, b4y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b4y-1*ui_s; gfx_printf("%.0f%%", ui_throw*100);

// 5 Size
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b5y-label_lift; gfx_printf("Size");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b5y,barw,barh); gfx_roundrect(barx,b5y,barw,barh,6*ui_s,1);
gfx_set(src_cr,src_cg,src_cb,1); gfx_rect(barx,b5y,barw*ui_size,barh);
gfx_set(1,1,1, hover_bar==5 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_size, b5y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b5y-1*ui_s; gfx_printf("%.2f", ui_size);

// 6 Push Out
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b6y-label_lift; gfx_printf("Push Out");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b6y,barw,barh); gfx_roundrect(barx,b6y,barw,barh,6*ui_s,1);
gfx_set(0.95,0.66,0.24,1); gfx_rect(barx,b6y,barw*ui_push,barh);
gfx_set(1,1,1, hover_bar==6 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_push, b6y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b6y-1*ui_s; gfx_printf("%.2f", ui_push);

// 7 Room
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b7y-label_lift; gfx_printf("Room");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b7y,barw,barh); gfx_roundrect(barx,b7y,barw,barh,6*ui_s,1);
gfx_set(bounce_r,bounce_g,bounce_b,1); gfx_rect(barx,b7y,barw*ui_room,barh);
gfx_set(1,1,1, hover_bar==7 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_room, b7y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b7y-1*ui_s; gfx_printf("%.2f", ui_room);

// 8 Occlusion
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b8y-label_lift; gfx_printf("Occlusion");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b8y,barw,barh); gfx_roundrect(barx,b8y,barw,barh,6*ui_s,1);
gfx_set(occ_cr,occ_cg,occ_cb,1); gfx_rect(barx,b8y,barw*ui_occ,barh);
gfx_set(1,1,1, hover_bar==8 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_occ, b8y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b8y-1*ui_s; gfx_printf("%.2f", ui_occ);

// 9 Motion
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b9y-label_lift; gfx_printf("Motion");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b9y,barw,barh); gfx_roundrect(barx,b9y,barw,barh,6*ui_s,1);
gfx_set(ok_r,ok_g,ok_b,1); gfx_rect(barx,b9y,barw*ui_motion,barh);
gfx_set(1,1,1, hover_bar==9 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_motion, b9y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b9y-1*ui_s; gfx_printf("%.2f", ui_motion);

// 10 Output
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b10y-label_lift; gfx_printf("Output");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b10y,barw,barh); gfx_roundrect(barx,b10y,barw,barh,6*ui_s,1);
gfx_set(0.85,0.88,0.93,1); gfx_rect(barx,b10y,barw*trim_n,barh);
zero_x = barx + barw*(18/30);
gfx_set(0.10,0.10,0.12,0.85); gfx_line(zero_x, b10y, zero_x, b10y+barh);
gfx_set(1,1,1, hover_bar==10 ? 0.95 : 0.70); gfx_circle(barx + barw*trim_n, b10y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b10y-1*ui_s; gfx_printf("%.1fdB", ui_trim);

// --- right card 3: visual key + advanced readouts ---
gfx_setfont(2,"Arial",fs2,'b');
gfx_set(txt_r,txt_g,txt_b,1);
gfx_x = c3x + 14*ui_s; gfx_y = c3y + 10*ui_s; gfx_printf("Visual Keys");

gfx_setfont(4,"Arial",fs4);
gfx_set(0.90,0.92,0.96,1);
line_h = fs4 + 4*ui_s;
c3tx = c3x + 14*ui_s;
c3ty = c3y + 30*ui_s;
gfx_x = c3tx; gfx_y = c3ty + 0*line_h; gfx_printf("Size = orange halo/cloud");
gfx_x = c3tx; gfx_y = c3ty + 1*line_h; gfx_printf("Distance = grey rings/dashes");
gfx_x = c3tx; gfx_y = c3ty + 2*line_h; gfx_printf("Push Out = listener shell");
(c3h > 88*ui_s) ? (
  gfx_x = c3tx; gfx_y = c3ty + 3*line_h; gfx_printf("Room = cyan | Motion = green");
);
(c3h > 108*ui_s) ? (
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = c3tx; gfx_y = c3ty + 5*line_h; gfx_printf("Drag=place | Wheel=distance | Ctrl=throw");
);
(c3h > 128*ui_s) ? (
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = c3tx; gfx_y = c3ty + 6*line_h; gfx_printf("Curve %.2f -> eff %.2f | ITD %.3f ms", ui_curve, last_cue_curve_eff, last_itd_ms);
);

// footer
gfx_setfont(4,"Arial",fs4);
gfx_set(mut_r,mut_g,mut_b,1);
gfx_x = pad; gfx_y = gfx_h - foot_h + 7*ui_s;
gfx_printf("V6.2.1: aligned hover help; slider hitboxes and tooltip hitboxes now share the same lane geometry.");

// --- hover tooltip card ---
(tooltip_show) ? (
  tip_w = 318*ui_s;
  tip_h = 88*ui_s;
  tip_w < 230 ? tip_w = 230;
  tip_h < 72 ? tip_h = 72;

  // Dock tooltip away from the active region. Near-cursor cards covered the next
  // lanes and made the controls feel offset even when the math was correct.
  mouse_x >= rx ? (
    // Hovering right-side controls: put help on the canvas side.
    tip_x = canvas_x + 16*ui_s;
    tip_y = canvas_y + canvas_h - tip_h - 16*ui_s;
  ) : (
    // Hovering the canvas/chips: put help in the lower-right info area.
    tip_x = rx;
    tip_y = c3y + c3h - tip_h - 8*ui_s;
    tip_y < c3y + 8*ui_s ? tip_y = c3y + 8*ui_s;
  );
  tip_x + tip_w > gfx_w - pad ? tip_x = gfx_w - pad - tip_w;
  tip_y + tip_h > gfx_h - pad ? tip_y = gfx_h - pad - tip_h;
  tip_x < pad ? tip_x = pad;
  tip_y < pad ? tip_y = pad;

  gfx_set(0,0,0,0.42);
  gfx_rect(tip_x + 4*ui_s, tip_y + 5*ui_s, tip_w, tip_h);
  gfx_roundrect(tip_x + 4*ui_s, tip_y + 5*ui_s, tip_w, tip_h, 10*ui_s, 1);

  gfx_set(0.065,0.075,0.098,0.97);
  gfx_rect(tip_x, tip_y, tip_w, tip_h);
  gfx_roundrect(tip_x, tip_y, tip_w, tip_h, 10*ui_s, 1);
  gfx_set(0.40,0.47,0.60,0.88);
  gfx_roundrect(tip_x, tip_y, tip_w, tip_h, 10*ui_s, 0);

  // Accent stripe by visual/control family.
  tip_id == 22 || tip_id == 107 ? gfx_set(bounce_r,bounce_g,bounce_b,0.96) :
  tip_id == 108 || tip_id == 29 ? gfx_set(occ_cr,occ_cg,occ_cb,0.96) :
  tip_id == 109 || tip_id == 28 ? gfx_set(ok_r,ok_g,ok_b,0.96) :
  tip_id == 103 || tip_id == 27 ? gfx_set(0.78,0.82,0.92,0.96) :
  tip_id == 106 || tip_id == 23 ? gfx_set(0.95,0.66,0.24,0.96) :
  gfx_set(src_cr,src_cg,src_cb,0.96);
  gfx_rect(tip_x, tip_y, 4*ui_s, tip_h);

  tip_tx = tip_x + 13*ui_s;
  tip_title_y = tip_y + 9*ui_s;
  tip_l1 = tip_y + 31*ui_s;
  tip_l2 = tip_y + 49*ui_s;
  tip_l3 = tip_y + 67*ui_s;

  gfx_setfont(2,"Arial",fs2,'b');
  gfx_set(txt_r,txt_g,txt_b,1);
  gfx_x = tip_tx; gfx_y = tip_title_y;
  tip_id == 20 ? gfx_printf("Source Object") :
  tip_id == 21 ? gfx_printf("Cue Ghost") :
  tip_id == 22 ? gfx_printf("Room Bounces") :
  tip_id == 23 ? gfx_printf("Push Out Shell") :
  tip_id == 24 ? gfx_printf("Stage Placement") :
  tip_id == 25 ? gfx_printf("Canvas Controls") :
  tip_id == 26 ? gfx_printf("Size Halo") :
  tip_id == 27 ? gfx_printf("Distance Rings") :
  tip_id == 28 ? gfx_printf("Motion Trail") :
  tip_id == 29 ? gfx_printf("Occlusion Wedge") :
  tip_id == 30 ? gfx_printf("Automation Safe") :
  tip_id >= 41 && tip_id <= 48 ? gfx_printf("Snap Placement") :
  tip_id == 101 ? gfx_printf("Lateral") :
  tip_id == 102 ? gfx_printf("Front / Rear") :
  tip_id == 103 ? gfx_printf("Distance") :
  tip_id == 104 ? gfx_printf("Spatial Throw") :
  tip_id == 105 ? gfx_printf("Size") :
  tip_id == 106 ? gfx_printf("Push Out") :
  tip_id == 107 ? gfx_printf("Room") :
  tip_id == 108 ? gfx_printf("Occlusion") :
  tip_id == 109 ? gfx_printf("Motion") :
  tip_id == 110 ? gfx_printf("Output Trim") : gfx_printf("Help");

  gfx_setfont(4,"Arial",fs4);
  gfx_set(0.82,0.86,0.93,1);

  tip_id == 20 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Drag to place the visual object.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Shift = fine, Alt = distance only.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Orange halo/cloud shows Size.");
  ) : tip_id == 21 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Effective DSP direction after Throw/Curve.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Solid orb = visual; ghost = cue target.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Visual %.0f deg | Cue %.0f deg", last_visual_az, last_cue_az);
  ) : tip_id == 22 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Cyan wall hits are early bounces.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Room raises bounce opacity and glow.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Room Size changes geometry timing.");
  ) : tip_id == 23 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Externalization cue around the listener.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Push Out helps leave the head.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Not distance, not gain.");
  ) : tip_id == 24 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("X = Lateral, Y = Front/Rear.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Wheel = Distance.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click canvas = reset position.");
  ) : tip_id == 25 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Drag source/room to place object.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Ctrl-wheel = Spatial Throw.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Alt-wheel = Push Out.");
  ) : tip_id == 26 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Size means source extent/diffusion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("It grows the orange halo/cloud.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("It is not Distance.");
  ) : tip_id == 27 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Distance is range from the listener.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Grey rings/dashes show close-to-far.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Wheel over canvas edits it.");
  ) : tip_id == 28 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Motion is tiny anti-collapse drift.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Green dots show the movement envelope.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Low values add life, not travel.");
  ) : tip_id == 29 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Occlusion means blocked/screened source.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Purple wedge marks the blocker cue.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Higher values darken the direct path.");
  ) : tip_id == 30 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Caps aggressive cue motion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Use for fast drawn automation.");
    gfx_x = tip_tx; gfx_y = tip_l3; ui_safe ? gfx_printf("Currently ON.") : gfx_printf("Currently OFF.");
  ) : tip_id >= 41 && tip_id <= 48 ? (
    gfx_x = tip_tx; gfx_y = tip_l1;
    tip_id == 41 ? gfx_printf("Center front quick placement.") :
    tip_id == 42 ? gfx_printf("30 deg left-front quick placement.") :
    tip_id == 43 ? gfx_printf("45 deg left-front quick placement.") :
    tip_id == 44 ? gfx_printf("60 deg left-front quick placement.") :
    tip_id == 45 ? gfx_printf("30 deg right-front quick placement.") :
    tip_id == 46 ? gfx_printf("45 deg right-front quick placement.") :
    tip_id == 47 ? gfx_printf("60 deg right-front quick placement.") : gfx_printf("Centered rear quick placement.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Click to jump visual position.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Spatial Throw still controls intensity.");
  ) : tip_id == 101 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Left/right object coordinate. %.2f", ui_lat);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Automation-safe replacement for azimuth.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Canvas X also edits this.");
  ) : tip_id == 102 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Front wall to rear wall placement. %.2f", ui_fb);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("+ = front, 0 = side, - = rear.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Canvas Y also edits this.");
  ) : tip_id == 103 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Near/far range from listener: %.2f m", last_dist_m);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Grey rings/dashes show distance only.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Does not mean source Size.");
  ) : tip_id == 104 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Spatial cue intensity, not loudness.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Scales ITD, shadow, pinna, side cues.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Use lower values for mix-safe positions.");
  ) : tip_id == 105 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Apparent object size/diffusion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Orange halo/cloud grows with Size.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Does not mean farther away.");
  ) : tip_id == 106 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Out-of-head externalization strength.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Shown as listener shell/separation rays.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Former Externalize control.");
  ) : tip_id == 107 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Early reflection and room cue amount.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Cyan bounces/wall glow scale with Room.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("More Room = less surgical, more external.");
  ) : tip_id == 108 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Blocked or screened source feel.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Darkens/smears direct sound.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Purple wedge shows blocker cue.");
  ) : tip_id == 109 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Tiny anti-collapse drift.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Green trail shows motion envelope.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Low values add life, not travel.");
  ) : tip_id == 110 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Final gain after spatial processing.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Use for level match, not distance.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click resets to 0 dB.");
  );
);
