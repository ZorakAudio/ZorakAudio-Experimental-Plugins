  sid == 2 ? (mn=-1; mx=1;) :
  sid == 3 ? (mn=0; mx=1;) :
  sid == 4 ? (mn=0; mx=1;) :
  sid == 5 ? (mn=0; mx=1;) :
  sid == 6 ? (mn=0; mx=1;) :
  sid == 7 ? (mn=0; mx=1;) :
  sid == 8 ? (mn=0; mx=1;) :
  sid == 9 ? (mn=0; mx=1;) :
             (mn=-18; mx=12;);

