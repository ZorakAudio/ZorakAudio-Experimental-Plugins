    v > mx ? v = mx;
  ) : (
    nrm = (mouse_x - barx) / barw;
    nrm < 0 ? nrm = 0;
    nrm > 1 ? nrm = 1;
    v = mn + nrm * (mx - mn);
  );

  sid == 1 ? slider1 = v :
  sid == 2 ? slider3 = v :
  sid == 3 ? slider2 = v :
  sid == 4 ? slider4 = v :
  sid == 5 ? slider5 = v :
  sid == 6 ? slider6 = v :
  sid == 7 ? slider7 = v :
  sid == 8 ? slider8 = v :
  sid == 9 ? slider9 = v : slider10 = v;

