
desc:Performance Texture Engine (PTE)

// #FILE: Texture {Texture to be injected based on input envelope}
filename:0,Texture

options:gfx_hz=30 maxmem=32000000 ownership=hybrid

slider1:0.75<0,1,0.001>-Mix
slider2:0<-24,24,0.1>-Texture Gain (dB)
slider3:1.25<0.1,8,0.001>-Sensitivity
slider4:0.08<0,1,0.0001>-Gate Threshold
slider5:0.58<0,1,0.001>-Flow
slider6:0.72<0,1,0.001>-Focus
slider7:0.65<0,1,0.001>-Grounding
slider8:0.22<0,1,0.001>-Jitter
slider9:220<10,3000,1>-Slice (ms)
slider10:0<0,3,1{One-Shot,Random,Granular,Gran Synth}>-Playback Mode
slider11:0<0,1,1{Dry+Wet,Wet Only}>-Output Mode
slider12:1<0,1,1{Off,On}>-Auto-Reload On File Change
slider13:0<0,1,1{Off,Reload}>-Reload Texture
slider14:30<0,720,0.1>-Max Load (s,0=all)
slider15:10<0.1,2000,0.1>-Attack (ms)
slider16:90<0.1,3000,0.1>-Decay (ms)
slider17:0.45<0,1,0.001>-Sustain
slider18:180<0.1,5000,0.1>-Release (ms)
slider19:0<-1,1,0.001>-Attack Curve
slider20:0<-1,1,0.001>-Decay Curve
slider21:0<-1,1,0.001>-Release Curve
slider22:4<0.1,200,0.1>-Follower Attack (ms)
slider23:120<1,4000,1>-Follower Release (ms)
slider24:0.70<0.05,0.99,0.001>-Gate Hysteresis
slider25:1<0,1,0.001>-Support
slider26:0<0,2,1{Free,Tight,Clamp}>-Gate Release Mode
slider27:0<0,1,1{Fixed,Auto}>-Auto Slice
slider28:0<-24,24,0.01>-Global Pitch (st)
slider29:0<0,4,1{Neutral,Cloth,Wet,Bed,Friction}>-Material Profile
slider30:0<0,1,1{Off,On}>-Debug Overlay
slider31:0<0,1,0.001>-Env Mix
slider32:180<20,1500,1>-Env Speed (ms)
slider33:0<0,1,0.001>-Slice Rand
slider34:0<0,1,0.001>-Support Rand
slider35:0<0,3,1{Auto,Input,Sidechain,MIDI}>-Trigger Source
slider36:0<0,1,1{Mono,Poly}>-MIDI Note Mode

@init
ln10 = 2.302585092994046;
ln2  = 0.6931471805599453;
PI   = 3.14159265358979323846;
eps  = 0.000000000001;

tex_base = 0;

// reserve a tail zone for summaries / candidates / voices
meta_base = 31500000;

wf_base = meta_base;
wf_max_bins = 1800;
wf_scan_cap = 64;

cand_base = wf_base + wf_max_bins * 2 + 4096;
cand_max = 2048;
cand_stride = 19; // start,rms,peak,flux,zc,contrast,score,rank,edge,slope,hf,motion,onset,phase,family,scale,pc1,pc2,novelty

heat_base = cand_base + cand_max * cand_stride + 4096;
hist_base = heat_base + wf_max_bins + 1024;
hist_bins = 32;

attack_pool_base  = hist_base + hist_bins + 1024;
body_pool_base    = attack_pool_base + cand_max + 1024;
release_pool_base = body_pool_base + cand_max + 1024;
debris_pool_base  = release_pool_base + cand_max + 1024;

recent_base = debris_pool_base + cand_max + 4096;
recent_max = 24;

voice_base = recent_base + recent_max + 4096;
max_voices = 24;
v_stride = 13; // active,start,src_pos,src_len,rate,amp,phaseofs,cand,mode,spawn_support,note_tag,age,env_len

midi_note_vel_base = voice_base + max_voices * v_stride + 4096;
midi_note_order_base = midi_note_vel_base + 128 + 64;
cc_map_base = midi_note_order_base + 128 + 64;
cc_param_count = 36;
midi_evt_on_base = cc_map_base + cc_param_count + 64;
midi_evt_off_base = midi_evt_on_base + 128;
midi_note_countdown_base = midi_evt_off_base + 128;
midi_active_list_base = midi_note_countdown_base + 128;
midi_poly_max = 8;
cc_amt_base = midi_active_list_base + midi_poly_max + 64;
cc_center_base = cc_amt_base + cc_param_count + 64;
cc_last_base = cc_center_base + cc_param_count + 64;
cc_dirty_base = cc_last_base + cc_param_count + 64;

// offline structured-model layer: phase-conditional clusters, HSMM state stats,
// NMF-style fingerprints, sparse graph neighbors, and export-ready tokens.
cand_cluster_base = cc_dirty_base + cc_param_count + 64;
cand_state_base = cand_cluster_base + cand_max + 64;
cand_token_base = cand_state_base + cand_max + 64;
cand_nmf0_base = cand_token_base + cand_max + 64;
cand_nmf1_base = cand_nmf0_base + cand_max + 64;
cand_nmf2_base = cand_nmf1_base + cand_max + 64;
graph_k = 6;
cand_graph_idx_base = cand_nmf2_base + cand_max + 64;
cand_graph_w_base = cand_graph_idx_base + cand_max * graph_k + 64;
sorted_idx_base = cand_graph_w_base + cand_max * graph_k + 64;
tmp_idx_base = sorted_idx_base + cand_max + 64;
tmp_val_base = tmp_idx_base + cand_max + 64;
beam_width = 6;
beam_idx_base = tmp_val_base + cand_max + 64;
beam_score_base = beam_idx_base + beam_width + 64;
state_count = 24; // 4 phases * 2 scales * 3 clusters
state_trans_base = beam_score_base + beam_width + 64;
state_dur_mean_base = state_trans_base + state_count * state_count + 64;
state_dur_var_base = state_dur_mean_base + state_count + 64;
state_dur_count_base = state_dur_var_base + state_count + 64;
state_entry_base = state_dur_count_base + state_count + 64;
nmf_w_base = state_entry_base + state_count + 64;
nmf_acc_base = nmf_w_base + 32 + 64;

freembuf(nmf_acc_base + 64 + 4096);

// file state
tex_loaded = 0;
tex_sig = 0;
tex_ch = 0;
tex_sr = srate;
tex_items = 0;
tex_frames = 0;
tex_rate = 1;
tex_truncated = 0;

src_ch = 0;
src_sr = 0;
src_items = 0;
src_frames = 0;

wf_bins = 0;
wf_absmax = 1;
wf_ready = 0;

cand_count = 0;
cand_live_count = 0;
cand_short_live_count = 0;
cand_med_live_count = 0;
cand_reject_score = 0.001;
attack_pool_count = 0;
body_pool_count = 0;
release_pool_count = 0;
debris_pool_count = 0;
analysis_ready = 0;
ana_win = 0;
ana_hop = 0;
ana_win_short = 0;
ana_hop_short = 0;
ana_win_med = 0;
ana_hop_med = 0;
score_peak = 1;
best_cand = 0;
best_start = 0;

cloud_center = 0;
cloud_radius_frames = 2048;
texture_running = 0;
spawn_countdown = 0;

follow = 0;
follow_ui_peak = 0.25;
det_raw = 0;
det_soft = 0;
det_mix = 0;
det_prev = 0;
det_prime = 0;
support_sig = 0;
support_drive = 0;
support_mix = 0;
support_prev = 0;
support_rise = 0;
support_fall = 0;
wake_force = 0;
gate = 0;
gate_peak = 0;
trig_v = 0;

meter_out = 0;
support_gain = 1;
trig_flash = 0;
last_spawn_flash = 0;
last_spawn_start = 0;
last_spawn_len = 0;
last_spawn_envlen = 0;
last_spawn_phase = 0;
last_spawn_mode = 0;
voices_last_count = 0;
spawn_continuation = 0;

file_state = 0;
last_reload = 0;
ui_force_reload = 0;

seed = 123456789;

phase_att = 1;
phase_body = 2;
phase_rel = 3;
phase_deb = 4;
scale_short = 1;
scale_med = 2;
last_phase = 0;
last_family = 0;
desired_family = 0;
desired_phase = 2;
desired_phase2 = 4;
last_state = 0;
last_token = -1;
state_run_count = 0;
state_run_ms = 0;
dbg_w_hsmm = 1;
dbg_w_graph = 1;
dbg_w_texstat = 1;
dbg_w_token = 1;
dbg_sel_state = 0;
dbg_sel_token = -1;
corpus_nrms_mean = 0.35;
corpus_hf_mean = 0.35;
corpus_motion_mean = 0.35;
corpus_ctr_mean = 0.35;
corpus_slope_mean = 0;
corpus_onset_mean = 0.25;
codec_token_peak = 1;

def_a = 8;
def_d = 70;
def_s = 0.55;
def_r = 180;
def_ac = 0;
def_dc = 0;
def_rc = 0;

ui_lmb_last = 0;
ui_rmb_last = 0;
ui_mmb_last = 0;
ui_active_kind = 0; // 0 none, 1 macro, 2 env point, 3 knob, 4 curve, 5 follow bar
ui_active_id = 0;
ui_drag_start_x = 0;
ui_drag_start_y = 0;
ui_drag_start_val = 0;
ui_drag_start_val2 = 0;

midi_active_count = 0;
midi_held_note = -1;
midi_held_vel = 0;
midi_note_gate = 0;
midi_note_on_evt = 0;
midi_note_off_evt = 0;
midi_note_changed_evt = 0;
midi_note_vel_norm = 0;
midi_note_pitch_st = 0;
midi_note_pitch_cents = 0;
midi_order_counter = 1;
source_mode = 0;
eff_source_mode = 1;
auto_source_mode = 1;
last_source_mode = -1;
auto_in_level = 0;
auto_sc_level = 0;
auto_midi_level = 0;
auto_src_c = 0.9982;
midi_root_note = 60;
cc_picker_param = 0;
cc_picker_current = -1;
cc_browser_active = 0;
cc_browser_param = 0;
cc_browser_page = 0;
cc_browser_hover = -1;
cc_browser_selected = -2;
ui_button_click = 0;
midi_mode = 0;
midi_poly_count = 0;
block_event_arm = 0;
midi_block_evt_on = 0;
midi_block_evt_off = 0;
midi_block_evt_change = 0;
spawn_pitch_override_active = 0;
spawn_pitch_override_cents = 0;
spawn_support_override_active = 0;
spawn_support_override_val = 0;
spawn_note_tag = -1;
last_midi_mode = -1;

last_profile_sel = -1;

recent_family_mean = 0;
recent_nrms_mean = 0;
recent_hf_mean = 0;
recent_motion_mean = 0;
recent_zc_mean = 0;
recent_ctr_mean = 0;
recent_slope_p_mean = 0;
recent_slope_n_mean = 0;

dbg_capture_ci = -1;
dbg_w_base = 1;
dbg_w_phase = 1;
dbg_w_scale = 1;
dbg_w_family = 1;
dbg_w_compat = 1;
dbg_w_total = 1;
dbg_w_pca = 1;
dbg_sel_novel = 0;
pca_var1 = 0.000001;
pca_var2 = 0.000001;
pca_novelty_peak = 0.000001;

// coarse spectral-envelope imprint states (wet-only, broad-band, smoothed)
env_shape_mix = 0;
env_shape_speed_ms = 180;
env_shape_floor = 0.00025;
env_shape_max_ratio = 1.0;
env_lp1_c = 0; env_lp2_c = 0; env_lp3_c = 0;
env_band_atk_c = 0; env_band_rel_c = 0;
env_gain_atk_c = 0; env_gain_rel_c = 0;
dry_lp1 = 0; dry_lp2 = 0; dry_lp3 = 0;
wetm_lp1 = 0; wetm_lp2 = 0; wetm_lp3 = 0;
wetL_lp1 = 0; wetL_lp2 = 0; wetL_lp3 = 0;
wetR_lp1 = 0; wetR_lp2 = 0; wetR_lp3 = 0;
dry_env0 = 0; dry_env1 = 0; dry_env2 = 0; dry_env3 = 0;
wet_env0 = 0; wet_env1 = 0; wet_env2 = 0; wet_env3 = 0;
env_gain0 = 1; env_gain1 = 1; env_gain2 = 1; env_gain3 = 1;
env_shape_conf = 0;

ri = 0;
loop(recent_max,
  mem[recent_base + ri] = -1;
  ri += 1;
);
recent_head = 0;

vi = 0;
loop(max_voices,
  mem[voice_base + vi * v_stride] = 0;
  vi += 1;
);
ni = 0;
loop(128,
  mem[midi_evt_on_base + ni] = 0;
  mem[midi_evt_off_base + ni] = 0;
  mem[midi_note_countdown_base + ni] = 0;
  ni += 1;
);
ni = 0;
loop(midi_poly_max,
  mem[midi_active_list_base + ni] = -1;
  ni += 1;
);

ni = 0;
loop(128,
  mem[midi_note_vel_base + ni] = 0;
  mem[midi_note_order_base + ni] = 0;
  ni += 1;
);

ci = 0;
loop(cc_param_count + 1,
  mem[cc_map_base + ci] = -1;
  mem[cc_amt_base + ci] = 0.20;
  mem[cc_center_base + ci] = -1000;
  mem[cc_last_base + ci] = -1000;
  mem[cc_dirty_base + ci] = 0;
  ci += 1;
);

@slider
slider17 < 0 ? slider17 = 0;
slider17 > 1 ? slider17 = 1;
slider19 < -1 ? slider19 = -1;
slider19 > 1 ? slider19 = 1;
slider20 < -1 ? slider20 = -1;
slider20 > 1 ? slider20 = 1;
slider21 < -1 ? slider21 = -1;
slider21 > 1 ? slider21 = 1;
slider33 < 0 ? slider33 = 0;
slider33 > 1 ? slider33 = 1;
slider34 < 0 ? slider34 = 0;
slider34 > 1 ? slider34 = 1;

function clamp_slider(v, lo, hi) (
  v < lo ? v = lo;
  v > hi ? v = hi;
  v;
);

function cc_param_norm_slider(param) local(t) (
  param == 1 ? t = slider1 :
  param == 2 ? t = (slider2 + 24) / 48 :
  param == 3 ? t = log(slider3 / 0.1) / log(8 / 0.1) :
  param == 4 ? t = slider4 :
  param == 5 ? t = slider5 :
  param == 6 ? t = slider6 :
  param == 7 ? t = slider7 :
  param == 8 ? t = slider8 :
  param == 9 ? t = log(slider9 / 10) / log(3000 / 10) :
  param == 10 ? t = slider10 / 3 :
  param == 11 ? t = slider11 :
  param == 12 ? t = slider12 :
  param == 13 ? t = slider13 :
  param == 14 ? t = slider14 / 720 :
  param == 15 ? t = log(slider15 / 0.1) / log(2000 / 0.1) :
  param == 16 ? t = log(slider16 / 0.1) / log(3000 / 0.1) :
  param == 17 ? t = slider17 :
  param == 18 ? t = log(slider18 / 0.1) / log(5000 / 0.1) :
  param == 19 ? t = (slider19 + 1) * 0.5 :
  param == 20 ? t = (slider20 + 1) * 0.5 :
  param == 21 ? t = (slider21 + 1) * 0.5 :
  param == 22 ? t = log(slider22 / 0.1) / log(200 / 0.1) :
  param == 23 ? t = log(slider23 / 1) / log(4000 / 1) :
  param == 24 ? t = (slider24 - 0.05) / (0.99 - 0.05) :
  param == 25 ? t = slider25 :
  param == 26 ? t = slider26 / 2 :
  param == 27 ? t = slider27 :
  param == 28 ? t = (slider28 + 24) / 48 :
  param == 29 ? t = slider29 / 4 :
  param == 30 ? t = slider30 :
  param == 31 ? t = slider31 :
  param == 32 ? t = log(slider32 / 20) / log(1500 / 20) :
  param == 33 ? t = slider33 :
  param == 34 ? t = slider34 :
  param == 35 ? t = slider35 / 3 :
  param == 36 ? t = slider36 :
  t = 0;
  clamp_slider(t, 0, 1);
);

cur_profile_sel = floor(slider29 + 0.5);
last_profile_sel < 0 ? last_profile_sel = cur_profile_sel;
cur_profile_sel != last_profile_sel ? (
  // Profile changes update behavioral priors only.
  // Do not resurrect stale macro/envelope state from any cache.
  last_profile_sel = cur_profile_sel;
);

wet = slider1;
tex_gain = exp((slider2 / 20) * ln10);

sensitivity = slider3;

// threshold lives directly on the detector soft-knee meter.
th_on = slider4;
th_off = slider4 * slider24;
th_off < 0 ? th_off = 0;

knee_hi = th_on;
knee_lo = th_off;
det_sat_k = 1.35 + 0.20 * min(1, (sensitivity - 0.1) / 7.9);

mode = floor(slider10 + 0.5);
source_mode = floor(slider35 + 0.5);
midi_mode = floor(slider36 + 0.5);

flow = slider5;
focus = slider6;
grounding = slider7;
jitter = slider8;
dur_ms = slider9;

flow_sq = flow * flow;
dur_var = 0.10 + 0.35 * flow;
density =
  mode == 0 ? 1 :
  mode == 1 ? (0.85 + flow_sq * 15.0) :
  mode == 2 ? (3.0 + pow(flow, 1.6) * 42.0) :
  (2.2 + pow(flow, 1.55) * 28.0);

interesting = focus;
repeat_avoid = 0.20 + 0.80 * focus;
pos_wander = 0.03 + flow_sq * 0.97;

pitch_jit = pow(jitter, 1.15) * 72;
amp_jit_db = jitter * 4.5;
phase_jit_deg = pow(jitter, 0.95) * 180;
global_pitch_st = slider28;
global_pitch_cents = global_pitch_st * 100;

support_budget = slider25;
slice_rand_amt = slider33;
support_rand_amt = slider34;
slice_rand_span = 1 + 0.60 * slice_rand_amt;
slice_rand_down_pct = (1 - 1 / max(1.000001, slice_rand_span)) * 100;
slice_rand_up_pct = (slice_rand_span - 1) * 100;
support_rand_down_pct = 22 * support_rand_amt;
support_rand_up_pct = 8 * support_rand_amt;
gate_rel_mode = floor(slider26 + 0.5);
auto_slice = slider27 > 0.5;
profile = floor(slider29 + 0.5);
debug_overlay = slider30 > 0.5;

env_shape_mix = slider31;
env_shape_speed_ms = slider32;
env_shape_speed_s = max(1, floor(env_shape_speed_ms * 0.001 * srate));
env_shape_atk_s = max(1, floor(env_shape_speed_s * 0.35));
env_gain_atk_s = max(1, floor(env_shape_speed_s * 0.50));
env_band_atk_c = exp(-1 / env_shape_atk_s);
env_band_rel_c = exp(-1 / env_shape_speed_s);
env_gain_atk_c = exp(-1 / env_gain_atk_s);
env_gain_rel_c = exp(-1 / env_shape_speed_s);
env_lp1_c = exp(-2 * PI * 180 / srate);
env_lp2_c = exp(-2 * PI * 900 / srate);
env_lp3_c = exp(-2 * PI * 3800 / srate);
env_shape_max_ratio = exp((8 / 20) * ln10);

// lightweight material profile layer: changes priors, not engines.
profile == 0 ? (
  profile_att_class = 1.00; profile_body_class = 1.00; profile_rel_class = 1.00; profile_deb_class = 1.00;
  profile_att_pick  = 1.00; profile_body_pick  = 1.00; profile_rel_pick  = 1.00; profile_deb_pick  = 1.00;
  profile_comp_mul = 1.00;  profile_family_lock = 0.95;
  profile_short_att = 1.08; profile_short_body = 0.90; profile_short_rel = 0.96; profile_short_deb = 1.24;
  profile_med_att   = 0.98; profile_med_body   = 1.12; profile_med_rel   = 1.04; profile_med_deb   = 0.84;
  profile_len_att = 0.96; profile_len_body = 1.00; profile_len_rel = 1.00; profile_len_deb = 0.84;
) : profile == 1 ? (
  profile_att_class = 0.92; profile_body_class = 1.08; profile_rel_class = 0.96; profile_deb_class = 1.22;
  profile_att_pick  = 0.90; profile_body_pick  = 1.06; profile_rel_pick  = 0.94; profile_deb_pick  = 1.18;
  profile_comp_mul = 0.92;  profile_family_lock = 0.90;
  profile_short_att = 1.14; profile_short_body = 0.84; profile_short_rel = 0.94; profile_short_deb = 1.32;
  profile_med_att   = 0.92; profile_med_body   = 1.10; profile_med_rel   = 1.02; profile_med_deb   = 0.76;
  profile_len_att = 0.90; profile_len_body = 0.96; profile_len_rel = 0.92; profile_len_deb = 0.78;
) : profile == 2 ? (
  profile_att_class = 1.16; profile_body_class = 1.12; profile_rel_class = 1.18; profile_deb_class = 0.76;
  profile_att_pick  = 1.14; profile_body_pick  = 1.10; profile_rel_pick  = 1.20; profile_deb_pick  = 0.72;
  profile_comp_mul = 1.10;  profile_family_lock = 1.20;
  profile_short_att = 1.00; profile_short_body = 0.82; profile_short_rel = 0.94; profile_short_deb = 1.08;
  profile_med_att   = 1.08; profile_med_body   = 1.20; profile_med_rel   = 1.12; profile_med_deb   = 0.78;
  profile_len_att = 0.96; profile_len_body = 1.12; profile_len_rel = 1.08; profile_len_deb = 0.74;
) : profile == 3 ? (
  profile_att_class = 0.88; profile_body_class = 1.22; profile_rel_class = 1.14; profile_deb_class = 0.66;
  profile_att_pick  = 0.84; profile_body_pick  = 1.22; profile_rel_pick  = 1.18; profile_deb_pick  = 0.60;
  profile_comp_mul = 1.22;  profile_family_lock = 1.28;
  profile_short_att = 0.96; profile_short_body = 0.72; profile_short_rel = 0.84; profile_short_deb = 0.90;
  profile_med_att   = 1.02; profile_med_body   = 1.24; profile_med_rel   = 1.14; profile_med_deb   = 0.74;
  profile_len_att = 0.90; profile_len_body = 1.18; profile_len_rel = 1.12; profile_len_deb = 0.78;
) : (
  profile_att_class = 1.16; profile_body_class = 1.18; profile_rel_class = 0.92; profile_deb_class = 0.86;
  profile_att_pick  = 1.18; profile_body_pick  = 1.16; profile_rel_pick  = 0.88; profile_deb_pick  = 0.82;
  profile_comp_mul = 1.08;  profile_family_lock = 1.06;
  profile_short_att = 1.22; profile_short_body = 0.90; profile_short_rel = 0.90; profile_short_deb = 1.20;
  profile_med_att   = 0.92; profile_med_body   = 1.12; profile_med_rel   = 1.04; profile_med_deb   = 0.82;
  profile_len_att = 0.88; profile_len_body = 1.02; profile_len_rel = 0.90; profile_len_deb = 0.74;
);

input_link =
  mode == 0 ? 0.88 :
  mode == 1 ? 0.58 :
  mode == 2 ? 0.35 :
  0.48;

env_a_ms = slider15;
env_d_ms = slider16;
sus = slider17;
env_r_ms = slider18;

atk_curve = slider19;
dec_curve = slider20;
rel_curve = slider21;

wet_only = slider11 > 0.5;
auto_reload = slider12 > 0.5;

follow_atk_ms = slider22;
follow_rel_ms = slider23;

f_atk_s = max(1, floor(follow_atk_ms * 0.001 * srate));
f_rel_s = max(1, floor(follow_rel_ms * 0.001 * srate));

f_atk_c = exp(-1 / f_atk_s);
f_rel_c = exp(-1 / f_rel_s);

sup_atk_ms = max(2, follow_atk_ms * 0.70);
sup_rel_ms = max(10, follow_rel_ms * 0.80);
sup_atk_s = max(1, floor(sup_atk_ms * 0.001 * srate));
sup_rel_s = max(1, floor(sup_rel_ms * 0.001 * srate));
sup_atk_c = exp(-1 / sup_atk_s);
sup_rel_c = exp(-1 / sup_rel_s);

support_floor =
  mode == 0 ? 0 :
  mode == 1 ? (0.02 + 0.04 * flow_sq) :
  mode == 2 ? (0.04 + 0.04 * flow_sq) :
  (0.03 + 0.03 * flow_sq);
support_floor > 0.08 ? support_floor = 0.08;

env_a_s_base = max(1, floor(env_a_ms * 0.001 * srate));
env_d_s_base = max(1, floor(env_d_ms * 0.001 * srate));
env_r_s_base = max(1, floor(env_r_ms * 0.001 * srate));

source_mode != last_source_mode ? (
  follow = 0;
  det_raw = det_soft = det_mix = det_prev = det_prime = 0;
  support_sig = support_drive = support_mix = support_prev = 0;
  support_rise = support_fall = 0;
  wake_force = 0;
  gate = 0;
  gate_peak = 0;
  texture_running = 0;
  spawn_countdown = 0;
  last_source_mode = source_mode;
);

midi_mode != last_midi_mode ? (
  texture_running = 0;
  spawn_countdown = 0;
  ni = 0;
  loop(128,
    mem[midi_note_countdown_base + ni] = 0;
    ni += 1;
  );
  last_midi_mode = midi_mode;
);

// Keep a per-parameter user center for CC automation.
// CC-applied changes set cc_dirty so they do not re-center themselves.
ci = 1;
loop(cc_param_count,
  cn = cc_param_norm_slider(ci);
  lastn = mem[cc_last_base + ci];
  cd = mem[cc_dirty_base + ci];
  (lastn < -100) || (abs(cn - lastn) > 0.0000001) ? (
    cd > 0 ? (
      mem[cc_dirty_base + ci] = 0;
    ) : (
      mem[cc_center_base + ci] = cn;
    );
    mem[cc_last_base + ci] = cn;
  );
  ci += 1;
);

@serialize
ser_ver = 1.03;
file_var(0, ser_ver);
ser_ver < 1 ? (
  ci = 0;
  loop(cc_param_count + 1,
    mem[cc_map_base + ci] = -1;
    mem[cc_amt_base + ci] = 0.20;
    ci += 1;
  );
) : (
  ci = 1;
  loop(cc_param_count,
    ccv = mem[cc_map_base + ci];
    file_var(0, ccv);
    mem[cc_map_base + ci] = ccv;
    ci += 1;
  );

  ser_ver >= 1.03 ? (
    ci = 1;
    loop(cc_param_count,
      cca = mem[cc_amt_base + ci];
      file_var(0, cca);
      mem[cc_amt_base + ci] = cca;
      ci += 1;
    );
  ) : (
    ci = 1;
    loop(cc_param_count,
      mem[cc_amt_base + ci] = 0.20;
      ci += 1;
    );
  );
);

@block
function cc_param_is_relative(param) (
  !((param == 10) || (param == 11) || (param == 12) || (param == 13) ||
    (param == 26) || (param == 27) || (param == 29) || (param == 30) ||
    (param == 35) || (param == 36));
);

function cc_clamp01(v) (
  v < 0 ? v = 0;
  v > 1 ? v = 1;
  v;
);

function cc_param_norm_block(param) local(t) (
  param == 1 ? t = slider1 :
  param == 2 ? t = (slider2 + 24) / 48 :
  param == 3 ? t = log(slider3 / 0.1) / log(8 / 0.1) :
  param == 4 ? t = slider4 :
  param == 5 ? t = slider5 :
  param == 6 ? t = slider6 :
  param == 7 ? t = slider7 :
  param == 8 ? t = slider8 :
  param == 9 ? t = log(slider9 / 10) / log(3000 / 10) :
  param == 10 ? t = slider10 / 3 :
  param == 11 ? t = slider11 :
  param == 12 ? t = slider12 :
  param == 13 ? t = slider13 :
  param == 14 ? t = slider14 / 720 :
  param == 15 ? t = log(slider15 / 0.1) / log(2000 / 0.1) :
  param == 16 ? t = log(slider16 / 0.1) / log(3000 / 0.1) :
  param == 17 ? t = slider17 :
  param == 18 ? t = log(slider18 / 0.1) / log(5000 / 0.1) :
  param == 19 ? t = (slider19 + 1) * 0.5 :
  param == 20 ? t = (slider20 + 1) * 0.5 :
  param == 21 ? t = (slider21 + 1) * 0.5 :
  param == 22 ? t = log(slider22 / 0.1) / log(200 / 0.1) :
  param == 23 ? t = log(slider23 / 1) / log(4000 / 1) :
  param == 24 ? t = (slider24 - 0.05) / (0.99 - 0.05) :
  param == 25 ? t = slider25 :
  param == 26 ? t = slider26 / 2 :
  param == 27 ? t = slider27 :
  param == 28 ? t = (slider28 + 24) / 48 :
  param == 29 ? t = slider29 / 4 :
  param == 30 ? t = slider30 :
  param == 31 ? t = slider31 :
  param == 32 ? t = log(slider32 / 20) / log(1500 / 20) :
  param == 33 ? t = slider33 :
  param == 34 ? t = slider34 :
  param == 35 ? t = slider35 / 3 :
  param == 36 ? t = slider36 :
  t = 0;
  cc_clamp01(t);
);

function cc_param_apply_norm(param, t) (
  t = cc_clamp01(t);
  param == 1 ? ( slider1 = t; sliderchange(slider1); ) :
  param == 2 ? ( slider2 = -24 + t * 48; sliderchange(slider2); ) :
  param == 3 ? ( slider3 = 0.1 * exp(log(8 / 0.1) * t); sliderchange(slider3); ) :
  param == 4 ? ( slider4 = t; sliderchange(slider4); ) :
  param == 5 ? ( slider5 = t; sliderchange(slider5); ) :
  param == 6 ? ( slider6 = t; sliderchange(slider6); ) :
  param == 7 ? ( slider7 = t; sliderchange(slider7); ) :
  param == 8 ? ( slider8 = t; sliderchange(slider8); ) :
  param == 9 ? ( slider9 = 10 * exp(log(3000 / 10) * t); sliderchange(slider9); ) :
  param == 14 ? ( slider14 = t * 720; sliderchange(slider14); ) :
  param == 15 ? ( slider15 = 0.1 * exp(log(2000 / 0.1) * t); sliderchange(slider15); ) :
  param == 16 ? ( slider16 = 0.1 * exp(log(3000 / 0.1) * t); sliderchange(slider16); ) :
  param == 17 ? ( slider17 = t; sliderchange(slider17); ) :
  param == 18 ? ( slider18 = 0.1 * exp(log(5000 / 0.1) * t); sliderchange(slider18); ) :
  param == 19 ? ( slider19 = -1 + t * 2; sliderchange(slider19); ) :
  param == 20 ? ( slider20 = -1 + t * 2; sliderchange(slider20); ) :
  param == 21 ? ( slider21 = -1 + t * 2; sliderchange(slider21); ) :
  param == 22 ? ( slider22 = 0.1 * exp(log(200 / 0.1) * t); sliderchange(slider22); ) :
  param == 23 ? ( slider23 = 1 * exp(log(4000 / 1) * t); sliderchange(slider23); ) :
  param == 24 ? ( slider24 = 0.05 + t * (0.99 - 0.05); sliderchange(slider24); ) :
  param == 25 ? ( slider25 = t; sliderchange(slider25); ) :
  param == 28 ? ( slider28 = -24 + t * 48; sliderchange(slider28); ) :
  param == 31 ? ( slider31 = t; sliderchange(slider31); ) :
  param == 32 ? ( slider32 = 20 * exp(log(1500 / 20) * t); sliderchange(slider32); ) :
  param == 33 ? ( slider33 = t; sliderchange(slider33); ) :
  param == 34 ? ( slider34 = t; sliderchange(slider34); );
);

function cc_apply_param(param, ccval) local(t, ctr, amt, bipolar) (
  t = ccval / 127;
  cc_param_is_relative(param) ? (
    ctr = mem[cc_center_base + param];
    ctr < -10 ? (
      ctr = cc_param_norm_block(param);
      mem[cc_center_base + param] = ctr;
    );
    amt = mem[cc_amt_base + param];
    amt < 0 ? amt = 0;
    amt > 1 ? amt = 1;
    bipolar = t * 2 - 1;
    cc_param_apply_norm(param, ctr + bipolar * amt);
  ) : (
    param == 10 ? ( slider10 = floor(t * 3.999); sliderchange(slider10); ) :
    param == 11 ? ( slider11 = t >= 0.5 ? 1 : 0; sliderchange(slider11); ) :
    param == 12 ? ( slider12 = t >= 0.5 ? 1 : 0; sliderchange(slider12); ) :
    param == 13 ? ( ccval >= 64 ? ( ui_force_reload = 1; slider13 = 1; sliderchange(slider13); ); ) :
    param == 26 ? ( slider26 = floor(t * 2.999); sliderchange(slider26); ) :
    param == 27 ? ( slider27 = t >= 0.5 ? 1 : 0; sliderchange(slider27); ) :
    param == 29 ? ( slider29 = floor(t * 4.999); sliderchange(slider29); ) :
    param == 30 ? ( slider30 = t >= 0.5 ? 1 : 0; sliderchange(slider30); ) :
    param == 35 ? ( slider35 = floor(t * 3.999); sliderchange(slider35); ) :
    param == 36 ? ( slider36 = t >= 0.5 ? 1 : 0; sliderchange(slider36); );
  );
  mem[cc_dirty_base + param] = 1;
);

midi_note_on_evt = 0;
midi_note_off_evt = 0;
midi_note_changed_evt = 0;
midi_block_evt_on = 0;
midi_block_evt_off = 0;
midi_block_evt_change = 0;
block_event_arm = 0;
ni = 0;
loop(128,
  mem[midi_evt_on_base + ni] = 0;
  mem[midi_evt_off_base + ni] = 0;
  ni += 1;
);
ni = 0;
loop(midi_poly_max,
  mem[midi_active_list_base + ni] = -1;
  ni += 1;
);

function midi_flush_all_notes() local(fi) (
  fi = 0;
  loop(128,
    mem[midi_note_vel_base + fi] = 0;
    mem[midi_note_order_base + fi] = 0;
    mem[midi_evt_on_base + fi] = 0;
    mem[midi_evt_off_base + fi] = 1;
    mem[midi_note_countdown_base + fi] = 0;
    fi += 1;
  );
  midi_active_count = 0;
  midi_held_note = -1;
  midi_held_vel = 0;
  midi_note_gate = 0;
  midi_note_vel_norm = 0;
  midi_note_pitch_st = 0;
  midi_note_pitch_cents = 0;
);

raw_block_on = 0;
raw_block_off = 0;
panic_all_notes = 0;

while (midirecv(offset, msg1, msg2, msg3)) (
  status = msg1 & 240;
  chan = msg1 & 15;
  midisend(offset, msg1, msg2, msg3);

  (msg1 == $xFC) || (msg1 == $xFF) ? (
    panic_all_notes = 1;
  ) : (status == $x90) && (msg3 > 0) ? (
    mem[midi_note_vel_base + msg2] = msg3 / 127;
    mem[midi_note_order_base + msg2] = midi_order_counter;
    mem[midi_evt_on_base + msg2] = msg3 / 127;
    mem[midi_evt_off_base + msg2] = 0;
    mem[midi_note_countdown_base + msg2] = 0;
    midi_order_counter += 1;
    raw_block_on = 1;
  ) : (((status == $x80) || ((status == $x90) && (msg3 == 0)))) ? (
    mem[midi_note_vel_base + msg2] = 0;
    mem[midi_note_order_base + msg2] = 0;
    mem[midi_evt_off_base + msg2] = 1;
    mem[midi_evt_on_base + msg2] = 0;
    mem[midi_note_countdown_base + msg2] = 0;
    raw_block_off = 1;
  ) : (status == $xB0) ? (
    ((msg2 == 120) || (msg2 == 123)) ? (
      panic_all_notes = 1;
    ) : (
      cci = 1;
      loop(cc_param_count,
        mem[cc_map_base + cci] == msg2 ? cc_apply_param(cci, msg3);
        cci += 1;
      );
    );
  );
);

panic_all_notes ? (
  midi_flush_all_notes();
  raw_block_off = 1;
  raw_block_on = 0;
);

midi_active_count = 0;
prev_note_gate = midi_note_gate;
prev_held_note = midi_held_note;
best_ord = 0;
midi_held_note = -1;
midi_held_vel = 0;
ni = 0;
loop(128,
  mem[midi_note_vel_base + ni] > 0 ? midi_active_count += 1;
  ordv = mem[midi_note_order_base + ni];
  ordv > best_ord ? (
    best_ord = ordv;
    midi_held_note = ni;
    midi_held_vel = mem[midi_note_vel_base + ni];
  );
  ni += 1;
);
midi_note_gate = midi_held_note >= 0;
midi_note_vel_norm = midi_note_gate ? midi_held_vel : 0;
midi_note_pitch_st = midi_note_gate ? (midi_held_note - midi_root_note) : 0;
midi_note_pitch_cents = midi_note_pitch_st * 100;

// For mono control, derive block events from the FINAL held-note state,
// not from any transient note-on that happened earlier in the same block.
// That prevents note-on/note-off flurries inside one block from creating
// ghost retriggers after the finger is already gone.
midi_note_on_evt = 0;
midi_note_off_evt = 0;
midi_note_changed_evt = 0;

(!prev_note_gate && midi_note_gate) ? (
  midi_note_on_evt = 1;
) : (prev_note_gate && !midi_note_gate) ? (
  midi_note_off_evt = 1;
) : (prev_note_gate && midi_note_gate && (midi_held_note != prev_held_note)) ? (
  midi_note_changed_evt = 1;
);

midi_block_evt_on = midi_note_on_evt;
midi_block_evt_off = midi_note_off_evt || raw_block_off;
midi_block_evt_change = midi_note_changed_evt;
block_event_arm = 1;

midi_poly_count = 0;
best_prev_ord = 2147483647;
pi = 0;
loop(midi_poly_max,
  best_ord = 0;
  best_note = -1;
  ni = 0;
  loop(128,
    ordv = mem[midi_note_order_base + ni];
    (ordv > 0) && (ordv < best_prev_ord) && (ordv > best_ord) ? (
      best_ord = ordv;
      best_note = ni;
    );
    ni += 1;
  );
  best_note >= 0 ? (
    mem[midi_active_list_base + pi] = best_note;
    midi_poly_count += 1;
    best_prev_ord = best_ord;
  ) : (
    mem[midi_active_list_base + pi] = -1;
  );
  pi += 1;
);

// If no notes remain, flush per-note schedulers so stale countdowns cannot
// resurrect old MIDI lanes later.
(midi_active_count <= 0) ? (
  ni = 0;
  loop(128,
    mem[midi_note_countdown_base + ni] = 0;
    mem[midi_evt_on_base + ni] = 0;
    ni += 1;
  );
  pi = 0;
  loop(midi_poly_max,
    mem[midi_active_list_base + pi] = -1;
    pi += 1;
  );
);

reload_now = ui_force_reload || ((slider13 > 0.5) && (last_reload <= 0.5));
last_reload = slider13;
ui_force_reload = 0;
reload_now ? slider13 = 0;
reload_now ? tex_sig = 0;

h = file_open(0);
file_state = 0;

h > 0 ? (
  ok = file_riff(h, tmp_ch, tmp_sr);
  ok ? (
    tmp_ch = max(1, floor(tmp_ch + 0.5));
    tmp_sr = max(1, floor(tmp_sr + 0.5));

    items_total = file_avail(h);

    src_ch = tmp_ch;
    src_sr = tmp_sr;
    src_items = items_total;
    src_frames = floor(items_total / tmp_ch);

    items_total > 0 ? (
      sig = items_total + tmp_ch * 1000000000 + floor(tmp_sr);

      auto_reload_now = 0;
      auto_reload && (tex_sig > 0) && (sig != tex_sig) ? auto_reload_now = 1;

      need_copy = 0;
      (sig != tex_sig) ? need_copy = 1;
      reload_now ? need_copy = 1;
      auto_reload_now ? need_copy = 1;
      (tex_loaded <= 0) ? need_copy = 1;

      need_copy ? (
        file_rewind(h);

        items_to_copy = items_total;
        tex_truncated = 0;

        slider14 > 0 ? (
          max_frames_slider = floor(slider14 * tmp_sr);
          max_items_slider = max_frames_slider * tmp_ch;
          max_items_slider < items_to_copy ? (
            items_to_copy = max_items_slider;
            tex_truncated = 1;
          );
        );

        max_items_mem = meta_base - tex_base - 16384;
        items_to_copy > max_items_mem ? (
          items_to_copy = max_items_mem;
          tex_truncated = 1;
        );

        copied = file_mem(h, tex_base, items_to_copy);

        copied > 0 ? (
          tex_loaded = 1;
          tex_sig = sig;
          tex_ch = tmp_ch;
          tex_sr = tmp_sr;
          tex_items = copied;
          tex_frames = floor(copied / tex_ch);
          tex_rate = tex_sr / srate;

          follow = 0;
          det_raw = 0;
          det_soft = 0;
          det_mix = 0;
          det_prev = 0;
          det_prime = 0;
          support_sig = 0;
          support_drive = 0;
          support_mix = 0;
          support_prev = 0;
          support_rise = 0;
          support_fall = 0;
          wake_force = 0;
          last_phase = 0;
          last_family = 0;
          last_state = 0;
          last_token = -1;
          state_run_count = 0;
          dbg_sel_state = 0;
          dbg_sel_token = -1;
          desired_phase = phase_body;
          desired_phase2 = phase_deb;
          gate = 0;
          gate_peak = 0;
          trig_v = 0;
          texture_running = 0;
          spawn_countdown = 0;
          meter_out = 0;
          support_gain = 1;
          trig_flash = 0;
          last_spawn_flash = 0;
          last_spawn_envlen = 0;
          last_spawn_phase = 0;
          voices_last_count = 0;
          spawn_continuation = 0;
          auto_in_level = 0;
          auto_sc_level = 0;
          auto_midi_level = 0;

          ri = 0;
          loop(recent_max,
            mem[recent_base + ri] = -1;
            ri += 1;
          );
          recent_head = 0;

          vi = 0;
          loop(max_voices,
            mem[voice_base + vi * v_stride] = 0;
            vi += 1;
          );
          ni = 0;
          loop(128,
            mem[midi_evt_on_base + ni] = 0;
            mem[midi_evt_off_base + ni] = 0;
            mem[midi_note_countdown_base + ni] = 0;
            ni += 1;
          );
          pi = 0;
          loop(midi_poly_max,
            mem[midi_active_list_base + pi] = -1;
            pi += 1;
          );

          // waveform summary
          wf_ready = 0;
          wf_absmax = 0.001;
          wf_meanpk = 0.10;
          wf_draw_ref = 1;
          wf_meanpk_acc = 0;

          wf_bins = floor(tex_frames / 64);
          wf_bins < 128 ? wf_bins = 128;
          wf_bins > wf_max_bins ? wf_bins = wf_max_bins;
          wf_bins > tex_frames ? wf_bins = tex_frames;
          wf_bins < 16 ? wf_bins = 16;

          frame0 = 0;
          b = 0;
          loop(wf_bins,
            frame1 = floor((b + 1) * tex_frames / wf_bins);
            frame1 <= frame0 ? frame1 = frame0 + 1;
            frame1 > tex_frames ? frame1 = tex_frames;

            span = frame1 - frame0;
            step = floor(span / wf_scan_cap);
            step < 1 ? step = 1;

            mn = 0;
            mx = 0;
            first = 1;
            f = frame0;

            loop(max(1, floor((span + step - 1) / step)),
              idx = tex_base + f * tex_ch;
              v = mem[idx];
              tex_ch > 1 ? v = 0.5 * (v + mem[idx + 1]);

              first ? (
                mn = v;
                mx = v;
                first = 0;
              ) : (
                v < mn ? mn = v;
                v > mx ? mx = v;
              );

              av = abs(v);
              av > wf_absmax ? wf_absmax = av;

              f += step;
              f >= frame1 ? f = frame1 - 1;
            );

            mem[wf_base + b * 2]     = mn;
            mem[wf_base + b * 2 + 1] = mx;

            bpk = max(abs(mn), abs(mx));
            wf_meanpk_acc += bpk;

            frame0 = frame1;
            b += 1;
          );

          wf_absmax <= 0 ? wf_absmax = 1;
          wf_meanpk = wf_meanpk_acc / max(1, wf_bins);
          robust_ref = max(0.02, wf_meanpk * 3.5);
          wf_draw_ref = wf_absmax;
          robust_ref < wf_draw_ref ? wf_draw_ref = robust_ref;
          wf_ready = 1;

          // analysis pass: candidate grains
          analysis_ready = 0;
          cand_count = 0;
          cand_live_count = 0;
          cand_short_live_count = 0;
          cand_med_live_count = 0;
          cand_reject_score = 0.001;
          attack_pool_count = 0;
          body_pool_count = 0;
          release_pool_count = 0;
          debris_pool_count = 0;
          score_peak = 1;
          best_cand = 0;
          best_start = 0;

          ana_win_short = floor(tex_sr * 0.018);
          ana_win_short < 128 ? ana_win_short = 128;
          ana_win_short > 2048 ? ana_win_short = 2048;
          ana_win_short > tex_frames ? ana_win_short = tex_frames;

          ana_win_med = floor(tex_sr * 0.040);
          ana_win_med < 256 ? ana_win_med = 256;
          ana_win_med > 4096 ? ana_win_med = 4096;
          ana_win_med > tex_frames ? ana_win_med = tex_frames;

          ana_hop_short = floor(ana_win_short * 0.30);
          ana_hop_short < 32 ? ana_hop_short = 32;
          ana_hop_med = floor(ana_win_med * 0.25);
          ana_hop_med < 64 ? ana_hop_med = 64;

          short_budget = floor(cand_max * 0.58);
          short_budget < 1 ? short_budget = 1;
          med_budget = cand_max - short_budget;
          med_budget < 1 ? med_budget = 1;

          short_est = (tex_frames >= ana_win_short) ? (floor((tex_frames - ana_win_short) / ana_hop_short) + 1) : 0;
          short_est > short_budget ? (
            ana_hop_short = floor((tex_frames - ana_win_short) / max(1, short_budget - 1));
            ana_hop_short < 1 ? ana_hop_short = 1;
          );

          med_est = (tex_frames >= ana_win_med) ? (floor((tex_frames - ana_win_med) / ana_hop_med) + 1) : 0;
          med_est > med_budget ? (
            ana_hop_med = floor((tex_frames - ana_win_med) / max(1, med_budget - 1));
            ana_hop_med < 1 ? ana_hop_med = 1;
          );

          ana_win = ana_win_med;
          ana_hop = ana_hop_med;

          cand_count = 0;
          cand_short_live_count = 0;
          cand_med_live_count = 0;

          max_rms = 0.000001;
          max_peak = 0.000001;
          max_flux = 0.000001;
          max_zc = 0.000001;
          max_edge = 0.000001;
          max_hf = 0.000001;
          max_motion = 0.000001;
          max_onset = 0.000001;
          max_slope_pos = 0.000001;
          max_slope_neg = 0.000001;

          // short-scale pass
          short_count = (tex_frames >= ana_win_short) ? (floor((tex_frames - ana_win_short) / ana_hop_short) + 1) : 0;
          short_count > short_budget ? short_count = short_budget;
          f0 = 0;
          ci = 0;
          loop(short_count,
            cur_win = ana_win_short;
            sumsq = 0;
            peak = 0;
            flux = 0;
            zc = 0;
            hf_proxy = 0;
            prevv = 0;
            preva = 0;
            first = 1;
            n = 0;

            third_n = floor(cur_win / 3);
            third_n < 1 ? third_n = 1;
            q1n = floor(cur_win * 0.25);
            q2n = floor(cur_win * 0.50);
            q3n = floor(cur_win * 0.75);
            q1n < 1 ? q1n = 1;
            q2n <= q1n ? q2n = q1n + 1;
            q3n <= q2n ? q3n = q2n + 1;
            q3n >= cur_win ? q3n = cur_win - 1;

            front_sumsq = 0;
            back_sumsq = 0;
            q0sq = 0;
            q1sq = 0;
            q2sq = 0;
            q3sq = 0;

            loop(cur_win,
              idx = tex_base + (f0 + n) * tex_ch;
              v = mem[idx];
              tex_ch > 1 ? v = 0.5 * (v + mem[idx + 1]);

              av = abs(v);
              sumsq += v * v;
              av > peak ? peak = av;

              n < third_n ? front_sumsq += v * v;
              n >= cur_win - third_n ? back_sumsq += v * v;

              n < q1n ? (
                q0sq += v * v;
              ) : n < q2n ? (
                q1sq += v * v;
              ) : n < q3n ? (
                q2sq += v * v;
              ) : (
                q3sq += v * v;
              );

              first ? (
                prevv = v;
                preva = av;
                first = 0;
              ) : (
                flux += abs(av - preva);
                hf_proxy += abs(v - prevv);
                ((v >= 0) != (prevv >= 0)) ? zc += 1;
                prevv = v;
                preva = av;
              );

              n += 1;
            );

            rms = sqrt(sumsq / max(1, cur_win));
            fluxn = flux / max(1, cur_win);
            zcn = zc / max(1, cur_win);
            hfn = hf_proxy / max(1, cur_win);

            front_rms = sqrt(front_sumsq / max(1, third_n));
            back_rms = sqrt(back_sumsq / max(1, third_n));
            slope = back_rms - front_rms;

            rms0 = sqrt(q0sq / max(1, q1n));
            rms1 = sqrt(q1sq / max(1, q2n - q1n));
            rms2 = sqrt(q2sq / max(1, q3n - q2n));
            rms3 = sqrt(q3sq / max(1, cur_win - q3n));
            motion = (abs(rms1 - rms0) + abs(rms2 - rms1) + abs(rms3 - rms2)) / 3;

            ctx_len = third_n;
            pre_start = f0 - ctx_len;
            pre_start < 0 ? pre_start = 0;
            pre_len = f0 - pre_start;
            pre_sumsq = 0;
            m = 0;
            loop(pre_len,
              idx = tex_base + (pre_start + m) * tex_ch;
              pv = mem[idx];
              tex_ch > 1 ? pv = 0.5 * (pv + mem[idx + 1]);
              pre_sumsq += pv * pv;
              m += 1;
            );
            prev_ctx_rms = pre_len > 0 ? sqrt(pre_sumsq / max(1, pre_len)) : 0;
            onset = front_rms - prev_ctx_rms;
            onset < 0 ? onset = 0;

            fm1 = f0 > 0 ? (f0 - 1) : f0;
            fp1 = f0 < tex_frames - 1 ? (f0 + 1) : f0;

            idxm = tex_base + fm1 * tex_ch;
            idx0 = tex_base + f0  * tex_ch;
            idxp = tex_base + fp1 * tex_ch;

            vm = mem[idxm];
            v0 = mem[idx0];
            vp = mem[idxp];
            tex_ch > 1 ? (
              vm = 0.5 * (vm + mem[idxm + 1]);
              v0 = 0.5 * (v0 + mem[idx0 + 1]);
              vp = 0.5 * (vp + mem[idxp + 1]);
            );
            edge0 = abs(v0) + 0.5 * abs(vp - vm);

            base = cand_base + cand_count * cand_stride;
            mem[base     ] = f0;
            mem[base + 1 ] = rms;
            mem[base + 2 ] = peak;
            mem[base + 3 ] = fluxn;
            mem[base + 4 ] = zcn;
            mem[base + 5 ] = 0;
            mem[base + 6 ] = 0;
            mem[base + 7 ] = 0;
            mem[base + 8 ] = edge0;
            mem[base + 9 ] = slope;
            mem[base + 10] = hfn;
            mem[base + 11] = motion;
            mem[base + 12] = onset;
            mem[base + 13] = 0;
            mem[base + 14] = 0;
            mem[base + 15] = scale_short;
            mem[base + 16] = 0;
            mem[base + 17] = 0;
            mem[base + 18] = 0;

            rms > max_rms ? max_rms = rms;
            peak > max_peak ? max_peak = peak;
            fluxn > max_flux ? max_flux = fluxn;
            zcn > max_zc ? max_zc = zcn;
            edge0 > max_edge ? max_edge = edge0;
            hfn > max_hf ? max_hf = hfn;
            motion > max_motion ? max_motion = motion;
            onset > max_onset ? max_onset = onset;
            slope > max_slope_pos ? max_slope_pos = slope;
            (-slope) > max_slope_neg ? max_slope_neg = -slope;

            f0 += ana_hop_short;
            cand_count += 1;
            ci += 1;
          );

          // medium-scale pass
          med_count = (tex_frames >= ana_win_med) ? (floor((tex_frames - ana_win_med) / ana_hop_med) + 1) : 0;
          med_count > med_budget ? med_count = med_budget;
          f0 = 0;
          ci = 0;
          loop(med_count,
            cur_win = ana_win_med;
            sumsq = 0;
            peak = 0;
            flux = 0;
            zc = 0;
            hf_proxy = 0;
            prevv = 0;
            preva = 0;
            first = 1;
            n = 0;

            third_n = floor(cur_win / 3);
            third_n < 1 ? third_n = 1;
            q1n = floor(cur_win * 0.25);
            q2n = floor(cur_win * 0.50);
            q3n = floor(cur_win * 0.75);
            q1n < 1 ? q1n = 1;
            q2n <= q1n ? q2n = q1n + 1;
            q3n <= q2n ? q3n = q2n + 1;
            q3n >= cur_win ? q3n = cur_win - 1;

            front_sumsq = 0;
            back_sumsq = 0;
            q0sq = 0;
            q1sq = 0;
            q2sq = 0;
            q3sq = 0;

            loop(cur_win,
              idx = tex_base + (f0 + n) * tex_ch;
              v = mem[idx];
              tex_ch > 1 ? v = 0.5 * (v + mem[idx + 1]);

              av = abs(v);
              sumsq += v * v;
              av > peak ? peak = av;

              n < third_n ? front_sumsq += v * v;
              n >= cur_win - third_n ? back_sumsq += v * v;

              n < q1n ? (
                q0sq += v * v;
              ) : n < q2n ? (
                q1sq += v * v;
              ) : n < q3n ? (
                q2sq += v * v;
              ) : (
                q3sq += v * v;
              );

              first ? (
                prevv = v;
                preva = av;
                first = 0;
              ) : (
                flux += abs(av - preva);
                hf_proxy += abs(v - prevv);
                ((v >= 0) != (prevv >= 0)) ? zc += 1;
                prevv = v;
                preva = av;
              );

              n += 1;
            );

            rms = sqrt(sumsq / max(1, cur_win));
            fluxn = flux / max(1, cur_win);
            zcn = zc / max(1, cur_win);
            hfn = hf_proxy / max(1, cur_win);

            front_rms = sqrt(front_sumsq / max(1, third_n));
            back_rms = sqrt(back_sumsq / max(1, third_n));
            slope = back_rms - front_rms;

            rms0 = sqrt(q0sq / max(1, q1n));
            rms1 = sqrt(q1sq / max(1, q2n - q1n));
            rms2 = sqrt(q2sq / max(1, q3n - q2n));
            rms3 = sqrt(q3sq / max(1, cur_win - q3n));
            motion = (abs(rms1 - rms0) + abs(rms2 - rms1) + abs(rms3 - rms2)) / 3;

            ctx_len = third_n;
            pre_start = f0 - ctx_len;
            pre_start < 0 ? pre_start = 0;
            pre_len = f0 - pre_start;
            pre_sumsq = 0;
            m = 0;
            loop(pre_len,
              idx = tex_base + (pre_start + m) * tex_ch;
              pv = mem[idx];
              tex_ch > 1 ? pv = 0.5 * (pv + mem[idx + 1]);
              pre_sumsq += pv * pv;
              m += 1;
            );
            prev_ctx_rms = pre_len > 0 ? sqrt(pre_sumsq / max(1, pre_len)) : 0;
            onset = front_rms - prev_ctx_rms;
            onset < 0 ? onset = 0;

            fm1 = f0 > 0 ? (f0 - 1) : f0;
            fp1 = f0 < tex_frames - 1 ? (f0 + 1) : f0;

            idxm = tex_base + fm1 * tex_ch;
            idx0 = tex_base + f0  * tex_ch;
            idxp = tex_base + fp1 * tex_ch;

            vm = mem[idxm];
            v0 = mem[idx0];
            vp = mem[idxp];
            tex_ch > 1 ? (
              vm = 0.5 * (vm + mem[idxm + 1]);
              v0 = 0.5 * (v0 + mem[idx0 + 1]);
              vp = 0.5 * (vp + mem[idxp + 1]);
            );
            edge0 = abs(v0) + 0.5 * abs(vp - vm);

            base = cand_base + cand_count * cand_stride;
            mem[base     ] = f0;
            mem[base + 1 ] = rms;
            mem[base + 2 ] = peak;
            mem[base + 3 ] = fluxn;
            mem[base + 4 ] = zcn;
            mem[base + 5 ] = 0;
            mem[base + 6 ] = 0;
            mem[base + 7 ] = 0;
            mem[base + 8 ] = edge0;
            mem[base + 9 ] = slope;
            mem[base + 10] = hfn;
            mem[base + 11] = motion;
            mem[base + 12] = onset;
            mem[base + 13] = 0;
            mem[base + 14] = 0;
            mem[base + 15] = scale_med;
            mem[base + 16] = 0;
            mem[base + 17] = 0;
            mem[base + 18] = 0;

            rms > max_rms ? max_rms = rms;
            peak > max_peak ? max_peak = peak;
            fluxn > max_flux ? max_flux = fluxn;
            zcn > max_zc ? max_zc = zcn;
            edge0 > max_edge ? max_edge = edge0;
            hfn > max_hf ? max_hf = hfn;
            motion > max_motion ? max_motion = motion;
            onset > max_onset ? max_onset = onset;
            slope > max_slope_pos ? max_slope_pos = slope;
            (-slope) > max_slope_neg ? max_slope_neg = -slope;

            f0 += ana_hop_med;
            cand_count += 1;
            ci += 1;
          );
          max_ctr = 0.000001;
          ci = 0;
          loop(cand_count,
            base = cand_base + ci * cand_stride;
            rms = mem[base + 1];

            prms = ci > 0 ? mem[base - cand_stride + 1] : rms;
            nrms = ci < cand_count - 1 ? mem[base + cand_stride + 1] : rms;

            ctr = abs(rms - 0.5 * (prms + nrms));
            mem[base + 5] = ctr;
            ctr > max_ctr ? max_ctr = ctr;

            ci += 1;
          );

          hb = 0;
          loop(wf_bins,
            mem[heat_base + hb] = 0;
            hb += 1;
          );

          score_peak = 0.000001;
          best_score = -1;
          total_score = 0;
          hard_valid_count = 0;
          cand_live_count = 0;
          cand_reject_score = 0.001;

          ci = 0;
          loop(cand_count,
            base = cand_base + ci * cand_stride;

            nrms  = mem[base + 1] / max_rms;
            npeak = mem[base + 2] / max_peak;
            nflux = mem[base + 3] / max_flux;
            nzc   = mem[base + 4] / max_zc;
            nctr  = mem[base + 5] / max_ctr;
            nedge = mem[base + 8] / max_edge;
            nslope_p = max(0, mem[base + 9]) / max_slope_pos;
            nslope_n = max(0, -mem[base + 9]) / max_slope_neg;
            nhf = mem[base + 10] / max_hf;
            nmotion = mem[base + 11] / max_motion;
            nonset = mem[base + 12] / max_onset;

            quiet_gate = nrms < 0.025 ? (nrms / 0.025) : 1;
            quiet_gate < 0 ? quiet_gate = 0;
            quiet_gate > 1 ? quiet_gate = 1;

            zc_shape = 1 - abs(nzc - 0.35) / 0.35;
            zc_shape < 0 ? zc_shape = 0;
            zc_shape > 1 ? zc_shape = 1;

            score = quiet_gate * (
              0.24 * nflux +
              0.18 * nctr  +
              0.10 * npeak +
              0.10 * sqrt(nrms) +
              0.08 * zc_shape +
              0.10 * nmotion +
              0.08 * nonset +
              0.04 * nslope_p +
              0.04 * nhf +
              0.04 * (1 - min(1, nedge))
            );

            score < 0.001 ? score = 0.001;
            mem[base + 6] = score;
            mem[base + 7] = 0;

            hard_valid =
              (nrms > 0.020) &&
              (npeak > 0.018) &&
              ((nflux > 0.030) || (nctr > 0.028) || (nmotion > 0.040) || (nonset > 0.050)) &&
              (score > 0.035);

            (nzc > 0.92) && (nflux < 0.08) && (nctr < 0.05) ? hard_valid = 0;
            nedge > 0.92 ? hard_valid = 0;
            (nhf > 0.96) && (nmotion < 0.04) && (nonset < 0.03) ? hard_valid = 0;

            hard_valid ? (
              hard_valid_count += 1;
              score > score_peak ? score_peak = score;
            );

            ci += 1;
          );

          scan_score_peak = score_peak;
          scan_score_peak < 0.000001 ? scan_score_peak = 0.000001;

          hb = 0;
          loop(hist_bins,
            mem[hist_base + hb] = 0;
            hb += 1;
          );

          use_percentile = hard_valid_count > 16;
          use_percentile ? (
            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              score = mem[base + 6];

              nrms  = mem[base + 1] / max_rms;
              npeak = mem[base + 2] / max_peak;
              nflux = mem[base + 3] / max_flux;
              nzc   = mem[base + 4] / max_zc;
              nctr  = mem[base + 5] / max_ctr;
              nedge = mem[base + 8] / max_edge;
              nmotion = mem[base + 11] / max_motion;
              nonset = mem[base + 12] / max_onset;
              nhf = mem[base + 10] / max_hf;

              hard_valid =
                (nrms > 0.020) &&
                (npeak > 0.018) &&
                ((nflux > 0.030) || (nctr > 0.028) || (nmotion > 0.040) || (nonset > 0.050)) &&
                (score > 0.035);
              (nzc > 0.92) && (nflux < 0.08) && (nctr < 0.05) ? hard_valid = 0;
              nedge > 0.92 ? hard_valid = 0;
              (nhf > 0.96) && (nmotion < 0.04) && (nonset < 0.03) ? hard_valid = 0;

              hard_valid ? (
                hb = floor((score / max(scan_score_peak, 0.000001)) * (hist_bins - 1));
                hb < 0 ? hb = 0;
                hb >= hist_bins ? hb = hist_bins - 1;
                mem[hist_base + hb] += 1;
              );

              ci += 1;
            );

            reject_frac = 0.40;
            reject_target = floor(hard_valid_count * reject_frac);
            reject_target < 0 ? reject_target = 0;
            reject_target > hard_valid_count - 1 ? reject_target = hard_valid_count - 1;

            accum_reject = 0;
            reject_bin = 0;
            done = 0;
            hb = 0;
            loop(hist_bins,
              done <= 0 ? (
                accum_reject += mem[hist_base + hb];
                accum_reject > reject_target ? (
                  reject_bin = hb;
                  done = 1;
                );
              );
              hb += 1;
            );

            cand_reject_score = scan_score_peak * (reject_bin / max(1, hist_bins - 1));
          ) : (
            cand_reject_score = 0.001;
          );

          hb = 0;
          loop(wf_bins,
            mem[heat_base + hb] = 0;
            hb += 1;
          );

          score_peak = 0.000001;
          best_score = -1;
          total_score = 0;
          cand_live_count = 0;

          ci = 0;
          loop(cand_count,
            base = cand_base + ci * cand_stride;
            score = mem[base + 6];

            nrms  = mem[base + 1] / max_rms;
            npeak = mem[base + 2] / max_peak;
            nflux = mem[base + 3] / max_flux;
            nzc   = mem[base + 4] / max_zc;
            nctr  = mem[base + 5] / max_ctr;
            nedge = mem[base + 8] / max_edge;
            nmotion = mem[base + 11] / max_motion;
            nonset = mem[base + 12] / max_onset;
            nhf = mem[base + 10] / max_hf;

            hard_valid =
              (nrms > 0.020) &&
              (npeak > 0.018) &&
              ((nflux > 0.030) || (nctr > 0.028) || (nmotion > 0.040) || (nonset > 0.050)) &&
              (score > 0.035);
            (nzc > 0.92) && (nflux < 0.08) && (nctr < 0.05) ? hard_valid = 0;
            nedge > 0.92 ? hard_valid = 0;
            (nhf > 0.96) && (nmotion < 0.04) && (nonset < 0.03) ? hard_valid = 0;

            valid = hard_valid;
            use_percentile && (score <= cand_reject_score) ? valid = 0;

            valid ? (
              rankn = (score - cand_reject_score) / max(0.000001, scan_score_peak - cand_reject_score);
              rankn < 0 ? rankn = 0;
              rankn > 1 ? rankn = 1;
              mem[base + 7] = rankn;

              cand_live_count += 1;
              floor(mem[base + 15] + 0.5) == scale_short ? cand_short_live_count += 1 : cand_med_live_count += 1;
              total_score += score;
              score > score_peak ? score_peak = score;

              score > best_score ? (
                best_score = score;
                best_cand = ci;
                best_start = mem[base];
              );

              hb = floor((mem[base] / max(1, tex_frames - 1)) * (wf_bins - 1));
              hb < 0 ? hb = 0;
              hb >= wf_bins ? hb = wf_bins - 1;
              score > mem[heat_base + hb] ? mem[heat_base + hb] = score;
            ) : (
              mem[base + 7] = 0;
            );

            ci += 1;
          );

          cand_live_count <= 0 ? (
            hb = 0;
            loop(wf_bins,
              mem[heat_base + hb] = 0;
              hb += 1;
            );

            score_peak = scan_score_peak;
            best_score = -1;
            cand_live_count = 0;

            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              score = mem[base + 6];
              rankn = score / max(0.000001, scan_score_peak);
              rankn < 0 ? rankn = 0;
              rankn > 1 ? rankn = 1;
              mem[base + 7] = rankn;
              cand_live_count += 1;
              floor(mem[base + 15] + 0.5) == scale_short ? cand_short_live_count += 1 : cand_med_live_count += 1;

              score > best_score ? (
                best_score = score;
                best_cand = ci;
                best_start = mem[base];
              );

              hb = floor((mem[base] / max(1, tex_frames - 1)) * (wf_bins - 1));
              hb < 0 ? hb = 0;
              hb >= wf_bins ? hb = wf_bins - 1;
              score > mem[heat_base + hb] ? mem[heat_base + hb] = score;

              ci += 1;
            );
          );

          hb = 0;
          loop(wf_bins,
            mem[heat_base + hb] /= max(score_peak, 0.000001);
            hb += 1;
          );

          // compact descriptor-space PCA pass: learn 2 dominant material axes
          // from live candidates and use deviation in that space as a novelty cue.
          pca_var1 = 0.000001;
          pca_var2 = 0.000001;
          pca_novelty_peak = 0.000001;

          cand_live_count > 3 ? (
            pca_count = 0;
            pca_mean0 = 0; pca_mean1 = 0; pca_mean2 = 0; pca_mean3 = 0; pca_mean4 = 0; pca_mean5 = 0;

            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 7] > 0 ? (
                px0 = mem[base + 1] / max(0.000001, max_rms);
                px1 = mem[base + 3] / max(0.000001, max_flux);
                px2 = mem[base + 10] / max(0.000001, max_hf);
                px3 = mem[base + 11] / max(0.000001, max_motion);
                px4 = mem[base + 5] / max(0.000001, max_ctr);
                px5 = mem[base + 9] / max(0.000001, max(max_slope_pos, max_slope_neg));
                px5 < -1 ? px5 = -1;
                px5 > 1 ? px5 = 1;

                pca_mean0 += px0;
                pca_mean1 += px1;
                pca_mean2 += px2;
                pca_mean3 += px3;
                pca_mean4 += px4;
                pca_mean5 += px5;
                pca_count += 1;
              );
              ci += 1;
            );

            inv_pca_n = 1 / max(1, pca_count);
            pca_mean0 *= inv_pca_n; pca_mean1 *= inv_pca_n; pca_mean2 *= inv_pca_n;
            pca_mean3 *= inv_pca_n; pca_mean4 *= inv_pca_n; pca_mean5 *= inv_pca_n;

            c00 = 0; c01 = 0; c02 = 0; c03 = 0; c04 = 0; c05 = 0;
            c11 = 0; c12 = 0; c13 = 0; c14 = 0; c15 = 0;
            c22 = 0; c23 = 0; c24 = 0; c25 = 0;
            c33 = 0; c34 = 0; c35 = 0;
            c44 = 0; c45 = 0;
            c55 = 0;

            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 7] > 0 ? (
                x0 = mem[base + 1] / max(0.000001, max_rms) - pca_mean0;
                x1 = mem[base + 3] / max(0.000001, max_flux) - pca_mean1;
                x2 = mem[base + 10] / max(0.000001, max_hf) - pca_mean2;
                x3 = mem[base + 11] / max(0.000001, max_motion) - pca_mean3;
                x4 = mem[base + 5] / max(0.000001, max_ctr) - pca_mean4;
                x5 = mem[base + 9] / max(0.000001, max(max_slope_pos, max_slope_neg)) - pca_mean5;

                c00 += x0 * x0; c01 += x0 * x1; c02 += x0 * x2; c03 += x0 * x3; c04 += x0 * x4; c05 += x0 * x5;
                c11 += x1 * x1; c12 += x1 * x2; c13 += x1 * x3; c14 += x1 * x4; c15 += x1 * x5;
                c22 += x2 * x2; c23 += x2 * x3; c24 += x2 * x4; c25 += x2 * x5;
                c33 += x3 * x3; c34 += x3 * x4; c35 += x3 * x5;
                c44 += x4 * x4; c45 += x4 * x5;
                c55 += x5 * x5;
              );
              ci += 1;
            );

            inv_cov_n = 1 / max(1, pca_count - 1);
            c00 *= inv_cov_n; c01 *= inv_cov_n; c02 *= inv_cov_n; c03 *= inv_cov_n; c04 *= inv_cov_n; c05 *= inv_cov_n;
            c11 *= inv_cov_n; c12 *= inv_cov_n; c13 *= inv_cov_n; c14 *= inv_cov_n; c15 *= inv_cov_n;
            c22 *= inv_cov_n; c23 *= inv_cov_n; c24 *= inv_cov_n; c25 *= inv_cov_n;
            c33 *= inv_cov_n; c34 *= inv_cov_n; c35 *= inv_cov_n;
            c44 *= inv_cov_n; c45 *= inv_cov_n; c55 *= inv_cov_n;

            w10 = 0.41; w11 = 0.31; w12 = 0.23; w13 = 0.47; w14 = 0.29; w15 = 0.37;
            pnorm = sqrt(w10*w10 + w11*w11 + w12*w12 + w13*w13 + w14*w14 + w15*w15);
            pnorm < 0.000001 ? pnorm = 1;
            w10 /= pnorm; w11 /= pnorm; w12 /= pnorm; w13 /= pnorm; w14 /= pnorm; w15 /= pnorm;

            pi_iter = 0;
            loop(8,
              nw0 = c00*w10 + c01*w11 + c02*w12 + c03*w13 + c04*w14 + c05*w15;
              nw1 = c01*w10 + c11*w11 + c12*w12 + c13*w13 + c14*w14 + c15*w15;
              nw2 = c02*w10 + c12*w11 + c22*w12 + c23*w13 + c24*w14 + c25*w15;
              nw3 = c03*w10 + c13*w11 + c23*w12 + c33*w13 + c34*w14 + c35*w15;
              nw4 = c04*w10 + c14*w11 + c24*w12 + c34*w13 + c44*w14 + c45*w15;
              nw5 = c05*w10 + c15*w11 + c25*w12 + c35*w13 + c45*w14 + c55*w15;
              pnorm = sqrt(nw0*nw0 + nw1*nw1 + nw2*nw2 + nw3*nw3 + nw4*nw4 + nw5*nw5);
              pnorm < 0.000001 ? pnorm = 1;
              w10 = nw0 / pnorm; w11 = nw1 / pnorm; w12 = nw2 / pnorm; w13 = nw3 / pnorm; w14 = nw4 / pnorm; w15 = nw5 / pnorm;
              pi_iter += 1;
            );

            w20 = -0.33; w21 = 0.52; w22 = 0.58; w23 = -0.21; w24 = 0.42; w25 = -0.28;
            proj = w20*w10 + w21*w11 + w22*w12 + w23*w13 + w24*w14 + w25*w15;
            w20 -= proj * w10; w21 -= proj * w11; w22 -= proj * w12; w23 -= proj * w13; w24 -= proj * w14; w25 -= proj * w15;
            pnorm = sqrt(w20*w20 + w21*w21 + w22*w22 + w23*w23 + w24*w24 + w25*w25);
            pnorm < 0.000001 ? pnorm = 1;
            w20 /= pnorm; w21 /= pnorm; w22 /= pnorm; w23 /= pnorm; w24 /= pnorm; w25 /= pnorm;

            pi_iter = 0;
            loop(10,
              nw0 = c00*w20 + c01*w21 + c02*w22 + c03*w23 + c04*w24 + c05*w25;
              nw1 = c01*w20 + c11*w21 + c12*w22 + c13*w23 + c14*w24 + c15*w25;
              nw2 = c02*w20 + c12*w21 + c22*w22 + c23*w23 + c24*w24 + c25*w25;
              nw3 = c03*w20 + c13*w21 + c23*w22 + c33*w23 + c34*w24 + c35*w25;
              nw4 = c04*w20 + c14*w21 + c24*w22 + c34*w23 + c44*w24 + c45*w25;
              nw5 = c05*w20 + c15*w21 + c25*w22 + c35*w23 + c45*w24 + c55*w25;
              proj = nw0*w10 + nw1*w11 + nw2*w12 + nw3*w13 + nw4*w14 + nw5*w15;
              nw0 -= proj * w10; nw1 -= proj * w11; nw2 -= proj * w12; nw3 -= proj * w13; nw4 -= proj * w14; nw5 -= proj * w15;
              pnorm = sqrt(nw0*nw0 + nw1*nw1 + nw2*nw2 + nw3*nw3 + nw4*nw4 + nw5*nw5);
              pnorm < 0.000001 ? pnorm = 1;
              w20 = nw0 / pnorm; w21 = nw1 / pnorm; w22 = nw2 / pnorm; w23 = nw3 / pnorm; w24 = nw4 / pnorm; w25 = nw5 / pnorm;
              pi_iter += 1;
            );

            pca_var1 = 0.000001;
            pca_var2 = 0.000001;
            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 7] > 0 ? (
                x0 = mem[base + 1] / max(0.000001, max_rms) - pca_mean0;
                x1 = mem[base + 3] / max(0.000001, max_flux) - pca_mean1;
                x2 = mem[base + 10] / max(0.000001, max_hf) - pca_mean2;
                x3 = mem[base + 11] / max(0.000001, max_motion) - pca_mean3;
                x4 = mem[base + 5] / max(0.000001, max_ctr) - pca_mean4;
                x5 = mem[base + 9] / max(0.000001, max(max_slope_pos, max_slope_neg)) - pca_mean5;

                pc1 = x0*w10 + x1*w11 + x2*w12 + x3*w13 + x4*w14 + x5*w15;
                pc2 = x0*w20 + x1*w21 + x2*w22 + x3*w23 + x4*w24 + x5*w25;
                mem[base + 16] = pc1;
                mem[base + 17] = pc2;
                pca_var1 += pc1 * pc1;
                pca_var2 += pc2 * pc2;
              ) : (
                mem[base + 16] = 0;
                mem[base + 17] = 0;
              );
              ci += 1;
            );

            pca_var1 /= max(1, pca_count);
            pca_var2 /= max(1, pca_count);
            pca_var1 < 0.000001 ? pca_var1 = 0.000001;
            pca_var2 < 0.000001 ? pca_var2 = 0.000001;

            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 7] > 0 ? (
                pc1 = mem[base + 16];
                pc2 = mem[base + 17];
                nov = sqrt((pc1 * pc1) / pca_var1 + (pc2 * pc2) / pca_var2);
                mem[base + 18] = nov;
                nov > pca_novelty_peak ? pca_novelty_peak = nov;
              ) : (
                mem[base + 18] = 0;
              );
              ci += 1;
            );

            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 7] > 0 ? (
                mem[base + 18] /= max(pca_novelty_peak, 0.000001);
              );
              ci += 1;
            );
          ) : (
            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              mem[base + 16] = 0;
              mem[base + 17] = 0;
              mem[base + 18] = 0;
              ci += 1;
            );
          );

          attack_pool_count = 0;
          body_pool_count = 0;
          release_pool_count = 0;
          debris_pool_count = 0;

          ci = 0;
          loop(cand_count,
            base = cand_base + ci * cand_stride;
            rankn = mem[base + 7];

            rankn > 0 ? (
              nrms  = mem[base + 1] / max_rms;
              npeak = mem[base + 2] / max_peak;
              nflux = mem[base + 3] / max_flux;
              nzc   = mem[base + 4] / max_zc;
              nctr  = mem[base + 5] / max_ctr;
              nedge = mem[base + 8] / max_edge;
              slope = mem[base + 9];
              nslope_p = max(0, slope) / max_slope_pos;
              nslope_n = max(0, -slope) / max_slope_neg;
              slope_abs = abs(slope) / max(max_slope_pos, max_slope_neg);
              slope_abs > 1 ? slope_abs = 1;
              slope_neutral = 1 - slope_abs;
              nhf = mem[base + 10] / max_hf;
              nmotion = mem[base + 11] / max_motion;
              nonset = mem[base + 12] / max_onset;
              nnov = mem[base + 18];
              nnov < 0 ? nnov = 0;
              nnov > 1 ? nnov = 1;
              zc_shape = 1 - abs(nzc - 0.35) / 0.35;
              zc_shape < 0 ? zc_shape = 0;
              zc_shape > 1 ? zc_shape = 1;

              attack_sc = (0.42 * nonset + 0.22 * nslope_p + 0.16 * nflux + 0.12 * nctr + 0.08 * npeak) * profile_att_class + 0.06 * nnov;
              body_sc = (0.30 * nmotion + 0.22 * slope_neutral + 0.14 * sqrt(nrms) + 0.12 * nctr + 0.12 * rankn + 0.10 * (1 - min(1, nedge))) * profile_body_class + 0.03 * nnov;
              release_sc = (0.38 * nslope_n + 0.22 * (1 - nonset) + 0.16 * nmotion + 0.14 * (1 - min(1, nedge)) + 0.10 * rankn) * profile_rel_class + 0.04 * nnov;
              debris_sc = (0.40 * nhf + 0.18 * nzc + 0.16 * nflux + 0.12 * (1 - sqrt(nrms)) + 0.14 * (1 - min(1, nedge))) * profile_deb_class + 0.08 * nnov;

              profile == 1 ? (
                body_sc += 0.06 * nhf + 0.05 * nmotion;
                debris_sc += 0.08 * nhf;
              ) : profile == 2 ? (
                attack_sc += 0.06 * nslope_p + 0.05 * nonset;
                release_sc += 0.06 * nslope_n;
                body_sc += 0.04 * sqrt(nrms);
              ) : profile == 3 ? (
                body_sc += 0.08 * sqrt(nrms) + 0.04 * slope_neutral;
                release_sc += 0.05 * nslope_n;
              ) : profile == 4 ? (
                attack_sc += 0.07 * nflux + 0.05 * nonset;
                body_sc += 0.04 * nflux;
              );

              phase = phase_att;
              pbest = attack_sc;
              body_sc > pbest ? (
                phase = phase_body;
                pbest = body_sc;
              );
              release_sc > pbest ? (
                phase = phase_rel;
                pbest = release_sc;
              );
              debris_sc > pbest ? (
                phase = phase_deb;
                pbest = debris_sc;
              );

              phase == phase_att ? (
                family = 1;
                nslope_p > 0.46 ? family += 1;
                nonset > 0.44 ? family += 2;
                nhf > 0.54 ? family += 4;
              ) : phase == phase_body ? (
                family = 1;
                nrms > 0.46 ? family += 1;
                nmotion > 0.42 ? family += 2;
                nctr > 0.44 ? family += 4;
              ) : phase == phase_rel ? (
                family = 1;
                nslope_n > 0.40 ? family += 1;
                nmotion > 0.34 ? family += 2;
                (1 - min(1, nedge)) > 0.44 ? family += 4;
              ) : (
                family = 1;
                nhf > 0.50 ? family += 1;
                nzc > 0.48 ? family += 2;
                nonset > 0.38 ? family += 4;
              );

              mem[base + 13] = phase;
              mem[base + 14] = family;

              phase == phase_att ? (
                mem[attack_pool_base + attack_pool_count] = ci;
                attack_pool_count += 1;
              ) : phase == phase_body ? (
                mem[body_pool_base + body_pool_count] = ci;
                body_pool_count += 1;
              ) : phase == phase_rel ? (
                mem[release_pool_base + release_pool_count] = ci;
                release_pool_count += 1;
              ) : (
                mem[debris_pool_base + debris_pool_count] = ci;
                debris_pool_count += 1;
              );
            ) : (
              mem[base + 13] = 0;
              mem[base + 14] = 0;
            );

            ci += 1;
          );

          // ----- learned structure pass -----
          corpus_nrms_mean = 0;
          corpus_hf_mean = 0;
          corpus_motion_mean = 0;
          corpus_ctr_mean = 0;
          corpus_slope_mean = 0;
          corpus_onset_mean = 0;
          sorted_live_count = 0;
          ci = 0;
          loop(cand_count,
            base = cand_base + ci * cand_stride;
            rankn = mem[base + 7];
            mem[cand_cluster_base + ci] = 0;
            mem[cand_state_base + ci] = 0;
            mem[cand_token_base + ci] = 0;
            mem[cand_nmf0_base + ci] = 0;
            mem[cand_nmf1_base + ci] = 0;
            mem[cand_nmf2_base + ci] = 0;
            k = 0;
            loop(graph_k,
              mem[cand_graph_idx_base + ci * graph_k + k] = -1;
              mem[cand_graph_w_base + ci * graph_k + k] = 0;
              k += 1;
            );
            rankn > 0 ? (
              start_pos = mem[base];
              ins = sorted_live_count;
              j = 0;
              loop(sorted_live_count,
                prev = sorted_live_count - 1 - j;
                prev_idx = floor(mem[sorted_idx_base + prev]);
                prev_start = mem[cand_base + prev_idx * cand_stride];
                start_pos < prev_start ? (
                  mem[sorted_idx_base + prev + 1] = prev_idx;
                  ins = prev;
                );
                j += 1;
              );
              mem[sorted_idx_base + ins] = ci;
              sorted_live_count += 1;

              corpus_nrms_mean += mem[base + 1] / max(0.000001, max_rms);
              corpus_hf_mean += mem[base + 10] / max(0.000001, max_hf);
              corpus_motion_mean += mem[base + 11] / max(0.000001, max_motion);
              corpus_ctr_mean += mem[base + 5] / max(0.000001, max_ctr);
              corpus_slope_mean += (max(0, mem[base + 9]) / max(0.000001, max_slope_pos)) - (max(0, -mem[base + 9]) / max(0.000001, max_slope_neg));
              corpus_onset_mean += mem[base + 12] / max(0.000001, max_onset);
            );
            ci += 1;
          );
          sorted_live_count > 0 ? (
            corpus_nrms_mean /= sorted_live_count;
            corpus_hf_mean /= sorted_live_count;
            corpus_motion_mean /= sorted_live_count;
            corpus_ctr_mean /= sorted_live_count;
            corpus_slope_mean /= sorted_live_count;
            corpus_onset_mean /= sorted_live_count;
          );

          // phase-conditional clustering (3 clusters per phase-scale group)
          ph = 1;
          loop(4,
            sc = 1;
            loop(2,
              group_ct = 0;
              j = 0;
              loop(sorted_live_count,
                idx = floor(mem[sorted_idx_base + j]);
                base = cand_base + idx * cand_stride;
                cphase = floor(mem[base + 13] + 0.5);
                cscale = floor(mem[base + 15] + 0.5);
                (cphase == ph) && (cscale == sc) ? (
                  nrms = mem[base + 1] / max(0.000001, max_rms);
                  nzc = mem[base + 4] / max(0.000001, max_zc);
                  nctr = mem[base + 5] / max(0.000001, max_ctr);
                  nedge = mem[base + 8] / max(0.000001, max_edge);
                  slope = mem[base + 9];
                  nslope_p = max(0, slope) / max(0.000001, max_slope_pos);
                  nslope_n = max(0, -slope) / max(0.000001, max_slope_neg);
                  nhf = mem[base + 10] / max(0.000001, max_hf);
                  nmotion = mem[base + 11] / max(0.000001, max_motion);
                  nonset = mem[base + 12] / max(0.000001, max_onset);
                  axis =
                    ph == phase_att ? (0.52 * nonset + 0.30 * nslope_p + 0.18 * nhf) :
                    ph == phase_body ? (0.42 * nrms + 0.34 * nmotion + 0.24 * nctr) :
                    ph == phase_rel ? (0.48 * nslope_n + 0.28 * nmotion + 0.24 * (1 - min(1, nedge))) :
                    (0.44 * nhf + 0.26 * nzc + 0.30 * nonset);
                  ins = group_ct;
                  jj = 0;
                  loop(group_ct,
                    prev = group_ct - 1 - jj;
                    prevv = mem[tmp_val_base + prev];
                    axis < prevv ? (
                      mem[tmp_idx_base + prev + 1] = mem[tmp_idx_base + prev];
                      mem[tmp_val_base + prev + 1] = prevv;
                      ins = prev;
                    );
                    jj += 1;
                  );
                  mem[tmp_idx_base + ins] = idx;
                  mem[tmp_val_base + ins] = axis;
                  group_ct += 1;
                );
                j += 1;
              );
              group_ct > 0 ? (
                j = 0;
                loop(group_ct,
                  idx = floor(mem[tmp_idx_base + j]);
                  cluster = floor((j * 3) / max(1, group_ct));
                  cluster > 2 ? cluster = 2;
                  mem[cand_cluster_base + idx] = cluster + 1;
                  state_id = ((ph - 1) * 6) + ((sc - 1) * 3) + cluster + 1;
                  mem[cand_state_base + idx] = state_id;
                  j += 1;
                );
              );
              sc += 1;
            );
            ph += 1;
          );

          // explicit-duration HSMM-style state priors from source order.
          si = 0;
          loop(state_count,
            mem[state_dur_mean_base + si] = 0;
            mem[state_dur_var_base + si] = 0;
            mem[state_dur_count_base + si] = 0;
            mem[state_entry_base + si] = 0;
            sj = 0;
            loop(state_count,
              mem[state_trans_base + si * state_count + sj] = 0;
              sj += 1;
            );
            si += 1;
          );
          run_state = 0;
          run_count = 0;
          j = 0;
          loop(sorted_live_count,
            idx = floor(mem[sorted_idx_base + j]);
            st = floor(mem[cand_state_base + idx]);
            st > 0 ? (
              run_state <= 0 ? (
                mem[state_entry_base + st - 1] += 1;
                run_state = st;
                run_count = 1;
              ) : st == run_state ? (
                run_count += 1;
              ) : (
                mem[state_dur_mean_base + run_state - 1] += run_count;
                mem[state_dur_var_base + run_state - 1] += run_count * run_count;
                mem[state_dur_count_base + run_state - 1] += 1;
                mem[state_trans_base + (run_state - 1) * state_count + (st - 1)] += 1;
                run_state = st;
                run_count = 1;
              );
            );
            j += 1;
          );
          run_state > 0 ? (
            mem[state_dur_mean_base + run_state - 1] += run_count;
            mem[state_dur_var_base + run_state - 1] += run_count * run_count;
            mem[state_dur_count_base + run_state - 1] += 1;
          );
          si = 0;
          loop(state_count,
            cnt = mem[state_dur_count_base + si];
            cnt > 0 ? (
              meanv = mem[state_dur_mean_base + si] / cnt;
              varv = mem[state_dur_var_base + si] / cnt - meanv * meanv;
              varv < 0.10 ? varv = 0.10;
              mem[state_dur_mean_base + si] = meanv;
              mem[state_dur_var_base + si] = varv;
            ) : (
              mem[state_dur_mean_base + si] = 1.2;
              mem[state_dur_var_base + si] = 0.50;
            );
            si += 1;
          );

          // compact descriptor-NMF fingerprints (3 comps, 4 dims): body / transient / debris tendencies.
          mem[nmf_w_base + 0] = 0.80; mem[nmf_w_base + 1] = 0.20; mem[nmf_w_base + 2] = 0.72; mem[nmf_w_base + 3] = 0.24;
          mem[nmf_w_base + 4] = 0.24; mem[nmf_w_base + 5] = 0.44; mem[nmf_w_base + 6] = 0.34; mem[nmf_w_base + 7] = 0.84;
          mem[nmf_w_base + 8] = 0.18; mem[nmf_w_base + 9] = 0.86; mem[nmf_w_base +10] = 0.24; mem[nmf_w_base +11] = 0.42;
          it = 0;
          loop(4,
            ni = 0;
            loop(16,
              mem[nmf_acc_base + ni] = 0;
              ni += 1;
            );
            ci = 0;
            loop(cand_count,
              base = cand_base + ci * cand_stride;
              rankn = mem[base + 7];
              rankn > 0 ? (
                x0 = mem[base + 1] / max(0.000001, max_rms) + 0.0001;
                x1 = mem[base + 10] / max(0.000001, max_hf) + 0.0001;
                x2 = mem[base + 11] / max(0.000001, max_motion) + 0.0001;
                x3 = (0.55 * (mem[base + 12] / max(0.000001, max_onset)) + 0.45 * (mem[base + 5] / max(0.000001, max_ctr))) + 0.0001;
                d0 = x0 * mem[nmf_w_base + 0] + x1 * mem[nmf_w_base + 1] + x2 * mem[nmf_w_base + 2] + x3 * mem[nmf_w_base + 3];
                d1 = x0 * mem[nmf_w_base + 4] + x1 * mem[nmf_w_base + 5] + x2 * mem[nmf_w_base + 6] + x3 * mem[nmf_w_base + 7];
                d2 = x0 * mem[nmf_w_base + 8] + x1 * mem[nmf_w_base + 9] + x2 * mem[nmf_w_base +10] + x3 * mem[nmf_w_base +11];
                dsum = d0 + d1 + d2 + 0.000001;
                h0 = d0 / dsum;
                h1 = d1 / dsum;
                h2 = d2 / dsum;
                mem[cand_nmf0_base + ci] = h0;
                mem[cand_nmf1_base + ci] = h1;
                mem[cand_nmf2_base + ci] = h2;
                mem[nmf_acc_base + 0] += x0 * h0; mem[nmf_acc_base + 1] += x1 * h0; mem[nmf_acc_base + 2] += x2 * h0; mem[nmf_acc_base + 3] += x3 * h0; mem[nmf_acc_base + 12] += h0;
                mem[nmf_acc_base + 4] += x0 * h1; mem[nmf_acc_base + 5] += x1 * h1; mem[nmf_acc_base + 6] += x2 * h1; mem[nmf_acc_base + 7] += x3 * h1; mem[nmf_acc_base + 13] += h1;
                mem[nmf_acc_base + 8] += x0 * h2; mem[nmf_acc_base + 9] += x1 * h2; mem[nmf_acc_base +10] += x2 * h2; mem[nmf_acc_base +11] += x3 * h2; mem[nmf_acc_base + 14] += h2;
              );
              ci += 1;
            );
            k = 0;
            loop(3,
              den = mem[nmf_acc_base + 12 + k];
              den < 0.000001 ? den = 0.000001;
              b0 = mem[nmf_acc_base + k * 4 + 0] / den;
              b1 = mem[nmf_acc_base + k * 4 + 1] / den;
              b2 = mem[nmf_acc_base + k * 4 + 2] / den;
              b3 = mem[nmf_acc_base + k * 4 + 3] / den;
              bsum = b0 + b1 + b2 + b3 + 0.000001;
              mem[nmf_w_base + k * 4 + 0] = b0 / bsum;
              mem[nmf_w_base + k * 4 + 1] = b1 / bsum;
              mem[nmf_w_base + k * 4 + 2] = b2 / bsum;
              mem[nmf_w_base + k * 4 + 3] = b3 / bsum;
              k += 1;
            );
            it += 1;
          );
          ci = 0;
          codec_token_peak = 1;
          loop(cand_count,
            rankn = mem[cand_base + ci * cand_stride + 7];
            rankn > 0 ? (
              h0 = mem[cand_nmf0_base + ci];
              h1 = mem[cand_nmf1_base + ci];
              h2 = mem[cand_nmf2_base + ci];
              fp = h1 > h0 ? 2 : 1;
              h2 > (fp == 1 ? h0 : h1) ? fp = 3;
              st = floor(mem[cand_state_base + ci]);
              tok = ((st - 1) * 3) + fp;
              tok > codec_token_peak ? codec_token_peak = tok;
              mem[cand_token_base + ci] = tok;
            );
            ci += 1;
          );

          // sparse descriptor graph in PCA + fingerprint space.
          i = 0;
          loop(sorted_live_count,
            idx = floor(mem[sorted_idx_base + i]);
            base = cand_base + idx * cand_stride;
            cphase = floor(mem[base + 13] + 0.5);
            cscale = floor(mem[base + 15] + 0.5);
            cfamily = floor(mem[base + 14] + 0.5);
            pc1 = mem[base + 16] / max(0.000001, sqrt(pca_var1));
            pc2 = mem[base + 17] / max(0.000001, sqrt(pca_var2));
            h0 = mem[cand_nmf0_base + idx];
            h1 = mem[cand_nmf1_base + idx];
            h2 = mem[cand_nmf2_base + idx];
            k = 0;
            loop(graph_k,
              mem[cand_graph_idx_base + idx * graph_k + k] = -1;
              mem[cand_graph_w_base + idx * graph_k + k] = 0;
              k += 1;
            );
            j = 0;
            loop(sorted_live_count,
              jdx = floor(mem[sorted_idx_base + j]);
              jdx != idx ? (
                obase = cand_base + jdx * cand_stride;
                ophase = floor(mem[obase + 13] + 0.5);
                oscale = floor(mem[obase + 15] + 0.5);
                ofamily = floor(mem[obase + 14] + 0.5);
                compatible = (cphase == ophase) || (abs(cphase - ophase) == 1) || ((cphase == phase_deb) && (ophase == phase_body)) || ((cphase == phase_body) && (ophase == phase_deb));
                compatible ? (
                  opc1 = mem[obase + 16] / max(0.000001, sqrt(pca_var1));
                  opc2 = mem[obase + 17] / max(0.000001, sqrt(pca_var2));
                  oh0 = mem[cand_nmf0_base + jdx];
                  oh1 = mem[cand_nmf1_base + jdx];
                  oh2 = mem[cand_nmf2_base + jdx];
                  dpc = 0.55 * abs(pc1 - opc1) + 0.55 * abs(pc2 - opc2);
                  dnmf = 0.34 * abs(h0 - oh0) + 0.34 * abs(h1 - oh1) + 0.34 * abs(h2 - oh2);
                  dfam = cfamily == ofamily ? 0 : 0.14;
                  dscale = cscale == oscale ? 0 : 0.10;
                  dstart = abs(mem[base] - mem[obase]) / max(1, tex_sr * 0.40);
                  dstart > 1 ? dstart = 1;
                  dist = dpc + dnmf + dfam + dscale + 0.10 * dstart;
                  gw = 1 / (0.10 + dist);
                  minslot = 0;
                  minw = mem[cand_graph_w_base + idx * graph_k + 0];
                  k = 1;
                  loop(graph_k - 1,
                    curw = mem[cand_graph_w_base + idx * graph_k + k];
                    curw < minw ? (
                      minw = curw;
                      minslot = k;
                    );
                    k += 1;
                  );
                  gw > minw ? (
                    mem[cand_graph_w_base + idx * graph_k + minslot] = gw;
                    mem[cand_graph_idx_base + idx * graph_k + minslot] = jdx;
                  );
                );
              );
              j += 1;
            );
            i += 1;
          );

          cloud_center = best_start;
          cloud_radius_frames = max(128, floor(0.12 * tex_sr));
          analysis_ready = cand_live_count > 0;
          file_state = 2;
        ) : (
          tex_loaded = 0;
          tex_items = 0;
          tex_frames = 0;
          tex_rate = 1;
          wf_ready = 0;
          cand_count = 0;
          cand_live_count = 0;
          cand_short_live_count = 0;
          cand_med_live_count = 0;
          analysis_ready = 0;
          file_state = 3;
        );
      ) : (
        file_state = 2;
      );
    ) : (
      file_state = 1;
    );
  ) : (
    file_state = 1;
  );

  file_close(h);
) : (
  tex_loaded = 0;
  tex_sig = 0;
  tex_ch = 0;
  tex_sr = srate;
  tex_items = 0;
  tex_frames = 0;
  tex_rate = 1;
  tex_truncated = 0;

  src_ch = 0;
  src_sr = 0;
  src_items = 0;
  src_frames = 0;

  wf_ready = 0;
  cand_count = 0;
  cand_live_count = 0;
  cand_short_live_count = 0;
  cand_med_live_count = 0;
  attack_pool_count = 0;
  body_pool_count = 0;
  release_pool_count = 0;
  debris_pool_count = 0;
  analysis_ready = 0;
  last_phase = 0;
  last_family = 0;
  desired_family = 0;
  desired_phase = phase_body;
  desired_phase2 = phase_deb;
  file_state = 0;
);

trig_flash *= 0.92;
last_spawn_flash *= 0.94;
meter_out *= 0.90;
follow_ui_peak *= 0.97;
det_soft > follow_ui_peak ? follow_ui_peak = det_soft;

@sample
function clamp1(v, lo, hi) (
  v < lo ? v = lo;
  v > hi ? v = hi;
  v;
);

function rand01() (
  seed = seed * 196314165 + 907633515;
  seed = seed & 2147483647;
  seed / 2147483648;
);

function randSym() (
  rand01() * 2 - 1;
);

function shape01(t, k) local(p) (
  t = clamp1(t, 0, 1);
  k > 0 ? (
    p = 1 + k * 4;
    t = pow(t, p);
  ) : k < 0 ? (
    p = 1 + (-k) * 4;
    t = 1 - pow(1 - t, p);
  );
  t;
);

function smoothstep01(t) (
  t = clamp1(t, 0, 1);
  t * t * (3 - 2 * t);
);

function tex_read(frame, ch) local(i0, frac, i1, base0, base1, s0, s1, lim) (
  lim = tex_frames - 2;
  lim < 0 ? lim = 0;
  frame < 0 ? frame = 0;
  frame > lim ? frame = lim;
  i0 = floor(frame);
  frac = frame - i0;
  i1 = i0 + 1;
  i1 >= tex_frames ? i1 = tex_frames - 1;

  base0 = tex_base + i0 * tex_ch + ch;
  base1 = tex_base + i1 * tex_ch + ch;

  s0 = mem[base0];
  s1 = mem[base1];
  s0 + (s1 - s0) * frac;
);

function recent_weight(ci) local(j, ri, idx, agew, w) (
  w = 1;
  j = 0;
  loop(recent_max,
    ri = recent_head - 1 - j;
    ri < 0 ? ri += recent_max;
    idx = floor(mem[recent_base + ri]);

    idx == ci ? (
      agew = j / max(1, recent_max - 1);
      w *= 0.18 + 0.82 * agew;
    );

    j += 1;
  );
  w;
);

function phase_pool_base(ph) (
  ph == phase_att ? attack_pool_base :
  ph == phase_body ? body_pool_base :
  ph == phase_rel ? release_pool_base :
  debris_pool_base;
);

function phase_pool_count(ph) (
  ph == phase_att ? attack_pool_count :
  ph == phase_body ? body_pool_count :
  ph == phase_rel ? release_pool_count :
  debris_pool_count;
);

function cand_scale(ci) (
  floor(mem[cand_base + ci * cand_stride + 15] + 0.5);
);

function cand_win(ci) local(sc) (
  sc = cand_scale(ci);
  sc == scale_short ? ana_win_short : ana_win_med;
);

function cand_hop(ci) local(sc) (
  sc = cand_scale(ci);
  sc == scale_short ? ana_hop_short : ana_hop_med;
);

function phase_scale_weight(cur_phase, cur_scale, mode_local) local(w) (
  cur_phase == phase_att ? (
    w = cur_scale == scale_short ? profile_short_att : profile_med_att;
  ) : cur_phase == phase_body ? (
    w = cur_scale == scale_short ? profile_short_body : profile_med_body;
  ) : cur_phase == phase_rel ? (
    w = cur_scale == scale_short ? profile_short_rel : profile_med_rel;
  ) : (
    w = cur_scale == scale_short ? profile_short_deb : profile_med_deb;
  );

  mode_local == 0 ? (
    cur_phase == phase_att ? w *= 1.04;
    cur_phase == phase_deb ? w *= 0.94;
  ) : mode_local >= 2 ? (
    cur_phase == phase_body ? w *= 1.08;
    cur_phase == phase_att ? w *= 0.88;
  );

  w;
);

function family_desire_weight(cur_family, want_family, cur_phase, mode_local) local(w, diff) (
  want_family <= 0 ? (
    w = 1;
  ) : (
    diff = abs(cur_family - want_family);
    diff == 0 ? (
      w = 1.02 + 0.18 * profile_family_lock;
    ) : diff == 1 ? (
      w = 0.98 + 0.10 * profile_family_lock;
    ) : diff == 2 ? (
      w = 0.92 + 0.04 * profile_family_lock;
    ) : (
      w = 0.80 + 0.10 * (1 - profile_family_lock);
    );
  );

  cur_phase == phase_deb ? w *= (0.96 + 0.06 * (1 - profile_family_lock));
  mode_local >= 2 ? w *= 1.03;
  w;
);

function phase_transition_weight(prev_phase, cur_phase, mode_local) local(w) (
  w = 1;

  prev_phase == phase_att ? (
    cur_phase == phase_att ? w = 0.45 :
    cur_phase == phase_body ? w = 1.28 :
    cur_phase == phase_rel ? w = 0.62 :
    w = 0.86;
  ) : prev_phase == phase_body ? (
    cur_phase == phase_att ? w = 0.34 :
    cur_phase == phase_body ? w = 1.10 :
    cur_phase == phase_rel ? w = 0.88 :
    w = 0.74;
  ) : prev_phase == phase_rel ? (
    cur_phase == phase_att ? w = 0.22 :
    cur_phase == phase_body ? w = 0.78 :
    cur_phase == phase_rel ? w = 0.96 :
    w = 1.12;
  ) : prev_phase == phase_deb ? (
    cur_phase == phase_att ? w = 0.58 :
    cur_phase == phase_body ? w = 1.04 :
    cur_phase == phase_rel ? w = 0.82 :
    w = 0.46;
  );

  mode_local == 0 ? (
    cur_phase == phase_att ? w *= 1.08;
    cur_phase == phase_deb ? w *= 0.92;
  ) : mode_local >= 2 ? (
    cur_phase == phase_body ? w *= 1.18;
    cur_phase == phase_att ? w *= 0.72;
    cur_phase == phase_deb ? w *= 0.84;
  );

  w;
);

function phase_desire_weight(cur_phase, want_phase, mode_local) local(w) (
  w = 1;

  want_phase == phase_att ? (
    cur_phase == phase_att ? (
      w = mode_local == 0 ? 1.65 : mode_local == 1 ? 1.45 : 0.62;
    ) : cur_phase == phase_body ? (
      w = mode_local == 0 ? 0.88 : mode_local == 1 ? 0.98 : 1.12;
    ) : cur_phase == phase_rel ? (
      w = mode_local == 0 ? 0.30 : mode_local == 1 ? 0.42 : 0.38;
    ) : (
      w = mode_local == 0 ? 0.64 : mode_local == 1 ? 0.82 : 0.72;
    );
  ) : want_phase == phase_body ? (
    cur_phase == phase_att ? (
      w = mode_local == 0 ? 0.82 : mode_local == 1 ? 0.88 : 0.56;
    ) : cur_phase == phase_body ? (
      w = mode_local == 0 ? 1.34 : mode_local == 1 ? 1.24 : 1.46;
    ) : cur_phase == phase_rel ? (
      w = mode_local == 0 ? 0.72 : mode_local == 1 ? 0.78 : 0.86;
    ) : (
      w = mode_local == 0 ? 0.62 : mode_local == 1 ? 0.72 : 0.68;
    );
  ) : want_phase == phase_rel ? (
    cur_phase == phase_att ? (
      w = mode_local == 0 ? 0.24 : mode_local == 1 ? 0.34 : 0.28;
    ) : cur_phase == phase_body ? (
      w = mode_local == 0 ? 0.84 : mode_local == 1 ? 0.76 : 0.92;
    ) : cur_phase == phase_rel ? (
      w = mode_local == 0 ? 1.42 : mode_local == 1 ? 1.30 : 1.08;
    ) : (
      w = mode_local == 0 ? 0.96 : mode_local == 1 ? 1.08 : 0.92;
    );
  ) : (
    cur_phase == phase_att ? (
      w = mode_local == 0 ? 0.54 : mode_local == 1 ? 0.70 : 0.46;
    ) : cur_phase == phase_body ? (
      w = mode_local == 0 ? 0.82 : mode_local == 1 ? 0.92 : 0.86;
    ) : cur_phase == phase_rel ? (
      w = mode_local == 0 ? 0.76 : mode_local == 1 ? 0.82 : 0.72;
    ) : (
      w = mode_local == 0 ? 1.24 : mode_local == 1 ? 1.24 : 1.04;
    );
  );

  w;
);

function candidate_weight(ci, mode_local) local(base, score, rank, weight, nrms, npeak, nflux, nzc, nctr, nedge, zc_shape, mode_shape, rep, start, dist, cloud_w, prev_ci, prev_slot, pbase, drms, dflux, dzc, dctr, dedge, compat_amt, compat, prevs, nexts, peakish, gran_flux_fit, slope, nslope_p, nslope_n, slope_abs, slope_neutral, nhf, nmotion, nonset, cand_phase, phase_w, family, lastfam_w, cand_scale_v, scale_w, fam_w, phase_prof_w, base_dbg_w, family_dbg_w, compat_dbg_w, phase_relax_w, pca_novel, pca_w, pca_dbg_w, dpc1, dpc2, dpc) (
  base = cand_base + ci * cand_stride;
  score = mem[base + 6];
  rank = mem[base + 7];

  rank <= 0 ? (
    weight = 0;
  ) : (
    nrms  = mem[base + 1] / max(0.000001, max_rms);
    npeak = mem[base + 2] / max(0.000001, max_peak);
    nflux = mem[base + 3] / max(0.000001, max_flux);
    nzc   = mem[base + 4] / max(0.000001, max_zc);
    nctr  = mem[base + 5] / max(0.000001, max_ctr);
    nedge = mem[base + 8] / max(0.000001, max_edge);
    slope = mem[base + 9];
    nslope_p = max(0, slope) / max(0.000001, max_slope_pos);
    nslope_n = max(0, -slope) / max(0.000001, max_slope_neg);
    slope_abs = abs(slope) / max(0.000001, max(max_slope_pos, max_slope_neg));
    slope_abs > 1 ? slope_abs = 1;
    slope_neutral = 1 - slope_abs;
    nhf = mem[base + 10] / max(0.000001, max_hf);
    nmotion = mem[base + 11] / max(0.000001, max_motion);
    nonset = mem[base + 12] / max(0.000001, max_onset);
    cand_phase = floor(mem[base + 13] + 0.5);
    family = floor(mem[base + 14] + 0.5);
    cand_scale_v = floor(mem[base + 15] + 0.5);
    pca_novel = mem[base + 18];
    pca_novel < 0 ? pca_novel = 0;
    pca_novel > 1 ? pca_novel = 1;

    zc_shape = 1 - abs(nzc - 0.35) / 0.35;
    zc_shape < 0 ? zc_shape = 0;
    zc_shape > 1 ? zc_shape = 1;

    family_dbg_w = 1;
    lastfam_w = 1;
    compat_dbg_w = 1;
    pca_dbg_w = 1;

    weight = (1 - interesting) + interesting * (0.10 + 3.00 * score * score);
    weight *= (0.15 + 0.85 * rank);

    auto_slice ? (
      prevs = ci > 0 ? (mem[cand_base + (ci - 1) * cand_stride + 6] * mem[cand_base + (ci - 1) * cand_stride + 7]) : (score * rank);
      nexts = ci < cand_count - 1 ? (mem[cand_base + (ci + 1) * cand_stride + 6] * mem[cand_base + (ci + 1) * cand_stride + 7]) : (score * rank);
      peakish = ((score * rank >= prevs) && (score * rank >= nexts)) ? 1 : 0.20;
      weight *= peakish;
    );

    mode_local == 0 ? (
      mode_shape = 0.22 + 0.92 * nonset + 0.56 * nslope_p + 0.28 * nflux + 0.20 * nctr + 0.10 * npeak;
    ) : mode_local == 1 ? (
      mode_shape = 0.24 + 0.42 * rank + 0.24 * nmotion + 0.22 * nflux + 0.18 * nctr + 0.12 * nhf + 0.10 * sqrt(nrms);
    ) : (
      gran_flux_fit = 1 - abs(nflux - 0.38) / 0.38;
      gran_flux_fit < 0 ? gran_flux_fit = 0;
      gran_flux_fit > 1 ? gran_flux_fit = 1;
      mode_shape = 0.28 + 0.42 * rank + 0.34 * nmotion + 0.18 * sqrt(nrms) + 0.16 * slope_neutral + 0.10 * gran_flux_fit + 0.10 * (1 - min(1, nedge));
    );
    weight *= mode_shape;

    pca_w =
      mode_local == 0 ? (1.02 + (0.18 + 0.46 * interesting) * pca_novel) :
      mode_local == 1 ? (1.00 + (0.12 + 0.30 * interesting) * pca_novel) :
      (0.98 + (0.06 + 0.18 * interesting) * pca_novel);
    pca_dbg_w = pca_w;
    weight *= pca_w;

    rep = 1 - repeat_avoid + repeat_avoid * recent_weight(ci);
    weight *= rep;
    base_dbg_w = weight;

    phase_w = phase_desire_weight(cand_phase, desired_phase, mode_local);
    last_phase > 0 ? phase_w *= phase_transition_weight(last_phase, cand_phase, mode_local);
    phase_prof_w =
      cand_phase == phase_att ? profile_att_pick :
      cand_phase == phase_body ? profile_body_pick :
      cand_phase == phase_rel ? profile_rel_pick :
      profile_deb_pick;
    phase_w *= phase_prof_w;
    weight *= phase_w;

    scale_w = phase_scale_weight(cand_phase, cand_scale_v, mode_local);
    weight *= scale_w;

    fam_w = family_desire_weight(family, desired_family, cand_phase, mode_local);
    phase_relax_w = cand_phase == desired_phase ? 1 : cand_phase == desired_phase2 ? 0.92 : 0.84;
    fam_w *= phase_relax_w;
    family_dbg_w = fam_w;
    weight *= fam_w;

    prev_slot = recent_head - 1;
    prev_slot < 0 ? prev_slot += recent_max;
    prev_ci = floor(mem[recent_base + prev_slot]);

    prev_ci >= 0 ? (
      pbase = cand_base + prev_ci * cand_stride;
      drms  = abs(mem[base + 1] - mem[pbase + 1]) / max(0.000001, max_rms);
      dflux = abs(mem[base + 3] - mem[pbase + 3]) / max(0.000001, max_flux);
      dzc   = abs(mem[base + 4] - mem[pbase + 4]) / max(0.000001, max_zc);
      dctr  = abs(mem[base + 5] - mem[pbase + 5]) / max(0.000001, max_ctr);
      dedge = abs(mem[base + 8] - mem[pbase + 8]) / max(0.000001, max_edge);
      dstart = abs(mem[base] - mem[pbase]) / max(1, (cand_win(ci) + cand_win(prev_ci)) * 1.5);
      dstart > 1 ? dstart = 1;
      slope_flip = ((mem[base + 9] >= 0) != (mem[pbase + 9] >= 0)) ? 1 : 0;
      dpc1 = abs(mem[base + 16] - mem[pbase + 16]) / max(0.000001, sqrt(pca_var1));
      dpc2 = abs(mem[base + 17] - mem[pbase + 17]) / max(0.000001, sqrt(pca_var2));
      dpc = 0.5 * (dpc1 + dpc2);
      dpc > 1.5 ? dpc = 1.5;

      compat = exp(-(2.6 * drms + 2.3 * dflux + 1.6 * dzc + 1.9 * dctr + 1.2 * dedge + 0.85 * dstart + 0.35 * slope_flip + 0.55 * dpc));
      compat_amt = (mode_local == 0 ? 0.18 : mode_local == 1 ? 0.46 : 0.82) * profile_comp_mul;
      compat_amt > 0.96 ? compat_amt = 0.96;
      compat_dbg_w = (1 - compat_amt) + compat_amt * compat;
      weight *= compat_dbg_w;
    );

    (cand_phase == last_phase) && (family > 0) && (last_family > 0) ? (
      family == last_family ? (
        lastfam_w = 1.04 + 0.08 * profile_family_lock;
      ) : abs(family - last_family) == 1 ? (
        lastfam_w = 1.00 + 0.05 * profile_family_lock;
      ) : (
        lastfam_w = 0.94;
      );
      weight *= lastfam_w;
    );

    dbg_capture_ci == ci ? (
      dbg_w_base = base_dbg_w;
      dbg_w_phase = phase_w;
      dbg_w_scale = scale_w;
      dbg_w_family = family_dbg_w * lastfam_w;
      dbg_w_compat = compat_dbg_w;
      dbg_w_pca = pca_dbg_w;
      dbg_sel_novel = pca_novel;
      dbg_w_total = weight;
    );

    mode_local >= 2 ? (
      start = mem[base];
      dist = abs(start - cloud_center);
      cloud_w = 1 - min(1, dist / max(1, cloud_radius_frames));
      cloud_w = 0.12 + 0.88 * cloud_w * cloud_w;
      weight *= cloud_w;
    );
  );

  weight;
);

function hsmm_state_weight(ci, mode_local) local(st, row_sum, j, trans, transp, mean_run, run_ratio, w, entry_sum, ent) (
  st = floor(mem[cand_state_base + ci]);
  st <= 0 ? (
    w = 0.0001;
  ) : (
    w = 1;
    last_state > 0 ? (
      row_sum = 0;
      j = 0;
      loop(state_count,
        row_sum += mem[state_trans_base + (last_state - 1) * state_count + j];
        j += 1;
      );
      trans = mem[state_trans_base + (last_state - 1) * state_count + (st - 1)];
      transp = (trans + 1) / (row_sum + state_count);
      mean_run = mem[state_dur_mean_base + last_state - 1];
      mean_run < 1 ? mean_run = 1;
      run_ratio = state_run_count / mean_run;
      last_state == st ? (
        w = transp * (run_ratio < 0.70 ? 1.20 : run_ratio < 1.05 ? 1.02 : run_ratio < 1.45 ? 0.88 : 0.72);
      ) : (
        w = 0.82 + 1.45 * transp;
        run_ratio > 1.12 ? w *= 1.10;
      );
    ) : (
      entry_sum = 0;
      j = 0;
      loop(state_count,
        entry_sum += mem[state_entry_base + j];
        j += 1;
      );
      ent = mem[state_entry_base + st - 1];
      w = 0.90 + 0.60 * ((ent + 1) / max(1, entry_sum + state_count));
    );
  );
  w;
);

function graph_link_weight(prev_ci, ci) local(k, idx, w, best) (
  best = 0;
  prev_ci >= 0 ? (
    k = 0;
    loop(graph_k,
      idx = floor(mem[cand_graph_idx_base + prev_ci * graph_k + k]);
      idx == ci ? (
        w = mem[cand_graph_w_base + prev_ci * graph_k + k];
        w > best ? best = w;
      );
      k += 1;
    );
  );
  best > 0 ? (0.88 + 0.18 * min(1, best)) : 0.94;
);

function token_continuity_weight(ci) local(tok, st, w) (
  tok = floor(mem[cand_token_base + ci]);
  st = floor(mem[cand_state_base + ci]);
  w = 1;
  last_token > 0 ? (
    tok == last_token ? (
      w = 1.06;
    ) : floor((tok - 1) / 3) == floor((last_token - 1) / 3) ? (
      w = 1.02;
    ) : last_state > 0 && (st == last_state) ? (
      w = 0.98;
    ) : (
      w = 0.95;
    );
  );
  w;
);

function texture_stat_weight(ci) local(base, nrms, nhf, nmotion, nctr, nonset, nslope, p_nrms, p_hf, p_motion, p_ctr, p_onset, p_slope, err, w) (
  base = cand_base + ci * cand_stride;
  nrms = mem[base + 1] / max(0.000001, max_rms);
  nhf = mem[base + 10] / max(0.000001, max_hf);
  nmotion = mem[base + 11] / max(0.000001, max_motion);
  nctr = mem[base + 5] / max(0.000001, max_ctr);
  nonset = mem[base + 12] / max(0.000001, max_onset);
  nslope = (max(0, mem[base + 9]) / max(0.000001, max_slope_pos)) - (max(0, -mem[base + 9]) / max(0.000001, max_slope_neg));

  p_nrms = recent_w_sum > 0 ? (0.72 * recent_nrms_mean + 0.28 * nrms) : nrms;
  p_hf = recent_w_sum > 0 ? (0.72 * recent_hf_mean + 0.28 * nhf) : nhf;
  p_motion = recent_w_sum > 0 ? (0.72 * recent_motion_mean + 0.28 * nmotion) : nmotion;
  p_ctr = recent_w_sum > 0 ? (0.72 * recent_ctr_mean + 0.28 * nctr) : nctr;
  p_onset = recent_w_sum > 0 ? (0.68 * corpus_onset_mean + 0.32 * nonset) : nonset;
  p_slope = recent_w_sum > 0 ? (0.68 * corpus_slope_mean + 0.32 * nslope) : nslope;

  err =
    0.55 * abs(p_nrms - corpus_nrms_mean) +
    0.60 * abs(p_hf - corpus_hf_mean) +
    0.65 * abs(p_motion - corpus_motion_mean) +
    0.45 * abs(p_ctr - corpus_ctr_mean) +
    0.30 * abs(p_onset - corpus_onset_mean) +
    0.20 * abs(p_slope - corpus_slope_mean);

  w = exp(-1.05 * err);
  w < 0.78 ? w = 0.78 + 0.22 * w;
  w;
);

function structured_candidate_weight(ci, mode_local) local(w, hsmmw, texw, tokw, prev_slot, prev_ci, graphw) (
  w = candidate_weight(ci, mode_local);
  w > 0 ? (
    hsmmw = hsmm_state_weight(ci, mode_local);
    texw = texture_stat_weight(ci);
    tokw = token_continuity_weight(ci);
    prev_slot = recent_head - 1;
    prev_slot < 0 ? prev_slot += recent_max;
    prev_ci = floor(mem[recent_base + prev_slot]);
    graphw = graph_link_weight(prev_ci, ci);
    w *= hsmmw * texw * tokw * graphw;

    dbg_capture_ci == ci ? (
      dbg_w_hsmm = hsmmw;
      dbg_w_graph = graphw;
      dbg_w_texstat = texw;
      dbg_w_token = tokw;
    );
  );
  w;
);

function beam_lookahead_weight(ci, mode_local) local(k, nidx, best, nbw, edgew, nphase, tok, tbonus) (
  best = 0.0001;
  tok = floor(mem[cand_token_base + ci]);
  k = 0;
  loop(graph_k,
    nidx = floor(mem[cand_graph_idx_base + ci * graph_k + k]);
    nidx >= 0 ? (
      edgew = mem[cand_graph_w_base + ci * graph_k + k];
      nbw = candidate_weight(nidx, mode_local);
      nphase = floor(mem[cand_base + nidx * cand_stride + 13] + 0.5);
      tbonus = nphase == desired_phase2 ? 1.16 : nphase == desired_phase ? 1.04 : 0.94;
      floor(mem[cand_token_base + nidx]) == tok ? tbonus *= 1.04;
      nbw = edgew * nbw * tbonus;
      nbw > best ? best = nbw;
    );
    k += 1;
  );
  0.86 + 0.14 * (best / (best + 1));
);

function pick_candidate_beam(mode_local) local(primary_phase, secondary_phase, pbase, pcount, pbase2, pcount2, use_pools, i, idx, w, total, rr, accum, chosen, live_any, finalw, done) (
  primary_phase = desired_phase;
  secondary_phase = desired_phase2;
  pcount = phase_pool_count(primary_phase);
  pcount2 = (secondary_phase != primary_phase) ? phase_pool_count(secondary_phase) : 0;
  use_pools = (pcount + pcount2) > 0;
  i = 0;
  loop(beam_width,
    mem[beam_idx_base + i] = -1;
    mem[beam_score_base + i] = 0;
    i += 1;
  );

  use_pools ? (
    pbase = phase_pool_base(primary_phase);
    i = 0;
    loop(pcount,
      idx = floor(mem[pbase + i]);
      w = structured_candidate_weight(idx, mode_local);
      minslot = 0; minw = mem[beam_score_base + 0];
      j = 1;
      loop(beam_width - 1,
        curw = mem[beam_score_base + j];
        curw < minw ? (minw = curw; minslot = j;);
        j += 1;
      );
      w > minw ? (
        mem[beam_score_base + minslot] = w;
        mem[beam_idx_base + minslot] = idx;
      );
      i += 1;
    );
    pcount2 > 0 ? (
      pbase2 = phase_pool_base(secondary_phase);
      i = 0;
      loop(pcount2,
        idx = floor(mem[pbase2 + i]);
        w = structured_candidate_weight(idx, mode_local);
        minslot = 0; minw = mem[beam_score_base + 0];
        j = 1;
        loop(beam_width - 1,
          curw = mem[beam_score_base + j];
          curw < minw ? (minw = curw; minslot = j;);
          j += 1;
        );
        w > minw ? (
          mem[beam_score_base + minslot] = w;
          mem[beam_idx_base + minslot] = idx;
        );
        i += 1;
      );
    );
  ) : (
    i = 0;
    loop(cand_count,
      w = structured_candidate_weight(i, mode_local);
      minslot = 0; minw = mem[beam_score_base + 0];
      j = 1;
      loop(beam_width - 1,
        curw = mem[beam_score_base + j];
        curw < minw ? (minw = curw; minslot = j;);
        j += 1;
      );
      w > minw ? (
        mem[beam_score_base + minslot] = w;
        mem[beam_idx_base + minslot] = i;
      );
      i += 1;
    );
  );

  total = 0;
  live_any = 0;
  i = 0;
  loop(beam_width,
    idx = floor(mem[beam_idx_base + i]);
    idx >= 0 ? (
      finalw = mem[beam_score_base + i] * beam_lookahead_weight(idx, mode_local);
      mem[beam_score_base + i] = finalw;
      total += finalw;
      live_any = 1;
    );
    i += 1;
  );

  live_any <= 0 || total <= 0 ? (
    chosen = best_cand;
  ) : (
    rr = rand01() * total;
    accum = 0;
    chosen = best_cand;
    done = 0;
    i = 0;
    loop(beam_width,
      done <= 0 ? (
        idx = floor(mem[beam_idx_base + i]);
        idx >= 0 ? (
          accum += mem[beam_score_base + i];
          accum >= rr ? (
            chosen = idx;
            done = 1;
          );
        );
      );
      i += 1;
    );
  );
  chosen;
);

function pick_candidate(mode_local) local(primary_phase, secondary_phase, total, rr, accum, chosen, done, i, idx, weight, pbase, pcount, pbase2, pcount2, use_pools) (
  primary_phase = desired_phase;
  secondary_phase = desired_phase2;
  total = 0;

  pcount = phase_pool_count(primary_phase);
  pcount2 = (secondary_phase != primary_phase) ? phase_pool_count(secondary_phase) : 0;
  use_pools = (pcount + pcount2) > 0;

  use_pools ? (
    pbase = phase_pool_base(primary_phase);
    i = 0;
    loop(pcount,
      idx = floor(mem[pbase + i]);
      total += candidate_weight(idx, mode_local);
      i += 1;
    );

    pcount2 > 0 ? (
      pbase2 = phase_pool_base(secondary_phase);
      i = 0;
      loop(pcount2,
        idx = floor(mem[pbase2 + i]);
        total += candidate_weight(idx, mode_local);
        i += 1;
      );
    );
  ) : (
    i = 0;
    loop(cand_count,
      total += candidate_weight(i, mode_local);
      i += 1;
    );
  );

  total <= 0 ? (
    chosen = best_cand;
  ) : (
    rr = rand01() * total;
    accum = 0;
    chosen = best_cand;
    done = 0;

    use_pools ? (
      pbase = phase_pool_base(primary_phase);
      i = 0;
      loop(pcount,
        done <= 0 ? (
          idx = floor(mem[pbase + i]);
          weight = candidate_weight(idx, mode_local);
          accum += weight;
          accum >= rr ? (
            chosen = idx;
            done = 1;
          );
        );
        i += 1;
      );

      (done <= 0) && (pcount2 > 0) ? (
        pbase2 = phase_pool_base(secondary_phase);
        i = 0;
        loop(pcount2,
          done <= 0 ? (
            idx = floor(mem[pbase2 + i]);
            weight = candidate_weight(idx, mode_local);
            accum += weight;
            accum >= rr ? (
              chosen = idx;
              done = 1;
            );
          );
          i += 1;
        );
      );
    ) : (
      i = 0;
      loop(cand_count,
        done <= 0 ? (
          weight = candidate_weight(i, mode_local);
          accum += weight;
          accum >= rr ? (
            chosen = i;
            done = 1;
          );
        );
        i += 1;
      );
    );
  );

  chosen;
);

function refine_spawn_start(start, region_len, mode_local) local(search_back, search_fwd, lo, hi, fr, best_f, best_cost, vm, v0, vp, edge, future, cost, zc, best_anchor, best_onset, rise, pre_roll, sub_lo, sub_hi, future2, onset_cost) (
  ((mode_local >= 2) || (spawn_continuation > 0)) ? (
    search_back = min(floor(ana_win * 0.18), 96);
    search_fwd  = min(max(floor(region_len * 0.18), floor(ana_win * 0.20)), 256);

    lo = start - search_back;
    hi = start + search_fwd;
    lo < 1 ? lo = 1;
    hi > tex_frames - 3 ? hi = tex_frames - 3;

    best_f = start;
    best_cost = 1000000;
    fr = lo;
    loop(max(1, hi - lo + 1),
      vm = tex_read(fr - 1, 0);
      v0 = tex_read(fr, 0);
      vp = tex_read(fr + 1, 0);
      tex_ch > 1 ? (
        vm = 0.5 * (vm + tex_read(fr - 1, 1));
        v0 = 0.5 * (v0 + tex_read(fr, 1));
        vp = 0.5 * (vp + tex_read(fr + 1, 1));
      );

      edge = abs(v0) + 0.55 * abs(vp - vm);
      zc = ((v0 >= 0) != (vm >= 0)) ? 1 : 0;

      future = abs(tex_read(fr + 2, 0));
      tex_ch > 1 ? future = 0.5 * (future + abs(tex_read(fr + 2, 1)));
      cost = edge - 0.06 * future;

      zc > 0 ? cost *= 0.82;
      cost < best_cost ? (
        best_cost = cost;
        best_f = fr;
      );

      fr += 1;
    );
  ) : (
    // One-shot/random should start close to the candidate's salient attack, not
    // drag in a long quiet pre-roll that makes Wet feel pushed behind Dry.
    search_fwd = min(max(floor(region_len * 0.65), floor(ana_win * 0.90)), 4096);
    lo = start;
    hi = start + search_fwd;
    lo < 1 ? lo = 1;
    hi > tex_frames - 9 ? hi = tex_frames - 9;

    best_anchor = start;
    best_onset = -1000000;
    fr = lo;
    loop(max(1, hi - lo + 1),
      vm = tex_read(fr - 1, 0);
      v0 = tex_read(fr, 0);
      vp = tex_read(fr + 1, 0);
      future = abs(tex_read(fr + 4, 0));
      future2 = abs(tex_read(fr + 8, 0));
      tex_ch > 1 ? (
        vm = 0.5 * (vm + tex_read(fr - 1, 1));
        v0 = 0.5 * (v0 + tex_read(fr, 1));
        vp = 0.5 * (vp + tex_read(fr + 1, 1));
        future = 0.5 * (future + abs(tex_read(fr + 4, 1)));
        future2 = 0.5 * (future2 + abs(tex_read(fr + 8, 1)));
      );

      rise = abs(vp) - abs(vm);
      rise < 0 ? rise = 0;
      edge = abs(v0) + 0.40 * abs(vp - vm);
      zc = ((v0 >= 0) != (vm >= 0)) ? 1 : 0;

      onset_cost = 0.62 * abs(vp - vm) + 0.52 * rise + 0.18 * future + 0.12 * future2 - 0.10 * edge;
      zc > 0 ? onset_cost *= 1.06;

      onset_cost > best_onset ? (
        best_onset = onset_cost;
        best_anchor = fr;
      );

      fr += 1;
    );

    pre_roll = floor(max(0.002 * tex_sr, min(0.012 * tex_sr, env_a_ms * 0.001 * tex_sr * 0.65)));
    pre_roll < 8 ? pre_roll = 8;
    pre_roll > floor(ana_win * 0.45) ? pre_roll = floor(ana_win * 0.45);

    best_f = best_anchor - pre_roll;
    best_f < 1 ? best_f = 1;

    // Tiny local anti-click refinement around the onset-aligned start.
    sub_lo = best_f - min(floor(pre_roll * 0.50), 20);
    sub_hi = best_f + min(floor(pre_roll * 0.25), 12);
    sub_lo < 1 ? sub_lo = 1;
    sub_hi > tex_frames - 3 ? sub_hi = tex_frames - 3;

    best_cost = 1000000;
    fr = sub_lo;
    loop(max(1, sub_hi - sub_lo + 1),
      vm = tex_read(fr - 1, 0);
      v0 = tex_read(fr, 0);
      vp = tex_read(fr + 1, 0);
      tex_ch > 1 ? (
        vm = 0.5 * (vm + tex_read(fr - 1, 1));
        v0 = 0.5 * (v0 + tex_read(fr, 1));
        vp = 0.5 * (vp + tex_read(fr + 1, 1));
      );

      edge = abs(v0) + 0.45 * abs(vp - vm);
      zc = ((v0 >= 0) != (vm >= 0)) ? 1 : 0;
      cost = edge;
      zc > 0 ? cost *= 0.85;
      cost < best_cost ? (
        best_cost = cost;
        best_f = fr;
      );

      fr += 1;
    );
  );

  best_f;
);

function claim_voice() local(i, base, free_idx, steal_idx, best_prog, prog) (
  free_idx = -1;
  steal_idx = 0;
  best_prog = -1;
  i = 0;
  loop(max_voices,
    base = voice_base + i * v_stride;
    mem[base] <= 0 ? (
      free_idx < 0 ? free_idx = i;
    ) : (
      prog = mem[base + 2] / max(1, mem[base + 3]);
      prog > best_prog ? (
        best_prog = prog;
        steal_idx = i;
      );
    );
    i += 1;
  );
  free_idx >= 0 ? free_idx : steal_idx;
);

function compute_event_bounds(ci) local(base, peak_s, bound_low, left, right, cont, j, sc, max_bins, ev_end, cap_frames, cand_phase, phase_cap_mul, phase_bound_mul, local_win, local_hop, cand_sc, nb_sc) (
  base = cand_base + ci * cand_stride;
  cand_phase = floor(mem[base + 13] + 0.5);
  cand_sc = cand_scale(ci);
  local_win = cand_win(ci);
  local_hop = cand_hop(ci);
  peak_s = mem[base + 6] * max(0.25, mem[base + 7]);
  peak_s < 0.001 ? peak_s = 0.001;

  phase_cap_mul =
    cand_phase == phase_att ? 0.72 :
    cand_phase == phase_body ? 1.18 :
    cand_phase == phase_rel ? 0.90 :
    0.55;

  cap_frames = floor(dur_ms * 0.001 * tex_sr * phase_cap_mul);
  cap_frames < local_win ? cap_frames = local_win;
  max_bins = floor(cap_frames / max(1, local_hop));
  max_bins < 1 ? max_bins = 1;
  max_bins > cand_count ? max_bins = cand_count;

  phase_bound_mul =
    cand_phase == phase_att ? (0.26 + 0.32 * focus) :
    cand_phase == phase_body ? (0.16 + 0.22 * focus) :
    cand_phase == phase_rel ? (0.22 + 0.28 * focus) :
    (0.30 + 0.34 * focus);

  bound_low = peak_s * phase_bound_mul;
  bound_low < 0.001 ? bound_low = 0.001;

  left = ci;
  cont = 1;
  j = 0;
  loop(max_bins,
    cont ? (
      left > 0 ? (
        nb_sc = cand_scale(left - 1);
        nb_sc == cand_sc ? (
          sc = mem[cand_base + (left - 1) * cand_stride + 6] * mem[cand_base + (left - 1) * cand_stride + 7];
          sc >= bound_low ? left -= 1 : cont = 0;
        ) : (
          cont = 0;
        );
      ) : (
        cont = 0;
      );
    );
    j += 1;
  );

  right = ci;
  cont = 1;
  j = 0;
  loop(max_bins,
    cont ? (
      right < cand_count - 1 ? (
        nb_sc = cand_scale(right + 1);
        nb_sc == cand_sc ? (
          sc = mem[cand_base + (right + 1) * cand_stride + 6] * mem[cand_base + (right + 1) * cand_stride + 7];
          sc >= bound_low ? right += 1 : cont = 0;
        ) : (
          cont = 0;
        );
      ) : (
        cont = 0;
      );
    );
    j += 1;
  );

  auto_ev_start = mem[cand_base + left * cand_stride];
  ev_end = mem[cand_base + right * cand_stride];
  auto_ev_len = ev_end - auto_ev_start + local_win;

  auto_ev_len < local_win ? auto_ev_len = local_win;
  auto_ev_len > cap_frames ? auto_ev_len = cap_frames;
);

function env_eval(age, env_len, is_gran) local(a_s, d_s, r_s, hold_s, tot, scale, t, out, gw) (
  a_s = env_a_s_base;
  d_s = env_d_s_base;
  r_s = env_r_s_base;
  hold_s = 0;

  tot = a_s + d_s + r_s;
  tot > env_len ? (
    scale = env_len / max(1, tot);
    a_s = max(1, floor(a_s * scale));
    d_s = max(1, floor(d_s * scale));
    r_s = max(1, floor(r_s * scale));
    hold_s = 0;
  ) : (
    hold_s = env_len - tot;
    hold_s < 0 ? hold_s = 0;
  );

  age < a_s ? (
    t = age / max(1, a_s);
    out = shape01(t, atk_curve);
  ) : age < a_s + d_s ? (
    t = (age - a_s) / max(1, d_s);
    out = 1 + (sus - 1) * shape01(t, dec_curve);
  ) : age < a_s + d_s + hold_s ? (
    out = sus;
  ) : age < env_len ? (
    t = (age - (a_s + d_s + hold_s)) / max(1, r_s);
    out = sus * (1 - shape01(t, rel_curve));
  ) : (
    out = 0;
  );

  is_gran > 0 ? (
    gw = sin(PI * clamp1(age / max(1, env_len - 1), 0, 1));
    gw *= gw;
    out = out * 0.78 + gw * 0.22;
  );

  out;
);

function ola_window(age, env_len, mode_local, cand_phase) local(fade_ratio, fade_len, min_s, max_s, t, win_in, win_out, rem, out) (
  mode_local == 0 ? (
    fade_ratio =
      cand_phase == phase_att ? 0.06 :
      cand_phase == phase_rel ? 0.10 :
      cand_phase == phase_deb ? 0.08 :
      0.09;
  ) : mode_local == 1 ? (
    fade_ratio =
      cand_phase == phase_att ? 0.12 :
      cand_phase == phase_rel ? 0.22 :
      cand_phase == phase_deb ? 0.10 :
      0.18;
  ) : (
    fade_ratio =
      cand_phase == phase_att ? 0.18 :
      cand_phase == phase_rel ? 0.30 :
      cand_phase == phase_deb ? 0.12 :
      0.26;
  );

  // Preserve the first bite on fresh rises, but make ongoing grains overlap more smoothly.
  support_rise > 0.012 ? fade_ratio *= 0.70;
  support_fall > 0.010 ? fade_ratio *= 1.15;

  min_s = floor((mode_local == 0 ? 0.004 : mode_local == 1 ? 0.008 : 0.010) * srate);
  max_s = floor((mode_local >= 2 ? 0.060 : 0.040) * srate);

  fade_len = floor(env_len * fade_ratio);
  fade_len < min_s ? fade_len = min_s;
  fade_len > max_s ? fade_len = max_s;
  fade_len * 2 > env_len ? fade_len = max(1, floor(env_len * 0.5));

  out = 1;
  fade_len > 1 ? (
    age < fade_len ? (
      t = age / max(1, fade_len);
      win_in = sin(0.5 * PI * clamp1(t, 0, 1));
      win_in *= win_in;
    ) : (
      win_in = 1;
    );

    rem = env_len - 1 - age;
    rem < fade_len ? (
      t = rem / max(1, fade_len);
      win_out = sin(0.5 * PI * clamp1(t, 0, 1));
      win_out *= win_out;
    ) : (
      win_out = 1;
    );

    out = win_in * win_out;
    mode_local == 0 ? out = 0.55 + 0.45 * out;
  );

  out;
);

function spawn_voice(mode_local) local(ci, base, start, req_src_len, req_env_len, env_nom_len, rndf, wanderf, cents, rate, ampj, rms, peak, corr, maxsafe, trig_amp, strength, off, zcn, halfcyc_samp, phase_deg, slot, vb, sign, gran_mult, src_need, cap_src_len, score, local_support, start_region, cand_phase, phase_family, phase_len_mul, local_win, slice_rand_scale, sr, support_rand_mul) (
  (tex_loaded > 0) && (analysis_ready > 0) && (cand_count > 0) ? (
    ci = pick_candidate_beam(mode_local);
    base = cand_base + ci * cand_stride;

    dbg_capture_ci = ci;
    candidate_weight(ci, mode_local);
    dbg_capture_ci = -1;

    score = mem[base + 6];
    cand_phase = floor(mem[base + 13] + 0.5);
    phase_family = floor(mem[base + 14] + 0.5);
    start = mem[base];
    rndf = 1 + dur_var * randSym();
    rndf < 0.18 ? rndf = 0.18;

    cents = global_pitch_cents + ((spawn_pitch_override_active > 0) ? spawn_pitch_override_cents : ((((eff_source_mode == 3) || (mode >= 3)) ? midi_note_pitch_cents : 0))) + pitch_jit * randSym();
    rate = tex_sr / srate * exp((cents / 1200) * ln2);

    auto_slice ? (
      compute_event_bounds(ci);
      start = auto_ev_start;
      req_src_len = floor(auto_ev_len * (0.92 + 0.16 * rand01()));
      req_env_len = floor(req_src_len / max(rate, 0.000001));
    ) : (
      slice_rand_scale = 1;
      slice_rand_amt > 0 ? (
        sr = randSym();
        slice_rand_scale = exp(sr * log(max(1.000001, slice_rand_span)));
      );
      req_src_len = floor(dur_ms * 0.001 * tex_sr * rndf * slice_rand_scale);
      req_env_len = floor(dur_ms * 0.001 * srate * rndf * slice_rand_scale);
    );

    phase_len_mul =
      cand_phase == phase_att ? (mode_local == 0 ? 0.72 : 0.82) * profile_len_att :
      cand_phase == phase_body ? (mode_local >= 2 ? 1.18 : 1.05) * profile_len_body :
      cand_phase == phase_rel ? 0.90 * profile_len_rel :
      0.55 * profile_len_deb;
    req_src_len *= phase_len_mul;
    req_env_len *= (
      cand_phase == phase_att ? 0.92 * profile_len_att :
      cand_phase == phase_body ? 1.05 * profile_len_body :
      cand_phase == phase_rel ? 0.96 * profile_len_rel :
      0.78 * profile_len_deb
    );

    mode_local >= 2 ? (
      gran_mult = 0.78 + 0.28 * rand01();
      req_src_len *= gran_mult;
      req_env_len *= gran_mult;
    );

    req_src_len < 16 ? req_src_len = 16;
    req_env_len < 8 ? req_env_len = 8;

    env_nom_len = env_a_s_base + env_d_s_base + env_r_s_base;
    env_nom_len < 8 ? env_nom_len = 8;

    // Grain articulation should remain a per-voice envelope, not be collapsed
    // by slice/event duration. Short slices may still bias source length, but
    // the voice envelope should not shrink below the programmed ADSR surface.
    req_env_len < env_nom_len ? req_env_len = env_nom_len;

    src_need = floor(req_env_len * rate) + 8;
    req_src_len < src_need ? req_src_len = src_need;
    req_src_len > tex_frames - 2 ? req_src_len = tex_frames - 2;

    wanderf = pos_wander * pos_wander * tex_sr * 0.40 + pos_wander * req_src_len * 0.75;
    mode_local >= 2 ? (
      start += randSym() * wanderf * 0.35;
    ) : (
      start += randSym() * wanderf;
    );

    start < 0 ? start = 0;
    cap_src_len = tex_frames - req_src_len - 2;
    start > cap_src_len ? start = cap_src_len;
    start < 0 ? start = 0;

    start_region = req_src_len;
    local_win = cand_scale(ci) == scale_short ? ana_win_short : ana_win_med;
    start_region > local_win * 2 ? start_region = local_win * 2;
    start_region < local_win ? start_region = local_win;
    spawn_continuation = ((mode_local > 0) && (voices_last_count > 0) && ((support_drive > 0.14) || (support_fall > 0.006)));
    start = refine_spawn_start(start, start_region, mode_local);
    spawn_continuation = 0;
    start > cap_src_len ? start = cap_src_len;
    start < 0 ? start = 0;

    ampj = exp((amp_jit_db * randSym() / 20) * ln10);

    rms = mem[base + 1];
    peak = mem[base + 2];
    corr = 1;
    grounding > 0 ? (
      corr = 0.14 / max(0.025, rms);
      corr = pow(corr, grounding * 0.60);
      maxsafe = 0.96 / max(0.02, peak);
      corr > maxsafe ? corr = maxsafe;
      corr < 0.35 ? corr = 0.35;
      corr > 2.75 ? corr = 2.75;
    );

    trig_amp = 0.38 + 0.62 * pow(max(trig_v, 0.001), 0.60);
    strength = (1 - input_link) + input_link * trig_amp;
    strength *= (0.15 + 0.85 * ((spawn_support_override_active > 0) ? spawn_support_override_val : support_mix));
    mode_local == 1 ? strength *= 0.92;
    mode_local >= 2 ? strength *= 0.80;

    // Pre-budget highly salient grains so low Support behaves like backing texture, not foreground theft.
    local_support = support_budget + (1 - support_budget) * (1 - 0.75 * max(score, mem[base + 7]));
    support_rand_mul = 1;
    support_rand_amt > 0 ? (
      sr = randSym();
      sr > 0 ? sr *= 0.35;
      support_rand_mul += 0.22 * support_rand_amt * sr;
    );
    local_support *= support_rand_mul;
    local_support < 0.22 ? local_support = 0.22;
    local_support > 1.10 ? local_support = 1.10;
    strength *= local_support;

    // phase jitter in actual sample-offset terms:
    // mem[base + 4] is zero-crossing density in crossings/sample.
    // 1 / zc ~= half-cycle in samples, so ±180° ~= ±half-cycle.
    zcn = mem[base + 4];
    halfcyc_samp = 1 / max(0.005, zcn);
    halfcyc_samp > 128 ? halfcyc_samp = 128;

    phase_deg = phase_jit_deg * randSym();
    off = halfcyc_samp * (phase_deg / 180);

    sign = 1;

    slot = claim_voice();
    vb = voice_base + slot * v_stride;

    mem[vb     ] = 1;
    mem[vb + 1 ] = start;
    mem[vb + 2 ] = 0;
    mem[vb + 3 ] = req_src_len;
    mem[vb + 4 ] = rate;
    mem[vb + 5 ] = wet * tex_gain * ampj * corr * strength;
    mem[vb + 6 ] = off;
    mem[vb + 7 ] = ci;
    mem[vb + 8 ] = mode_local;
    mem[vb + 9 ] = (spawn_support_override_active > 0) ? spawn_support_override_val : support_sig;
    mem[vb + 10] = spawn_note_tag;
    mem[vb + 11] = 0;
    mem[vb + 12] = req_env_len;

    mem[recent_base + recent_head] = ci;
    recent_head += 1;
    recent_head >= recent_max ? recent_head = 0;

    last_phase = cand_phase;
    last_family = phase_family;
    sel_state = floor(mem[cand_state_base + ci]);
    sel_token = floor(mem[cand_token_base + ci]);
    sel_state == last_state ? (
      state_run_count += 1;
    ) : (
      state_run_count = 1;
    );
    last_state = sel_state;
    last_token = sel_token;
    dbg_sel_state = sel_state;
    dbg_sel_token = sel_token;

    mode_local >= 2 ? (
      cloud_center = cloud_center * 0.82 + start * 0.18 + randSym() * cloud_radius_frames * 0.05;
    ) : (
      cloud_center = start;
    );

    last_spawn_start = start;
    last_spawn_len = req_src_len;
    last_spawn_envlen = req_env_len;
    last_spawn_phase = cand_phase;
    last_spawn_mode = mode_local;
    last_spawn_flash = 1;
  );
);


// sample-local MIDI event latches: block MIDI parsing should not retrigger every sample.
midi_evt_on_s = 0;
midi_evt_off_s = 0;
midi_evt_change_s = 0;
midi_block_first_sample = 0;
block_event_arm ? (
  midi_evt_on_s = midi_block_evt_on;
  midi_evt_off_s = midi_block_evt_off;
  midi_evt_change_s = midi_block_evt_change;
  midi_block_first_sample = 1;
  block_event_arm = 0;
);
poly_synth = (mode >= 3) && (midi_mode > 0);

// follower / detector
in_abs = abs(spl0);
abs(spl1) > in_abs ? in_abs = abs(spl1);
sc_abs = abs(spl2);
abs(spl3) > sc_abs ? sc_abs = abs(spl3);

in_abs > auto_in_level ? auto_in_level = in_abs : auto_in_level = in_abs + auto_src_c * (auto_in_level - in_abs);
sc_abs > auto_sc_level ? auto_sc_level = sc_abs : auto_sc_level = sc_abs + auto_src_c * (auto_sc_level - sc_abs);
midi_lvl = midi_note_gate ? midi_note_vel_norm : 0;
midi_lvl > auto_midi_level ? auto_midi_level = midi_lvl : auto_midi_level = midi_lvl + auto_src_c * (auto_midi_level - midi_lvl);

auto_source_mode = 1;
auto_midi_level > 0.020 ? (
  auto_source_mode = 3;
) : (auto_sc_level > 0.0012) && (auto_sc_level > auto_in_level * 1.12) ? (
  auto_source_mode = 2;
);

eff_source_mode = source_mode == 0 ? auto_source_mode : source_mode;
raw_in_abs = in_abs;
eff_source_mode == 2 ? raw_in_abs = sc_abs;
eff_source_mode == 3 ? raw_in_abs = midi_note_vel_norm;
(mode >= 3) && midi_note_gate ? (
  midi_force_raw = 0.22 + 0.78 * midi_note_vel_norm;
  midi_force_raw > raw_in_abs ? raw_in_abs = midi_force_raw;
);

// detector extraction + first smoothing
// treat the detector as a continuous confidence signal, not a binary gate.
det_raw = raw_in_abs * sensitivity;

det_raw > follow ? (
  follow = det_raw + f_atk_c * (follow - det_raw);
) : (
  follow = det_raw + f_rel_c * (follow - det_raw);
);

// soft saturation: weak motion blooms a bit, strong motion compresses gently.
det_soft = 1 - exp(-det_sat_k * max(0, follow));
det_soft < 0 ? det_soft = 0;
det_soft > 1 ? det_soft = 1;

// onset assist / priming: wake the detector quickly on fresh transients without
// making the whole confidence path twitchy all the time.
det_rise = det_raw - det_prev;
det_prev = det_raw;
det_rise < 0 ? det_rise = 0;

startup_idle = (gate <= 0) && (support_sig < 0.04);
det_prime = 0;
det_rise > 0 ? (
  det_prime = 1 - exp(-(0.85 + 0.15 * sensitivity) * det_rise);
  det_prime *= startup_idle ? 0.85 : 0.18;
);
det_prime < 0 ? det_prime = 0;
det_prime > 1 ? det_prime = 1;

det_mix = det_soft;
det_prime > det_mix ? det_mix = det_prime;
det_mix < 0 ? det_mix = 0;
det_mix > 1 ? det_mix = 1;
det_mix > follow_ui_peak ? follow_ui_peak = det_mix;

// soft-knee participation map
knee_span = knee_hi - knee_lo;
knee_span <= eps ? knee_span = eps;
knee_t = (det_mix - knee_lo) / knee_span;
support_raw = smoothstep01(knee_t);

// final support smoothing
support_raw > support_sig ? (
  support_sig = support_raw + sup_atk_c * (support_sig - support_raw);
) : (
  support_sig = support_raw + sup_rel_c * (support_sig - support_raw);
);

// seed the support state slightly on cold onsets so the first bite is not shaved off.
startup_idle ? (
  support_seed = support_raw * (0.30 + 0.45 * det_prime);
  support_seed > support_sig ? support_sig = support_seed;
);

// optional baseline: whisper-level motion can still grow a faint bed,
// but true silence still collapses to zero.
support_drive = support_sig + support_floor * det_soft * (1 - support_sig);
support_drive < 0 ? support_drive = 0;
support_drive > 1 ? support_drive = 1;

midi_gate_mode = (eff_source_mode == 3) || (mode >= 3);
midi_note_gate ? (
  midi_seed = 0.24 + 0.76 * midi_note_vel_norm;
  midi_gate_mode ? (
    support_sig < midi_seed * 0.68 ? support_sig = midi_seed * 0.68;
    support_drive < midi_seed ? support_drive = midi_seed;
  );
);

support_rise = support_drive - support_prev;
support_rise < 0 ? support_rise = 0;
support_fall = support_prev - support_drive;
support_fall < 0 ? support_fall = 0;

wake_force = 0;
wake_force_idle = 0;
wake_force_prime = 0;
wake_force_rise = 0;

(support_prev < 0.025) ? (
  wake_force_idle = clamp1((support_drive - 0.040) / 0.18, 0, 1);
);

wake_force_prime = clamp1((det_prime - 0.10) / 0.50, 0, 1) * clamp1((support_drive - 0.02) / 0.18, 0, 1);
wake_force_rise  = clamp1((support_rise - 0.015) / 0.16, 0, 1) * clamp1((support_drive - 0.05) / 0.22, 0, 1);

wake_force = wake_force_idle * 0.70;
wake_force_prime * 0.85 > wake_force ? wake_force = wake_force_prime * 0.85;
wake_force_rise > wake_force ? wake_force = wake_force_rise;
wake_force < 0 ? wake_force = 0;
wake_force > 1 ? wake_force = 1;

support_prev = support_drive;

support_mix =
  mode == 0 ? max(0.18, 0.22 + 0.78 * support_drive) :
  support_drive;

cur_v = support_drive;

note_on = 0;
note_off = 0;
trig_on = 0.10;
trig_off = 0.04;

gate_open_ctl = support_sig;
prime_gate = det_prime * (0.65 + 0.10 * sensitivity + 0.18 * wake_force);
prime_gate > 1 ? prime_gate = 1;
prime_gate > gate_open_ctl ? gate_open_ctl = prime_gate;

gate_support_enable = (!midi_gate_mode) || midi_note_gate;

gate <= 0 ? (
  gate_support_enable && (gate_open_ctl >= trig_on) ? (
    gate = 1;
    note_on = 1;
    gate_peak = support_drive;
    trig_v = cur_v;
  );
) : (
  (!gate_support_enable) || (support_sig <= trig_off) ? (
    gate = 0;
    note_off = 1;
  );
);

gate > 0 ? (
  support_sig > gate_peak ? gate_peak = support_sig;
  peak_v = support_drive;
  peak_v > trig_v ? trig_v = peak_v;
);

midi_gate_mode ? (
  poly_synth ? (
    midi_note_gate ? (
      gate = 1;
      gate_peak = max(gate_peak, max(support_drive, midi_note_vel_norm));
      trig_v = max(cur_v, midi_note_vel_norm);
      midi_evt_on_s ? note_on = 1;
    ) : (gate > 0) ? (
      gate = 0;
      note_off = 1;
    );
  ) : (
    midi_retrig = midi_evt_on_s || midi_evt_change_s;
    midi_retrig ? (
      gate = 1;
      note_on = 1;
      gate_peak = max(gate_peak, max(support_drive, midi_note_vel_norm));
      trig_v = max(cur_v, midi_note_vel_norm);
    );
    (!midi_note_gate && (gate > 0)) ? (
      gate = 0;
      note_off = 1;
    );
  );
  !midi_note_gate ? note_on = 0;
);

note_on ? (
  desired_phase = phase_att;
  desired_phase2 = phase_body;
) : support_fall > 0.018 ? (
  desired_phase = phase_rel;
  desired_phase2 = phase_deb;
) : support_rise > 0.022 ? (
  desired_phase = phase_att;
  desired_phase2 = phase_body;
) : support_drive < 0.10 ? (
  desired_phase = phase_deb;
  desired_phase2 = phase_body;
) : (
  desired_phase = phase_body;
  desired_phase2 = support_drive > 0.65 ? phase_deb : phase_att;
);

mode == 0 ? (
  desired_phase == phase_deb ? desired_phase = phase_att;
  desired_phase2 = desired_phase == phase_att ? phase_body : phase_att;
) : mode >= 2 ? (
  desired_phase == phase_att ? desired_phase = phase_body;
  support_fall > 0.020 ? (
    desired_phase = phase_rel;
    desired_phase2 = phase_deb;
  ) : support_drive > 0.18 ? (
    desired_phase = phase_body;
    desired_phase2 = phase_deb;
  );
);

// desired family uses short recent descriptor memory; same-phase continuity still wins.
recent_family_mean = 0;
recent_nrms_mean = 0;
recent_hf_mean = 0;
recent_motion_mean = 0;
recent_zc_mean = 0;
recent_ctr_mean = 0;
recent_slope_p_mean = 0;
recent_slope_n_mean = 0;
recent_w_sum = 0;
j = 0;
loop(6,
  recent_slot = recent_head - 1 - j;
  recent_slot < 0 ? recent_slot += recent_max;
  recent_ci = floor(mem[recent_base + recent_slot]);
  recent_ci >= 0 ? (
    rbase = cand_base + recent_ci * cand_stride;
    rw = 1 - 0.12 * j;
    rw < 0.35 ? rw = 0.35;

    recent_family_mean += floor(mem[rbase + 14] + 0.5) * rw;
    recent_nrms_mean += (mem[rbase + 1] / max(0.000001, max_rms)) * rw;
    recent_hf_mean += (mem[rbase + 10] / max(0.000001, max_hf)) * rw;
    recent_motion_mean += (mem[rbase + 11] / max(0.000001, max_motion)) * rw;
    recent_zc_mean += (mem[rbase + 4] / max(0.000001, max_zc)) * rw;
    recent_ctr_mean += (mem[rbase + 5] / max(0.000001, max_ctr)) * rw;
    rslope = mem[rbase + 9];
    recent_slope_p_mean += (max(0, rslope) / max(0.000001, max_slope_pos)) * rw;
    recent_slope_n_mean += (max(0, -rslope) / max(0.000001, max_slope_neg)) * rw;
    recent_w_sum += rw;
  );
  j += 1;
);

recent_w_sum > 0 ? (
  recent_family_mean /= recent_w_sum;
  recent_nrms_mean /= recent_w_sum;
  recent_hf_mean /= recent_w_sum;
  recent_motion_mean /= recent_w_sum;
  recent_zc_mean /= recent_w_sum;
  recent_ctr_mean /= recent_w_sum;
  recent_slope_p_mean /= recent_w_sum;
  recent_slope_n_mean /= recent_w_sum;
) : (
  recent_family_mean = max(1, last_family);
);

same_phase_fam = (last_phase > 0) && (last_phase == desired_phase) && (last_family > 0);
same_phase_fam ? (
  desired_family = last_family;
) : desired_phase == phase_att ? (
  desired_family = 1;
  recent_slope_p_mean > 0.38 ? desired_family += 1;
  recent_hf_mean > 0.50 ? desired_family += 2;
  recent_motion_mean > 0.40 ? desired_family += 4;
) : desired_phase == phase_body ? (
  desired_family = 1;
  recent_nrms_mean > 0.42 ? desired_family += 1;
  recent_motion_mean > 0.40 ? desired_family += 2;
  recent_ctr_mean > 0.40 ? desired_family += 4;
) : desired_phase == phase_rel ? (
  desired_family = 1;
  recent_slope_n_mean > 0.34 ? desired_family += 1;
  recent_motion_mean > 0.32 ? desired_family += 2;
  recent_hf_mean < 0.42 ? desired_family += 4;
) : (
  desired_family = 1;
  recent_hf_mean > 0.46 ? desired_family += 1;
  recent_zc_mean > 0.44 ? desired_family += 2;
  recent_slope_p_mean > 0.28 ? desired_family += 4;
);

desired_family < 1 ? desired_family = 1;
desired_family > 8 ? desired_family = 8;

profile == 1 ? (
  desired_phase == phase_deb ? desired_family = max(desired_family, 3);
  desired_phase == phase_body ? (recent_hf_mean > 0.46 ? desired_family = min(8, desired_family + 1););
) : profile == 2 ? (
  desired_phase == phase_body ? desired_family = max(desired_family, 2);
  desired_phase == phase_rel ? desired_family = min(8, desired_family + 1);
) : profile == 3 ? (
  desired_phase == phase_body ? desired_family = max(desired_family, 4);
  desired_phase == phase_rel ? desired_family = min(8, desired_family + 1);
) : profile == 4 ? (
  desired_phase == phase_att ? desired_family = max(desired_family, 3);
  desired_phase == phase_deb ? desired_family = min(8, desired_family + 1);
);

cloud_radius_frames = max(128, floor((dur_ms * 0.001 * tex_sr) * (0.90 + pos_wander * 3.20) + tex_sr * 0.02));


voice_mode = mode >= 3 ? 2 : mode;
(!poly_synth) && note_on && tex_loaded && analysis_ready ? (
  voice_mode == 0 ? (
    spawn_pitch_override_active = 0;
    spawn_support_override_active = 0;
    spawn_note_tag = -1;
    spawn_voice(0);
  ) : (
    // First grain must land exactly when the source event clears the gate.
    // Do not wait for the random/granular scheduler to "wake up" later.
    spawn_pitch_override_active = 0;
    spawn_support_override_active = 0;
    spawn_note_tag = -1;
    spawn_voice(voice_mode);
    texture_running = 1;

    note_density_eff = density * max(0.22, support_drive);
    note_base_interval = srate / max(0.12, note_density_eff);
    spawn_countdown = max(1, floor(note_base_interval * (0.80 + 0.14 * rand01())));
  );
  trig_flash = 1;
);

(!poly_synth) && note_off ? (
  texture_running = 0;

  gate_rel_mode > 0 ? (
    gate_tail_s =
      gate_rel_mode == 1 ? max(8, min(env_r_s_base, floor(0.035 * srate))) :
      max(4, min(env_r_s_base, floor(0.012 * srate)));

    vi = 0;
    loop(max_voices,
      vb = voice_base + vi * v_stride;
      mem[vb] > 0 ? (
        agev = mem[vb + 11];
        new_end = agev + gate_tail_s;
        mem[vb + 12] > new_end ? mem[vb + 12] = new_end;
      );
      vi += 1;
    );
  );
);

poly_synth ? (
  poly_density_div = sqrt(max(1, midi_poly_count));
  poly_spawn_budget = 3;
  midi_block_first_sample ? (
    ni = 0;
    loop(128,
      mem[midi_evt_off_base + ni] > 0 ? (
        gate_rel_mode > 0 ? (
          gate_tail_s =
            gate_rel_mode == 1 ? max(8, min(env_r_s_base, floor(0.035 * srate))) :
            max(4, min(env_r_s_base, floor(0.012 * srate)));
          vi = 0;
          loop(max_voices,
            vb = voice_base + vi * v_stride;
            (mem[vb] > 0) && (floor(mem[vb + 10] + 0.5) == ni) ? (
              agev = mem[vb + 11];
              new_end = agev + gate_tail_s;
              mem[vb + 12] > new_end ? mem[vb + 12] = new_end;
            );
            vi += 1;
          );
        );
        mem[midi_note_countdown_base + ni] = 0;
        mem[midi_evt_off_base + ni] = 0;
      );
      ni += 1;
    );
  );

  poly_spawns = 0;
  pi = 0;
  loop(midi_poly_count,
    notev = floor(mem[midi_active_list_base + pi]);
    notev >= 0 ? (
      note_vel = mem[midi_note_vel_base + notev];
      note_sup = max(0.18 + 0.82 * note_vel, max(support_drive * (0.30 + 0.70 * note_vel), note_vel * 0.72));
      note_density_eff = density * max(0.12, note_sup) / poly_density_div;
      note_base_interval = srate / max(0.10, note_density_eff);

      cd = mem[midi_note_countdown_base + notev];
      wake_force > 0 ? (
        wake_pull = 0.76 - 0.42 * wake_force;
        wake_pull < 0.24 ? wake_pull = 0.24;
        cd > floor(note_base_interval * wake_pull) ? cd = floor(note_base_interval * wake_pull);
      );

      note_on_vel = mem[midi_evt_on_base + notev];
      note_on_vel > 0 ? (
        cd = 0;
      );

      cd -= 1;
      (cd <= 0) && (poly_spawns < poly_spawn_budget) ? (
        spawn_pitch_override_active = 1;
        spawn_pitch_override_cents = (notev - midi_root_note) * 100;
        spawn_support_override_active = 1;
        spawn_support_override_val = note_sup;
        spawn_note_tag = notev;
        spawn_voice(2);
        spawn_pitch_override_active = 0;
        spawn_support_override_active = 0;
        spawn_note_tag = -1;
        poly_spawns += 1;
        trig_flash = 1;
        jitter_amt = 0.14;
        cd = max(1, floor(note_base_interval * (1 + randSym() * jitter_amt)));
        mem[midi_evt_on_base + notev] = 0;
      );
      cd < 1 ? cd = 1;
      mem[midi_note_countdown_base + notev] = cd;
    );
    pi += 1;
  );
) : mode > 0 ? (
  density_eff = density * max(0.05, support_drive);
  spawn_prob = 0.10 + 0.90 * support_drive;

  // When support is clearly falling, bias toward fewer late spawns so the texture
  // resolves through overlap instead of firing a fresh event right at the end.
  support_fall > 0.010 ? (
    tail_guard = 1 - min(0.55, support_fall * 14);
    density_eff *= tail_guard;
    spawn_prob *= (0.70 + 0.30 * tail_guard);
  );

  // Support should shape density/assertiveness, but gate permission should
  // decide whether new voices are allowed at all. Otherwise Dry+Wet feels like
  // the whole texture engine is shifted later by support attack/release lag.
  texture_running = ((mode >= 3) ? midi_note_gate : (gate > 0)) && tex_loaded && analysis_ready;
  base_interval = srate / max(0.12, density_eff);

  // Minimum overlap-add guarantee: if density is sparse, do not allow the hop to
  // outrun the previous grain's tail completely. This keeps random/granular motion
  // from sounding like isolated re-triggers.
  last_spawn_envlen > 0 ? (
    hop_ratio =
      mode >= 2 ? (
        last_spawn_phase == phase_body ? 0.48 :
        last_spawn_phase == phase_rel ? 0.54 :
        last_spawn_phase == phase_att ? 0.62 :
        0.72
      ) : (
        last_spawn_phase == phase_body ? 0.72 :
        last_spawn_phase == phase_rel ? 0.66 :
        last_spawn_phase == phase_att ? 0.82 :
        0.88
      );
    support_fall > 0.010 ? hop_ratio *= 1.08;
    overlap_interval = floor(last_spawn_envlen * hop_ratio);
    overlap_interval < 1 ? overlap_interval = 1;
    base_interval > overlap_interval ? base_interval = overlap_interval;
  );

  texture_running ? (
    wake_force > 0 ? (
      wake_pull = 0.70 - 0.45 * wake_force;
      wake_pull < 0.18 ? wake_pull = 0.18;
      spawn_countdown = min(spawn_countdown, max(1, floor(base_interval * wake_pull)));
    );
    spawn_countdown > base_interval ? spawn_countdown = base_interval;

    spawn_countdown -= 1;
    spawn_countdown <= 0 ? (
      spawn_gate = spawn_prob + 0.35 * wake_force;
      spawn_gate > 1 ? spawn_gate = 1;
      ((wake_force > 0.72) || (rand01() <= spawn_gate)) ? (
        spawn_pitch_override_active = 0;
        spawn_support_override_active = 0;
        spawn_note_tag = -1;
        spawn_voice(voice_mode);
      );
      jitter_amt = voice_mode >= 2 ? 0.18 : 0.35;
      spawn_countdown = max(1, floor(base_interval * (1 + randSym() * jitter_amt)));
    );
  ) : (
    spawn_countdown = 0;
  );
);

// render active voices
texL = 0;
texR = 0;
active_ct = 0;

(tex_loaded > 0) && (tex_frames > 1) ? (
  vi = 0;
  loop(max_voices,
    vb = voice_base + vi * v_stride;

    mem[vb] > 0 ? (
      srcpos  = mem[vb + 2];
      srclen  = mem[vb + 3];
      age     = mem[vb + 11];
      envlen  = mem[vb + 12];

      (age >= envlen) || (srcpos >= srclen) ? (
        mem[vb] = 0;
      ) : (
        is_gran = (mem[vb + 8] == 2);
        envv = env_eval(age, envlen, is_gran);
        envv < 0 ? envv = 0;

        ci = floor(mem[vb + 7]);
        cand_phase = ci >= 0 ? floor(mem[cand_base + ci * cand_stride + 13] + 0.5) : phase_body;
        envv *= ola_window(age, envlen, mem[vb + 8], cand_phase);

        src = mem[vb + 1] + srcpos + mem[vb + 6];
        gate_rel_mode >= 2 && (gate <= 0) ? (
          spawn_sup = mem[vb + 9];
          spawn_sup < 0.06 ? spawn_sup = 0.06;
          rel_ratio = support_sig / spawn_sup;
          rel_ratio < 0 ? rel_ratio = 0;
          rel_ratio > 1 ? rel_ratio = 1;
          // Clamp should feel like a post-release leash, not a second master envelope
          // constantly re-owning already spawned voices.
          motion_env = 0.30 + 0.70 * sqrt(rel_ratio);
        ) : (
          motion_env = 1;
        );

        gain = mem[vb + 5] * envv * motion_env;
        pol = 1;
        note_tag = floor(mem[vb + 10] + 0.5);

        envv > 0 ? (
          tex_ch > 1 ? (
            sL = tex_read(src, 0);
            sR = tex_read(src, 1);
            texL += sL * gain * pol;
            texR += sR * gain * pol;
          ) : (
            sM = tex_read(src, 0);
            texL += sM * gain * pol;
            texR += sM * gain * pol;
          );

          active_ct += 1;
        );

        srcpos += mem[vb + 4];
        age += 1;
        mem[vb + 2] = srcpos;
        mem[vb + 11] = age;
        (age >= envlen) || (srcpos >= srclen) ? mem[vb] = 0;
      );
    );

    vi += 1;
  );
);

active_ct > 1 ? (
  ov_norm = 1 / sqrt(max(1, active_ct * 0.75));
  texL *= ov_norm;
  texR *= ov_norm;
);

voices_last_count = active_ct;

// coarse spectral-envelope imprinting: let the dry input lend broad timbral body
// to the generated wet texture without full-bin vocoder weirdness.
env_shape_conf = 0;
env_shape_mix > 0.0001 ? (
  env_shape_conf = env_shape_mix * clamp1(0.12 + 0.88 * max(support_drive, raw_in_abs * 3), 0, 1);

  dry_m = 0.5 * (spl0 + spl1);
  dry_lp1 = dry_m + env_lp1_c * (dry_lp1 - dry_m);
  dry_lp2 = dry_m + env_lp2_c * (dry_lp2 - dry_m);
  dry_lp3 = dry_m + env_lp3_c * (dry_lp3 - dry_m);
  dry_b0 = dry_lp1;
  dry_b1 = dry_lp2 - dry_lp1;
  dry_b2 = dry_lp3 - dry_lp2;
  dry_b3 = dry_m - dry_lp3;

  dry_a0 = abs(dry_b0); dry_a1 = abs(dry_b1); dry_a2 = abs(dry_b2); dry_a3 = abs(dry_b3);
  dry_a0 > dry_env0 ? (dry_env0 = dry_a0 + env_band_atk_c * (dry_env0 - dry_a0);) : (dry_env0 = dry_a0 + env_band_rel_c * (dry_env0 - dry_a0););
  dry_a1 > dry_env1 ? (dry_env1 = dry_a1 + env_band_atk_c * (dry_env1 - dry_a1);) : (dry_env1 = dry_a1 + env_band_rel_c * (dry_env1 - dry_a1););
  dry_a2 > dry_env2 ? (dry_env2 = dry_a2 + env_band_atk_c * (dry_env2 - dry_a2);) : (dry_env2 = dry_a2 + env_band_rel_c * (dry_env2 - dry_a2););
  dry_a3 > dry_env3 ? (dry_env3 = dry_a3 + env_band_atk_c * (dry_env3 - dry_a3);) : (dry_env3 = dry_a3 + env_band_rel_c * (dry_env3 - dry_a3););

  wet_m = 0.5 * (texL + texR);
  wetm_lp1 = wet_m + env_lp1_c * (wetm_lp1 - wet_m);
  wetm_lp2 = wet_m + env_lp2_c * (wetm_lp2 - wet_m);
  wetm_lp3 = wet_m + env_lp3_c * (wetm_lp3 - wet_m);
  wet_b0 = wetm_lp1;
  wet_b1 = wetm_lp2 - wetm_lp1;
  wet_b2 = wetm_lp3 - wetm_lp2;
  wet_b3 = wet_m - wetm_lp3;

  wet_a0 = abs(wet_b0); wet_a1 = abs(wet_b1); wet_a2 = abs(wet_b2); wet_a3 = abs(wet_b3);
  wet_a0 > wet_env0 ? (wet_env0 = wet_a0 + env_band_atk_c * (wet_env0 - wet_a0);) : (wet_env0 = wet_a0 + env_band_rel_c * (wet_env0 - wet_a0););
  wet_a1 > wet_env1 ? (wet_env1 = wet_a1 + env_band_atk_c * (wet_env1 - wet_a1);) : (wet_env1 = wet_a1 + env_band_rel_c * (wet_env1 - wet_a1););
  wet_a2 > wet_env2 ? (wet_env2 = wet_a2 + env_band_atk_c * (wet_env2 - wet_a2);) : (wet_env2 = wet_a2 + env_band_rel_c * (wet_env2 - wet_a2););
  wet_a3 > wet_env3 ? (wet_env3 = wet_a3 + env_band_atk_c * (wet_env3 - wet_a3);) : (wet_env3 = wet_a3 + env_band_rel_c * (wet_env3 - wet_a3););

  ratio0 = (dry_env0 + env_shape_floor) / (wet_env0 + env_shape_floor);
  ratio1 = (dry_env1 + env_shape_floor) / (wet_env1 + env_shape_floor);
  ratio2 = (dry_env2 + env_shape_floor) / (wet_env2 + env_shape_floor);
  ratio3 = (dry_env3 + env_shape_floor) / (wet_env3 + env_shape_floor);
  ratio0 > env_shape_max_ratio ? ratio0 = env_shape_max_ratio; ratio0 < 1 / env_shape_max_ratio ? ratio0 = 1 / env_shape_max_ratio;
  ratio1 > env_shape_max_ratio ? ratio1 = env_shape_max_ratio; ratio1 < 1 / env_shape_max_ratio ? ratio1 = 1 / env_shape_max_ratio;
  ratio2 > env_shape_max_ratio ? ratio2 = env_shape_max_ratio; ratio2 < 1 / env_shape_max_ratio ? ratio2 = 1 / env_shape_max_ratio;
  ratio3 > env_shape_max_ratio ? ratio3 = env_shape_max_ratio; ratio3 < 1 / env_shape_max_ratio ? ratio3 = 1 / env_shape_max_ratio;

  tgt_g0 = exp(log(ratio0) * env_shape_conf);
  tgt_g1 = exp(log(ratio1) * env_shape_conf);
  tgt_g2 = exp(log(ratio2) * env_shape_conf);
  tgt_g3 = exp(log(ratio3) * env_shape_conf);

  tgt_g0 > env_gain0 ? (env_gain0 = tgt_g0 + env_gain_atk_c * (env_gain0 - tgt_g0);) : (env_gain0 = tgt_g0 + env_gain_rel_c * (env_gain0 - tgt_g0););
  tgt_g1 > env_gain1 ? (env_gain1 = tgt_g1 + env_gain_atk_c * (env_gain1 - tgt_g1);) : (env_gain1 = tgt_g1 + env_gain_rel_c * (env_gain1 - tgt_g1););
  tgt_g2 > env_gain2 ? (env_gain2 = tgt_g2 + env_gain_atk_c * (env_gain2 - tgt_g2);) : (env_gain2 = tgt_g2 + env_gain_rel_c * (env_gain2 - tgt_g2););
  tgt_g3 > env_gain3 ? (env_gain3 = tgt_g3 + env_gain_atk_c * (env_gain3 - tgt_g3);) : (env_gain3 = tgt_g3 + env_gain_rel_c * (env_gain3 - tgt_g3););

  wetL_lp1 = texL + env_lp1_c * (wetL_lp1 - texL);
  wetL_lp2 = texL + env_lp2_c * (wetL_lp2 - texL);
  wetL_lp3 = texL + env_lp3_c * (wetL_lp3 - texL);
  wetR_lp1 = texR + env_lp1_c * (wetR_lp1 - texR);
  wetR_lp2 = texR + env_lp2_c * (wetR_lp2 - texR);
  wetR_lp3 = texR + env_lp3_c * (wetR_lp3 - texR);

  Lb0 = wetL_lp1;
  Lb1 = wetL_lp2 - wetL_lp1;
  Lb2 = wetL_lp3 - wetL_lp2;
  Lb3 = texL - wetL_lp3;
  Rb0 = wetR_lp1;
  Rb1 = wetR_lp2 - wetR_lp1;
  Rb2 = wetR_lp3 - wetR_lp2;
  Rb3 = texR - wetR_lp3;

  texL = Lb0 * env_gain0 + Lb1 * env_gain1 + Lb2 * env_gain2 + Lb3 * env_gain3;
  texR = Rb0 * env_gain0 + Rb1 * env_gain1 + Rb2 * env_gain2 + Rb3 * env_gain3;
);

out_abs = abs(texL);
abs(texR) > out_abs ? out_abs = abs(texR);

// salience budget: detector support + user Support budget keep texture from leaping ahead.
input_sal = raw_in_abs;
det_mix > input_sal ? input_sal = det_mix;
input_sal > 1 ? input_sal = 1;
input_sal < 0 ? input_sal = 0;

support_ceiling = input_sal + (support_budget * support_mix) * (1 - input_sal);
support_ceiling < 0 ? support_ceiling = 0;
support_ceiling > 1 ? support_ceiling = 1;

target_support_gain = out_abs > eps ? min(1, support_ceiling / out_abs) : 1;
target_support_gain < support_gain ? (
  support_gain = target_support_gain + 0.20 * (support_gain - target_support_gain);
) : (
  support_gain = target_support_gain + 0.96 * (support_gain - target_support_gain);
);

support_gain < 0 ? support_gain = 0;
support_gain > 1 ? support_gain = 1;

texL *= support_gain;
texR *= support_gain;
out_abs *= support_gain;

out_abs > meter_out ? meter_out = out_abs;

wet_only ? (
  spl0 = texL;
  spl1 = texR;
) : (
  spl0 += texL;
  spl1 += texR;
);

@gfx 1120 700

function clampg(v, lo, hi) (
  v < lo ? v = lo;
  v > hi ? v = hi;
  v;
);

function spx(v) (
  max(1, floor(v * ui_s + 0.5));
);

function hit(mx, my, x, y, w, h) (
  (mx >= x) && (mx < x + w) && (my >= y) && (my < y + h);
);

function point_hit(mx, my, px, py, r) local(dx, dy) (
  dx = mx - px;
  dy = my - py;
  dx * dx + dy * dy <= r * r;
);

function knob_hit(mx, my, cx, cy, r) local(dx,dy) (
  dx = mx - cx;
  dy = my - cy;
  dx*dx + dy*dy <= r*r;
);

function norm_log(v, lo, hi) local(r) (
  v = clampg(v, lo, hi);
  r = log(hi / lo);
  r <= 0 ? 0 : log(v / lo) / r;
);

function denorm_log(t, lo, hi) local(r) (
  t = clampg(t, 0, 1);
  r = log(hi / lo);
  r <= 0 ? lo : lo * exp(r * t);
);

function norm_lin(v, lo, hi) (
  (v - lo) / max(0.000001, hi - lo);
);

function denorm_lin(t, lo, hi) (
  lo + clampg(t, 0, 1) * (hi - lo);
);

function shape01g(t, k) local(p) (
  t = clampg(t, 0, 1);
  k > 0 ? (
    p = 1 + k * 4;
    t = pow(t, p);
  ) : k < 0 ? (
    p = 1 + (-k) * 4;
    t = 1 - pow(1 - t, p);
  );
  t;
);

function center_text(x, y, w, rr, gg, bb, s) local(tw, th) (
  gfx_measurestr(s, tw, th);
  gfx_r = rr; gfx_g = gg; gfx_b = bb; gfx_a = 1;
  gfx_x = x + (w - tw) * 0.5;
  gfx_y = y;
  gfx_drawstr(s);
);

function draw_button(x, y, w, h, onv, hov, rr, gg, bb, txt) (
  gfx_r = onv ? rr : rr * 0.38;
  gfx_g = onv ? gg : gg * 0.38;
  gfx_b = onv ? bb : bb * 0.38;
  hov ? (
    gfx_r += 0.08;
    gfx_g += 0.08;
    gfx_b += 0.08;
  );
  gfx_a = 1;
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.16; gfx_g = 0.18; gfx_b = 0.23; gfx_a = 1;
  gfx_roundrect(x, y, w, h, spx(6), 1);
  center_text(x, y + spx(5), w, 0.95, 0.97, 0.99, txt);
);

function draw_meter(x, y, w, h, val, rr, gg, bb, m1, m2) local(fillw, mx1, mx2) (
  gfx_r = 0.10; gfx_g = 0.12; gfx_b = 0.16; gfx_a = 1;
  gfx_rect(x, y, w, h, 1);

  fillw = w * clampg(val, 0, 1);
  gfx_r = rr; gfx_g = gg; gfx_b = bb; gfx_a = 1;
  gfx_rect(x, y, fillw, h, 1);

  gfx_r = 0.16; gfx_g = 0.18; gfx_b = 0.23; gfx_a = 1;
  gfx_roundrect(x, y, w, h, spx(4), 1);

  m1 >= 0 ? (
    mx1 = x + w * clampg(m1, 0, 1);
    gfx_r = 0.98; gfx_g = 0.92; gfx_b = 0.30; gfx_a = 1;
    gfx_line(mx1, y - spx(2), mx1, y + h + spx(2), 1);
  );
  m2 >= 0 ? (
    mx2 = x + w * clampg(m2, 0, 1);
    gfx_r = 0.86; gfx_g = 0.58; gfx_b = 0.22; gfx_a = 1;
    gfx_line(mx2, y - spx(2), mx2, y + h + spx(2), 1);
  );
);

function draw_curve_seg(x1, y1, x2, y2, k) local(i, steps, t, tt, px, py, lx, ly) (
  steps = 48;
  lx = x1;
  ly = y1;
  i = 1;
  loop(steps,
    t = i / steps;
    tt = shape01g(t, k);
    px = x1 + (x2 - x1) * t;
    py = y1 + (y2 - y1) * tt;
    gfx_line(lx, ly, px, py, 1);
    lx = px;
    ly = py;
    i += 1;
  );
);

function draw_knob_shell(cx, cy, rad, n, rr, gg, bb, hovered, active)
local(start_ang, end_ang, ang, i, px1, py1, px2, py2) (
  start_ang = PI * 0.75;
  end_ang   = PI * 2.25;
  n = clampg(n, 0, 1);
  ang = start_ang + (end_ang - start_ang) * n;

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.18;
  gfx_circle(cx + 2, cy + 3, rad, 1, 1);

  gfx_r = 0.11; gfx_g = 0.13; gfx_b = 0.17; gfx_a = 1;
  gfx_circle(cx, cy, rad + 5, 1, 1);

  i = 0;
  loop(4,
    gfx_r = 0.18; gfx_g = 0.20; gfx_b = 0.24; gfx_a = 1;
    gfx_arc(cx, cy, rad - i, start_ang, end_ang, 1);
    i += 1;
  );

  i = 0;
  loop(4,
    gfx_r = rr; gfx_g = gg; gfx_b = bb; gfx_a = active ? 1 : (hovered ? 0.96 : 0.86);
    gfx_arc(cx, cy, rad - i, start_ang, ang, 1);
    i += 1;
  );

  active ? (
    gfx_r = 0.22; gfx_g = 0.26; gfx_b = 0.33;
  ) : hovered ? (
    gfx_r = 0.18; gfx_g = 0.21; gfx_b = 0.27;
  ) : (
    gfx_r = 0.15; gfx_g = 0.18; gfx_b = 0.23;
  );
  gfx_a = 1;
  gfx_circle(cx, cy, rad - 9, 1, 1);

  gfx_r = 0.30; gfx_g = 0.33; gfx_b = 0.38; gfx_a = 1;
  gfx_circle(cx, cy, rad - 9, 0, 1);

  px1 = cx + cos(ang) * (rad - 24);
  py1 = cy + sin(ang) * (rad - 24);
  px2 = cx + cos(ang) * (rad - 12);
  py2 = cy + sin(ang) * (rad - 12);

  gfx_r = 0.98; gfx_g = 0.99; gfx_b = 1.00; gfx_a = 1;
  gfx_line(px1, py1, px2, py2, 1);
);

function draw_slope_pill(x, y, w, h, val, hovered, active, lbl) local(nx, mxp) (
  nx = clampg((val + 1) * 0.5, 0, 1);

  gfx_r = 0.10; gfx_g = 0.12; gfx_b = 0.16; gfx_a = 1;
  gfx_rect(x, y, w, h, 1);

  gfx_r = 0.22; gfx_g = 0.26; gfx_b = 0.34; gfx_a = hovered ? 0.95 : 0.82;
  gfx_rect(x + 1, y + 1, floor(nx * (w - 2)), h - 2, 1);

  gfx_r = 0.20; gfx_g = 0.22; gfx_b = 0.28; gfx_a = 1;
  gfx_roundrect(x, y, w, h, spx(6), 1);

  gfx_r = 0.72; gfx_g = 0.78; gfx_b = 0.88; gfx_a = 1;
  gfx_line(x + w * 0.5, y - spx(1), x + w * 0.5, y + h + spx(1), 1);

  mxp = x + nx * w;
  gfx_r = 0.98; gfx_g = 0.98; gfx_b = 0.99; gfx_a = 1;
  gfx_line(mxp, y - spx(2), mxp, y + h + spx(2), 1);

  active ? (
    gfx_r = 0.98; gfx_g = 0.99; gfx_b = 1.00;
  ) : (
    gfx_r = 0.76; gfx_g = 0.80; gfx_b = 0.88;
  );
  gfx_a = 1;
  center_text(x, y + h + spx(3), w, gfx_r, gfx_g, gfx_b, lbl);
);

function macro_norm(id) (
  id == 1 ? norm_log(slider9, 10, 3000) :
  id == 2 ? norm_lin(slider5, 0, 1) :
  id == 3 ? norm_lin(slider6, 0, 1) :
  id == 4 ? norm_lin(slider7, 0, 1) :
  id == 5 ? norm_lin(slider8, 0, 1) :
  id == 6 ? norm_lin(slider28, -24, 24) :
  id == 7 ? norm_log(slider3, 0.1, 8) :
  id == 8 ? norm_lin(slider25, 0, 1) :
  id == 9 ? norm_lin(slider1, 0, 1) :
  id == 10 ? norm_lin(slider31, 0, 1) :
  0;
);

function macro_set(id, t) (
  id == 1 ? (slider9 = denorm_log(t, 10, 3000); sliderchange(slider9););
  id == 2 ? (slider5 = denorm_lin(t, 0, 1); sliderchange(slider5););
  id == 3 ? (slider6 = denorm_lin(t, 0, 1); sliderchange(slider6););
  id == 4 ? (slider7 = denorm_lin(t, 0, 1); sliderchange(slider7););
  id == 5 ? (slider8 = denorm_lin(t, 0, 1); sliderchange(slider8););
  id == 6 ? (slider28 = denorm_lin(t, -24, 24); sliderchange(slider28););
  id == 7 ? (slider3 = denorm_log(t, 0.1, 8); sliderchange(slider3););
  id == 8 ? (slider25 = denorm_lin(t, 0, 1); sliderchange(slider25););
  id == 9 ? (slider1 = denorm_lin(t, 0, 1); sliderchange(slider1););
  id == 10 ? (slider31 = denorm_lin(t, 0, 1); sliderchange(slider31););
);

function macro_strings(id) (
  id == 1 ? (
    sprintf(#mlab, auto_slice ? "Slice Cap" : "Slice");
    sprintf(#mval, "%.0f ms", slider9);
  ) : id == 2 ? (
    sprintf(#mlab, "Flow");
    sprintf(#mval, "%.0f%%", slider5 * 100);
  ) : id == 3 ? (
    sprintf(#mlab, "Focus");
    sprintf(#mval, "%.0f%%", slider6 * 100);
  ) : id == 4 ? (
    sprintf(#mlab, "Grounding");
    sprintf(#mval, "%.0f%%", slider7 * 100);
  ) : id == 5 ? (
    sprintf(#mlab, "Jitter");
    sprintf(#mval, "%.0f%%", slider8 * 100);
  ) : id == 6 ? (
    sprintf(#mlab, "Pitch");
    sprintf(#mval, "%+.2f st", slider28);
  ) : id == 7 ? (
    sprintf(#mlab, "Sensitivity");
    sprintf(#mval, "%.2f x", slider3);
  ) : id == 8 ? (
    sprintf(#mlab, "Support");
    sprintf(#mval, "%.0f%%", slider25 * 100);
  ) : id == 9 ? (
    sprintf(#mlab, "Mix");
    sprintf(#mval, "%.0f%%", slider1 * 100);
  ) : id == 10 ? (
    sprintf(#mlab, "Env Mix");
    sprintf(#mval, "%.0f%%", slider31 * 100);
  );
);

function macro_color(id) (
  id <= 2 ? (
    mr = 0.26; mg = 0.70; mb = 0.92;
  ) : id <= 4 ? (
    mr = 0.34; mg = 0.84; mb = 0.54;
  ) : id == 5 ? (
    mr = 0.74; mg = 0.56; mb = 0.96;
  ) : id == 6 ? (
    mr = 0.94; mg = 0.48; mb = 0.88;
  ) : id <= 8 ? (
    mr = 0.96; mg = 0.72; mb = 0.24;
  ) : id == 9 ? (
    mr = 0.88; mg = 0.82; mb = 0.36;
  ) : (
    mr = 0.28; mg = 0.86; mb = 0.84;
  );
);

function knob_norm(id) (
  id == 1 ? norm_log(slider15, 0.1, 2000) :
  id == 2 ? norm_log(slider16, 0.1, 3000) :
  id == 3 ? norm_lin(slider17, 0, 1) :
  norm_log(slider18, 0.1, 5000);
);

function knob_set(id, t) (
  id == 1 ? (slider15 = denorm_log(t, 0.1, 2000); sliderchange(slider15););
  id == 2 ? (slider16 = denorm_log(t, 0.1, 3000); sliderchange(slider16););
  id == 3 ? (slider17 = denorm_lin(t, 0, 1); sliderchange(slider17););
  id == 4 ? (slider18 = denorm_log(t, 0.1, 5000); sliderchange(slider18););
);

function curve_norm(id) (
  id == 1 ? norm_lin(slider19, -1, 1) :
  id == 2 ? norm_lin(slider20, -1, 1) :
  norm_lin(slider21, -1, 1);
);

function curve_set(id, t) (
  id == 1 ? (slider19 = denorm_lin(t, -1, 1); sliderchange(slider19););
  id == 2 ? (slider20 = denorm_lin(t, -1, 1); sliderchange(slider20););
  id == 3 ? (slider21 = denorm_lin(t, -1, 1); sliderchange(slider21););
);

function cc_name(cc, outstr) (
  cc < 0 ? strcpy(outstr, "Off") : sprintf(outstr, "CC %d", cc);
);

function cc_friendly_name(cc, outstr) (
  cc < 0 ? strcpy(outstr, "Off") :
  cc == 0 ? strcpy(outstr, "Bank Sel") :
  cc == 1 ? strcpy(outstr, "Mod Wheel") :
  cc == 2 ? strcpy(outstr, "Breath") :
  cc == 4 ? strcpy(outstr, "Foot") :
  cc == 5 ? strcpy(outstr, "Porta") :
  cc == 7 ? strcpy(outstr, "Volume") :
  cc == 10 ? strcpy(outstr, "Pan") :
  cc == 11 ? strcpy(outstr, "Expression") :
  cc == 12 ? strcpy(outstr, "FX1") :
  cc == 13 ? strcpy(outstr, "FX2") :
  cc == 16 ? strcpy(outstr, "Gen 1") :
  cc == 17 ? strcpy(outstr, "Gen 2") :
  cc == 18 ? strcpy(outstr, "Gen 3") :
  cc == 19 ? strcpy(outstr, "Gen 4") :
  cc == 20 ? strcpy(outstr, "Gen 5") :
  cc == 21 ? strcpy(outstr, "Gen 6") :
  cc == 22 ? strcpy(outstr, "Gen 7") :
  cc == 23 ? strcpy(outstr, "Gen 8") :
  cc == 64 ? strcpy(outstr, "Sustain") :
  cc == 71 ? strcpy(outstr, "Reson") :
  cc == 74 ? strcpy(outstr, "Bright") :
  cc == 91 ? strcpy(outstr, "Reverb") :
  cc == 93 ? strcpy(outstr, "Chorus") :
  sprintf(outstr, "CC %d", cc);
);

function cc_common_num(idx) (
  idx == 0 ? -1 :
  idx == 1 ? 1 :
  idx == 2 ? 7 :
  idx == 3 ? 11 :
  idx == 4 ? 74 :
  idx == 5 ? 71 :
  idx == 6 ? 64 :
  idx == 7 ? 91 :
  idx == 8 ? 93 :
  idx == 9 ? 2 :
  idx == 10 ? 4 :
  idx == 11 ? 5 :
  idx == 12 ? 10 :
  idx == 13 ? 12 :
  idx == 14 ? 13 :
  idx == 15 ? 16 :
  idx == 16 ? 17 :
  idx == 17 ? 18 :
  idx == 18 ? 19 :
  idx == 19 ? 20 :
  idx == 20 ? 21 :
  idx == 21 ? 22 :
  idx == 22 ? 23 : -2;
);

function cc_amt_text(param, outstr) local(a) (
  a = mem[cc_amt_base + param];
  a < 0 ? a = 0;
  a > 1 ? a = 1;
  sprintf(outstr, "±%.0f%%", a * 100);
);

function begin_cc_range_assign(param) local(sel, a) (
  strcpy(#menu_ctx, "");
  strcat(#menu_ctx, "Off (Direct around center)|");
  strcat(#menu_ctx, "±5%|±10%|±15%|±20%|±25%|±35%|±50%|±75%|±100%");
  gfx_x = mx; gfx_y = my;
  sel = gfx_showmenu(#menu_ctx);
  sel == 1 ? a = 0 :
  sel == 2 ? a = 0.05 :
  sel == 3 ? a = 0.10 :
  sel == 4 ? a = 0.15 :
  sel == 5 ? a = 0.20 :
  sel == 6 ? a = 0.25 :
  sel == 7 ? a = 0.35 :
  sel == 8 ? a = 0.50 :
  sel == 9 ? a = 0.75 :
  sel == 10 ? a = 1.00;
  (sel >= 1) && (sel <= 10) ? (
    mem[cc_amt_base + param] = a;
    ui_button_click = 1;
  );
);

function begin_cc_assign(param) local(cur) (
  cur = mem[cc_map_base + param];
  cc_browser_param = param;
  cc_browser_selected = -2;
  cc_browser_hover = -1;
  cc_browser_active = 1;
  cc_browser_page = 0;
  cur >= 0 ? (
    cur < 32 ? cc_browser_page = 1 : cur < 64 ? cc_browser_page = 2 : cur < 96 ? cc_browser_page = 3 : cc_browser_page = 4;
  );
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);

function show_cc_pick(current) (
  current;
);

function param_name(param, outstr) (
  param == 1 ? strcpy(outstr, "Mix") :
  param == 2 ? strcpy(outstr, "Gain") :
  param == 3 ? strcpy(outstr, "Sensitivity") :
  param == 4 ? strcpy(outstr, "Threshold") :
  param == 5 ? strcpy(outstr, "Flow") :
  param == 6 ? strcpy(outstr, "Focus") :
  param == 7 ? strcpy(outstr, "Grounding") :
  param == 8 ? strcpy(outstr, "Jitter") :
  param == 9 ? strcpy(outstr, "Slice") :
  param == 10 ? strcpy(outstr, "Playback Mode") :
  param == 11 ? strcpy(outstr, "Output") :
  param == 12 ? strcpy(outstr, "Auto Reload") :
  param == 13 ? strcpy(outstr, "Reload") :
  param == 14 ? strcpy(outstr, "Max Load") :
  param == 15 ? strcpy(outstr, "Attack") :
  param == 16 ? strcpy(outstr, "Decay") :
  param == 17 ? strcpy(outstr, "Sustain") :
  param == 18 ? strcpy(outstr, "Release") :
  param == 19 ? strcpy(outstr, "Attack Curve") :
  param == 20 ? strcpy(outstr, "Decay Curve") :
  param == 21 ? strcpy(outstr, "Release Curve") :
  param == 22 ? strcpy(outstr, "Follow Attack") :
  param == 23 ? strcpy(outstr, "Follow Release") :
  param == 24 ? strcpy(outstr, "Hysteresis") :
  param == 25 ? strcpy(outstr, "Support") :
  param == 26 ? strcpy(outstr, "Gate Release") :
  param == 27 ? strcpy(outstr, "Auto Slice") :
  param == 28 ? strcpy(outstr, "Global Pitch") :
  param == 29 ? strcpy(outstr, "Profile") :
  param == 30 ? strcpy(outstr, "Debug") :
  param == 31 ? strcpy(outstr, "Env Mix") :
  param == 32 ? strcpy(outstr, "Env Speed") :
  param == 33 ? strcpy(outstr, "Slice Rand") :
  param == 34 ? strcpy(outstr, "Support Rand") :
  param == 35 ? strcpy(outstr, "Source") :
  param == 36 ? strcpy(outstr, "MIDI Voice") : strcpy(outstr, "Param");
);

function param_default_text(param, outstr) (
  param == 1 ? sprintf(outstr, "75%%") :
  param == 2 ? sprintf(outstr, "0.0 dB") :
  param == 3 ? sprintf(outstr, "1.25x") :
  param == 4 ? sprintf(outstr, "0.08") :
  param == 5 ? sprintf(outstr, "58%%") :
  param == 6 ? sprintf(outstr, "72%%") :
  param == 7 ? sprintf(outstr, "65%%") :
  param == 8 ? sprintf(outstr, "22%%") :
  param == 9 ? sprintf(outstr, "220 ms") :
  param == 10 ? sprintf(outstr, "One-Shot") :
  param == 11 ? sprintf(outstr, "Dry+Wet") :
  param == 12 ? sprintf(outstr, "On") :
  param == 13 ? sprintf(outstr, "Off") :
  param == 14 ? sprintf(outstr, "30 s") :
  param == 15 ? sprintf(outstr, "10 ms") :
  param == 16 ? sprintf(outstr, "90 ms") :
  param == 17 ? sprintf(outstr, "0.450") :
  param == 18 ? sprintf(outstr, "180 ms") :
  param == 19 ? sprintf(outstr, "0.00") :
  param == 20 ? sprintf(outstr, "0.00") :
  param == 21 ? sprintf(outstr, "0.00") :
  param == 22 ? sprintf(outstr, "4 ms") :
  param == 23 ? sprintf(outstr, "120 ms") :
  param == 24 ? sprintf(outstr, "70%%") :
  param == 25 ? sprintf(outstr, "100%%") :
  param == 26 ? sprintf(outstr, "Free") :
  param == 27 ? sprintf(outstr, "Fixed") :
  param == 28 ? sprintf(outstr, "+0.00 st") :
  param == 29 ? sprintf(outstr, "Neutral") :
  param == 30 ? sprintf(outstr, "Off") :
  param == 31 ? sprintf(outstr, "0%%") :
  param == 32 ? sprintf(outstr, "180 ms") :
  param == 33 ? sprintf(outstr, "0%%") :
  param == 34 ? sprintf(outstr, "0%%") :
  param == 35 ? sprintf(outstr, "Auto") :
  param == 36 ? sprintf(outstr, "Mono") : sprintf(outstr, "-");
);

function param_apply_default(param) (
  param == 1 ? (slider1 = 0.75; sliderchange(slider1);) :
  param == 2 ? (slider2 = 0; sliderchange(slider2);) :
  param == 3 ? (slider3 = 1.25; sliderchange(slider3);) :
  param == 4 ? (slider4 = 0.08; sliderchange(slider4);) :
  param == 5 ? (slider5 = 0.58; sliderchange(slider5);) :
  param == 6 ? (slider6 = 0.72; sliderchange(slider6);) :
  param == 7 ? (slider7 = 0.65; sliderchange(slider7);) :
  param == 8 ? (slider8 = 0.22; sliderchange(slider8);) :
  param == 9 ? (slider9 = 220; sliderchange(slider9);) :
  param == 10 ? (slider10 = 0; sliderchange(slider10);) :
  param == 11 ? (slider11 = 0; sliderchange(slider11);) :
  param == 12 ? (slider12 = 1; sliderchange(slider12);) :
  param == 13 ? (slider13 = 0; sliderchange(slider13);) :
  param == 14 ? (slider14 = 30; sliderchange(slider14);) :
  param == 15 ? (slider15 = 10; sliderchange(slider15);) :
  param == 16 ? (slider16 = 90; sliderchange(slider16);) :
  param == 17 ? (slider17 = 0.45; sliderchange(slider17);) :
  param == 18 ? (slider18 = 180; sliderchange(slider18);) :
  param == 19 ? (slider19 = 0; sliderchange(slider19);) :
  param == 20 ? (slider20 = 0; sliderchange(slider20);) :
  param == 21 ? (slider21 = 0; sliderchange(slider21);) :
  param == 22 ? (slider22 = 4; sliderchange(slider22);) :
  param == 23 ? (slider23 = 120; sliderchange(slider23);) :
  param == 24 ? (slider24 = 0.70; sliderchange(slider24);) :
  param == 25 ? (slider25 = 1; sliderchange(slider25);) :
  param == 26 ? (slider26 = 0; sliderchange(slider26);) :
  param == 27 ? (slider27 = 0; sliderchange(slider27);) :
  param == 28 ? (slider28 = 0; sliderchange(slider28);) :
  param == 29 ? (slider29 = 0; sliderchange(slider29);) :
  param == 30 ? (slider30 = 0; sliderchange(slider30);) :
  param == 31 ? (slider31 = 0; sliderchange(slider31);) :
  param == 32 ? (slider32 = 180; sliderchange(slider32);) :
  param == 33 ? (slider33 = 0; sliderchange(slider33);) :
  param == 34 ? (slider34 = 0; sliderchange(slider34);) :
  param == 35 ? (slider35 = 0; sliderchange(slider35);) :
  param == 36 ? (slider36 = 0; sliderchange(slider36););
);

function open_param_menu1(p1) local(sel, ccv) (
  param_name(p1, #p1n);
  param_default_text(p1, #p1d);
  cc_name(mem[cc_map_base + p1], #p1c);
  cc_amt_text(p1, #p1a);
  strcpy(#menu_ctx, "");
  sprintf(#menu_item, "%s: Set CC (%s)", #p1n, #p1c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p1n, #p1a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p1n, #p1d); strcat(#menu_ctx, #menu_item);
  gfx_x = mx; gfx_y = my;
  sel = gfx_showmenu(#menu_ctx);
  sel == 1 ? (
    begin_cc_assign(p1);
  ) : sel == 2 ? (
    begin_cc_range_assign(p1);
  ) : sel == 3 ? (
    param_apply_default(p1);
    ui_add_undo = 1;
    ui_button_click = 1;
  );
);

function open_param_menu2(p1,p2) local(sel, ccv) (
  param_name(p1, #p1n); param_default_text(p1, #p1d); cc_name(mem[cc_map_base + p1], #p1c); cc_amt_text(p1, #p1a);
  param_name(p2, #p2n); param_default_text(p2, #p2d); cc_name(mem[cc_map_base + p2], #p2c); cc_amt_text(p2, #p2a);
  strcpy(#menu_ctx, "");
  sprintf(#menu_item, "%s: Set CC (%s)", #p1n, #p1c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p1n, #p1a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p1n, #p1d); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC (%s)", #p2n, #p2c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p2n, #p2a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p2n, #p2d); strcat(#menu_ctx, #menu_item);
  gfx_x = mx; gfx_y = my;
  sel = gfx_showmenu(#menu_ctx);
  sel == 1 ? (begin_cc_assign(p1);) :
  sel == 2 ? (begin_cc_range_assign(p1);) :
  sel == 3 ? (param_apply_default(p1); ui_add_undo = 1; ui_button_click = 1;) :
  sel == 4 ? (begin_cc_assign(p2);) :
  sel == 5 ? (begin_cc_range_assign(p2);) :
  sel == 6 ? (param_apply_default(p2); ui_add_undo = 1; ui_button_click = 1;);
);

function open_param_menu4(p1,p2,p3,p4) local(sel, ccv) (
  param_name(p1, #p1n); param_default_text(p1, #p1d); cc_name(mem[cc_map_base + p1], #p1c); cc_amt_text(p1, #p1a);
  param_name(p2, #p2n); param_default_text(p2, #p2d); cc_name(mem[cc_map_base + p2], #p2c); cc_amt_text(p2, #p2a);
  param_name(p3, #p3n); param_default_text(p3, #p3d); cc_name(mem[cc_map_base + p3], #p3c); cc_amt_text(p3, #p3a);
  param_name(p4, #p4n); param_default_text(p4, #p4d); cc_name(mem[cc_map_base + p4], #p4c); cc_amt_text(p4, #p4a);
  strcpy(#menu_ctx, "");
  sprintf(#menu_item, "%s: Set CC (%s)", #p1n, #p1c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p1n, #p1a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p1n, #p1d); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC (%s)", #p2n, #p2c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p2n, #p2a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p2n, #p2d); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC (%s)", #p3n, #p3c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p3n, #p3a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p3n, #p3d); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC (%s)", #p4n, #p4c); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set CC Range (%s)", #p4n, #p4a); strcat(#menu_ctx, #menu_item); strcat(#menu_ctx, "|");
  sprintf(#menu_item, "%s: Set to Default (%s)", #p4n, #p4d); strcat(#menu_ctx, #menu_item);
  gfx_x = mx; gfx_y = my;
  sel = gfx_showmenu(#menu_ctx);
  sel == 1 ? (begin_cc_assign(p1);) :
  sel == 2 ? (begin_cc_range_assign(p1);) :
  sel == 3 ? (param_apply_default(p1); ui_add_undo = 1; ui_button_click = 1;) :
  sel == 4 ? (begin_cc_assign(p2);) :
  sel == 5 ? (begin_cc_range_assign(p2);) :
  sel == 6 ? (param_apply_default(p2); ui_add_undo = 1; ui_button_click = 1;) :
  sel == 7 ? (begin_cc_assign(p3);) :
  sel == 8 ? (begin_cc_range_assign(p3);) :
  sel == 9 ? (param_apply_default(p3); ui_add_undo = 1; ui_button_click = 1;) :
  sel == 10 ? (begin_cc_assign(p4);) :
  sel == 11 ? (begin_cc_range_assign(p4);) :
  sel == 12 ? (param_apply_default(p4); ui_add_undo = 1; ui_button_click = 1;);
);

gfx_getchar();

mx = mouse_x;
my = mouse_y;
lmb = mouse_cap & 1;
rmb = mouse_cap & 2;
mmb = mouse_cap & 64;
wheel = mouse_wheel;
mouse_wheel = 0;

base_w = 1120;
base_h = 700;
ui_s = min(gfx_w / base_w, gfx_h / base_h);
ui_s > 1 ? ui_s = 1;
ui_s < 0.55 ? ui_s = 0.55;

ft_title = max(11, spx(16));
ft_panel = max(10, spx(14));
ft_body  = max(10, spx(12));
ft_small = max(9,  spx(11));
ft_meta  = max(8,  spx(10));
ft_knob  = max(9,  spx(13));
ft_tiny  = max(7,  spx(9));

click = lmb && !ui_lmb_last;
rclick = rmb && !ui_rmb_last;
release = !lmb && ui_lmb_last;

ui_lmb_last = lmb > 0;
ui_rmb_last = rmb > 0;
ui_mmb_last = mmb > 0;

modal_click = cc_browser_active > 0 ? click : 0;
modal_rclick = cc_browser_active > 0 ? rclick : 0;
modal_release = cc_browser_active > 0 ? release : 0;
modal_wheel = cc_browser_active > 0 ? wheel : 0;
modal_lmb = cc_browser_active > 0 ? lmb : 0;
cc_browser_active > 0 ? (
  click = 0; rclick = 0; release = 0; wheel = 0;
  lmb = 0; rmb = 0; mmb = 0;
  ui_active_kind = 0;
  ui_active_id = 0;
);

fine_mult = (mouse_cap & 8) ? 0.35 : 1.0;
coarse_mult = (mouse_cap & 4) ? 2.40 : 1.0;
wheel_step = (wheel / 120.0) * 0.035 * fine_mult * coarse_mult;
drag_div = (mouse_cap & 8) ? 520 : ((mouse_cap & 4) ? 120 : 240);
time_drag_scale = (mouse_cap & 8) ? 0.004 : ((mouse_cap & 4) ? 0.018 : 0.0095);

ui_add_undo = 0;
ui_button_click = 0;

pad = spx(16);
top_h = spx(32);

wf_x = pad;
wf_y = pad + top_h + spx(12);
wf_w = gfx_w - pad * 2;
wf_h = floor(gfx_h * 0.35);
wf_h < spx(142) ? wf_h = spx(142);

footer_y = wf_y + wf_h + spx(6);
lower_y = wf_y + wf_h + spx(14);

env_x = pad;
env_y = lower_y;
env_w = floor((gfx_w - pad * 3) * 0.56);
env_h = gfx_h - env_y - pad;
env_h < spx(232) ? env_h = spx(232);

side_x = env_x + env_w + pad;
side_y = env_y;
side_w = gfx_w - side_x - pad;
side_h = env_h;

btn_h = spx(24);
btn_gap = spx(8);
mode_w = spx(152);
prof_w = spx(102);
src_w = spx(88);
midi_w = spx(86);
slice_w = spx(90);
gate_w = spx(116);
out_w = spx(102);
util_w = spx(84);
reload_w = spx(76);

reload_x = gfx_w - pad - reload_w;
auto_x   = reload_x - util_w - btn_gap;
out_x    = auto_x - out_w - btn_gap;
gate_x   = out_x - gate_w - btn_gap;
slice_x  = gate_x - slice_w - btn_gap;
midi_x   = slice_x - midi_w - btn_gap;
prof_x   = midi_x - prof_w - btn_gap;
src_x    = prof_x - src_w - btn_gap;
mode_x   = src_x - mode_w - btn_gap;
top_y    = spx(10);

gfx_r = 0.055; gfx_g = 0.060; gfx_b = 0.078; gfx_a = 1;
gfx_rect(0, 0, gfx_w, gfx_h, 1);

// header
gfx_setfont(1, "Verdana", ft_title);
gfx_r = 0.98; gfx_g = 0.91; gfx_b = 0.55; gfx_a = 1;
gfx_x = pad; gfx_y = spx(10);
gfx_printf("PTE");

gfx_setfont(1, "Verdana", ft_body);
gfx_r = 0.80; gfx_g = 0.84; gfx_b = 0.90; gfx_a = 1;
gfx_x = pad + spx(52); gfx_y = spx(12);
file_state == 0 ? (
  gfx_printf("No texture assigned");
) : (file_state == 1) ? (
  gfx_printf("Waiting for file...");
) : (file_state == 3) ? (
  gfx_printf("Load failed or copy exceeded memory cap");
) : (
  loaded_sec = tex_sr > 0 ? tex_frames / tex_sr : 0;
  source_sec = src_sr > 0 ? src_frames / src_sr : 0;

  tex_truncated > 0 ? (
    gfx_printf("Loaded %.2fs of %.2fs  •  %g ch  •  %.1fkHz  •  %d/%d live  •  S%d M%d  •  A%d B%d R%d D%d", loaded_sec, source_sec, tex_ch, tex_sr / 1000, cand_live_count, cand_count, cand_short_live_count, cand_med_live_count, attack_pool_count, body_pool_count, release_pool_count, debris_pool_count);
  ) : (
    gfx_printf("Loaded %.2fs  •  %g ch  •  %.1fkHz  •  %d/%d live  •  S%d M%d  •  A%d B%d R%d D%d", loaded_sec, tex_ch, tex_sr / 1000, cand_live_count, cand_count, cand_short_live_count, cand_med_live_count, attack_pool_count, body_pool_count, release_pool_count, debris_pool_count);
  );
);

// top buttons
mode_label =
  slider10 < 0.5 ? "MODE: ONE-SHOT" :
  slider10 < 1.5 ? "MODE: RANDOM" :
  slider10 < 2.5 ? "MODE: GRANULAR" :
  "MODE: GRAN SYNTH";
mode_r = slider10 < 0.5 ? 0.20 : slider10 < 1.5 ? 0.72 : slider10 < 2.5 ? 0.52 : 0.82;
mode_g = slider10 < 0.5 ? 0.66 : slider10 < 1.5 ? 0.50 : slider10 < 2.5 ? 0.34 : 0.34;
mode_b = slider10 < 0.5 ? 0.92 : slider10 < 1.5 ? 0.22 : slider10 < 2.5 ? 0.84 : 0.96;
hov = hit(mx, my, mode_x, top_y, mode_w, btn_h);
click && hov ? (
  next_mode = floor(slider10 + 0.5) + 1;
  next_mode > 3 ? next_mode = 0;
  slider10 = next_mode;
  sliderchange(slider10);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(10);
);
draw_button(mode_x, top_y, mode_w, btn_h, 1, hov, mode_r, mode_g, mode_b, mode_label);

profile == 0 ? sprintf(#profbtn, "PROF: NEUTRAL") :
profile == 1 ? sprintf(#profbtn, "PROF: CLOTH") :
profile == 2 ? sprintf(#profbtn, "PROF: WET") :
profile == 3 ? sprintf(#profbtn, "PROF: BED") :
sprintf(#profbtn, "PROF: FRICTION");
hov = hit(mx, my, prof_x, top_y, prof_w, btn_h);
click && hov ? (
  next_profile = floor(slider29 + 0.5) + 1;
  next_profile > 4 ? next_profile = 0;
  slider29 = next_profile;
  sliderchange(slider29);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu2(29, 30);
);
draw_button(prof_x, top_y, prof_w, btn_h, 1, hov, 0.46, 0.60, 0.94, #profbtn);

source_mode == 0 ? sprintf(#srcbtn, "SRC: AUTO") : source_mode == 1 ? sprintf(#srcbtn, "SRC: INPUT") : source_mode == 2 ? sprintf(#srcbtn, "SRC: SC 3/4") : sprintf(#srcbtn, "SRC: MIDI");
hov = hit(mx, my, src_x, top_y, src_w, btn_h);
click && hov ? (
  next_src = floor(slider35 + 0.5) + 1;
  next_src > 3 ? next_src = 0;
  slider35 = next_src;
  sliderchange(slider35);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(35);
);
draw_button(src_x, top_y, src_w, btn_h, 1, hov, 0.62, 0.54, 0.94, #srcbtn);

slider36 > 0.5 ? sprintf(#midibtn, "MIDI: POLY") : sprintf(#midibtn, "MIDI: MONO");
hov = hit(mx, my, midi_x, top_y, midi_w, btn_h);
click && hov ? (
  slider36 = slider36 > 0.5 ? 0 : 1;
  sliderchange(slider36);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(36);
);
draw_button(midi_x, top_y, midi_w, btn_h, slider36 > 0.5, hov, 0.72, 0.46, 0.90, #midibtn);

hov = hit(mx, my, slice_x, top_y, slice_w, btn_h);
click && hov ? (
  slider27 = slider27 > 0.5 ? 0 : 1;
  sliderchange(slider27);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(27);
);
slider27 > 0.5 ? sprintf(#btn, "AUTO SLICE") : sprintf(#btn, "FIXED SLICE");
draw_button(slice_x, top_y, slice_w, btn_h, slider27 > 0.5, hov, 0.30, 0.60, 0.88, #btn);

hov = hit(mx, my, gate_x, top_y, gate_w, btn_h);
click && hov ? (
  next_gate = floor(slider26 + 0.5) + 1;
  next_gate > 2 ? next_gate = 0;
  slider26 = next_gate;
  sliderchange(slider26);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(26);
);
gate_label =
  slider26 < 0.5 ? "REL: FREE" :
  slider26 < 1.5 ? "REL: TIGHT" :
  "REL: CLAMP";
draw_button(gate_x, top_y, gate_w, btn_h, slider26 > 0.5, hov, 0.78, 0.46, 0.22, gate_label);

hov = hit(mx, my, out_x, top_y, out_w, btn_h);
click && hov ? (
  slider11 = slider11 > 0.5 ? 0 : 1;
  sliderchange(slider11);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(11);
);
slider11 > 0.5 ? sprintf(#btn, "WET ONLY") : sprintf(#btn, "DRY+WET");
draw_button(out_x, top_y, out_w, btn_h, slider11 > 0.5, hov, 0.20, 0.48, 0.70, #btn);

hov = hit(mx, my, auto_x, top_y, util_w, btn_h);
click && hov ? (
  slider12 = slider12 > 0.5 ? 0 : 1;
  sliderchange(slider12);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu1(12);
);
slider12 > 0.5 ? sprintf(#btn, "AUTO ON") : sprintf(#btn, "AUTO OFF");
draw_button(auto_x, top_y, util_w, btn_h, slider12 > 0.5, hov, 0.18, 0.62, 0.34, #btn);

hov = hit(mx, my, reload_x, top_y, reload_w, btn_h);
click && hov ? (
  ui_force_reload = 1;
  slider13 = 1;
  sliderchange(slider13);
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_button_click = 1;
);
rclick && hov ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu2(13, 14);
);
sprintf(#btn, "RELOAD");
draw_button(reload_x, top_y, reload_w, btn_h, 1, hov, 0.54, 0.32, 0.18, #btn);


profile == 0 ? sprintf(#profname, "Neutral") :
profile == 1 ? sprintf(#profname, "Cloth") :
profile == 2 ? sprintf(#profname, "Wet") :
profile == 3 ? sprintf(#profname, "Bed") :
sprintf(#profname, "Friction");
slider10 < 0.5 ? sprintf(#modebuf, "One-Shot") :
slider10 < 1.5 ? sprintf(#modebuf, "Random") :
slider10 < 2.5 ? sprintf(#modebuf, "Granular") :
sprintf(#modebuf, "Gran Synth");
desired_phase == phase_att ? sprintf(#wantph, "ATT") : desired_phase == phase_body ? sprintf(#wantph, "BODY") : desired_phase == phase_rel ? sprintf(#wantph, "REL") : sprintf(#wantph, "DEB");
last_phase == phase_att ? sprintf(#lastph, "ATT") : last_phase == phase_body ? sprintf(#lastph, "BODY") : last_phase == phase_rel ? sprintf(#lastph, "REL") : last_phase == phase_deb ? sprintf(#lastph, "DEB") : sprintf(#lastph, "-");

// waveform panel
// waveform panel
gfx_r = 0.085; gfx_g = 0.095; gfx_b = 0.122; gfx_a = 1;
gfx_rect(wf_x, wf_y, wf_w, wf_h, 1);
gfx_r = 0.16; gfx_g = 0.18; gfx_b = 0.24; gfx_a = 1;
gfx_roundrect(wf_x, wf_y, wf_w, wf_h, spx(8), 1);

mid_y = wf_y + wf_h * 0.5;
gfx_r = 0.13; gfx_g = 0.17; gfx_b = 0.22; gfx_a = 1;
gfx_line(wf_x, mid_y, wf_x + wf_w, mid_y, 1);

(tex_loaded > 0) && (wf_ready > 0) && (wf_bins > 0) ? (
  xstep = wf_w / max(1, wf_bins);

  draw_ref = wf_draw_ref;
  draw_ref < 0.000001 ? draw_ref = wf_absmax;
  draw_ref < 0.000001 ? draw_ref = 1;
  scale = (wf_h * 0.44) / draw_ref;
  wf_right = wf_x + wf_w - 1;

  i = 0;
  loop(wf_bins,
    mn = mem[wf_base + i * 2];
    mxv = mem[wf_base + i * 2 + 1];

    x = wf_x + i * xstep;
    x2c = x + max(1, floor(xstep + 0.5));
    x2c > wf_x + wf_w ? x2c = wf_x + wf_w;
    bar_w = x2c - x;
    bar_w < 1 ? bar_w = 1;

    y1 = mid_y - mxv * scale;
    y2 = mid_y - mn * scale;
    y1 < wf_y ? y1 = wf_y;
    y1 > wf_y + wf_h ? y1 = wf_y + wf_h;
    y2 < wf_y ? y2 = wf_y;
    y2 > wf_y + wf_h ? y2 = wf_y + wf_h;

    hv = mem[heat_base + i];
    gfx_r = 0.82 * hv;
    gfx_g = 0.44 * hv;
    gfx_b = 0.16 * hv;
    gfx_a = 0.10 + 0.14 * hv;
    x < wf_x + wf_w ? gfx_rect(x, wf_y + wf_h - spx(18), bar_w, spx(18), 1);

    xline = x;
    xline > wf_right ? xline = wf_right;
    gfx_r = 0.66; gfx_g = 0.84; gfx_b = 0.94; gfx_a = 0.90;
    gfx_line(xline, y1, xline, y2, 1);

    i += 1;
  );
) : (
  gfx_setfont(1, "Verdana", ft_small);
  file_state == 0 ? sprintf(#wavebuf, "Assign a file to the Texture slot.") :
  file_state == 1 ? sprintf(#wavebuf, "Texture file is present but not ready yet.") :
  file_state == 3 ? sprintf(#wavebuf, "Texture copy failed. Reduce Max Load or file length.") :
  sprintf(#wavebuf, "Waveform summary not ready.");

  gfx_r = 0.76; gfx_g = 0.79; gfx_b = 0.86; gfx_a = 1;
  gfx_x = wf_x + spx(18); gfx_y = wf_y + spx(18);
  gfx_drawstr(#wavebuf);
);

(tex_loaded > 0) ? (
  wf_right = wf_x + wf_w - 1;

  last_spawn_len > 0 ? (
    lx1 = wf_x + (last_spawn_start / max(1, tex_frames)) * wf_w;
    lx2 = wf_x + ((last_spawn_start + last_spawn_len) / max(1, tex_frames)) * wf_w;
    lx1 = clampg(lx1, wf_x, wf_right);
    lx2 = clampg(lx2, wf_x, wf_x + wf_w);
    lx2 < lx1 + 2 ? lx2 = min(wf_x + wf_w, lx1 + 2);

    last_spawn_mode == 0 ? (
      gfx_r = 0.18; gfx_g = 0.62; gfx_b = 0.94;
    ) : last_spawn_mode == 1 ? (
      gfx_r = 0.88; gfx_g = 0.62; gfx_b = 0.18;
    ) : last_spawn_mode == 2 ? (
      gfx_r = 0.70; gfx_g = 0.42; gfx_b = 0.94;
    ) : (
      gfx_r = 0.92; gfx_g = 0.36; gfx_b = 0.96;
    );
    gfx_a = 0.08 + 0.12 * last_spawn_flash;
    gfx_rect(lx1, wf_y, max(1, lx2 - lx1), wf_h, 1);
  );

  vi = 0;
  loop(max_voices,
    vb = voice_base + vi * v_stride;
    mem[vb] > 0 ? (
      vstart = mem[vb + 1];
      vlen   = mem[vb + 3];
      vpos   = mem[vb + 2];
      vmode  = mem[vb + 8];

      x1 = wf_x + (vstart / max(1, tex_frames)) * wf_w;
      x2 = wf_x + ((vstart + vlen) / max(1, tex_frames)) * wf_w;
      px = wf_x + ((vstart + vpos) / max(1, tex_frames)) * wf_w;

      x1 = clampg(x1, wf_x, wf_right);
      x2 = clampg(x2, wf_x, wf_x + wf_w);
      px = clampg(px, wf_x, wf_right);
      x2 < x1 + 2 ? x2 = min(wf_x + wf_w, x1 + 2);

      vmode == 0 ? (
        gfx_r = 0.18; gfx_g = 0.70; gfx_b = 0.96;
      ) : vmode == 1 ? (
        gfx_r = 0.92; gfx_g = 0.66; gfx_b = 0.20;
      ) : vmode == 2 ? (
        gfx_r = 0.76; gfx_g = 0.52; gfx_b = 0.98;
      ) : (
        gfx_r = 0.94; gfx_g = 0.38; gfx_b = 0.98;
      );
      gfx_a = 0.06;
      gfx_rect(x1, wf_y, max(1, x2 - x1), wf_h, 1);

      gfx_a = 0.85;
      gfx_line(px, wf_y, px, wf_y + wf_h, 1);
    );
    vi += 1;
  );
);


debug_overlay ? (
  dbg_x = wf_x + spx(10);
  dbg_y = wf_y + spx(10);
  dbg_w = spx(260);
  dbg_h = spx(154);

  gfx_r = 0.06; gfx_g = 0.08; gfx_b = 0.11; gfx_a = 0.86;
  gfx_rect(dbg_x, dbg_y, dbg_w, dbg_h, 1);
  gfx_r = 0.24; gfx_g = 0.28; gfx_b = 0.36; gfx_a = 1;
  gfx_roundrect(dbg_x, dbg_y, dbg_w, dbg_h, spx(6), 1);

  gfx_setfont(1, "Verdana", ft_meta);
  gfx_r = 0.94; gfx_g = 0.96; gfx_b = 0.98; gfx_a = 1;
  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(6);
  gfx_printf("DBG %s  •  S%d M%d  •  fam %d→%d", #profname, cand_short_live_count, cand_med_live_count, last_family, desired_family);

  gfx_r = 0.76; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(24);
  gfx_printf("phase %s→%s  •  support %.0f%%  rise %.0f%%  fall %.0f%%", #lastph, #wantph, support_sig * 100, support_rise * 100, support_fall * 100);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(40);
  gfx_printf("pools A%d B%d R%d D%d  •  wake %.2f", attack_pool_count, body_pool_count, release_pool_count, debris_pool_count, wake_force);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(56);
  gfx_printf("W base %.2f  ph %.2f  fam %.2f  sc %.2f  pca %.2f", dbg_w_base, dbg_w_phase, dbg_w_family, dbg_w_scale, dbg_w_pca);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(72);
  gfx_printf("comp %.2f  sel %.2f  nov %.2f  PCApk %.2f", dbg_w_compat, dbg_w_total, dbg_sel_novel, pca_novelty_peak);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(88);
  gfx_printf("recent fam %.1f  nHF %.2f  nMot %.2f", recent_family_mean, recent_hf_mean, recent_motion_mean);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(104);
  gfx_printf("state %d  tok %d  hsmm %.2f  graph %.2f", dbg_sel_state, dbg_sel_token, dbg_w_hsmm, dbg_w_graph);

  gfx_x = dbg_x + spx(8); gfx_y = dbg_y + spx(120);
  gfx_printf("tex %.2f  tokW %.2f  corp %.2f/%.2f/%.2f", dbg_w_texstat, dbg_w_token, corpus_nrms_mean, corpus_hf_mean, corpus_motion_mean);

  // phase-colored candidate ticks near the top edge of the waveform.
  i = 0;
  loop(cand_count,
    base = cand_base + i * cand_stride;
    rankn = mem[base + 7];
    rankn > 0 ? (
      cstart = mem[base];
      cphase = floor(mem[base + 13] + 0.5);
      cscale = floor(mem[base + 15] + 0.5);
      cx = wf_x + (cstart / max(1, tex_frames)) * wf_w;
      cx = clampg(cx, wf_x, wf_x + wf_w - 1);
      cscale == scale_short ? tick_h = spx(10) : tick_h = spx(18);

      cphase == phase_att ? (
        gfx_r = 0.28; gfx_g = 0.84; gfx_b = 0.98;
      ) : cphase == phase_body ? (
        gfx_r = 0.38; gfx_g = 0.90; gfx_b = 0.52;
      ) : cphase == phase_rel ? (
        gfx_r = 0.94; gfx_g = 0.72; gfx_b = 0.32;
      ) : (
        gfx_r = 0.94; gfx_g = 0.52; gfx_b = 0.94;
      );
      gfx_a = 0.10 + 0.32 * rankn;
      gfx_line(cx, wf_y + spx(2), cx, wf_y + spx(2) + tick_h, 1);
    );
    i += 1;
  );
) : (
  0;
);

over_wf = hit(mx, my, wf_x, wf_y, wf_w, wf_h);
over_wf && (tex_loaded > 0) ? (
  hover_n = clampg((mx - wf_x) / wf_w, 0, 1);
  hover_x = wf_x + hover_n * wf_w;
  hover_x = clampg(hover_x, wf_x, wf_x + wf_w - 1);
  hover_sec = tex_sr > 0 ? (hover_n * tex_frames) / tex_sr : 0;

  gfx_r = 0.98; gfx_g = 0.92; gfx_b = 0.52; gfx_a = 0.82;
  gfx_line(hover_x, wf_y, hover_x, wf_y + wf_h, 1);

  sprintf(#hoverbuf, "%.3fs", hover_sec);
  gfx_setfont(1, "Verdana", ft_small);
  gfx_measurestr(#hoverbuf, hov_tw, hov_th);
  hov_tx = hover_x + spx(8);
  hov_tx + hov_tw > wf_x + wf_w - spx(6) ? hov_tx = hover_x - hov_tw - spx(8);
  hov_tx < wf_x + spx(6) ? hov_tx = wf_x + spx(6);
  gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.98; gfx_a = 1;
  gfx_x = hov_tx; gfx_y = wf_y + spx(8);
  gfx_drawstr(#hoverbuf);

  click ? (
    cloud_center = floor(hover_n * tex_frames);
  );
);


// envelope panel
gfx_r = 0.085; gfx_g = 0.095; gfx_b = 0.122; gfx_a = 1;
gfx_rect(env_x, env_y, env_w, env_h, 1);
gfx_r = 0.16; gfx_g = 0.18; gfx_b = 0.24; gfx_a = 1;
gfx_roundrect(env_x, env_y, env_w, env_h, spx(8), 1);

gfx_setfont(1, "Verdana", ft_panel);
gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.98; gfx_a = 1;
gfx_x = env_x + spx(14); gfx_y = env_y + spx(12);
gfx_printf("Envelope");


e_pad = spx(18);
graph_x = env_x + e_pad;
graph_y = env_y + spx(42);
graph_w = env_w - e_pad * 2;
graph_h = spx(136);

gfx_r = 0.11; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
gfx_rect(graph_x, graph_y, graph_w, graph_h, 1);
gfx_r = 0.15; gfx_g = 0.18; gfx_b = 0.22; gfx_a = 1;
gfx_roundrect(graph_x, graph_y, graph_w, graph_h, 6, 1);

gy = graph_y;
loop(4,
  gfx_line(graph_x, gy, graph_x + graph_w, gy, 1);
  gy += graph_h / 3;
);

gx = graph_x;
loop(5,
  gfx_line(gx, graph_y, gx, graph_y + graph_h, 1);
  gx += graph_w / 4;
);

wa = 0.12 + 0.88 * norm_log(slider15, 0.1, 2000);
wd = 0.12 + 0.88 * norm_log(slider16, 0.1, 3000);
wr = 0.12 + 0.88 * norm_log(slider18, 0.1, 5000);
ws = 0.28;

sumw = wa + wd + ws + wr;
aw = graph_w * wa / sumw;
dw = graph_w * wd / sumw;
sw = graph_w * ws / sumw;
rw = graph_w * wr / sumw;

p0x = graph_x;
p0y = graph_y + graph_h;

p1x = p0x + aw;
p1y = graph_y;

sus_y = graph_y + (1 - slider17) * graph_h;

p2x = p1x + dw;
p2y = sus_y;

p3x = p2x + sw;
p3y = sus_y;

p4x = p3x + rw;
p4y = graph_y + graph_h;

gfx_r = 0.18; gfx_g = 0.54; gfx_b = 0.88; gfx_a = 0.10;
fx = p0x;
loop(max(1, floor(graph_w)),
  t = (fx - p0x) / max(1, p4x - p0x);
  gfx_line(fx, p0y, fx, p0y - (p0y - sus_y) * t, 1);
  fx += 1;
);

gfx_r = 0.30; gfx_g = 0.88; gfx_b = 0.98; gfx_a = 1;
draw_curve_seg(p0x, p0y, p1x, p1y, slider19);
draw_curve_seg(p1x, p1y, p2x, p2y, slider20);
gfx_line(p2x, p2y, p3x, p3y, 1);
draw_curve_seg(p3x, p3y, p4x, p4y, slider21);

hover_env_pt = 0;
point_hit(mx, my, p1x, p1y, 8) ? hover_env_pt = 1;
point_hit(mx, my, p2x, p2y, 8) ? hover_env_pt = 2;
point_hit(mx, my, p3x, p3y, 8) ? hover_env_pt = 3;

hover_env_seg = 0;
hit(mx, my, graph_x, graph_y, graph_w, graph_h) && (hover_env_pt == 0) ? (
  mx < p1x ? hover_env_seg = 1 :
  mx < p2x ? hover_env_seg = 2 :
  mx < p3x ? hover_env_seg = 0 :
  hover_env_seg = 3;
);

gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.99; gfx_a = 1;
gfx_circle(p1x, p1y, hover_env_pt == 1 ? 6 : 4, 1, 1);
gfx_circle(p2x, p2y, hover_env_pt == 2 ? 6 : 4, 1, 1);
gfx_circle(p3x, p3y, hover_env_pt == 3 ? 6 : 4, 1, 1);

gfx_setfont(1, "Verdana", ft_meta);
gfx_r = 0.72; gfx_g = 0.78; gfx_b = 0.86; gfx_a = 1;
gfx_x = p0x + spx(6); gfx_y = graph_y + graph_h + spx(4); gfx_printf("A");
gfx_x = p1x + spx(6); gfx_y = graph_y + graph_h + spx(4); gfx_printf("D");
gfx_x = p2x + spx(6); gfx_y = graph_y + graph_h + spx(4); gfx_printf("S");
gfx_x = p3x + spx(6); gfx_y = graph_y + graph_h + spx(4); gfx_printf("R");

// knob band
knob_band_y = graph_y + graph_h + spx(56);
slot_w = env_w / 4;
k_r = spx(42);
slot_w < spx(160) ? k_r = min(k_r, spx(38));

k_y = knob_band_y + spx(52);
k1_x = env_x + slot_w * 0.5;
k2_x = env_x + slot_w * 1.5;
k3_x = env_x + slot_w * 2.5;
k4_x = env_x + slot_w * 3.5;

hover_knob = 0;
knob_hit(mx, my, k1_x, k_y, k_r + 10) ? hover_knob = 1;
knob_hit(mx, my, k2_x, k_y, k_r + 10) ? hover_knob = 2;
knob_hit(mx, my, k3_x, k_y, k_r + 10) ? hover_knob = 3;
knob_hit(mx, my, k4_x, k_y, k_r + 10) ? hover_knob = 4;

a_n = knob_norm(1);
d_n = knob_norm(2);
s_n = knob_norm(3);
r_n = knob_norm(4);

draw_knob_shell(k1_x, k_y, k_r, a_n, 0.96, 0.54, 0.20, hover_knob == 1, (ui_active_kind == 3) && (ui_active_id == 1));
draw_knob_shell(k2_x, k_y, k_r, d_n, 0.95, 0.72, 0.24, hover_knob == 2, (ui_active_kind == 3) && (ui_active_id == 2));
draw_knob_shell(k3_x, k_y, k_r, s_n, 0.34, 0.90, 0.44, hover_knob == 3, (ui_active_kind == 3) && (ui_active_id == 3));
draw_knob_shell(k4_x, k_y, k_r, r_n, 0.74, 0.54, 0.96, hover_knob == 4, (ui_active_kind == 3) && (ui_active_id == 4));

slider15 < 100 ? sprintf(#vA, "%.1f", slider15) : sprintf(#vA, "%.0f", slider15);
slider16 < 100 ? sprintf(#vD, "%.1f", slider16) : sprintf(#vD, "%.0f", slider16);
sprintf(#vS, "%.3f", slider17);
slider18 < 100 ? sprintf(#vR, "%.1f", slider18) : sprintf(#vR, "%.0f", slider18);

gfx_setfont(1, "Verdana", ft_knob);
center_text(k1_x - k_r, k_y - 12, k_r * 2, 0.98, 0.99, 1.00, #vA);
center_text(k2_x - k_r, k_y - 12, k_r * 2, 0.98, 0.99, 1.00, #vD);
center_text(k3_x - k_r, k_y - 12, k_r * 2, 0.98, 0.99, 1.00, #vS);
center_text(k4_x - k_r, k_y - 12, k_r * 2, 0.98, 0.99, 1.00, #vR);

gfx_setfont(1, "Verdana", ft_tiny);
center_text(k1_x - k_r, k_y + 4, k_r * 2, 0.75, 0.80, 0.86, "ms");
center_text(k2_x - k_r, k_y + 4, k_r * 2, 0.75, 0.80, 0.86, "ms");
center_text(k3_x - k_r, k_y + 4, k_r * 2, 0.75, 0.80, 0.86, "");
center_text(k4_x - k_r, k_y + 4, k_r * 2, 0.75, 0.80, 0.86, "ms");

gfx_setfont(1, "Verdana", ft_small);
center_text(k1_x - 64, k_y + k_r + 18, 128, 0.82, 0.86, 0.92, "ATTACK");
center_text(k2_x - 64, k_y + k_r + 18, 128, 0.82, 0.86, 0.92, "DECAY");
center_text(k3_x - 64, k_y + k_r + 18, 128, 0.82, 0.86, 0.92, "SUSTAIN");
center_text(k4_x - 64, k_y + k_r + 18, 128, 0.82, 0.86, 0.92, "RELEASE");

// slope strips
s_w = spx(92);
s_h = spx(12);
s_y = k_y + k_r + spx(42);
s1_x = k1_x - s_w * 0.5;
s2_x = k2_x - s_w * 0.5;
s3_x = k4_x - s_w * 0.5;

hover_slope = 0;
hit(mx, my, s1_x, s_y, s_w, s_h + 18) ? hover_slope = 1;
hit(mx, my, s2_x, s_y, s_w, s_h + 18) ? hover_slope = 2;
hit(mx, my, s3_x, s_y, s_w, s_h + 18) ? hover_slope = 3;

draw_slope_pill(s1_x, s_y, s_w, s_h, slider19, hover_slope == 1, (ui_active_kind == 4) && (ui_active_id == 1), "A CURVE");
draw_slope_pill(s2_x, s_y, s_w, s_h, slider20, hover_slope == 2, (ui_active_kind == 4) && (ui_active_id == 2), "D CURVE");
draw_slope_pill(s3_x, s_y, s_w, s_h, slider21, hover_slope == 3, (ui_active_kind == 4) && (ui_active_id == 3), "R CURVE");

// side panel
gfx_r = 0.085; gfx_g = 0.095; gfx_b = 0.122; gfx_a = 1;
gfx_rect(side_x, side_y, side_w, side_h, 1);
gfx_r = 0.16; gfx_g = 0.18; gfx_b = 0.24; gfx_a = 1;
gfx_roundrect(side_x, side_y, side_w, side_h, spx(8), 1);

sp = spx(16);
sx = side_x + sp;
sy = side_y + spx(14);
sw = side_w - sp * 2;

pitch_disp = pow(slider8, 1.15) * 72;
amp_disp = slider8 * 4.5;
phase_disp = pow(slider8, 0.95) * 180;
flow_density =
  slider10 < 0.5 ? 1 :
  slider10 < 1.5 ? (0.85 + slider5 * slider5 * 15.0) :
  slider10 < 2.5 ? (3.0 + pow(slider5, 1.6) * 42.0) :
  (2.2 + pow(slider5, 1.55) * 28.0);
wander_pct = (0.03 + slider5 * slider5 * 0.97) * 100;
repeat_pct = (0.20 + 0.80 * slider6) * 100;

gfx_setfont(1, "Verdana", ft_panel);
gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.98; gfx_a = 1;
gfx_x = sx; gfx_y = sy;
gfx_printf("Playback");

gfx_setfont(1, "Verdana", ft_small);
gfx_r = 0.74; gfx_g = 0.78; gfx_b = 0.86; gfx_a = 1;
gfx_x = sx; gfx_y = sy + spx(22);
slider10 < 0.5 ? sprintf(#modebuf, "One-Shot") :
slider10 < 1.5 ? sprintf(#modebuf, "Random") :
slider10 < 2.5 ? sprintf(#modebuf, "Granular") :
sprintf(#modebuf, "Gran Synth");
profile == 0 ? sprintf(#profname, "Neutral") :
profile == 1 ? sprintf(#profname, "Cloth") :
profile == 2 ? sprintf(#profname, "Wet") :
profile == 3 ? sprintf(#profname, "Bed") :
sprintf(#profname, "Friction");
desired_phase == phase_att ? sprintf(#wantph, "ATT") : desired_phase == phase_body ? sprintf(#wantph, "BODY") : desired_phase == phase_rel ? sprintf(#wantph, "REL") : sprintf(#wantph, "DEB");
last_phase == phase_att ? sprintf(#lastph, "ATT") : last_phase == phase_body ? sprintf(#lastph, "BODY") : last_phase == phase_rel ? sprintf(#lastph, "REL") : last_phase == phase_deb ? sprintf(#lastph, "DEB") : sprintf(#lastph, "-");
source_mode == 0 ? (eff_source_mode == 1 ? sprintf(#srcshort, "A>IN") : eff_source_mode == 2 ? sprintf(#srcshort, "A>SC") : sprintf(#srcshort, "A>M")) : source_mode == 1 ? sprintf(#srcshort, "IN") : source_mode == 2 ? sprintf(#srcshort, "SC") : sprintf(#srcshort, "MIDI");
midi_note_gate ? sprintf(#notebuf, "%d", midi_held_note) : sprintf(#notebuf, "-");
gfx_printf("%s/%s/%s  •  n%s  •  active %d  •  %s→%s  •  fam %d→%d", #profname, #modebuf, #srcshort, #notebuf, voices_last_count, #lastph, #wantph, last_family, desired_family);

gfx_x = sx; gfx_y = sy + spx(38);
gfx_printf("Tune %+.2f st  •  Jit ±%.1fct / ±%.1fdB / ±%.0f°  •  S%d/M%d", slider28, pitch_disp, amp_disp, phase_disp, cand_short_live_count, cand_med_live_count);

// follower meter
follow_warp = 0.35;
follow_inv_warp = 1 / follow_warp;

follow_det = clampg(det_mix, 0, 1);
follow_disp = pow(follow_det, follow_warp);
thr_on_disp  = pow(clampg(slider4, 0, 1), follow_warp);
thr_off_disp = pow(clampg(slider4 * slider24, 0, 1), follow_warp);

follow_bar_x = sx;
follow_bar_y = sy + spx(72);
follow_bar_w = sw;
follow_bar_h = spx(14);
hover_follow_bar = hit(mx, my, follow_bar_x, follow_bar_y - spx(4), follow_bar_w, follow_bar_h + spx(10));

gfx_setfont(1, "Verdana", ft_meta);
gfx_r = 0.82; gfx_g = 0.86; gfx_b = 0.92; gfx_a = 1;
gfx_x = sx; gfx_y = sy + spx(56);
gfx_printf("FOLLOW");
draw_meter(follow_bar_x, follow_bar_y, follow_bar_w, follow_bar_h, follow_disp, 0.24, 0.72, 0.92, thr_on_disp, thr_off_disp);

gfx_r = 0.70; gfx_g = 0.76; gfx_b = 0.84; gfx_a = 1;
gfx_x = sx; gfx_y = sy + spx(92);
gfx_printf("knee %.4f→%.4f  live %.0f%%  onset %.0f%%  wake %.2f", slider4 * slider24, slider4, support_sig * 100, det_prime * 100, wake_force);

out_disp = 1 - exp(-2.4 * meter_out);
gfx_r = 0.82; gfx_g = 0.86; gfx_b = 0.92; gfx_a = 1;
gfx_x = sx; gfx_y = sy + spx(118);
gfx_printf("TEXTURE OUT");
draw_meter(sx, sy + spx(134), sw, spx(14), out_disp, 0.32, 0.94, 0.44, -1, -1);

gfx_r = 0.70; gfx_g = 0.76; gfx_b = 0.84; gfx_a = 1;
gfx_x = sx; gfx_y = sy + spx(154);
gfx_printf("peak %.5f  gate %g  live %.0f%%  duck %.0f%%", meter_out, gate, support_mix * 100, support_gain * 100);

// macro controls
macro_y0 = sy + spx(172);
row_h = spx(27);
row_gap = spx(3);
col_gap = spx(14);
col_w = floor((sw - col_gap) * 0.5);
c1x = sx;
c2x = sx + col_w + col_gap;

hover_macro = 0;
i = 0;
loop(10,
  cid = i + 1;
  col = cid <= 5 ? 0 : 1;
  row = col ? (cid - 6) : (cid - 1);
  cx = col ? c2x : c1x;
  cy = macro_y0 + row * (row_h + row_gap);

  over = hit(mx, my, cx, cy, col_w, row_h);
  over ? hover_macro = cid;

  n = macro_norm(cid);
  macro_color(cid);
  macro_strings(cid);
  (mouse_cap & 4) && over && (cid == 1) ? (
    sprintf(#mlab, auto_slice ? "Slice Rand*" : "Slice Rand");
    sprintf(#mval, "-%.0f/+%.0f%%", slice_rand_down_pct, slice_rand_up_pct);
  ) : (mouse_cap & 4) && over && (cid == 8) ? (
    sprintf(#mlab, "Support Rand");
    sprintf(#mval, "-%.0f/+%.0f%%", support_rand_down_pct, support_rand_up_pct);
  );

  gfx_r = 0.10; gfx_g = 0.12; gfx_b = 0.16; gfx_a = 1;
  gfx_rect(cx, cy, col_w, row_h, 1);

  fill_w = floor((col_w - 2) * clampg(n, 0, 1));
  gfx_r = mr; gfx_g = mg; gfx_b = mb; gfx_a = over ? 0.92 : 0.80;
  gfx_rect(cx + 1, cy + 1, fill_w, row_h - 2, 1);

  gfx_r = 0.17; gfx_g = 0.19; gfx_b = 0.24; gfx_a = 1;
  gfx_roundrect(cx, cy, col_w, row_h, spx(5), 1);

  gfx_setfont(1, "Verdana", ft_meta);
  gfx_r = 0.94; gfx_g = 0.96; gfx_b = 0.98; gfx_a = 1;
  gfx_x = cx + spx(8); gfx_y = cy + spx(5);
  gfx_drawstr(#mlab);

  gfx_measurestr(#mval, tw, th);
  gfx_x = cx + col_w - tw - spx(8); gfx_y = cy + spx(5);
  gfx_drawstr(#mval);

  i += 1;
);

// compact status values used by the header + tooltips
flow_density =
  slider10 < 0.5 ? 1 :
  slider10 < 1.5 ? (0.85 + slider5 * slider5 * 15.0) :
  slider10 < 2.5 ? (3.0 + pow(slider5, 1.6) * 42.0) :
  (2.2 + pow(slider5, 1.55) * 28.0);
wander_pct = (0.03 + slider5 * slider5 * 0.97) * 100;
repeat_pct = (0.20 + 0.80 * slider6) * 100;
pitch_disp = pow(slider8, 1.15) * 72;
amp_disp = slider8 * 4.5;
phase_disp = pow(slider8, 0.95) * 180;

// follow bar interaction
rclick && hover_follow_bar ? (
  ui_active_kind = 0; ui_active_id = 0;
  open_param_menu4(4, 24, 22, 23);
);

click && (ui_active_kind == 0) && hover_follow_bar ? (
  ui_active_kind = 5;
  ui_active_id = 1;
);

(ui_active_kind == 5) && lmb ? (
  nx = clampg((mx - follow_bar_x) / max(1, follow_bar_w), 0, 1);
  slider4 = pow(nx, follow_inv_warp);
  slider4 < 0 ? slider4 = 0;
  slider4 > 1 ? slider4 = 1;
  sliderchange(slider4);
);

wheel != 0 && hover_follow_bar ? (
  slider24 += (wheel / 120.0) * 0.020 * fine_mult * coarse_mult;
  slider24 = clampg(slider24, 0.05, 0.99);
  sliderchange(slider24);
  ui_add_undo = 1;
);

(ui_active_kind == 5) && release ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_add_undo = 1;
);

// macro interaction
rclick && (hover_macro > 0) ? (
  ui_active_kind = 0; ui_active_id = 0;
  hover_macro == 1 ? open_param_menu2(9, 33) :
  hover_macro == 2 ? open_param_menu1(5) :
  hover_macro == 3 ? open_param_menu1(6) :
  hover_macro == 4 ? open_param_menu1(7) :
  hover_macro == 5 ? open_param_menu1(8) :
  hover_macro == 6 ? open_param_menu1(28) :
  hover_macro == 7 ? open_param_menu1(3) :
  hover_macro == 8 ? open_param_menu2(25, 34) :
  hover_macro == 9 ? open_param_menu2(1, 2) :
  hover_macro == 10 ? open_param_menu2(31, 32);
);
click && (ui_active_kind == 0) && (hover_macro > 0) ? (
  ui_active_kind = 1;
  ui_active_id = hover_macro;
  ui_drag_start_x = mx;
  ui_drag_start_y = my;
  ui_drag_start_val = macro_norm(hover_macro);
);

wheel != 0 && (hover_macro == 10) && (hover_slope == 0) && (hover_knob == 0) && (mouse_cap & 8) ? (
  slider32 += (wheel / 120.0) * 12 * coarse_mult;
  slider32 = clampg(slider32, 20, 1500);
  sliderchange(slider32);
  ui_add_undo = 1;
) : wheel != 0 && (hover_macro == 1) && (hover_slope == 0) && (hover_knob == 0) && (mouse_cap & 4) ? (
  rand_step = (wheel / 120.0) * 0.025 * fine_mult;
  slider33 += rand_step;
  slider33 = clampg(slider33, 0, 1);
  sliderchange(slider33);
  ui_add_undo = 1;
) : wheel != 0 && (hover_macro == 8) && (hover_slope == 0) && (hover_knob == 0) && (mouse_cap & 4) ? (
  rand_step = (wheel / 120.0) * 0.025 * fine_mult;
  slider34 += rand_step;
  slider34 = clampg(slider34, 0, 1);
  sliderchange(slider34);
  ui_add_undo = 1;
) : wheel != 0 && (hover_macro > 0) && (hover_slope == 0) && (hover_knob == 0) ? (
  macro_set(hover_macro, macro_norm(hover_macro) + wheel_step);
  ui_add_undo = 1;
);

(ui_active_kind == 1) && lmb ? (
  delta_n = (mx - ui_drag_start_x) / drag_div;
  macro_set(ui_active_id, ui_drag_start_val + delta_n);
);

(ui_active_kind == 1) && release ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_add_undo = 1;
);

// main knob interaction
rclick && (hover_knob > 0) ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  hover_knob == 1 ? open_param_menu1(15) :
  hover_knob == 2 ? open_param_menu1(16) :
  hover_knob == 3 ? open_param_menu1(17) :
  open_param_menu1(18);
);

click && (ui_active_kind == 0) && (hover_knob > 0) ? (
  ui_active_kind = 3;
  ui_active_id = hover_knob;
  ui_drag_start_y = my;
  ui_drag_start_val = knob_norm(hover_knob);
);

wheel != 0 && (hover_knob > 0) ? (
  knob_set(hover_knob, knob_norm(hover_knob) + wheel_step);
  ui_add_undo = 1;
);

(ui_active_kind == 3) && lmb ? (
  delta_n = (ui_drag_start_y - my) / drag_div;
  knob_set(ui_active_id, ui_drag_start_val + delta_n);
);

(ui_active_kind == 3) && release ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_add_undo = 1;
);

// slope strip interaction
rclick && (hover_slope > 0) ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  hover_slope == 1 ? open_param_menu1(19) :
  hover_slope == 2 ? open_param_menu1(20) :
  open_param_menu1(21);
);

click && (ui_active_kind == 0) && (hover_slope > 0) ? (
  ui_active_kind = 4;
  ui_active_id = hover_slope;
  ui_drag_start_x = mx;
  ui_drag_start_val = curve_norm(hover_slope);
);

wheel != 0 && (hover_slope > 0) ? (
  curve_set(hover_slope, curve_norm(hover_slope) + wheel_step * 1.4);
  ui_add_undo = 1;
);

(ui_active_kind == 4) && lmb ? (
  delta_n = (mx - ui_drag_start_x) / 160;
  curve_set(ui_active_id, ui_drag_start_val + delta_n);
);

(ui_active_kind == 4) && release ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_add_undo = 1;
);

// envelope graph interaction
click && (ui_active_kind == 0) && (hover_env_pt > 0) ? (
  ui_active_kind = 2;
  ui_active_id = hover_env_pt;
  ui_drag_start_x = mx;
  ui_drag_start_y = my;
  ui_drag_start_val =
    hover_env_pt == 1 ? slider15 :
    hover_env_pt == 2 ? slider16 :
    slider18;
  ui_drag_start_val2 = slider17;
);

(ui_active_kind == 2) && lmb ? (
  dx = mx - ui_drag_start_x;
  dy = my - ui_drag_start_y;

  ui_active_id == 1 ? (
    slider15 = clampg(ui_drag_start_val * exp(dx * time_drag_scale), 0.1, 2000);
    sliderchange(slider15);
  ) : ui_active_id == 2 ? (
    slider16 = clampg(ui_drag_start_val * exp(dx * time_drag_scale), 0.1, 3000);
    slider17 = clampg(ui_drag_start_val2 - dy / 160, 0, 1);
    sliderchange(slider16);
    sliderchange(slider17);
  ) : ui_active_id == 3 ? (
    slider18 = clampg(ui_drag_start_val * exp(dx * time_drag_scale), 0.1, 5000);
    sliderchange(slider18);
  );
);

(ui_active_kind == 2) && release ? (
  ui_active_kind = 0;
  ui_active_id = 0;
  ui_add_undo = 1;
);

rclick && (hover_env_pt > 0) ? (
  ui_active_kind = 0; ui_active_id = 0;
  hover_env_pt == 1 ? open_param_menu1(15) : hover_env_pt == 2 ? open_param_menu2(16, 17) : open_param_menu1(18);
);

wheel != 0 && (hover_env_seg > 0) && (hover_slope == 0) ? (
  curve_set(hover_env_seg, curve_norm(hover_env_seg) + wheel_step * 1.2);
  ui_add_undo = 1;
);

(mmb && wheel != 0 && (hover_env_seg > 0)) ? (
  curve_set(hover_env_seg, curve_norm(hover_env_seg) + wheel_step * 1.2);
  ui_add_undo = 1;
);

!lmb && (ui_active_kind == 0) ? (
  ui_active_id = 0;
);


// hover tooltip
tip_on = 0;
sprintf(#tip1, "");
sprintf(#tip2, "");

hover_mode_btn  = hit(mx, my, mode_x, top_y, mode_w, btn_h);
hover_prof_btn  = hit(mx, my, prof_x, top_y, prof_w, btn_h);
hover_src_btn   = hit(mx, my, src_x, top_y, src_w, btn_h);
hover_midi_btn  = hit(mx, my, midi_x, top_y, midi_w, btn_h);
hover_slice_btn = hit(mx, my, slice_x, top_y, slice_w, btn_h);
hover_gate_btn  = hit(mx, my, gate_x, top_y, gate_w, btn_h);
hover_out_btn   = hit(mx, my, out_x, top_y, out_w, btn_h);
hover_auto_btn  = hit(mx, my, auto_x, top_y, util_w, btn_h);
hover_reload_btn= hit(mx, my, reload_x, top_y, reload_w, btn_h);
tip_pitch_cents = floor(abs(slider28) * 100 + 0.5);
slider28 < 0 ? tip_pitch_cents = -tip_pitch_cents;

hover_env_pt == 1 ? (
  tip_on = 1;
  sprintf(#tip1, "Attack point: drag right for longer onset.");
  sprintf(#tip2, "Current attack %.1f ms, curve %.2f.", slider15, slider19);
) : hover_env_pt == 2 ? (
  tip_on = 1;
  sprintf(#tip1, "Decay/Sustain point: drag right for decay, up/down for sustain.");
  sprintf(#tip2, "Current decay %.1f ms, sustain %.3f, curve %.2f.", slider16, slider17, slider20);
) : hover_env_pt == 3 ? (
  tip_on = 1;
  sprintf(#tip1, "Release point: drag right for longer tail.");
  sprintf(#tip2, "Current release %.1f ms, curve %.2f.", slider18, slider21);
) : hover_slope == 1 ? (
  tip_on = 1;
  sprintf(#tip1, "Attack curve strip. Wheel or drag for concave/linear/convex.");
  sprintf(#tip2, "Current attack curve %.2f.", slider19);
) : hover_slope == 2 ? (
  tip_on = 1;
  sprintf(#tip1, "Decay curve strip. Wheel or drag to reshape the fall.");
  sprintf(#tip2, "Current decay curve %.2f.", slider20);
) : hover_slope == 3 ? (
  tip_on = 1;
  sprintf(#tip1, "Release curve strip. Wheel or drag to tighten or soften the tail.");
  sprintf(#tip2, "Current release curve %.2f.", slider21);
) : hover_knob == 1 ? (
  tip_on = 1;
  sprintf(#tip1, "Attack time for every grain envelope.");
  sprintf(#tip2, "Current attack %.1f ms.", slider15);
) : hover_knob == 2 ? (
  tip_on = 1;
  sprintf(#tip1, "Decay time after the attack peak.");
  sprintf(#tip2, "Current decay %.1f ms.", slider16);
) : hover_knob == 3 ? (
  tip_on = 1;
  sprintf(#tip1, "Sustain level held before release.");
  sprintf(#tip2, "Current sustain %.3f.", slider17);
) : hover_knob == 4 ? (
  tip_on = 1;
  sprintf(#tip1, "Release time for every grain tail.");
  sprintf(#tip2, "Current release %.1f ms.", slider18);
) : hover_follow_bar ? (
  tip_on = 1;
  sprintf(#tip1, "Continuous detector: drag the high knee, wheel the low knee/hysteresis.");
  sprintf(#tip2, "Det %.4f, onset %.4f, knee %.4f→%.4f, live %.0f%%.", det_mix, det_prime, slider4 * slider24, slider4, support_sig * 100);
) : hover_macro == 1 ? (
  tip_on = 1;
  auto_slice ? (
    sprintf(#tip1, "Slice cap for auto event bounds.");
    sprintf(#tip2, "Current cap %.0f ms. Ctrl+wheel parks Slice Rand at -%.0f/+%.0f%%, but it is ignored while Auto Slice is on.", slider9, slice_rand_down_pct, slice_rand_up_pct);
  ) : (
    sprintf(#tip1, "Fixed per-grain slice duration.");
    sprintf(#tip2, "Current slice %.0f ms. Ctrl+wheel sets Slice Rand to -%.0f/+%.0f%% per grain.", slider9, slice_rand_down_pct, slice_rand_up_pct);
  );
) : hover_macro == 2 ? (
  tip_on = 1;
  sprintf(#tip1, "Flow changes density and position wander.");
  sprintf(#tip2, "Current density %.2f/s, wander %.0f%%.", flow_density, wander_pct);
) : hover_macro == 3 ? (
  tip_on = 1;
  sprintf(#tip1, "Focus prefers more salient grains and avoids repeats.");
  sprintf(#tip2, "Repeat-avoid %.0f%% with tighter event picking.", repeat_pct);
) : hover_macro == 4 ? (
  tip_on = 1;
  sprintf(#tip1, "Grounding normalizes uneven source dynamics.");
  sprintf(#tip2, "Current grounding %.0f%%.", slider7 * 100);
) : hover_macro == 5 ? (
  tip_on = 1;
  sprintf(#tip1, "Jitter adds per-grain pitch, level, and phase offset variation.");
  sprintf(#tip2, "Now ±%.1f ct, ±%.1f dB, ±%.0f°.", pitch_disp, amp_disp, phase_disp);
) : hover_macro == 6 ? (
  tip_on = 1;
  sprintf(#tip1, "Global pitch shifts the entire texture engine.");
  sprintf(#tip2, "Current tune %+.2f st (%+d cents).", slider28, tip_pitch_cents);
) : hover_macro == 7 ? (
  tip_on = 1;
  sprintf(#tip1, "Sensitivity drives the detector before saturation + soft-knee participation.");
  sprintf(#tip2, "Current sensitivity %.2fx. Higher blooms quieter motion sooner.", slider3);
) : hover_macro == 8 ? (
  tip_on = 1;
  sprintf(#tip1, "Support is the salience budget applied after detector support is computed.");
  sprintf(#tip2, "Current support %.0f%%. Ctrl+wheel adds per-grain Support Rand of -%.0f/+%.0f%% without touching detector stability.", slider25 * 100, support_rand_down_pct, support_rand_up_pct);
) : hover_macro == 9 ? (
  tip_on = 1;
  sprintf(#tip1, "Dry/wet blend for the texture layer.");
  sprintf(#tip2, "Current mix %.0f%% texture.", slider1 * 100);
) : hover_macro == 10 ? (
  tip_on = 1;
  sprintf(#tip1, "Broad spectral-envelope imprint from dry input onto wet texture only.");
  sprintf(#tip2, "Current mix %.0f%%, speed %.0f ms. Shift+wheel adjusts speed. Coarse 4-band shaping, bounded and smoothed.", slider31 * 100, slider32);
) : hover_mode_btn ? (
  tip_on = 1;
  slider10 < 0.5 ? (
    sprintf(#tip1, "One-Shot: one event per trigger, best for punctuated actions.");
  ) : slider10 < 1.5 ? (
    sprintf(#tip1, "Random: event-weighted wandering through the source.");
  ) : slider10 < 2.5 ? (
    sprintf(#tip1, "Granular: denser cloud around the current region with continuity bias.");
  ) : (
    sprintf(#tip1, "Gran Synth: MIDI-note-driven texture synth. Held notes force pitch and gate like a normal synth; source selection can still feed Input/SC support when wanted.");
  );
  sprintf(#tip2, "Current mode %s. Phase pools A%d B%d R%d D%d. OLA smoothing is active.", #modebuf, attack_pool_count, body_pool_count, release_pool_count, debris_pool_count);
) : hover_prof_btn ? (
  tip_on = 1;
  sprintf(#tip1, "Material profile changes phase priors, continuity, scale bias, and duration behavior.");
  debug_overlay ? sprintf(#dbgtxt, "on") : sprintf(#dbgtxt, "off");
  sprintf(#tip2, "Current profile %s. Short/medium live S%d M%d. Right-click opens CC/default menu; debug is mappable too (%s).", #profname, cand_short_live_count, cand_med_live_count, #dbgtxt);
) : hover_src_btn ? (
  tip_on = 1;
  source_mode == 0 ? (
    eff_source_mode == 1 ? sprintf(#tip1, "Auto source: currently listening to Input 1/2.") : eff_source_mode == 2 ? sprintf(#tip1, "Auto source: currently listening to Sidechain 3/4.") : sprintf(#tip1, "Auto source: currently driven by MIDI.");
  ) : source_mode == 1 ? sprintf(#tip1, "Input source: detector listens to channels 1/2.") : source_mode == 2 ? sprintf(#tip1, "Sidechain source: detector listens to channels 3/4.") : sprintf(#tip1, "MIDI source: detector/support are driven by held MIDI notes.");
  sprintf(#tip2, "Current selector %s. Auto prioritizes live MIDI, otherwise the stronger of Input or SC. In Gran Synth, MIDI always owns pitch and gate.", #srcbtn);
) : hover_midi_btn ? (
  tip_on = 1;
  slider36 > 0.5 ? sprintf(#tip1, "MIDI Poly: up to %d recent held notes get their own granular schedulers.", midi_poly_max) : sprintf(#tip1, "MIDI Mono: last-note priority with the lightest CPU cost and tightest response.");
  sprintf(#tip2, "Poly shares density across active notes, limits per-sample spawns, and tags note voices for clean release handling.");
) : hover_slice_btn ? (
  tip_on = 1;
  slider27 > 0.5 ? (
    sprintf(#tip1, "Auto Slice uses local salience peaks + event bounds.");
    sprintf(#tip2, "Slice becomes a cap instead of a fixed duration.");
  ) : (
    sprintf(#tip1, "Fixed Slice forces a nominal duration for every grain.");
    sprintf(#tip2, "Switch to Auto for score-driven event lengths.");
  );
) : hover_gate_btn ? (
  tip_on = 1;
  slider26 < 0.5 ? (
    sprintf(#tip1, "Free release: grains keep their own tail.");
  ) : slider26 < 1.5 ? (
    sprintf(#tip1, "Tight release: tails are shortened on gate-off.");
  ) : (
    sprintf(#tip1, "Clamp release: after gate-off, tails are leashed relative to their spawn support.");
  );
  sprintf(#tip2, "Useful when wetness should not overshoot the physical action.");
) : hover_out_btn ? (
  tip_on = 1;
  slider11 > 0.5 ? (
    sprintf(#tip1, "Wet Only outputs just the texture layer.");
  ) : (
    sprintf(#tip1, "Dry+Wet keeps the original input underneath.");
  );
  sprintf(#tip2, "Current output peak %.5f.", meter_out);
) : hover_auto_btn ? (
  tip_on = 1;
  sprintf(#tip1, "Auto Reload watches the file slot and refreshes when it changes.");
  slider12 > 0.5 ? sprintf(#tip2, "Auto reload is on.") : sprintf(#tip2, "Auto reload is off.");
) : hover_reload_btn ? (
  tip_on = 1;
  sprintf(#tip1, "Manual reload of the file slot and analysis cache.");
  sprintf(#tip2, "Use after changing source files or if the host misses an update.");
) : over_wf ? (
  tip_on = 1;
  sprintf(#tip1, "Waveform + salience heat. Click to move the granular cloud.");
  auto_slice ? (
    sprintf(#tip2, "Auto Slice is on: local score peaks define event lengths. Target %s.", #wantph);
  ) : (
    sprintf(#tip2, "Fixed Slice is on: grains use the current slice duration. Target %s.", #wantph);
  );
);

tip_on ? (
  gfx_setfont(1, "Verdana", ft_meta);
  gfx_measurestr(#tip1, tip_tw1, tip_th1);
  gfx_measurestr(#tip2, tip_tw2, tip_th2);
  tip_pad = spx(8);
  tip_w = max(tip_tw1, tip_tw2) + tip_pad * 2;
  tip_h = tip_th1 + tip_th2 + tip_pad * 2 + spx(2);

  tip_x = mx + spx(16);
  tip_y = my + spx(18);
  tip_x + tip_w > gfx_w - pad ? tip_x = gfx_w - pad - tip_w;
  tip_y + tip_h > gfx_h - pad ? tip_y = my - tip_h - spx(14);
  tip_x < pad ? tip_x = pad;
  tip_y < pad ? tip_y = pad;

  gfx_r = 0.07; gfx_g = 0.09; gfx_b = 0.12; gfx_a = 0.96;
  gfx_rect(tip_x, tip_y, tip_w, tip_h, 1);
  gfx_r = 0.22; gfx_g = 0.26; gfx_b = 0.34; gfx_a = 1;
  gfx_roundrect(tip_x, tip_y, tip_w, tip_h, spx(6), 1);

  gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.99; gfx_a = 1;
  gfx_x = tip_x + tip_pad; gfx_y = tip_y + tip_pad;
  gfx_drawstr(#tip1);

  gfx_r = 0.76; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
  gfx_x = tip_x + tip_pad; gfx_y = tip_y + tip_pad + tip_th1 + spx(2);
  gfx_drawstr(#tip2);
);



cc_browser_active ? (
  param_name(cc_browser_param, #ccptitle);
  cc_name(mem[cc_map_base + cc_browser_param], #cccur);

  ov_pad = spx(18);
  ov_x = pad + spx(10);
  ov_y = pad + spx(18);
  ov_w = gfx_w - ov_x * 2;
  ov_h = gfx_h - ov_y * 2;
  ov_tab_h = spx(26);
  ov_tab_gap = spx(8);
  ov_grid_y = ov_y + spx(74);
  ov_cols = 4;
  ov_rows = 8;
  ov_cell_gap = spx(8);
  ov_cell_w = floor((ov_w - ov_pad * 2 - ov_cell_gap * (ov_cols - 1)) / ov_cols);
  ov_cell_h = spx(34);
  ov_grid_x = ov_x + ov_pad;

  gfx_r = 0.02; gfx_g = 0.03; gfx_b = 0.05; gfx_a = 0.90;
  gfx_rect(0, 0, gfx_w, gfx_h, 1);

  gfx_r = 0.05; gfx_g = 0.07; gfx_b = 0.10; gfx_a = 0.98;
  gfx_rect(ov_x, ov_y, ov_w, ov_h, 1);
  gfx_r = 0.18; gfx_g = 0.22; gfx_b = 0.30; gfx_a = 1;
  gfx_roundrect(ov_x, ov_y, ov_w, ov_h, spx(8), 1);

  gfx_setfont(1, "Verdana", ft_small);
  gfx_r = 0.70; gfx_g = 0.76; gfx_b = 0.84; gfx_a = 1;
  gfx_x = ov_x + ov_pad; gfx_y = ov_y + spx(12);
  gfx_printf("CC ASSIGNMENT");

  gfx_setfont(1, "Verdana", ft_panel);
  gfx_r = 0.96; gfx_g = 0.97; gfx_b = 0.99; gfx_a = 1;
  gfx_x = ov_x + ov_pad; gfx_y = ov_y + spx(32);
  gfx_printf("Assign %s CC", #ccptitle);

  gfx_setfont(1, "Verdana", ft_meta);
  gfx_r = 0.58; gfx_g = 0.64; gfx_b = 0.72; gfx_a = 1;
  gfx_x = ov_x + ov_pad; gfx_y = ov_y + spx(52);
  gfx_printf("Pages kill the horrible endless CC scroll. Pick a common target or jump by 32.");
  gfx_r = 0.16; gfx_g = 0.88; gfx_b = 0.94; gfx_a = 1;
  gfx_measurestr(#cccur, ccw, cch);
  gfx_x = ov_x + ov_w - ov_pad - ccw; gfx_y = ov_y + spx(16);
  gfx_drawstr(#cccur);

  tab_x = ov_x + ov_pad;
  ti = 0;
  loop(5,
    ti == 0 ? strcpy(#tabtxt, "COMMON") : ti == 1 ? strcpy(#tabtxt, "0-31") : ti == 2 ? strcpy(#tabtxt, "32-63") : ti == 3 ? strcpy(#tabtxt, "64-95") : strcpy(#tabtxt, "96-127");
    tab_w = floor((ov_w - ov_pad * 2 - ov_tab_gap * 4) / 5);
    tab_hov = hit(mx, my, tab_x, ov_y + spx(62), tab_w, ov_tab_h);
    modal_click && tab_hov ? cc_browser_page = ti;
    draw_button(tab_x, ov_y + spx(62), tab_w, ov_tab_h, cc_browser_page == ti, tab_hov, 0.18, 0.56, 0.48, #tabtxt);
    tab_x += tab_w + ov_tab_gap;
    ti += 1;
  );

  cc_browser_selected = -2;
  ci = 0;
  loop(ov_rows,
    cj = 0;
    loop(ov_cols,
      cell_idx = ci * ov_cols + cj;
      cell_x = ov_grid_x + cj * (ov_cell_w + ov_cell_gap);
      cell_y = ov_grid_y + ci * (ov_cell_h + ov_cell_gap);
      ccnum = -2;
      cc_browser_page == 0 ? (
        ccnum = cc_common_num(cell_idx);
      ) : (
        ccnum = (cc_browser_page - 1) * 32 + cell_idx;
        ccnum > 127 ? ccnum = -2;
      );

      ccnum != -2 ? (
        cc_friendly_name(ccnum, #cclbl);
        ccnum < 0 ? strcpy(#cctop, "OFF") : sprintf(#cctop, "CC %d", ccnum);
        cell_hov = hit(mx, my, cell_x, cell_y, ov_cell_w, ov_cell_h);
        is_sel = mem[cc_map_base + cc_browser_param] == ccnum;

        gfx_r = is_sel ? 0.10 : 0.08; gfx_g = is_sel ? 0.36 : 0.11; gfx_b = is_sel ? 0.26 : 0.15; gfx_a = 1;
        cell_hov ? (gfx_r += 0.05; gfx_g += 0.05; gfx_b += 0.05;);
        gfx_rect(cell_x, cell_y, ov_cell_w, ov_cell_h, 1);
        gfx_r = 0.18; gfx_g = 0.22; gfx_b = 0.30; gfx_a = 1;
        gfx_roundrect(cell_x, cell_y, ov_cell_w, ov_cell_h, spx(6), 1);

        gfx_setfont(1, "Verdana", ft_small);
        gfx_r = 0.95; gfx_g = 0.97; gfx_b = 0.99; gfx_a = 1;
        gfx_x = cell_x + spx(10); gfx_y = cell_y + spx(6);
        gfx_drawstr(#cctop);

        gfx_setfont(1, "Verdana", ft_tiny);
        gfx_r = 0.62; gfx_g = 0.68; gfx_b = 0.76; gfx_a = 1;
        gfx_x = cell_x + spx(10); gfx_y = cell_y + spx(20);
        gfx_drawstr(#cclbl);

        modal_click && cell_hov ? cc_browser_selected = ccnum;
      );
      cj += 1;
    );
    ci += 1;
  );

  close_x = ov_x + ov_w - ov_pad - spx(80);
  close_y = ov_y + ov_h - ov_pad - spx(24);
  close_hov = hit(mx, my, close_x, close_y, spx(80), spx(24));
  draw_button(close_x, close_y, spx(80), spx(24), 0, close_hov, 0.40, 0.22, 0.22, "CLOSE");

  (modal_click && close_hov) || modal_rclick ? (
    cc_browser_active = 0;
  );
  cc_browser_selected != -2 ? (
    mem[cc_map_base + cc_browser_param] = cc_browser_selected;
    cc_browser_active = 0;
    ui_button_click = 1;
  );
);
ui_button_click ? ui_add_undo = 0;
ui_add_undo ? sliderchange(-1);
