gfx_drawstr("ENVELOPE");
gfx_r = 0.10; gfx_g = 0.58; gfx_b = 1.0; gfx_a = 0.90; gfx_circle(mid_x + 10, mid_y + 25, 4, 1);
gfx_r = 0.26; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.35; gfx_line(mid_x + 18, mid_y + 39, mid_x + mid_w - 18, mid_y + 39);
pt_in(mid_x, mid_y, mid_w, 34) ? ui_hover_id = 1300;

graph_x = mid_x + 16; graph_y = mid_y + 48; graph_w = mid_w - 32; graph_h = 190;
