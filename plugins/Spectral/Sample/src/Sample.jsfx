desc:Load-and-Go Psycho MultiSampler (FluxBridge + tape + hybrid)
tags:instrument sampler ui

// Slot 0 is the load-and-go sample bank.
// Use the filename slot UI for this effect and choose Open Multiple... on slot 0.
filename:0,sample.wav

slider1:0<0,1,1{idle,rescan}>--Force rescan slot 0
slider2:3<0.1,500,0.1>--Attack (ms)
slider3:110<1,5000,1>--Decay (ms)
slider4:0.82<0,1,0.001>--Sustain level
slider5:180<5,5000,1>--Release (ms)
slider6:0<-1,1,0.001>--Color (-warmer / +brighter)
slider7:0<-1,1,0.001>--Focus (-softer / +clearer)
slider8:0.18<0,1,0.001>--Width
slider9:0.22<0,1,0.001>--Liveliness
slider10:0.30<0,1,0.001>--Truth (0=matched / 1=raw)
slider11:-9<-24,12,0.1>--Output (dB)
slider12:0<-24,24,0.01>--Pitch (semitones)
slider13:0<0,1,1{random,sequence}>--Sequence mode
slider14:1<1,4,0.001>--Stretch (x)
slider15:0<0,1,0.001>--Weight
slider16:0<0,2,1{auto,punch,off}>--Transient mode
slider17:1<0,2,1{raw,tape,hybrid}>--Playback mode
slider18:0.55<0,1,0.001>--Granular body
slider19:0.35<0,1,0.001>--Tail borrow
slider20:20<0,2000,1>--Hold (ms)
@init
/*
Multi-file slot API used here:
  h     = file_open_multi(slot[, mode]);
  count = file_multi_count(h);
  ok    = file_multi_select(h, index);

After selecting an entry, the normal file APIs operate on the currently selected file:
  file_avail(h);
  file_mem(h, memIndex, length);
  file_riff(h, nch, srate);
  file_rewind(h);
  file_close(h);

This instrument stays load-and-go:
- slot 0 is polled automatically
- a cheap signature pass detects changes
- the bank reload is deferred until voices are idle
- no zones or bank metadata are required
*/

function clamp(x lo hi)
(
  min(hi, max(lo, x));
);

function clamp01(x)
(
  clamp(x, 0, 1);
);

function wrap_in_range(x lo hi) local(span)
(
  span = max(1, hi - lo);
  while (x < lo) (x += span;);
  while (x >= hi) (x -= span;);
  x;
);

function curve_denorm(norm vmin vmax mode) local(n ratio)
(
  n = clamp01(norm);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    exp(log(max(vmin, 0.000001)) + n * log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    sqrt(n);
  ) : (
    vmin + n * (vmax - vmin);
  );
);

function curve_norm(val vmin vmax mode) local(v ratio)
(
  v = clamp(val, vmin, vmax);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    clamp01(log(max(v, 0.000001) / max(vmin, 0.000001)) / log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    clamp01(v * v);
  ) : (
    clamp01((v - vmin) / max(vmax - vmin, 0.000001));
  );
);

function env_curve01(t) local(k d)
(
  k = ENV_VIS_SHAPE;
  d = 1 - exp(-k);
  d <= 0 ? clamp01(t) : (1 - exp(-k * clamp01(t))) / d;
);

function stretch_window(age gsize) local(t tri)
(
  t = clamp01((age + 0.5) / max(gsize, 1));
  tri = 1 - abs(2 * t - 1);
  tri = clamp01(tri);
  tri * tri * (3 - 2 * tri);
);

function lerp(a b t)
(
  a + (b-a)*t;
);

function db2amp(db)
(
  exp(db * 0.11512925464970229);
);

function midi_ratio(semi)
(
  exp(semi * 0.0577622650466621);
);

function cents_ratio(cents)
(
  exp(cents * 0.000577622650466621);
);

function cc_to_u01(cc)
(
  clamp01(cc / 127);
);

function cc_to_s11(cc)
(
  clamp((cc / 63.5) - 1, -1, 1);
);

function cc_to_ratio(cc)
(
  cc <= 63 ? (cc / 63) : (1 + ((cc - 64) / 63) * 3);
);

function m2e_apply_cc(base ccnum ccval) local(off)
(
  off = ccnum - base;

  off == 0  ? m2e_env_raw = cc_to_u01(ccval);
  off == 5  ? m2e_rigid_abs_raw = cc_to_u01(ccval);
  off == 6  ? m2e_rigid_rel_raw = cc_to_u01(ccval);
  off == 17 ? m2e_impact_raw = cc_to_u01(ccval);
  off == 18 ? m2e_pan_raw = cc_to_u01(ccval);
  off == 19 ? m2e_entropy_raw = cc_to_u01(ccval);
  off == 20 ? m2e_axis_v_raw = cc_to_s11(ccval);
  off == 21 ? m2e_axis_acc_raw = cc_to_s11(ccval);
  off == 24 ? m2e_lat_v_raw = cc_to_s11(ccval);
  off == 28 ? m2e_lat_amp_raw = cc_to_u01(ccval);
  off == 29 ? m2e_micro_raw = cc_to_u01(ccval);
  off == 31 ? m2e_meso_raw = cc_to_u01(ccval);
  off == 32 ? m2e_macro_raw = cc_to_u01(ccval);
  off == 33 ? m2e_excite_raw = cc_to_u01(ccval);
  off == 34 ? m2e_activity_raw = cc_to_ratio(ccval);

  m2e_rigid_raw = 0.5 * (m2e_rigid_abs_raw + m2e_rigid_rel_raw);
);

function m2e_decode_snapshot(base) local(i cc)
(
  i = 0;
  while (i < M2E_LANE_COUNT) (
    (m2e_clock_samps - m2e_cc_age_base[base + i]) <= (m2e_detect_window_samps * 4) ? (
      cc = clamp(m2e_cc_val_base[base + i], 0, 127);
      m2e_apply_cc(base, base + i, cc);
    );
    i += 1;
  );
);

function m2e_detect_base(now_samps) local(base k age count g0 g1 g2 g3 best best_count)
(
  best = -1;
  best_count = 0;

  base = M2E_BASE_MIN;
  while (base <= M2E_BASE_MAX) (
    count = 0;
    g0 = 0; g1 = 0; g2 = 0; g3 = 0;

    k = 0;
    while (k < M2E_LANE_COUNT) (
      age = now_samps - m2e_cc_age_base[base + k];
      age <= m2e_detect_window_samps ? (
        count += 1;
        k <= 4 ? g0 = 1;
        (k >= 15 && k <= 19) ? g1 = 1;
        (k >= 20 && k <= 28) ? g2 = 1;
        k >= 29 ? g3 = 1;
      );
      k += 1;
    );

    (g0 && g1 && g2 && g3 && (count > best_count)) ? (
      best_count = count;
      best = base;
    );

    base += 1;
  );

  m2e_detect_count = best_count;
  best_count >= M2E_DETECT_MIN ? best : -1;
);

function m2e_reset() local(i)
(
  i = 0;
  while (i < 128) (
    m2e_cc_age_base[i] = -1000000000;
    m2e_cc_val_base[i] = 0;
    i += 1;
  );

  m2e_base = M2E_BASE_FIXED;
  m2e_detect_count = 0;
  m2e_active = 0;
  m2e_last_msg_samps = -1000000000;
  m2e_last_any_cc_samps = -1000000000;
  m2e_target = 0;
  m2e_mix = 0;

  m2e_env_raw = 0.5;
  m2e_rigid_abs_raw = 0;
  m2e_rigid_rel_raw = 0;
  m2e_rigid_raw = 0;
  m2e_impact_raw = 0;
  m2e_pan_raw = 0.5;
  m2e_entropy_raw = 0;
  m2e_axis_v_raw = 0;
  m2e_axis_acc_raw = 0;
  m2e_lat_v_raw = 0;
  m2e_lat_amp_raw = 0;
  m2e_micro_raw = 0;
  m2e_meso_raw = 0;
  m2e_macro_raw = 0;
  m2e_excite_raw = 0;
  m2e_activity_raw = 1;

  m2e_env_s = m2e_env_raw;
  m2e_rigid_s = m2e_rigid_raw;
  m2e_impact_s = m2e_impact_raw;
  m2e_pan_s = m2e_pan_raw;
  m2e_entropy_s = m2e_entropy_raw;
  m2e_axis_v_s = m2e_axis_v_raw;
  m2e_axis_acc_s = m2e_axis_acc_raw;
  m2e_lat_v_s = m2e_lat_v_raw;
  m2e_lat_amp_s = m2e_lat_amp_raw;
  m2e_micro_s = m2e_micro_raw;
  m2e_meso_s = m2e_meso_raw;
  m2e_macro_s = m2e_macro_raw;
  m2e_excite_s = m2e_excite_raw;
  m2e_activity_s = m2e_activity_raw;
);

function mono_frame(ptr nch frame) local(base)
(
  base = ptr + frame * nch;
  nch >= 2 ? 0.5 * (base[0] + base[1]) : base[0];
);

function pt_in(x y w h)
(
  mouse_x >= x && mouse_x <= (x + w) && mouse_y >= y && mouse_y <= (y + h);
);

function recent_penalty(sample_id) local(i pen)
(
  pen = 0;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] == sample_id ? pen += (RECENT_LEN - i);
    i += 1;
  );
  pen;
);

function push_recent(sample_id) local(i)
(
  i = RECENT_LEN - 1;
  while (i > 0) (
    recent_base[i] = recent_base[i-1];
    i -= 1;
  );
  recent_base[0] = sample_id;
);

function grain_hist_clear_voice(vix) local(base j)
(
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] = -1;
    grain_hist_pos_base[base + j] = -1000000;
    grain_hist_phase_base[base + j] = -1;
    j += 1;
  );
);

function reset_grain_histories() local(vix)
(
  vix = 0;
  while (vix < MAX_VOICES) (
    grain_hist_clear_voice(vix);
    vix += 1;
  );
);

function grain_hist_push(vix sid pos lo hi) local(base j span phasebin)
(
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  base = vix * GRAIN_HIST_LEN;
  j = GRAIN_HIST_LEN - 1;
  while (j > 0) (
    grain_hist_sid_base[base + j] = grain_hist_sid_base[base + j - 1];
    grain_hist_pos_base[base + j] = grain_hist_pos_base[base + j - 1];
    grain_hist_phase_base[base + j] = grain_hist_phase_base[base + j - 1];
    j -= 1;
  );
  grain_hist_sid_base[base] = sid;
  grain_hist_pos_base[base] = pos;
  grain_hist_phase_base[base] = phasebin;
);

function grain_sid_penalty(vix sid) local(base j pen)
(
  pen = 0;
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] == sid ? pen += (GRAIN_HIST_LEN - j) * 0.22;
    j += 1;
  );
  pen;
);

function grain_hist_penalty(vix sid pos lo hi) local(base j pen span phasebin hsid hpos hbin near1 near2)
(
  pen = 0;
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  near1 = max(12, floor(span * 0.09));
  near2 = max(24, floor(span * 0.18));
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    hsid = grain_hist_sid_base[base + j] | 0;
    hsid >= 0 ? (
      hpos = grain_hist_pos_base[base + j];
      hbin = grain_hist_phase_base[base + j] | 0;
      hsid == sid ? pen += (GRAIN_HIST_LEN - j) * 0.16;
      hbin == phasebin ? pen += (GRAIN_HIST_LEN - j) * 0.06;
      (hsid == sid && abs(pos - hpos) < near2) ? pen += (GRAIN_HIST_LEN - j) * 0.22;
      (hsid == sid && abs(pos - hpos) < near1) ? pen += (GRAIN_HIST_LEN - j) * 0.38;
      (hsid == sid && hbin == phasebin) ? pen += (GRAIN_HIST_LEN - j) * 0.14;
    );
    j += 1;
  );
  pen;
);

function choose_region_donor(src_sid region_mode wideness vix) local(
  src sm i pick accum totalw sid temp minspan
  src_lo src_hi src_span lo hi span
  brighterr sharperr transerr lenerr pitcherr regionerr histpen score weight
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    region_mode ? (
      src_lo = clamp(src[SM_TAILSTART], 0, max(0, src[SM_FRAMES] - 2));
      src_hi = max(src_lo + 1, src[SM_FRAMES] - 2);
      minspan = max(24, floor(hybrid_grain_samps * 0.22));
    ) : (
      src_lo = clamp(src[SM_HEADEND], 0, max(0, src[SM_TAILSTART] - 1));
      src_hi = clamp(src[SM_TAILSTART], src_lo + 1, max(src_lo + 1, src[SM_FRAMES] - 2));
      minspan = max(48, floor(hybrid_grain_samps * 0.36));
    );
    src_span = max(1, src_hi - src_lo);
    temp = lerp(10.0, 1.25, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        region_mode ? (
          lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
          hi = max(lo + 1, sm[SM_FRAMES] - 2);
        ) : (
          lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
          hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
        );
        span = max(1, hi - lo);

        span >= minspan ? (
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          regionerr = abs(log((span + 1) / (src_span + 1)));

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          histpen = grain_sid_penalty(vix, i);
          score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
          score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
          score += histpen * 0.24;

          weight = 0.0005 + exp(-score * temp);
          totalw += weight;
        );
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          region_mode ? (
            lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
            hi = max(lo + 1, sm[SM_FRAMES] - 2);
          ) : (
            lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
            hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
          );
          span = max(1, hi - lo);

          span >= minspan ? (
            brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
            sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
            transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
            lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
            regionerr = abs(log((span + 1) / (src_span + 1)));

            pitcherr = 0;
            (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
              pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
            );

            histpen = grain_sid_penalty(vix, i);
            score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
            score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
            score += histpen * 0.24;

            weight = 0.0005 + exp(-score * temp);
            accum += weight;
            accum >= pick ? (
              sid = i;
              i = sample_count;
            ) : i += 1;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);

function choose_region_pos(vix sid region_mode phase01 jitter_norm) local(
  sm lo hi span center pos jitter scale
  best bestscore score dist try limit
)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  region_mode ? (
    lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
    hi = max(lo + 1, sm[SM_FRAMES] - 2);
    limit = hybrid_tail_jitter;
  ) : (
    lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
    hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
    limit = hybrid_body_jitter;
  );
  span = max(1, hi - lo);
  center = lo + clamp01(phase01) * max(1, span - 1);
  best = clamp(center, lo, max(lo, hi - 1));
  bestscore = 1000000000;

  try = 0;
  while (try < GRAIN_CAND_TRIES) (
    scale = min(span * lerp(0.16, 0.52, clamp01(jitter_norm)), limit);
    jitter = (rand(1) - 0.5) * scale * 2;
    pos = center + jitter;
    region_mode ? (
      pos = clamp(pos, lo, max(lo, hi - 1));
    ) : (
      pos = wrap_in_range(pos, lo, hi);
    );
    dist = abs(pos - center) / max(1, span);
    score = grain_hist_penalty(vix, sid, pos, lo, hi) + dist * (region_mode ? 0.12 : 0.16);
    score < bestscore ? (
      bestscore = score;
      best = pos;
    );
    try += 1;
  );

  best;
);

function voices_busy() local(i v busy)
(
  busy = 0;
  i = 0;
  while (i < MAX_VOICES && !busy) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? busy = 1;
    i += 1;
  );
  busy;
);

function count_active_voices() local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? cnt += 1;
    i += 1;
  );
  cnt;
);

function estimate_pitch(sm) local(
  ptr nch sr frames attack
  start win endp i
  x prevsign signcur
  last_cross interval
  sumint sumint2 cnt
  mu var relvar freq note conf
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;
  attack = sm[SM_ATTACK] | 0;

  note = 60;
  conf = 0;

  start = attack + min(64, max(8, floor(frames * 0.02)));
  win   = min(2048, frames - start - 1);

  win > 256 ? (
    last_cross = -1;
    sumint = 0;
    sumint2 = 0;
    cnt = 0;

    x = mono_frame(ptr, nch, start);
    prevsign = x >= 0 ? 1 : -1;

    i = start + 1;
    endp = start + win;
    while (i < endp) (
      x = mono_frame(ptr, nch, i);
      signcur = x >= 0 ? 1 : -1;

      signcur != prevsign ? (
        last_cross >= 0 ? (
          interval = i - last_cross;
          interval > 1 ? (
            sumint += interval;
            sumint2 += interval * interval;
            cnt += 1;
          );
        );
        last_cross = i;
        prevsign = signcur;
      );

      i += 1;
    );

    cnt >= 8 ? (
      mu = sumint / cnt;
      var = max(0, sumint2 / cnt - mu * mu);
      relvar = sqrt(var) / max(mu, 0.000001);
      freq = sr / max(2 * mu, 1);

      (freq >= 30 && freq <= 4000) ? (
        note = 69 + 17.31234049066756 * log(freq / 440);
        conf = clamp01(1 - relvar * 4);
      );
    );
  );

  sm[SM_PITCHNOTE] = note;
  sm[SM_PITCHCONF] = conf;
);

function analyze_sample(sm) local(
  ptr nch sr frames scan i x ax prev lp hf prevhf
  peak sumsq sumabs sumdiff brightsum roughsum rms bright edge
  thresh attack attack_ms sharp transrich
  target_rms norm lpcoef
  head_ms head_end tail_start tail_thresh tail_minlen
  step chunkabs cnt j found
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;

  peak = 0;
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  brightsum = 0;
  roughsum = 0;
  prev = 0;
  prevhf = 0;
  lp = 0;

  scan = min(frames, max(256, floor(sr * 0.16)));
  lpcoef = clamp(1400 / max(sr, 1), 0.01, 0.35);

  i = 0;
  while (i < scan) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    peak = max(peak, ax);
    sumsq += x * x;
    sumabs += ax;
    i > 0 ? sumdiff += abs(x - prev);

    lp += (x - lp) * lpcoef;
    hf = x - lp;
    brightsum += abs(hf);
    i > 0 ? roughsum += abs(hf - prevhf);

    prev = x;
    prevhf = hf;
    i += 1;
  );

  rms = sqrt(sumsq / max(scan, 1));
  bright = clamp01((brightsum / max(sumabs, 0.000001) - 0.08) * 2.1);
  edge = clamp01((roughsum / max(brightsum, 0.000001)) * 0.34);

  thresh = max(peak * 0.12, rms * 1.8);
  attack = -1;
  i = 0;
  while (i < scan && attack < 0) (
    abs(mono_frame(ptr, nch, i)) >= thresh ? attack = i;
    i += 1;
  );
  attack < 0 ? attack = 0;

  attack_ms = 1000 * attack / max(sr, 1);
  sharp = clamp01((1 - min(1, attack_ms / 70)) * 0.72 + edge * 0.28);
  transrich = clamp01(sharp * 0.64 + edge * 0.18 + (1 - min(1, attack_ms / 55)) * 0.24 + bright * 0.06);

  head_ms = 8 + transrich * 48;
  head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
  head_end = clamp(head_end, 0, max(0, frames - 2));

  tail_thresh = max(rms * (0.46 + 0.22 * transrich), peak * (0.040 + 0.020 * bright));
  step = max(1, floor(frames / 1024));
  tail_start = max(head_end + 16, frames - 2);
  found = 0;
  i = frames - 1;
  while (i > head_end + step && !found) (
    chunkabs = 0;
    cnt = 0;
    j = 0;
    while (j < step && (i - j) >= 0) (
      chunkabs += abs(mono_frame(ptr, nch, i - j));
      cnt += 1;
      j += 1;
    );
    (chunkabs / max(cnt, 1)) > tail_thresh ? (
      tail_start = clamp(i + step * 2, head_end + 16, max(head_end + 16, frames - 2));
      found = 1;
    );
    i -= step;
  );

  tail_minlen = min(max(floor(sr * (0.08 + 0.04 * (1 - transrich))), 192), max(192, floor(frames * 0.34)));
  !found ? tail_start = clamp(floor(frames * (0.60 + 0.14 * (1 - transrich))), head_end + 16, max(head_end + 16, frames - 2));
  tail_start = min(tail_start, max(head_end + 16, frames - tail_minlen));
  tail_start <= (head_end + 8) ? tail_start = min(max(head_end + 24, floor(frames * 0.72)), max(head_end + 24, frames - 2));
  tail_start = clamp(tail_start, min(head_end + 1, max(0, frames - 2)), max(0, frames - 2));

  target_rms = 0.12;
  norm = clamp(target_rms / max(rms, 0.000001), 0.25, 4.0);

  sm[SM_RMS]    = rms;
  sm[SM_PEAK]   = peak;
  sm[SM_EDGE]   = edge;
  sm[SM_ATTACK] = attack;
  sm[SM_SHARP]  = sharp;
  sm[SM_NORM]   = norm;
  sm[SM_LENMS]  = 1000 * frames / max(sr, 1);
  sm[SM_BRIGHT] = bright;
  sm[SM_FLAGS]  = transrich;
  sm[SM_HEADEND] = head_end;
  sm[SM_TAILSTART] = tail_start;

  estimate_pitch(sm);
);

function reset_voices() local(i j v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    v[VC_STAGE] = ENV_OFF;
    i += 1;
  );
);

function reset_weight_buffers() local(i)
(
  weight_ap1_pos = 0;
  weight_ap2_pos = 0;
  weight_er_pos = 0;
  weight_in_lp_l = 0;
  weight_in_lp_r = 0;
  weight_wet_lp_l = 0;
  weight_wet_lp_r = 0;

  i = 0;
  while (i < AP_BUF_LEN) (
    weight_ap1_l_base[i] = 0;
    weight_ap1_r_base[i] = 0;
    weight_ap2_l_base[i] = 0;
    weight_ap2_r_base[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < ER_BUF_LEN) (
    weight_er_l_base[i] = 0;
    weight_er_r_base[i] = 0;
    i += 1;
  );
);


function reset_bank_state() local(i)
(
  sample_count = 0;
  bank_pitchiness = 0;
  bank_brightness = 0;
  bank_sharpness = 0;
  next_audio = AUDIO_BASE;
  seq_cursor = 0;
  last_sid = -1;
  last_note = -1;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] = -1;
    i += 1;
  );
  reset_grain_histories();
  reset_voices();
  reset_weight_buffers();
  transient_guard_s = 0;
);

function load_one_selected_file(handle sample_index) local(
  ok istext nch sr avail words frames read_words sm
)
(
  ok = file_multi_select(handle, sample_index);
  ok ? (
    istext = file_text(handle);
    !istext ? (
      nch = 0;
      sr = 0;
      file_riff(handle, nch, sr);

      (nch > 0 && sr > 1000) ? (
        avail = max(0, file_avail(handle) | 0);
        words = avail - (avail % max(nch, 1));
        frames = floor(words / max(nch, 1));

        (frames > 1 && (next_audio + words + 8) < MEM_LIMIT) ? (
          read_words = file_mem(handle, next_audio, words);
          read_words = max(0, read_words | 0);
          read_words -= (read_words % max(nch, 1));
          frames = floor(read_words / max(nch, 1));

          frames > 1 ? (
            sm = sample_meta_base + sample_count * SM_STRIDE;
            sm[SM_PTR]      = next_audio;
            sm[SM_NCH]      = nch;
            sm[SM_SR]       = sr;
            sm[SM_FRAMES]   = frames;
            sm[SM_LASTUSED] = -1000000;
            analyze_sample(sm);
            sample_count += 1;
            next_audio += read_words + 8;
          );
        );
      );
    );
  );
);

function load_bank() local(
  bank count i sm spread_step spread_root pitch_sum bright_sum sharp_sum
)
(
  reset_bank_state();

  bank = file_open_multi(0);
  bank >= 0 ? (
    count = min(MAX_SAMPLES, max(0, file_multi_count(bank) | 0));

    i = 0;
    while (i < count) (
      load_one_selected_file(bank, i);
      i += 1;
    );

    file_close(bank);
  );

  sample_count > 0 ? (
    spread_step = sample_count > 1 ? (ROOT_HIGH - ROOT_LOW) / (sample_count - 1) : 0;
    pitch_sum = 0;
    bright_sum = 0;
    sharp_sum = 0;
    i = 0;
    while (i < sample_count) (
      sm = sample_meta_base + i * SM_STRIDE;
      spread_root = ROOT_LOW + i * spread_step;
      sm[SM_ROOT] = sm[SM_PITCHCONF] > 0.55 ? clamp(sm[SM_PITCHNOTE], 0, 127) : spread_root;
      pitch_sum += sm[SM_PITCHCONF];
      bright_sum += sm[SM_BRIGHT];
      sharp_sum += sm[SM_SHARP];
      i += 1;
    );
    bank_pitchiness = clamp01(pitch_sum / sample_count);
    bank_brightness = bright_sum / sample_count;
    bank_sharpness = sharp_sum / sample_count;
  );

  bank_loaded = sample_count > 0;
  seq_cursor = 0;
  rescan_flash = 1;
  freembuf(next_audio);
);

function compute_slot_signature() local(
  bank count sig i ok istext nch sr avail peek_words got j v
)
(
  sig = -1;
  bank = file_open_multi(0);
  bank >= 0 ? (
    count = max(0, file_multi_count(bank) | 0);
    sig = 2166136261 + count * 131;

    i = 0;
    while (i < count) (
      ok = file_multi_select(bank, i);
      sig = sig * 1.000003 + ok * 17 + i * 19;
      ok ? (
        istext = file_text(bank);
        sig = sig * 1.000003 + istext * 23;
        !istext ? (
          nch = 0;
          sr = 0;
          file_riff(bank, nch, sr);
          avail = max(0, file_avail(bank) | 0);
          sig = sig * 1.000003 + nch * 31 + sr * 0.017 + avail * 0.0019;

          peek_words = min(SIG_PEEK_WORDS, avail);
          peek_words > 0 ? (
            got = max(0, file_mem(bank, sig_scratch_base, peek_words) | 0);
            j = 0;
            while (j < got) (
              v = sig_scratch_base[j];
              sig += abs(v) * (j + 1) * 0.173;
              j += 1;
            );
          );
        );
      );
      i += 1;
    );

    file_close(bank);
  );

  sig;
);

function schedule_rescan(sig force)
(
  pending_signature = sig;
  rescan_pending = 1;
  force ? rescan_force = 1;
);

function poll_slot(force) local(sig)
(
  sig = compute_slot_signature();
  force || sig != slot_signature_loaded ? schedule_rescan(sig, force);
);

function choose_sample(note velnorm) local(
  i sm sid score bright_t brighterr sharp_t sharperr
  rep rep_scale totalw pick accum weight temp
)
(
  sample_count <= 0 ? 0 : (
    sequence_mode ? (
      sid = seq_cursor % max(sample_count, 1);
      seq_cursor = (seq_cursor + 1) % max(sample_count, 1);
      sid;
    ) : (
      bright_t = clamp01(0.5 + slider6 * 0.20 + (velnorm - 0.5) * 0.06);
      sharp_t  = clamp01(0.48 + slider7 * 0.22 + (velnorm - 0.5) * 0.10);
      rep_scale = 0.30 + slider9 * 1.45;
      temp = lerp(4.0, 1.4, slider9);
      totalw = 0;

      i = 0;
      while (i < sample_count) (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - bright_t);
        sharperr  = abs(sm[SM_SHARP] - sharp_t);
        score = brighterr * 0.95 + sharperr * 1.10;
        score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
        weight = 0.15 + exp(-score * temp);
        totalw += weight;
        i += 1;
      );

      totalw <= 0 ? (
        floor(rand(max(sample_count, 1)));
      ) : (
        pick = rand(totalw);
        accum = 0;
        sid = sample_count - 1;
        i = 0;
        while (i < sample_count) (
          sm = sample_meta_base + i * SM_STRIDE;
          brighterr = abs(sm[SM_BRIGHT] - bright_t);
          sharperr  = abs(sm[SM_SHARP] - sharp_t);
          score = brighterr * 0.95 + sharperr * 1.10;
          score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
          weight = 0.15 + exp(-score * temp);
          accum += weight;
          accum >= pick ? (
            sid = i;
            i = sample_count;
          ) : i += 1;
        );
        sid;
      );
    );
  );
);

function choose_tail_donor(src_sid wideness) local(
  src sm i pick accum totalw score weight sid
  brighterr sharperr transerr lenerr pitcherr tailerr temp
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    temp = lerp(8.0, 2.4, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
        sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
        transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
        lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
        tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

        pitcherr = 0;
        (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
          pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
        );

        score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
        score += pitcherr * (0.20 + 0.70 * bank_pitchiness);

        weight = 0.02 + exp(-score * temp);
        totalw += weight;
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
          score += pitcherr * (0.20 + 0.70 * bank_pitchiness);

          weight = 0.02 + exp(-score * temp);
          accum += weight;
          accum >= pick ? (
            sid = i;
            i = sample_count;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);


function alloc_voice() local(i v found best best_age)
(
  found = -1;
  best = 0;
  best_age = 100000000000;

  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] <= 0 ? (
      found = i;
      i = MAX_VOICES;
    ) : (
      v[VC_AGE] < best_age ? (
        best_age = v[VC_AGE];
        best = i;
      );
      i += 1;
    );
  );

  found >= 0 ? found : best;
);

function start_voice(note vel chan) local(
  velnorm sid sm donor donor_sm voice_idx v
  srcsr norm gain env0 lively playmode voice_stretch voice_stretch_norm
  driftcents raw_rate base_rate
  transrich transprot translock hold_ms trans_hold_src trans_hold_out attack_preroll
  j jmax pre startpos softskip gain_jit_db
  bodystart bodyend tailstart donor_tail min_body_span remain voice_hold_samps
)
(
  sample_count <= 0 ? 0 : (
    velnorm = vel / 127;
    sid = choose_sample(note, velnorm);
    sm = sample_meta_base + sid * SM_STRIDE;

    voice_idx = alloc_voice();
    v = voice_base + voice_idx * VC_STRIDE;

    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    grain_hist_clear_voice(voice_idx);

    note_counter += 1;
    last_note = note;
    last_sid = sid;

    lively = clamp01(slider9);
    playmode = playback_mode;
    playmode == 0 ? voice_stretch = 1 : voice_stretch = stretch_ratio;
    voice_stretch = max(1, voice_stretch);
    voice_stretch_norm = clamp01((voice_stretch - 1) / 3);

    srcsr = sm[SM_SR];
    norm  = sm[SM_NORM];
    gain  = (0.10 + 0.90 * (velnorm ^ 1.35)) * lerp(norm, 1, truth_mix);
    gain_jit_db = (rand(1) - 0.5) * lively * 0.8;
    gain *= db2amp(gain_jit_db);
    gain  = min(gain, 2.0);

    transrich = clamp01(sm[SM_FLAGS]);
    transprot = 0;
    transient_mode == 1 ? transprot = 1
    : transient_mode == 2 ? transprot = 0
    : transprot = clamp01((transrich - 0.38) / 0.44);
    translock = transprot >= 0.22 ? 1 : 0;

    driftcents = (rand(1) - 0.5) * (0.25 + lively * lively * 10.0);

    translock ? (
      attack_preroll = min(sm[SM_ATTACK], max(0, floor(srcsr * (0.00035 + 0.00045 * transprot))));
      jmax = floor(lively * (1 - transprot) * min(4, 1 + sm[SM_ATTACK] * 0.02));
      startpos = floor(sm[SM_ATTACK] - attack_preroll + (rand(1) - 0.5) * jmax);
    ) : (
      pre  = min(sm[SM_ATTACK], 8 + lively * 8);
      jmax = floor((0.25 + lively * 1.75) * min(16, 2 + sm[SM_ATTACK] * 0.08));
      softskip = max(0, -slider7) * min(16, 2 + sm[SM_ATTACK] * 0.06);
      startpos = floor(sm[SM_ATTACK] - pre + (rand(1) - 0.5) * jmax + softskip);
    );

    startpos = clamp(startpos, 0, max(0, sm[SM_FRAMES] - 2));
    raw_rate = (srcsr / srate) * midi_ratio(pitch_semi) * cents_ratio(driftcents);
    base_rate = raw_rate / voice_stretch;

    hold_ms = translock ? (lerp(3.5, 9.5, transprot) + voice_stretch_norm * lerp(0.0, 2.5, transprot)) : 0;
    hold_ms = min(hold_ms, sm[SM_LENMS] * 0.22);
    trans_hold_src = translock ? min(max(0, sm[SM_FRAMES] - 2 - startpos), floor(srcsr * hold_ms * 0.001)) : 0;
    trans_hold_out = translock ? clamp(floor(trans_hold_src / max(abs(raw_rate), 0.000001)), 0, 4096) : 0;

    bodystart = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_FRAMES] - 2));
    tailstart = clamp(sm[SM_TAILSTART], bodystart + 1, max(bodystart + 1, sm[SM_FRAMES] - 2));
    remain = max(1, tailstart - bodystart);
    min_body_span = min(max(48, floor(max(srcsr * (0.020 + 0.016 * lively), hybrid_grain_samps * 0.85))), remain);
    remain < min_body_span ? (
      bodystart = max(sm[SM_HEADEND], tailstart - min_body_span);
      bodystart = clamp(bodystart, 0, max(0, tailstart - 1));
    );
    bodyend = max(bodystart + 1, tailstart);
    voice_hold_samps = max(0, hold_samps);

    donor = choose_region_donor(sid, 1, tail_borrow * (0.55 + 0.45 * lively), voice_idx);
    donor < 0 ? donor = sid;
    donor_sm = sample_meta_base + donor * SM_STRIDE;
    donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));

    v[VC_ACTIVE] = 1;
    v[VC_NOTE]   = note;
    v[VC_CHAN]   = chan;
    v[VC_SAMPLE] = sid;
    v[VC_POS]    = startpos;
    v[VC_RATE]   = base_rate;
    v[VC_BASE]   = gain;
    env0 = (attack_samps <= 1 || (translock && attack_samps <= floor(0.010 * srate))) ? 1 : 0;
    v[VC_ENV]    = env0;
    v[VC_ASTEP]  = attack_coef;
    v[VC_DSTEP]  = decay_coef;
    v[VC_RSTEP]  = release_coef;
    v[VC_HLEFT]  = voice_hold_samps;
    v[VC_STAGE]  = env0 >= 1 ? (voice_hold_samps > 0 ? ENV_HOLD : ENV_DECAY) : ENV_ATTACK;
    v[VC_AGE]    = note_counter;

    v[VC_GMODE]    = (playmode == 2) ? 1 : 0;
    v[VC_OHOP]     = hybrid_hop_samps;
    v[VC_GSIZE]    = hybrid_grain_samps;
    v[VC_GTIMER]   = max(1, trans_hold_out + floor(hybrid_hop_samps * 0.6));
    v[VC_NEXTSRC]  = max(bodystart, min(startpos, bodyend - 1));
    v[VC_SRCHOP]   = max(0.25, abs(base_rate) * hybrid_hop_samps);
    v[VC_CANSPAWN] = (playmode == 2 && granular_amt > 0.0001) ? 1 : 0;
    v[VC_TLEFT]    = trans_hold_out;
    v[VC_TPROT]    = transprot;
    v[VC_DONOR]    = donor;
    v[VC_DONORPOS] = donor_tail;
    v[VC_BODYSTART]= bodystart;
    v[VC_TAILSTART]= tailstart;
    v[VC_BODYEND]  = bodyend;
    v[VC_GMIX]     = granular_amt;
    v[VC_TAILMIX]  = tail_borrow;
    v[VC_MODE]     = playmode;
    v[VC_STRETCH]  = voice_stretch;
    v[VC_THOLD]    = max(1, trans_hold_out);

    sm[SM_LASTUSED] = note_counter;
    push_recent(sid);
  );
);

function release_voice(note chan) local(i v donor donor_sm donor_tail)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_NOTE] == note && v[VC_CHAN] == chan && v[VC_STAGE] != ENV_RELEASE) ? (
      release_samps <= 1 ? (
        v[VC_ENV] = 0;
        v[VC_STAGE] = ENV_OFF;
        v[VC_ACTIVE] = 0;
      ) : (
        v[VC_STAGE] = ENV_RELEASE;
        v[VC_RSTEP] = release_coef;
        v[VC_HLEFT] = 0;
        v[VC_TLEFT] = 0;
        (v[VC_GMODE] > 0) ? (
          v[VC_CANSPAWN] = v[VC_GMIX] > 0.0001 ? 1 : 0;
          v[VC_POS] < v[VC_TAILSTART] ? v[VC_POS] = v[VC_TAILSTART];
          v[VC_NEXTSRC] < v[VC_TAILSTART] ? v[VC_NEXTSRC] = v[VC_TAILSTART];
          donor = v[VC_DONOR] | 0;
          donor_sm = sample_meta_base + donor * SM_STRIDE;
          donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));
          v[VC_DONORPOS] < donor_tail ? v[VC_DONORPOS] = donor_tail;
          v[VC_GTIMER] = min(v[VC_GTIMER], 1);
        ) : (
          v[VC_CANSPAWN] = 0;
        );
      );
    );
    i += 1;
  );
);

function ui_button(id x y w h) local(hot clicked)
(
  clicked = 0;
  hot = pt_in(x, y, w, h);

  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_pressed && hot && ui_active < 0 ? ui_active = id;
  ui_active == id ? (
    !mouse_down ? (
      hot ? clicked = 1;
      ui_active = -1;
    );
  );

  (hot || ui_active == id) ? (
    gfx_r = 0.24; gfx_g = 0.51; gfx_b = 0.76; gfx_a = 1;
  ) : (
    gfx_r = 0.16; gfx_g = 0.20; gfx_b = 0.26; gfx_a = 1;
  );
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.34; gfx_g = 0.42; gfx_b = 0.52; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);

  clicked;
);

function ui_knob(id x y r val vmin vmax defval wheel_step) local(hot norm ang px py vv dbl step_amt)
(
  hot = ((mouse_x - x) * (mouse_x - x) + (mouse_y - y) * (mouse_y - y)) <= r * r;
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    abs(val - defval) > 0.0000001 ? (
      val = defval;
      ui_value_changed = 1;
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
      ui_active = -1;
    ) : (
      ui_active = id;
      ui_down_y = mouse_y;
      ui_down_val = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(ui_down_val - (mouse_y - ui_down_y) / 150);
      vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
      abs(vv - val) > 0.0000001 ? (
        val = vv;
        ui_value_changed = 1;
      );
    ) : (
      ui_active = -1;
    );
  );

  gfx_r = 0.11; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
  gfx_circle(x, y, r, 1);
  gfx_r = 0.22; gfx_g = 0.28; gfx_b = 0.35; gfx_a = 1;
  gfx_circle(x, y, r, 0);

  norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);
  ang = (-0.75 + norm * 1.5) * 3.14159265358979;
  px = x + cos(ang) * (r - 7);
  py = y + sin(ang) * (r - 7);

  gfx_r = hot || ui_active == id ? 0.85 : 0.68;
  gfx_g = hot || ui_active == id ? 0.92 : 0.78;
  gfx_b = 0.98;
  gfx_a = 1;
  gfx_line(x, y, px, py);

  (hot || ui_active == id) ? (
    gfx_r = 0.35; gfx_g = 0.60; gfx_b = 0.86; gfx_a = 1;
    gfx_circle(x, y, r + 2, 0);
  );

  val;
);

function ui_vslider(id x y w h val vmin vmax curve_mode defval wheel_step) local(hot norm py vv fillh dbl step_amt)
(
  hot = pt_in(x, y, w, h);
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    abs(val - defval) > 0.0000001 ? (
      val = defval;
      ui_value_changed = 1;
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
      ui_active = -1;
    ) : (
      ui_active = id;
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, curve_mode);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, curve_mode);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(1 - ((mouse_y - y) / max(h, 1)));
      vv = curve_denorm(norm, vmin, vmax, curve_mode);
      abs(vv - val) > 0.0000001 ? (
        val = vv;
        ui_value_changed = 1;
      );
    ) : (
      ui_active = -1;
    );
  );

  gfx_r = 0.10; gfx_g = 0.13; gfx_b = 0.17; gfx_a = 1;
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.20; gfx_g = 0.25; gfx_b = 0.31; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);

  norm = curve_norm(val, vmin, vmax, curve_mode);
  fillh = clamp01(norm) * h;
  gfx_r = 0.26; gfx_g = 0.56; gfx_b = 0.84; gfx_a = 0.88;
  gfx_rect(x + 2, y + h - fillh + 2, w - 4, max(0, fillh - 4), 1);

  py = y + h - norm * h;
  gfx_r = 0.90; gfx_g = 0.95; gfx_b = 1.0; gfx_a = 1;
  gfx_rect(x - 2, py - 3, w + 4, 6, 1);

  hot || ui_active == id ? (
    gfx_r = 0.34; gfx_g = 0.64; gfx_b = 0.90; gfx_a = 1;
    gfx_rect(x - 2, y - 2, w + 4, h + 4, 0);
  );

  val;
);

function draw_curve_line(x1 y1 x2 y2) local(i steps t u px py nx ny)
(
  steps = 16;
  px = x1;
  py = y1;
  i = 1;
  while (i <= steps) (
    t = i / steps;
    u = env_curve01(t);
    nx = x1 + (x2 - x1) * t;
    ny = y1 + (y2 - y1) * u;
    gfx_line(px, py, nx, ny);
    px = nx;
    py = ny;
    i += 1;
  );
);

function draw_tooltip_box() local(tw1 th1 tw2 th2 tw th pad bx by bw bh)
(
  strlen(#tip_title) > 0 ? (
    pad = 10;

    gfx_setfont(1, "Arial", 14, 0);
    gfx_measurestr(#tip_title, tw1, th1);
    gfx_setfont(1, "Arial", 13, 0);
    gfx_measurestr(#tip_body, tw2, th2);

    tw = max(tw1, tw2);
    th = th1 + th2 + 6;
    bw = tw + pad * 2;
    bh = th + pad * 2;

    bx = clamp(mouse_x + 18, 8, gfx_w - bw - 8);
    by = clamp(mouse_y + 18, 8, gfx_h - bh - 8);

    gfx_r = 0.02; gfx_g = 0.03; gfx_b = 0.05; gfx_a = 0.65;
    gfx_rect(bx + 3, by + 4, bw, bh, 1);

    gfx_r = 0.085; gfx_g = 0.10; gfx_b = 0.135; gfx_a = 0.96;
    gfx_rect(bx, by, bw, bh, 1);
    gfx_r = 0.28; gfx_g = 0.48; gfx_b = 0.72; gfx_a = 1;
    gfx_rect(bx, by, bw, bh, 0);

    gfx_setfont(1, "Arial", 14, 0);
    gfx_r = 0.93; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad - 1;
    gfx_drawstr(#tip_title);

    gfx_setfont(1, "Arial", 13, 0);
    gfx_r = 0.73; gfx_g = 0.80; gfx_b = 0.90; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad + th1 + 3;
    gfx_drawstr(#tip_body);
  );
);

MAX_SAMPLES = 64;
MAX_VOICES  = 16;
RECENT_LEN  = 8;
ROOT_LOW    = 36;
ROOT_HIGH   = 84;
SIG_PEEK_WORDS = 48;
AP_BUF_LEN  = 4096;
ER_BUF_LEN  = 24576;
GRAIN_HIST_LEN = 6;
GRAIN_PHASE_BINS = 8;
GRAIN_CAND_TRIES = 5;

SM_PTR       = 0;
SM_NCH       = 1;
SM_SR        = 2;
SM_FRAMES    = 3;
SM_ATTACK    = 4;
SM_RMS       = 5;
SM_PEAK      = 6;
SM_EDGE      = 7;
SM_SHARP     = 8;
SM_PITCHNOTE = 9;
SM_PITCHCONF = 10;
SM_ROOT      = 11;
SM_NORM      = 12;
SM_LASTUSED  = 13;
SM_LENMS     = 14;
SM_BRIGHT    = 15;
SM_FLAGS     = 16;
SM_HEADEND   = 17;
SM_TAILSTART = 18;
SM_STRIDE    = 19;

VC_ACTIVE    = 0;
VC_NOTE      = 1;
VC_CHAN      = 2;
VC_SAMPLE    = 3;
VC_POS       = 4;
VC_RATE      = 5;
VC_BASE      = 6;
VC_ENV       = 7;
VC_ASTEP     = 8;
VC_DSTEP     = 9;
VC_RSTEP     = 10;
VC_STAGE     = 11;
VC_AGE       = 12;
VC_GMODE     = 13;
VC_OHOP      = 14;
VC_GSIZE     = 15;
VC_GTIMER    = 16;
VC_NEXTSRC   = 17;
VC_SRCHOP    = 18;
VC_CANSPAWN  = 19;
VC_TLEFT     = 20;
VC_TPROT     = 21;
VC_DONOR     = 22;
VC_DONORPOS  = 23;
VC_BODYSTART = 24;
VC_TAILSTART = 25;
VC_GMIX      = 26;
VC_TAILMIX   = 27;
VC_MODE      = 28;
VC_STRETCH   = 29;
VC_THOLD     = 30;
VC_BODYEND   = 31;
VC_HLEFT     = 32;
VC_GBASE     = 33;

VG_ACTIVE    = 0;
VG_AGE       = 1;
VG_SRC       = 2;
VG_SID       = 3;
VG_RATE      = 4;
VG_GAIN      = 5;
VG_STRIDE    = 6;
NUM_GRAINS   = 4;

VC_STRIDE    = VC_GBASE + NUM_GRAINS * VG_STRIDE;

ENV_OFF     = 0;
ENV_ATTACK  = 1;
ENV_HOLD    = 2;
ENV_DECAY   = 3;
ENV_SUSTAIN = 4;
ENV_RELEASE = 5;

CURVE_LINEAR  = 0;
CURVE_TIME    = 1;
CURVE_SUSTAIN = 2;
ENV_VIS_SHAPE = 6.90775527898214;

MASK_S1  = 1;
MASK_S2  = 2;
MASK_S3  = 4;
MASK_S4  = 8;
MASK_S5  = 16;
MASK_S6  = 32;
MASK_S7  = 64;
MASK_S8  = 128;
MASK_S9  = 256;
MASK_S10 = 512;
MASK_S11 = 1024;
MASK_S12 = 2048;
MASK_S13 = 4096;
MASK_S14 = 8192;
MASK_S15 = 16384;
MASK_S16 = 32768;
MASK_S17 = 65536;
MASK_S18 = 131072;
MASK_S19 = 262144;
MASK_S20 = 524288;

M2E_LANE_COUNT = 35;
M2E_BASE_FIXED = 20;
M2E_BASE_MIN   = M2E_BASE_FIXED;
M2E_BASE_MAX   = M2E_BASE_FIXED;
M2E_DETECT_MIN = 10;
M2E_CHAN       = 0;

sample_meta_base = 0;
voice_base = sample_meta_base + MAX_SAMPLES * SM_STRIDE;
recent_base = voice_base + MAX_VOICES * VC_STRIDE;
grain_hist_sid_base = recent_base + RECENT_LEN + 32;
grain_hist_pos_base = grain_hist_sid_base + MAX_VOICES * GRAIN_HIST_LEN;
grain_hist_phase_base = grain_hist_pos_base + MAX_VOICES * GRAIN_HIST_LEN;
sig_scratch_base = grain_hist_phase_base + MAX_VOICES * GRAIN_HIST_LEN + 32;

m2e_cc_age_base = sig_scratch_base + SIG_PEEK_WORDS + 64;
m2e_cc_val_base = m2e_cc_age_base + 128;

weight_ap1_l_base = m2e_cc_val_base + 128 + 64;
weight_ap1_r_base = weight_ap1_l_base + AP_BUF_LEN;
weight_ap2_l_base = weight_ap1_r_base + AP_BUF_LEN;
weight_ap2_r_base = weight_ap2_l_base + AP_BUF_LEN;
weight_er_l_base  = weight_ap2_r_base + AP_BUF_LEN;
weight_er_r_base  = weight_er_l_base + ER_BUF_LEN;

AUDIO_BASE  = weight_er_r_base + ER_BUF_LEN + 256;
MEM_LIMIT   = max(AUDIO_BASE + 1024, (__memtop() | 0) - 256);

note_counter = 0;
bank_loaded = 0;
bank_pitchiness = 0;
bank_brightness = 0;
bank_sharpness = 0;
truth_mix = 0;
out_trim = 1;
pitch_semi = 0;
sequence_mode = 0;
seq_cursor = 0;
playback_mode = 1;
granular_amt = 0.55;
tail_borrow = 0.35;
stretch_ratio = 1;
stretch_norm = 0;
hybrid_grain_samps = 1536;
hybrid_hop_samps = 256;
hybrid_body_jitter = 64;
hybrid_tail_jitter = 256;
stretch_grain_samps = 1024;
stretch_hop_samps = 256;
attack_samps = 64;
decay_samps = 2048;
sustain_level = 0.8;
release_samps = 2048;
hold_samps = 0;
attack_coef = 1;
decay_coef = 1;
release_coef = 0;
weight_amt = 0;
weight_mix = 0;
weight_body = 0;
weight_sat = 0;
weight_in_coeff = 0.02;
weight_wet_coeff = 0.01;
weight_ap_g1 = 0.2;
weight_ap_g2 = 0.2;
weight_ap1_len = 192;
weight_ap2_len = 384;
weight_tap1 = 384;
weight_tap2 = 672;
weight_tap3 = 960;
weight_tap4 = 1536;
weight_tap5 = 2256;
weight_tap6 = 3264;
weight_ap1_pos = 0;
weight_ap2_pos = 0;
weight_er_pos = 0;
weight_in_lp_l = 0;
weight_in_lp_r = 0;
weight_wet_lp_l = 0;
weight_wet_lp_r = 0;

slot_signature_loaded = -999999;
pending_signature = -999999;
rescan_pending = 0;
rescan_force = 0;
force_rescan_flag = 1;
poll_counter = 0;
poll_interval_samps = 22050;
rescan_flash = 0;
last_note = -1;
last_sid = -1;

ui_active = -1;
ui_down_y = 0;
ui_down_val = 0;
ui_prev_down = 0;
ui_prev_rdown = 0;
ui_value_changed = 0;
ui_hover_id = -1;
ui_wheel = 0;
ui_wheel_used = 0;
ui_now = 0;
ui_last_click_id = -1;
ui_last_click_t = -10;
ui_dblclick_time = 0.32;

mix_fast = 0;
mix_slow = 0;
tone_lp_l = 0;
tone_lp_r = 0;
focus_lp_l = 0;
focus_lp_r = 0;


tone_lp_coeff = 0.04;
focus_lp_coeff = 0.08;
env_att_coeff = 0.12;
env_rel_coeff = 0.01;
m2e_smooth_coeff = 0.002;
m2e_mode_coeff = 0.001;
m2e_detect_window_samps = 24000;
m2e_timeout_samps = 96000;
m2e_clock_samps = 0;
transient_guard_s = 0;

reset_bank_state();
m2e_reset();

@slider
attack_samps = max(1, floor(slider2 * srate * 0.001));
decay_samps = max(1, floor(slider3 * srate * 0.001));
sustain_level = clamp01(slider4);
release_samps = max(1, floor(slider5 * srate * 0.001));
hold_samps = max(0, floor(slider20 * srate * 0.001));
attack_coef = attack_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / attack_samps));
decay_coef = decay_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / decay_samps));
release_coef = release_samps <= 1 ? 0 : exp(-6.90775527898214 / release_samps);
truth_mix = clamp01(slider10);
out_trim = db2amp(slider11);
pitch_semi = clamp(slider12, -24, 24);
sequence_mode = (slider13 | 0) ? 1 : 0;
stretch_ratio = clamp(slider14, 1, 4);
stretch_norm = clamp01((stretch_ratio - 1) / 3);
weight_amt = clamp01(slider15);
transient_mode = clamp(slider16 | 0, 0, 2);
playback_mode = clamp(slider17 | 0, 0, 2);
granular_amt = clamp01(slider18);
tail_borrow = clamp01(slider19);
poll_interval_samps = max(1024, floor(0.35 * srate));

stretch_grain_samps = clamp(floor(srate * lerp(0.024, 0.070, stretch_norm)), 192, 4096);
stretch_hop_samps = max(24, floor(stretch_grain_samps * lerp(0.34, 0.22, stretch_norm)));
hybrid_grain_samps = clamp(floor(srate * lerp(0.028, 0.090, granular_amt) * lerp(1.0, 1.30, stretch_norm)), 160, 4096);
hybrid_hop_samps = max(20, floor(hybrid_grain_samps * lerp(0.34, 0.16, granular_amt)));
hybrid_body_jitter = max(6, floor(hybrid_grain_samps * (0.04 + 0.18 * slider9)));
hybrid_tail_jitter = max(24, floor(hybrid_grain_samps * (0.16 + 0.28 * tail_borrow + 0.10 * slider9)));

weight_scale = 1 + stretch_norm * 1.8;
weight_ap1_len = clamp(floor(srate * (0.0032 * weight_scale)), 16, AP_BUF_LEN - 1);
weight_ap2_len = clamp(floor(srate * (0.0066 * weight_scale)), 24, AP_BUF_LEN - 1);
weight_tap1 = clamp(floor(srate * (0.0085 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap2 = clamp(floor(srate * (0.0135 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap3 = clamp(floor(srate * (0.0205 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap4 = clamp(floor(srate * (0.0315 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap5 = clamp(floor(srate * (0.0470 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap6 = clamp(floor(srate * (0.0680 * weight_scale)), 1, ER_BUF_LEN - 1);

weight_mix = weight_amt * (0.10 + 0.42 * max(stretch_norm, 0.35));
weight_body = weight_amt * (0.02 + 0.10 * max(stretch_norm, 0.25));
weight_sat = weight_amt * (0.01 + 0.05 * stretch_norm);
weight_ap_g1 = clamp(0.10 + weight_amt * (0.28 + 0.10 * stretch_norm), 0, 0.72);
weight_ap_g2 = clamp(0.08 + weight_amt * (0.25 + 0.14 * stretch_norm), 0, 0.72);
weight_in_coeff = clamp((1400 - 700 * stretch_norm) / max(srate, 1), 0.002, 0.12);
weight_wet_coeff = clamp((900 - 350 * stretch_norm) / max(srate, 1), 0.001, 0.08);

tone_lp_coeff = clamp(1900 / max(srate, 1), 0.005, 0.18);
focus_lp_coeff = clamp(4400 / max(srate, 1), 0.01, 0.40);
env_att_coeff = clamp(1200 / max(srate, 1), 0.02, 0.5);
env_rel_coeff = clamp(60 / max(srate, 1), 0.001, 0.12);
m2e_smooth_coeff = clamp(42 / max(srate, 1), 0.0006, 0.02);
m2e_mode_coeff = clamp(24 / max(srate, 1), 0.0004, 0.02);
m2e_detect_window_samps = max(1024, floor(0.75 * srate));
m2e_timeout_samps = max(2048, floor(1.7 * srate));

((slider1 | 0) > 0) ? (
  force_rescan_flag = 1;
  slider1 = 0;
  sliderchange(MASK_S1);
);

@block
m2e_clock_samps += samplesblock;

force_rescan_flag ? (
  poll_slot(1);
  force_rescan_flag = 0;
  poll_counter = 0;
);

poll_counter += samplesblock;
while (poll_counter >= poll_interval_samps) (
  poll_counter -= poll_interval_samps;
  poll_slot(0);
);

while (midirecv(offset, msg1, msg23)) (
  status = msg1 & 240;
  chan   = msg1 & 15;
  note   = msg23 & 127;
  vel    = (msg23 / 256) & 127;

  status == 176 ? (
    (chan == M2E_CHAN) ? (
      ccnum = note;
      ccval = vel;

      (ccnum >= M2E_BASE_FIXED && ccnum < (M2E_BASE_FIXED + M2E_LANE_COUNT)) ? (
        m2e_cc_age_base[ccnum] = m2e_clock_samps;
        m2e_cc_val_base[ccnum] = ccval;
        m2e_last_any_cc_samps = m2e_clock_samps;

        m2e_base = M2E_BASE_FIXED;
        m2e_last_msg_samps = m2e_clock_samps;
        m2e_apply_cc(m2e_base, ccnum, ccval);
      );
    );
    midisend(offset, msg1, msg23);
  ) : (
    (status == 144 && vel > 0) ? (
      bank_loaded ? start_voice(note, vel, chan) : midisend(offset, msg1, msg23);
    ) : (
      (status == 128 || (status == 144 && vel == 0)) ? (
        bank_loaded ? release_voice(note, chan) : midisend(offset, msg1, msg23);
      ) : (
        midisend(offset, msg1, msg23);
      );
    );
  );
);

cand_base = m2e_detect_base(m2e_clock_samps);
cand_base >= 0 ? (
  m2e_base = M2E_BASE_FIXED;
  m2e_decode_snapshot(m2e_base);
  m2e_active = 1;
);

(m2e_active && ((m2e_clock_samps - m2e_last_msg_samps) > m2e_timeout_samps)) ? (
  m2e_active = 0;
);

m2e_target = m2e_active ? 1 : 0;

rescan_pending ? (
  (!voices_busy() || rescan_force) ? (
    load_bank();
    slot_signature_loaded = pending_signature;
    rescan_pending = 0;
    rescan_force = 0;
  );
);

@sample
outL = 0;
outR = 0;
punch_bus = 0;

i = 0;
while (i < MAX_VOICES) (
  v = voice_base + i * VC_STRIDE;

  v[VC_ACTIVE] > 0 ? (
    sid = v[VC_SAMPLE] | 0;
    sm  = sample_meta_base + sid * SM_STRIDE;
    frames = sm[SM_FRAMES] | 0;
    ptr = sm[SM_PTR] | 0;
    nch = max(1, sm[SM_NCH] | 0);

    stage = v[VC_STAGE] | 0;
    tleft = max(0, floor(v[VC_TLEFT]));
    body_start = max(0, floor(v[VC_BODYSTART]));
    tailstart = clamp(floor(v[VC_TAILSTART]), body_start, max(body_start, frames - 2));
    body_end = clamp(floor(v[VC_BODYEND]), body_start + 1, max(body_start + 1, frames - 2));

    rawL = 0;
    rawR = 0;
    grainL = 0;
    grainR = 0;
    got_raw = 0;
    got_grain = 0;
    direct_alive = 0;
    activeg = 0;

    // Direct playback path always carries the head and the core identity.
    pos = v[VC_POS];
    held_body_only = (v[VC_GMODE] > 0 && stage != ENV_RELEASE);
    body_cutoff = max(body_start + 1, tailstart);
    held_body_only && pos >= body_cutoff ? (
      pos = body_cutoff;
      v[VC_POS] = pos;
    ) : (
      ip = pos | 0;
      ip < (frames - 1) ? (
        frac = pos - ip;
        ip1 = ip + 1;
        p0 = ptr + ip * nch;
        p1 = ptr + ip1 * nch;

        nch >= 2 ? (
          rawL = p0[0] + (p1[0] - p0[0]) * frac;
          rawR = p0[1] + (p1[1] - p0[1]) * frac;
        ) : (
          x = p0[0] + (p1[0] - p0[0]) * frac;
          rawL = x;
          rawR = x;
        );

        got_raw = 1;
        direct_alive = 1;

        play_rate = v[VC_RATE];
        voice_stretch = max(1, v[VC_STRETCH]);
        (tleft > 0 && voice_stretch > 1.01 && v[VC_TPROT] > 0) ? (
          holdn = clamp01(tleft / max(1, v[VC_THOLD]));
          holdn = holdn * holdn;
          play_rate *= 1 + (voice_stretch - 1) * holdn * v[VC_TPROT];
        );

        pos += play_rate;
        held_body_only && pos >= body_cutoff ? (
          pos = body_cutoff;
          direct_alive = 0;
        );
        v[VC_POS] = pos;
        pos >= (frames - 1) ? direct_alive = 0;
      );
    );

    tleft > 0 ? (
      tleft -= 1;
      v[VC_TLEFT] = tleft;
    );

    // Hybrid mode overlays granular body/tail material after the protected head.
    (v[VC_GMODE] > 0 && v[VC_GMIX] > 0.0001) ? (
      stage == ENV_RELEASE ? (
        v[VC_NEXTSRC] < tailstart ? v[VC_NEXTSRC] = tailstart;
      );

      gran_hold_guard = ((stage == ENV_ATTACK || stage == ENV_HOLD) && direct_alive) ? 1 : 0;
      (tleft <= 0 && !gran_hold_guard) ? (
        hop = max(1, floor(v[VC_OHOP]));
        gsize = max(hop + 1, floor(v[VC_GSIZE]));
        timer = floor(v[VC_GTIMER]) - 1;
        spawn_guard = 0;

        while (timer <= 0 && spawn_guard < NUM_GRAINS && v[VC_CANSPAWN] > 0) (
          gslot = -1;
          oldest = 0;
          oldest_age = -1;

          gk = 0;
          while (gk < NUM_GRAINS) (
            gb = v + VC_GBASE + gk * VG_STRIDE;
            gb[VG_ACTIVE] <= 0 ? (
              gslot = gk;
              gk = NUM_GRAINS;
            ) : (
              gb[VG_AGE] > oldest_age ? (
                oldest_age = gb[VG_AGE];
                oldest = gk;
              );
              gk += 1;
            );
          );

          gslot < 0 ? gslot = oldest;
          gb = v + VC_GBASE + gslot * VG_STRIDE;

          source_exhausted = !direct_alive && stage != ENV_RELEASE;
          gsid = sid;
          gsm = sm;
          gframes = frames;
          gsrc = body_start;
          grate = v[VC_RATE];
          ggain = 1;
          ghist_lo = body_start;
          ghist_hi = max(body_start + 1, body_end);

          stage == ENV_RELEASE ? (
            donor_blend = clamp01(v[VC_TAILMIX]);
            self_lo = tailstart;
            self_hi = max(self_lo + 1, frames - 2);
            self_span = max(1, self_hi - self_lo);

            donor = v[VC_DONOR] | 0;
            donor < 0 ? donor = sid;
            donor_sm = sample_meta_base + donor * SM_STRIDE;
            donor_frames = donor_sm[SM_FRAMES] | 0;
            donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_frames - 2));
            donor_hi = max(donor_tail + 1, donor_frames - 2);
            donor_phase = clamp01((max(v[VC_DONORPOS], donor_tail) - donor_tail) / max(1, donor_hi - donor_tail));
            self_phase = clamp01((max(v[VC_POS], tailstart) - tailstart) / max(1, self_hi - self_lo));
            tail_phase01 = max(self_phase, donor_phase);

            self_pos = choose_region_pos(i, sid, 1, tail_phase01, 0.28 + 0.46 * donor_blend + 0.14 * slider9);
            self_pen = grain_hist_penalty(i, sid, self_pos, self_lo, self_hi);

            alt_sid = donor_blend > 0.001 ? choose_region_donor(sid, 1, clamp01(donor_blend * 0.55 + self_pen * 0.10 + 0.18), i) : sid;
            alt_sid != sid ? (
              alt_pos = choose_region_pos(i, alt_sid, 1, tail_phase01, 0.42 + 0.46 * donor_blend + 0.18 * slider9);
              alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
              alt_lo = clamp(alt_sm[SM_TAILSTART], 0, max(0, alt_sm[SM_FRAMES] - 2));
              alt_hi = max(alt_lo + 1, alt_sm[SM_FRAMES] - 2);
              alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

              (alt_pen > self_pen + 0.55 && sample_count > 2) ? (
                alt_sid2 = choose_region_donor(sid, 1, 1, i);
                (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                  alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                  alt_lo2 = clamp(alt_sm2[SM_TAILSTART], 0, max(0, alt_sm2[SM_FRAMES] - 2));
                  alt_hi2 = max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2);
                  alt_pos2 = choose_region_pos(i, alt_sid2, 1, tail_phase01, 0.55 + 0.22 * slider9);
                  alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                  alt_pen2 < alt_pen ? (
                    alt_sid = alt_sid2;
                    alt_sm = alt_sm2;
                    alt_lo = alt_lo2;
                    alt_hi = alt_hi2;
                    alt_pos = alt_pos2;
                    alt_pen = alt_pen2;
                  );
                );
              );

              use_alt = (alt_pen + 0.12 < self_pen) || (rand(1) < donor_blend * (0.42 + 0.14 * clamp01(self_pen * 0.30) + 0.12 * source_exhausted));
            ) : (
              use_alt = 0;
            );

            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.90 + 0.10 * tail_phase01;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
              v[VC_DONOR] = alt_sid;
              v[VC_DONORPOS] = min(max(alt_lo, alt_pos + hop * abs(grate) * (0.78 + 0.44 * rand(1))), max(alt_lo, alt_hi - 1));
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = self_lo;
              ghist_hi = self_hi;
              v[VC_DONOR] = sid;
              v[VC_DONORPOS] = min(max(self_lo, self_pos + hop * abs(grate) * (0.72 + 0.36 * rand(1))), max(self_lo, self_hi - 1));
            );
          ) : (
            grow_lo = body_start;
            grow_hi = min(max(grow_lo + 1, body_end), max(grow_lo + 1, frames - 2));
            grow_span = max(1, grow_hi - grow_lo);
            grow_cursor = wrap_in_range(v[VC_NEXTSRC], grow_lo, grow_hi);
            grow_phase01 = clamp01((grow_cursor - grow_lo) / max(1, grow_span - 1));
            advance = v[VC_SRCHOP] * (0.80 + 0.65 * rand(1));
            nextsrc = grow_cursor + advance;
            wrapped = nextsrc >= grow_hi;
            nextsrc = wrap_in_range(nextsrc, grow_lo, grow_hi);
            source_exhausted ? (
              nextsrc = wrap_in_range(nextsrc + (rand(1) - 0.5) * grow_span * 0.30, grow_lo, grow_hi);
            );
            v[VC_NEXTSRC] = nextsrc;

            self_pos = choose_region_pos(i, sid, 0, grow_phase01, 0.18 + 0.48 * slider9 + 0.22 * source_exhausted);
            self_pen = grain_hist_penalty(i, sid, self_pos, grow_lo, grow_hi);

            need_alt = source_exhausted || wrapped || (self_pen > 2.35) || (grow_span < max(64, floor(v[VC_GSIZE] * 0.55)));
            alt_sid = sid;
            alt_pen = 1000000000;

            need_alt && sample_count > 1 ? (
              alt_sid = choose_region_donor(sid, 0, clamp01(0.16 + 0.40 * source_exhausted + 0.20 * wrapped + 0.10 * slider9 + 0.08 * clamp01((self_pen - 1.2) * 0.6)), i);
              alt_sid != sid ? (
                alt_pos = choose_region_pos(i, alt_sid, 0, grow_phase01, 0.26 + 0.56 * slider9 + 0.24 * source_exhausted);
                alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
                alt_lo = clamp(alt_sm[SM_HEADEND], 0, max(0, alt_sm[SM_TAILSTART] - 1));
                alt_hi = clamp(alt_sm[SM_TAILSTART], alt_lo + 1, max(alt_lo + 1, alt_sm[SM_FRAMES] - 2));
                alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

                (alt_pen > self_pen + 0.65 && sample_count > 2) ? (
                  alt_sid2 = choose_region_donor(sid, 0, 1, i);
                  (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                    alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                    alt_lo2 = clamp(alt_sm2[SM_HEADEND], 0, max(0, alt_sm2[SM_TAILSTART] - 1));
                    alt_hi2 = clamp(alt_sm2[SM_TAILSTART], alt_lo2 + 1, max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2));
                    alt_pos2 = choose_region_pos(i, alt_sid2, 0, grow_phase01, 0.44 + 0.26 * slider9);
                    alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                    alt_pen2 < alt_pen ? (
                      alt_sid = alt_sid2;
                      alt_sm = alt_sm2;
                      alt_lo = alt_lo2;
                      alt_hi = alt_hi2;
                      alt_pos = alt_pos2;
                      alt_pen = alt_pen2;
                    );
                  );
                );
              );
            );

            use_alt = (alt_sid != sid) && (source_exhausted || (alt_pen + 0.18 < self_pen) || (wrapped && rand(1) < 0.65));
            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.95;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = grow_lo;
              ghist_hi = grow_hi;
            );
          );

          gb[VG_ACTIVE] = 1;
          gb[VG_AGE] = 0;
          gb[VG_SRC] = gsrc;
          gb[VG_SID] = gsid;
          gb[VG_RATE] = grate;
          gb[VG_GAIN] = ggain;
          grain_hist_push(i, gsid, gsrc, ghist_lo, ghist_hi);

          timer += hop;
          spawn_guard += 1;
        );

        v[VC_GTIMER] = timer;

        sumL = 0;
        sumR = 0;
        sumW = 0;
        activeg = 0;

        gk = 0;
        while (gk < NUM_GRAINS) (
          gb = v + VC_GBASE + gk * VG_STRIDE;

          gb[VG_ACTIVE] > 0 ? (
            gsid = gb[VG_SID] | 0;
            gsm = sample_meta_base + gsid * SM_STRIDE;
            gptr = gsm[SM_PTR] | 0;
            gnch = max(1, gsm[SM_NCH] | 0);
            gframes = gsm[SM_FRAMES] | 0;
            age = gb[VG_AGE];
            gsize = max(1, floor(v[VC_GSIZE]));

            age < gsize ? (
              srcp = gb[VG_SRC] + age * gb[VG_RATE];

              srcp < (gframes - 1) ? (
                ip = srcp | 0;
                frac = srcp - ip;
                ip1 = ip + 1;
                p0 = gptr + ip * gnch;
                p1 = gptr + ip1 * gnch;

                gnch >= 2 ? (
                  gl = p0[0] + (p1[0] - p0[0]) * frac;
                  gr = p0[1] + (p1[1] - p0[1]) * frac;
                ) : (
                  gx = p0[0] + (p1[0] - p0[0]) * frac;
                  gl = gx;
                  gr = gx;
                );

                w = stretch_window(age, gsize) * gb[VG_GAIN];
                sumL += gl * w;
                sumR += gr * w;
                sumW += w;
              );

              age += 1;
              gb[VG_AGE] = age;
              ((age >= gsize) || (srcp >= (gframes - 1))) ? (
                gb[VG_ACTIVE] = 0;
              ) : (
                activeg += 1;
              );
            ) : (
              gb[VG_ACTIVE] = 0;
            );
          );

          gk += 1;
        );

        sumW > 0 ? (
          grainL = sumL / sumW;
          grainR = sumR / sumW;
          got_grain = 1;
        );
      );
    );

    stage = v[VC_STAGE] | 0;
    env = v[VC_ENV];

    stage == ENV_ATTACK ? (
      env += (1 - env) * v[VC_ASTEP];
      env >= 0.999 ? (
        env = 1;
        stage = (v[VC_HLEFT] > 0) ? ENV_HOLD : ENV_DECAY;
      );
    );

    stage == ENV_HOLD ? (
      env = 1;
      hleft = max(0, floor(v[VC_HLEFT]) - 1);
      v[VC_HLEFT] = hleft;
      hleft <= 0 ? stage = ENV_DECAY;
    );

    stage == ENV_DECAY ? (
      env += (sustain_level - env) * v[VC_DSTEP];
      abs(env - sustain_level) <= 0.0005 ? (
        env = sustain_level;
        stage = ENV_SUSTAIN;
      );
    );

    stage == ENV_SUSTAIN ? (
      env = sustain_level;
    );

    stage == ENV_RELEASE ? (
      env *= v[VC_RSTEP];
      env <= 0.00005 ? (
        env = 0;
        v[VC_ACTIVE] = 0;
        stage = ENV_OFF;
      );
    );

    v[VC_STAGE] = stage;
    v[VC_ENV] = env;

    got_sig = 0;
    mix = 0;
    got_raw && got_grain ? (
      tail_phase = clamp01((v[VC_POS] - tailstart) / max(1, frames - tailstart));
      prebody_mix = (stage == ENV_ATTACK || stage == ENV_HOLD) ? 0 : 1;
      mix = clamp(v[VC_GMIX] * prebody_mix * (0.18 + 0.18 * tail_phase + (stage == ENV_RELEASE ? 0.40 : 0)), 0, 0.90);
      stage == ENV_RELEASE ? mix = max(mix, 0.28 + 0.42 * v[VC_TAILMIX] * v[VC_GMIX]);
      l = lerp(rawL, grainL, mix);
      r = lerp(rawR, grainR, mix);
      got_sig = 1;
    ) : got_raw ? (
      l = rawL;
      r = rawR;
      got_sig = 1;
    ) : got_grain ? (
      l = grainL;
      r = grainR;
      got_sig = 1;
    );

    g = v[VC_BASE] * env;
    keepalive = direct_alive || got_grain || activeg > 0 || (v[VC_GMODE] > 0 && stage != ENV_OFF && (stage != ENV_RELEASE || v[VC_CANSPAWN] > 0));

    (g > 0 && got_sig) ? (
      outL += l * g;
      outR += r * g;
      (v[VC_TLEFT] > 0) ? punch_bus = max(punch_bus, v[VC_TPROT]);
      (stage == ENV_HOLD && hold_samps > 0) ? punch_bus = max(punch_bus, (0.18 + 0.32 * clamp01(v[VC_HLEFT] / max(1, hold_samps))) * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
    ) : (
      (!keepalive || stage == ENV_OFF) ? v[VC_ACTIVE] = 0;
    );
  );

  i += 1;
);

midm = abs(0.5 * (outL + outR));
mix_fast += (midm - mix_fast) * (midm > mix_fast ? env_att_coeff : env_rel_coeff);
mix_slow += (midm - mix_slow) * env_rel_coeff;
transient = clamp01((mix_fast - mix_slow) * 10);
transient_guard = clamp01(max(punch_bus, transient * (0.72 + 0.28 * punch_bus)));
transient_guard_s += (transient_guard - transient_guard_s) * (transient_guard > transient_guard_s ? 0.12 : 0.02);

m2e_mix += (m2e_target - m2e_mix) * m2e_mode_coeff;
m2e_env_s += (m2e_env_raw - m2e_env_s) * m2e_smooth_coeff;
m2e_rigid_s += (m2e_rigid_raw - m2e_rigid_s) * m2e_smooth_coeff;
m2e_impact_s += (m2e_impact_raw - m2e_impact_s) * m2e_smooth_coeff;
m2e_pan_s += (m2e_pan_raw - m2e_pan_s) * m2e_smooth_coeff;
m2e_entropy_s += (m2e_entropy_raw - m2e_entropy_s) * m2e_smooth_coeff;
m2e_axis_v_s += (m2e_axis_v_raw - m2e_axis_v_s) * m2e_smooth_coeff;
m2e_axis_acc_s += (m2e_axis_acc_raw - m2e_axis_acc_s) * m2e_smooth_coeff;
m2e_lat_v_s += (m2e_lat_v_raw - m2e_lat_v_s) * m2e_smooth_coeff;
m2e_lat_amp_s += (m2e_lat_amp_raw - m2e_lat_amp_s) * m2e_smooth_coeff;
m2e_micro_s += (m2e_micro_raw - m2e_micro_s) * m2e_smooth_coeff;
m2e_meso_s += (m2e_meso_raw - m2e_meso_s) * m2e_smooth_coeff;
m2e_macro_s += (m2e_macro_raw - m2e_macro_s) * m2e_smooth_coeff;
m2e_excite_s += (m2e_excite_raw - m2e_excite_s) * m2e_smooth_coeff;
m2e_activity_s += (m2e_activity_raw - m2e_activity_s) * m2e_smooth_coeff;

m2e_depth = m2e_mix * (0.22 + 0.78 * max(0.18, slider9));
m2e_depth *= (1 - 0.35 * m2e_rigid_s);
(playback_mode == 2) ? m2e_depth *= (0.94 - 0.12 * granular_amt * (0.55 + 0.45 * tail_borrow));
m2e_depth = clamp01(m2e_depth);
m2e_activity_hi = clamp01((m2e_activity_s - 1) / 3);

m2e_tone_bias =
  ((m2e_excite_s - 0.5) * 0.18
  + (m2e_micro_s - 0.5) * 0.10
  + (m2e_meso_s - 0.5) * 0.05
  - (m2e_macro_s - 0.5) * 0.12
  + (m2e_env_s - 0.5) * 0.06) * m2e_depth;

m2e_focus_bias =
  (m2e_impact_s * 0.22
  + abs(m2e_axis_acc_s) * 0.10
  + abs(m2e_axis_v_s) * 0.04
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.06) * m2e_depth;

m2e_width_bias =
  (m2e_lat_amp_s * 0.24
  + m2e_activity_hi * 0.12
  + m2e_excite_s * 0.10
  - m2e_rigid_s * 0.08
  - m2e_entropy_s * 0.04) * m2e_depth;

m2e_pan_bias =
  (((m2e_pan_s - 0.5) * 2) * 0.20
  + m2e_lat_v_s * 0.08
  + m2e_axis_v_s * 0.04) * m2e_depth;

m2e_body_bias =
  ((m2e_env_s - 0.5) * 0.10
  + m2e_impact_s * 0.08
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.04) * m2e_depth;

m2e_sat_mix =
  (m2e_impact_s * 0.26
  + m2e_excite_s * 0.18
  + abs(m2e_axis_acc_s) * 0.08
  + m2e_meso_s * 0.06) * m2e_depth;
m2e_sat_mix = min(clamp01(m2e_sat_mix), 0.22);

trans_mode_mix = 0.6;
transient_mode == 1 ? trans_mode_mix = 1
: transient_mode == 2 ? trans_mode_mix = 0;
m2e_transient_damp = clamp(1 - transient_guard_s * (0.52 + 0.28 * trans_mode_mix), 0.12, 1);
m2e_tone_bias *= 0.48 + 0.52 * m2e_transient_damp;
m2e_focus_bias *= 0.18 + 0.82 * m2e_transient_damp * m2e_transient_damp;
m2e_width_bias *= 0.62 + 0.38 * m2e_transient_damp;
m2e_pan_bias *= 0.30 + 0.70 * m2e_transient_damp;
m2e_body_bias *= 0.56 + 0.44 * m2e_transient_damp;
m2e_sat_mix *= 0.16 + 0.84 * m2e_transient_damp * m2e_transient_damp;

tone_lp_l += (outL - tone_lp_l) * tone_lp_coeff;
tone_lp_r += (outR - tone_lp_r) * tone_lp_coeff;
focus_lp_l += (outL - focus_lp_l) * focus_lp_coeff;
focus_lp_r += (outR - focus_lp_r) * focus_lp_coeff;

tone_hp_l = outL - tone_lp_l;
tone_hp_r = outR - tone_lp_r;
focus_hp_l = outL - focus_lp_l;
focus_hp_r = outR - focus_lp_r;

tone_amt = clamp(slider6 + m2e_tone_bias, -1, 1);
focus_amt = clamp(slider7 + m2e_focus_bias, -1, 1);
width_amt = clamp(slider8 + m2e_width_bias, 0, 1);

outL += tone_amt * (tone_hp_l * 0.17 - tone_lp_l * 0.035);
outR += tone_amt * (tone_hp_r * 0.17 - tone_lp_r * 0.035);

focus_mix = focus_amt * (0.05 + transient * (0.11 + 0.08 * m2e_impact_s * m2e_depth));
outL += focus_hp_l * focus_mix;
outR += focus_hp_r * focus_mix;

mid = 0.5 * (outL + outR);
side = 0.5 * (outL - outR);
side *= 1 + width_amt * 0.22;
side += mid * m2e_pan_bias * 0.45;
mid *= 1 + m2e_body_bias;
outL = mid + side;
outR = mid - side;

satL = outL - (outL * outL * outL) * 0.1666666667;
satR = outR - (outR * outR * outR) * 0.1666666667;
outL = lerp(outL, satL, m2e_sat_mix);
outR = lerp(outR, satR, m2e_sat_mix);

weight_amt > 0.0001 ? (
  wmid = 0.5 * (outL + outR);
  wside = 0.5 * (outL - outR);

  weight_in_src_l = outL * 0.74 + wmid * 0.42 - wside * 0.06;
  weight_in_src_r = outR * 0.74 + wmid * 0.42 + wside * 0.06;

  weight_in_lp_l += (weight_in_src_l - weight_in_lp_l) * weight_in_coeff;
  weight_in_lp_r += (weight_in_src_r - weight_in_lp_r) * weight_in_coeff;

  ap_idx = weight_ap1_pos;
  ap_del = weight_ap1_l_base[ap_idx];
  ap1L = -weight_ap_g1 * weight_in_lp_l + ap_del;
  weight_ap1_l_base[ap_idx] = weight_in_lp_l + weight_ap_g1 * ap1L;
  ap_del = weight_ap1_r_base[ap_idx];
  ap1R = -weight_ap_g1 * weight_in_lp_r + ap_del;
  weight_ap1_r_base[ap_idx] = weight_in_lp_r + weight_ap_g1 * ap1R;
  weight_ap1_pos += 1;
  weight_ap1_pos >= weight_ap1_len ? weight_ap1_pos = 0;

  ap_idx = weight_ap2_pos;
  ap_del = weight_ap2_l_base[ap_idx];
  ap2L = -weight_ap_g2 * ap1L + ap_del;
  weight_ap2_l_base[ap_idx] = ap1L + weight_ap_g2 * ap2L;
  ap_del = weight_ap2_r_base[ap_idx];
  ap2R = -weight_ap_g2 * ap1R + ap_del;
  weight_ap2_r_base[ap_idx] = ap1R + weight_ap_g2 * ap2R;
  weight_ap2_pos += 1;
  weight_ap2_pos >= weight_ap2_len ? weight_ap2_pos = 0;

  er_idx = weight_er_pos;
  weight_er_l_base[er_idx] = ap2L;
  weight_er_r_base[er_idx] = ap2R;

  rd1 = er_idx - weight_tap1; rd1 < 0 ? rd1 += ER_BUF_LEN;
  rd2 = er_idx - weight_tap2; rd2 < 0 ? rd2 += ER_BUF_LEN;
  rd3 = er_idx - weight_tap3; rd3 < 0 ? rd3 += ER_BUF_LEN;
  rd4 = er_idx - weight_tap4; rd4 < 0 ? rd4 += ER_BUF_LEN;
  rd5 = er_idx - weight_tap5; rd5 < 0 ? rd5 += ER_BUF_LEN;
  rd6 = er_idx - weight_tap6; rd6 < 0 ? rd6 += ER_BUF_LEN;

  dl1 = weight_er_l_base[rd1]; dr1 = weight_er_r_base[rd1];
  dl2 = weight_er_l_base[rd2]; dr2 = weight_er_r_base[rd2];
  dl3 = weight_er_l_base[rd3]; dr3 = weight_er_r_base[rd3];
  dl4 = weight_er_l_base[rd4]; dr4 = weight_er_r_base[rd4];
  dl5 = weight_er_l_base[rd5]; dr5 = weight_er_r_base[rd5];
  dl6 = weight_er_l_base[rd6]; dr6 = weight_er_r_base[rd6];

  dm3 = 0.5 * (dl3 + dr3);
  dm6 = 0.5 * (dl6 + dr6);

  wetL = dl1 * 0.29 + dr2 * 0.22 + dm3 * 0.19 + dl4 * 0.14 + dr5 * 0.10 + dm6 * 0.07;
  wetR = dr1 * 0.29 + dl2 * 0.22 + dm3 * 0.19 + dr4 * 0.14 + dl5 * 0.10 + dm6 * 0.07;

  weight_er_pos += 1;
  weight_er_pos >= ER_BUF_LEN ? weight_er_pos = 0;

  weight_wet_lp_l += (wetL - weight_wet_lp_l) * weight_wet_coeff;
  weight_wet_lp_r += (wetR - weight_wet_lp_r) * weight_wet_coeff;

  wet_damp = 0.52 + 0.22 * stretch_norm;
  wetL = lerp(wetL, weight_wet_lp_l, wet_damp);
  wetR = lerp(wetR, weight_wet_lp_r, wet_damp);

  weight_duck = clamp(1 - transient_guard_s * (0.64 + 0.20 * trans_mode_mix + 0.08 * weight_amt), 0.14, 1);
  bloom = 0.5 * (weight_wet_lp_l + weight_wet_lp_r) * weight_body * (0.42 + 0.58 * weight_duck);
  outL += wetL * weight_mix * weight_duck + bloom;
  outR += wetR * weight_mix * weight_duck + bloom;

  heavySatL = outL - (outL * outL * outL) * 0.11;
  heavySatR = outR - (outR * outR * outR) * 0.11;
  outL = lerp(outL, heavySatL, weight_sat * (0.42 + 0.58 * weight_duck));
  outR = lerp(outR, heavySatR, weight_sat * (0.42 + 0.58 * weight_duck));
);

spl0 += outL * out_trim;
spl1 += outR * out_trim;

