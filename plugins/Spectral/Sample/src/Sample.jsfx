);
gfx_setfont(1, "Arial", 10, 0); gfx_r = 0.88; gfx_g = 0.93; gfx_b = 0.98; gfx_a = 1;
grain_input_alt_use ? sprintf(#ui_buf, "In%.2f", input_trigger_amt) : (input_trigger_amt > 0.04 ? sprintf(#ui_buf, "%.2f/In%.1f", slider18, input_trigger_amt) : sprintf(#ui_buf, "%.2f", slider18));
gfx_measurestr(#ui_buf, tw, th); gfx_x = kc - tw * 0.5; gfx_y = ky - th * 0.5; gfx_drawstr(#ui_buf);
gfx_setfont(1, "Arial", 11, 0); gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1;
