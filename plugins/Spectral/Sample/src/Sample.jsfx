gfx_rect(hint_x, hint_y, hint_w, hint_h, 1);
gfx_r = 0.18; gfx_g = 0.23; gfx_b = 0.29; gfx_a = 1;
gfx_rect(hint_x, hint_y, hint_w, hint_h, 0);
pt_in(hint_x, hint_y, hint_w, hint_h) ? ui_hover_id = 1401;

gfx_setfont(1, "Arial", 12, 0);
gfx_x = hint_x + 12; gfx_y = hint_y + 8; gfx_r = 0.83; gfx_g = 0.89; gfx_b = 0.96; gfx_a = 1;
gfx_drawstr("Hybrid = head direct, sustain in body, release in tail.");
gfx_x = hint_x + 12; gfx_y = hint_y + 24; gfx_r = 0.62; gfx_g = 0.71; gfx_b = 0.82; gfx_a = 1;
gfx_drawstr("Mode cycles Raw / Tape / Hybrid. Hold delays handoff.");
gfx_x = hint_x + 12; gfx_y = hint_y + 40; gfx_drawstr("Hybrid roams body grains and widens to same-phase matches before obvious repeats.");

rescan_flash > 0 ? rescan_flash = max(0, rescan_flash - 0.035);
rescan_flash > 0 ? (
  gfx_r = 0.35; gfx_g = 0.74; gfx_b = 0.98; gfx_a = rescan_flash * 0.65;
  gfx_circle(lamp_x, lamp_y + 12, 11 + rescan_flash * 10, 0);
  gfx_a = rescan_flash * 0.22;
  gfx_rect(x0, y0, gfx_w - 36, header_h, 0);
);

ui_hover_id == 1001 ? (
  sprintf(#tip_title, "Load-and-Go MultiSampler");
  sprintf(#tip_body, "Slot 0 is polled automatically. Drop in files and the bank reloads itself.");
);
ui_hover_id == 1002 ? (
  sprintf(#tip_title, "Auto-rescan status");
  sprintf(#tip_body, "Green means a bank is loaded. The text below shows whether a rescan is live or queued.");
);
ui_hover_id == 1003 ? (
  sprintf(#tip_title, "FluxBridge M2E");
  sprintf(#tip_body, "Listens only for the FluxBridge Receiver CC burst at fixed base 20 on MIDI channel 1 / channel 0 status bytes. When that exact 20-54 lane block is present, the sampler adds subtle motion-driven tone, focus, width, pan, and body contour, but transient-rich hits are protected so the attack stays intact.");
);
ui_hover_id == 1100 ? (
  sprintf(#tip_title, "Bank status");
  sprintf(#tip_body, "Shows whether slot 0 is loaded, how many samples are in memory, how many voices are active, and which sample was triggered last.");
);
ui_hover_id == 1101 ? (
  sprintf(#tip_title, "Pitch confidence");
  sprintf(#tip_body, "Average confidence of the auto pitch detector. This is informational now that playback is bank-wide instead of key-zoned.");
);
ui_hover_id == 1102 ? (
  sprintf(#tip_title, "Average brightness");
  sprintf(#tip_body, "Bank-wide high-band energy estimate used by the chooser and Color macro.");
);
ui_hover_id == 1103 ? (
  sprintf(#tip_title, "Average attack focus");
  sprintf(#tip_body, "Bank-wide onset sharpness estimate used by the chooser and Focus macro.");
);
ui_hover_id == 1200 ? (
  sprintf(#tip_title, "Sample map");
  sprintf(#tip_body, "Bars are shown in loaded-file order. Any trigger can now reach any bar; color still reflects inferred pitch, brightness, and focus.");
);
ui_hover_id >= 5000 ? (
  hov_sid = ui_hover_id - 5000;
  sm = sample_meta_base + hov_sid * SM_STRIDE;
  sprintf(#tip_title, "Sample %d", hov_sid + 1);
  sprintf(#tip_body, "Root %.0f | Bright %.2f | Focus %.2f | Punch %.2f | Len %.0f ms", sm[SM_ROOT], sm[SM_BRIGHT], sm[SM_SHARP], sm[SM_FLAGS], sm[SM_LENMS]);
);
ui_hover_id == 1300 ? (
  sprintf(#tip_title, "Envelope section");
  sprintf(#tip_body, "AHDSR is curved instead of linear. Sustain is body-only in Hybrid, Release switches to tail, and Hold delays the handoff from punch to granular sustain.");
);
ui_hover_id == 1301 ? (
  sprintf(#tip_title, "AHDSR graph");
  sprintf(#tip_body, "The graph shows AHDSR. In Hybrid mode the held note lives in the detected body window, while note-off jumps into the tail window for release.");
);
ui_hover_id == 1400 ? (
  sprintf(#tip_title, "Playback controls");
  sprintf(#tip_body, "Mode switches between Raw, Tape, and Hybrid. Hybrid now treats the sample as Head / Body / Tail: the hit stays direct, held notes live in the body, and note-off switches to the tail for release.");
);
ui_hover_id == 1401 ? (
  sprintf(#tip_title, "Playback notes");
  sprintf(#tip_body, "Raw ignores Stretch, Tape uses the natural slowdown path, and Hybrid keeps sustain in the body window while the grain picker widens to matched same-phase body donors before it falls into obvious repeats. Borrow still controls how much the tail and release lean on donor tails. Hold delays granular takeover so punch-heavy material stays meatier longer.");
);
ui_hover_id == 201 ? (
  sprintf(#tip_title, "Attack");
  sprintf(#tip_body, "Current %.1f ms. Log-scaled time control with curved rise. Attack is envelope rise only; Hold separately controls how long the hit stays at full level. Wheel adjusts; right-click or double-click resets.", slider2);
);
ui_hover_id == 202 ? (
  sprintf(#tip_title, "Decay");
  sprintf(#tip_body, "Current %.0f ms. Log-scaled time control with curved fall to Sustain. Wheel adjusts; right-click or double-click resets.", slider3);
);
ui_hover_id == 205 ? (
  sprintf(#tip_title, "Hold");
  sprintf(#tip_body, "Current %.0f ms. Keeps the envelope at full level after Attack. In Hybrid it also delays granular takeover and extra modulation so the head and early body stay punchier before the sustain body takes over. Wheel adjusts; right-click or double-click resets.", slider20);
);
ui_hover_id == 203 ? (
  sprintf(#tip_title, "Sustain");
  sprintf(#tip_body, "Current %.0f%%. Perceptually curved sustain level. In Hybrid this holds the body region only; it does not keep replaying the tail. Wheel adjusts; right-click or double-click resets.", slider4 * 100);
);
ui_hover_id == 204 ? (
  sprintf(#tip_title, "Release");
  sprintf(#tip_body, "Current %.0f ms. Log-scaled time control with curved fade-out. In Hybrid, note-off hands playback to the detected tail so Release shapes the tail instead of body sustain. Wheel adjusts; right-click or double-click resets.", slider5);
);
ui_hover_id == 301 ? (
  sprintf(#tip_title, "Color");
  sprintf(#tip_body, "Current %.2f. Gentle spectral tilt: negative warms, positive brightens. Wheel adjusts; right-click or double-click resets.", slider6);
);
ui_hover_id == 302 ? (
  sprintf(#tip_title, "Focus");
  sprintf(#tip_body, "Current %.2f. Negative softens, positive adds clarity. Wheel adjusts; right-click or double-click resets.", slider7);
);
ui_hover_id == 303 ? (
  sprintf(#tip_title, "Width");
  sprintf(#tip_body, "Current %.2f. Mild mid/side spread kept intentionally mono-safe. Wheel adjusts; right-click or double-click resets.", slider8);
);
ui_hover_id == 304 ? (
  sprintf(#tip_title, "Liveliness");
  sprintf(#tip_body, "Current %.2f. Controls start-position jitter, tiny detune drift, gain micro-variation, Random-mode adventurousness, and the depth of auto FluxBridge motion when present. Wheel adjusts; right-click or double-click resets.", slider9);
);
ui_hover_id == 305 ? (
  sprintf(#tip_title, "Truth");
  sprintf(#tip_body, "Current %.2f. 0 favors matched playback, 1 preserves raw sample behavior. Wheel adjusts; right-click or double-click resets.", slider10);
);
ui_hover_id == 306 ? (
  sprintf(#tip_title, "Output");
  sprintf(#tip_body, "Current %.1f dB. Final output trim after the macro and Weight stages. Wheel adjusts; right-click or double-click resets.", slider11);
);
ui_hover_id == 307 ? (
  sprintf(#tip_title, "Pitch");
  sprintf(#tip_body, "Current %+.1f semitones. Global transpose for every engine. In Tape and Hybrid it stacks on the same slowed-down rate path; in Raw it is simple repitching.", slider12);
);
ui_hover_id == 308 ? (
  sprintf(#tip_title, "Stretch");
  sprintf(#tip_body, "Current %.2fx. Used by Tape and Hybrid only. Higher values slow and lower the direct path naturally; Hybrid then layers structured grains after the head instead of stretching the hit itself.", slider14);
);
ui_hover_id == 309 ? (
  sprintf(#tip_title, "Weight");
  sprintf(#tip_body, "Current %.2f. Short ER-style thickener with damping and body bloom. In transient modes it ducks around the first hit so heavy attacks stay punchy.", slider15);
);
ui_hover_id == 310 ? (
  sprintf(#tip_title, "Granular body");
  sprintf(#tip_body, "Current %.2f. Only used in Hybrid mode. Low values keep the direct sample dominant; high values let segmented body grains take over more. The grain picker now avoids recently used starts and widens to matched same-phase body donors before it repeats obvious material.", slider18);
);
ui_hover_id == 311 ? (
  sprintf(#tip_title, "Tail borrow");
  sprintf(#tip_body, "Current %.2f. Only used in Hybrid mode. It chooses matched donor tails from elsewhere in the bank, but only for the tail and release path. If close donors get exhausted, the search widens to any coherent same-phase tails in the bank before falling back toward self reuse.", slider19);
);
ui_hover_id == 401 ? (
  sprintf(#tip_title, "Random / Sequence");
  (slider13 | 0) ? (
    sprintf(#tip_body, "Sequence mode walks through every loaded file in order, one trigger at a time.");
  ) : (
    sprintf(#tip_body, "Random mode chooses from the whole bank every trigger, with anti-repeat weighting and subtle descriptor matching.");
  );
);
ui_hover_id == 402 ? (
  sprintf(#tip_title, "Transient mode");
  (slider16 | 0) == 1 ? (
    sprintf(#tip_body, "Punch mode hard-locks playback to the detected onset, keeps the first hit closer to raw speed before slowdown or hybrid grains take over, and damps FluxBridge and Weight around the hit so heavy transients stay raw.");
  ) : (slider16 | 0) == 2 ? (
    sprintf(#tip_body, "Off disables transient locking. Start-position liveliness, head protection, and hybrid punch preservation are left fully free.");
  ) : (
    sprintf(#tip_body, "Auto infers whether a sample is transient-rich and only protects the head when the onset looks sharp enough to benefit.");
  );
);
ui_hover_id == 403 ? (
  sprintf(#tip_title, "Playback mode");
  (slider17 | 0) == 2 ? (
    sprintf(#tip_body, "Hybrid mode keeps the selected sample head direct, uses the body phase for held sustain, and now widens to matched same-phase body donors before repeating obvious grains. Borrow still pushes the tail and release toward donor tails after note-off.");
  ) : (slider17 | 0) == 1 ? (
    sprintf(#tip_body, "Tape mode is the current natural slowdown path: slower, lower, heavier, with transient protection on top.");
  ) : (
    sprintf(#tip_body, "Raw mode disables Stretch and plays the direct sample only, with Pitch, ADSR, Weight, and the existing macro and FluxBridge stages.");
  );
);

draw_tooltip_box();

gfx_slider_mask ? sliderchange(gfx_slider_mask);
ui_prev_down = mouse_down;
ui_prev_rdown = mouse_rdown;
