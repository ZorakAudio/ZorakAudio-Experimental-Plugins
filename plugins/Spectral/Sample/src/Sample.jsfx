);

ui_hover_id == 1001 ? (
  sprintf(#tip_title, "Load-and-Go MultiSampler");
  sprintf(#tip_body, "Slot 0 is polled automatically. Drop in files and the bank reloads itself.");
);
ui_hover_id == 1002 ? (
  sprintf(#tip_title, "Auto-rescan status");
  sprintf(#tip_body, "Green means a bank is loaded. The text below shows whether a rescan is live or queued.");
);
ui_hover_id == 1100 ? (
  sprintf(#tip_title, "Bank status");
  sprintf(#tip_body, "Shows whether slot 0 is loaded, how many samples are in memory, how many voices are active, and which sample was triggered last.");
);
ui_hover_id == 1101 ? (
  sprintf(#tip_title, "Pitch confidence");
  sprintf(#tip_body, "Average confidence of the auto pitch detector. This is informational now that playback is bank-wide instead of key-zoned.");
);
ui_hover_id == 1102 ? (
  sprintf(#tip_title, "Average brightness");
  sprintf(#tip_body, "Bank-wide high-band energy estimate used by the chooser and Color macro.");
);
ui_hover_id == 1103 ? (
  sprintf(#tip_title, "Average attack focus");
  sprintf(#tip_body, "Bank-wide onset sharpness estimate used by the chooser and Focus macro.");
);
ui_hover_id == 1200 ? (
  sprintf(#tip_title, "Sample map");
  sprintf(#tip_body, "Bars are shown in loaded-file order. Any trigger can now reach any bar; color still reflects inferred pitch, brightness, and focus.");
);
ui_hover_id >= 5000 ? (
  hov_sid = ui_hover_id - 5000;
  sm = sample_meta_base + hov_sid * SM_STRIDE;
