            corpus_want_region = cur_region_mode ? GC_REGION_TAIL : ((stage == ENV_ATTACK || stage == ENV_HOLD) ? GC_REGION_ATTACK : GC_REGION_BODY);
            // v32 stream role: anchor grains preserve phrase glue, texture grains
