slider13:0<0,2,1{random,sequence,walk}>--Selection mode
slider14:1<1,4,0.001>--Stretch (x)
slider15:0<0,1,0.001>--Weight
slider16:0<0,2,1{auto,punch,off}>--Transient mode
slider17:1<0,3,1{raw,tape,hybrid,granular}>--Playback mode
slider18:0.55<0,1,0.001>--Grain
slider19:0.35<0,1,0.001>--Spice
slider20:20<0,2000,1>--Hold (ms)
slider21:0<0,1,1{stereo,mono}>--Mono Source
slider22:0<0,1,0.001>--Dynamics
slider23:0<0,1,1{classic,gaussian}>--Onset align mode
slider24:0<0,65536,256>--Bank RAM Budget (MB, 0=unlimited)
slider25:0<0,1,0.001>--Clean
slider26:0<0,1,0.001>--Room Tame
slider27:0<0,100,0.1>--Push (%)
slider28:100<-100,100,1>--Attack slope (%)
slider29:-100<-100,100,1>--Decay slope (%)
slider30:-100<-100,100,1>--Release slope (%)
slider32:0<-18,18,0.1>--EQ Band 1 Gain (dB)
slider33:0<-18,18,0.1>--EQ Band 2 Gain (dB)
slider34:0<-18,18,0.1>--EQ Band 3 Gain (dB)
slider35:120<20,20000,1>--EQ Band 1 Freq (Hz)
slider36:950<20,20000,1>--EQ Band 2 Freq (Hz)
slider37:6500<20,20000,1>--EQ Band 3 Freq (Hz)
slider38:20<20,1000,1>--EQ HPF (Hz)
slider39:20000<1000,20000,1>--EQ LPF (Hz)
slider40:1.15<0.35,8,0.01>--EQ Band 1 Q
slider41:1.15<0.35,8,0.01>--EQ Band 2 Q
slider42:1.15<0.35,8,0.01>--EQ Band 3 Q
slider43:1<0,4,1{6,12,24,36,48}>--EQ HPF Slope
slider44:1<0,4,1{6,12,24,36,48}>--EQ LPF Slope
slider45:0.707<0.35,4,0.001>--EQ HPF Q
slider46:0.707<0.35,4,0.001>--EQ LPF Q
@init
/*
Runtime sample-pool API used here:
  pool  = sample_pool_from_slot(slot, #name);
  sample_pool_commit(pool);
  id    = sample_get(pool, index);
  value = sample_read_interp(pool, id, channel, phase);

Decoded audio is held outside JSFX mem[] as packed float32 by the runtime.
This keeps large banks from expanding into 64-bit JSFX double cells.

This instrument stays load-and-go:
- slot 0 is polled automatically
- sample_pool_generation() detects completed reloads
- the metadata rebuild is deferred until voices are idle
- no zones or bank metadata are required
*/

function clamp(x lo hi)
(
  min(hi, max(lo, x));
);

function clamp01(x)
(
  clamp(x, 0, 1);
);

function denorm_zap(x)
(
  abs(x) < DENORM_CUT ? 0 : x;
);

function denorm_guard_tick()
(
  denorm_flip = -denorm_flip;
  denorm_flip * DENORM_GUARD;
);

function denorm_near_silence(l r)
(
  (abs(l) + abs(r)) < DENORM_AUDIO_FLOOR;
);

function wrap_in_range(x lo hi) local(span)
(
  span = max(1, hi - lo);
  while (x < lo) (x += span;);
  while (x >= hi) (x -= span;);
  x;
);

function curve_denorm(norm vmin vmax mode) local(n ratio)
(
  n = clamp01(norm);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    exp(log(max(vmin, 0.000001)) + n * log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    sqrt(n);
  ) : (
    vmin + n * (vmax - vmin);
  );
);

function curve_norm(val vmin vmax mode) local(v ratio)
(
  v = clamp(val, vmin, vmax);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    clamp01(log(max(v, 0.000001) / max(vmin, 0.000001)) / log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    clamp01(v * v);
  ) : (
    clamp01((v - vmin) / max(vmax - vmin, 0.000001));
  );
);

function env_curve01(t) local(k d)
(
  k = ENV_VIS_SHAPE;
  d = 1 - exp(-k);
  d <= 0 ? clamp01(t) : (1 - exp(-k * clamp01(t))) / d;
);

function env_slope_shape(t slope_pct) local(n a p d)
(
  n = clamp01(t);
  a = clamp(slope_pct, -100, 100) / 100;

  abs(a) < 0.000001 ? (
    n;
  ) : a >= 0.999999 ? (
    // Full positive slope is the original one-pole envelope curve.
    env_curve01(n);
  ) : a > 0 ? (
    // Positive: fast start, slow finish.
    p = 1 + a * (ENV_VIS_SHAPE - 1);
    1 - ((1 - n) ^ p);
  ) : (
    // Negative: slow start, fast finish.
    p = 1 + (-a) * (ENV_VIS_SHAPE - 1);
    n ^ p;
  );
);

function env_slope_inv(y slope_pct) local(n a p d)
(
  n = clamp01(y);
  a = clamp(slope_pct, -100, 100) / 100;

  abs(a) < 0.000001 ? (
    n;
  ) : a >= 0.999999 ? (
    d = 1 - exp(-ENV_VIS_SHAPE);
    d <= 0 ? n : clamp01(-log(max(0.000000001, 1 - n * d)) / ENV_VIS_SHAPE);
  ) : a > 0 ? (
    p = 1 + a * (ENV_VIS_SHAPE - 1);
    1 - ((1 - n) ^ (1 / p));
  ) : (
    p = 1 + (-a) * (ENV_VIS_SHAPE - 1);
    n ^ (1 / p);
  );
);

function env_segment_slope(raw_slope polarity)
(
  clamp(raw_slope, -100, 100) * polarity;
);

function env_slope_is_classic(raw_slope polarity)
(
  env_segment_slope(raw_slope, polarity) >= 99.999;
);

function env_migrate_old_slope(v polarity)
(
  v == 0 ? (polarity == ENV_RISE ? 100 : -100)
  : v == 1 ? 0
  : v == 2 ? (polarity == ENV_RISE ? -70 : 70)
  : v == 3 ? (polarity == ENV_RISE ? 70 : -70)
  : v == 4 ? 0
  : v;
);

function stretch_window(age gsize) local(n denom)
(
  // Periodic Hann window for COLA-friendly grain overlap.
  // With a 25%% hop (4x overlap), the summed window is constant.
  n = clamp(age, 0, max(0, gsize - 1));
  denom = max(gsize, 1);
  0.5 - 0.5 * cos(6.283185307179586 * n / denom);
);

function lerp(a b t)
(
  a + (b-a)*t;
);

function stretch_window_morph(age gsize flatness) local(n hann fade edge tuk)
(
  // v35 MacroGrain OLAGlue: small grains keep Hann. Long coherent grains morph
  // toward a cosine-edged flat-top window so full-event material is not forced
  // through a huge whole-window fade.
  hann = stretch_window(age, gsize);
  flatness = clamp01(flatness);
  flatness <= 0.0001 ? (
    hann;
  ) : (
    n = clamp01(age / max(1, gsize - 1));
    fade = lerp(0.50, 0.17, flatness);
    n < fade ? (
      edge = n / max(0.000001, fade);
      tuk = 0.5 - 0.5 * cos(3.141592653589793 * edge);
    ) : n > (1 - fade) ? (
      edge = (1 - n) / max(0.000001, fade);
      tuk = 0.5 - 0.5 * cos(3.141592653589793 * edge);
    ) : (
      tuk = 1;
    );
    lerp(hann, tuk, flatness);
  );
);


function db2amp(db)
(
  exp(db * 0.11512925464970229);
);

function midi_ratio(semi)
(
  exp(semi * 0.0577622650466621);
);

function cents_ratio(cents)
(
  exp(cents * 0.000577622650466621);
);

function cc_to_u01(cc)
(
  clamp01(cc / 127);
);

function cc_to_s11(cc)
(
  clamp((cc / 63.5) - 1, -1, 1);
);

function cc_to_ratio(cc)
(
  cc <= 63 ? (cc / 63) : (1 + ((cc - 64) / 63) * 3);
);

function m2e_apply_cc(base ccnum ccval) local(off)
(
  off = ccnum - base;

  off == 0  ? m2e_env_raw = cc_to_u01(ccval);
  off == 5  ? m2e_rigid_abs_raw = cc_to_u01(ccval);
  off == 6  ? m2e_rigid_rel_raw = cc_to_u01(ccval);
  off == 17 ? m2e_impact_raw = cc_to_u01(ccval);
  off == 18 ? m2e_pan_raw = cc_to_u01(ccval);
  off == 19 ? m2e_entropy_raw = cc_to_u01(ccval);
  off == 20 ? m2e_axis_v_raw = cc_to_s11(ccval);
  off == 21 ? m2e_axis_acc_raw = cc_to_s11(ccval);
  off == 24 ? m2e_lat_v_raw = cc_to_s11(ccval);
  off == 28 ? m2e_lat_amp_raw = cc_to_u01(ccval);
  off == 29 ? m2e_micro_raw = cc_to_u01(ccval);
  off == 31 ? m2e_meso_raw = cc_to_u01(ccval);
  off == 32 ? m2e_macro_raw = cc_to_u01(ccval);
  off == 33 ? m2e_excite_raw = cc_to_u01(ccval);
  off == 34 ? m2e_activity_raw = cc_to_ratio(ccval);

  m2e_rigid_raw = 0.5 * (m2e_rigid_abs_raw + m2e_rigid_rel_raw);
);

function m2e_decode_snapshot(base) local(i cc)
(
  i = 0;
  while (i < M2E_LANE_COUNT) (
    (m2e_clock_samps - m2e_cc_age_base[base + i]) <= (m2e_detect_window_samps * 4) ? (
      cc = clamp(m2e_cc_val_base[base + i], 0, 127);
      m2e_apply_cc(base, base + i, cc);
    );
    i += 1;
  );
);

function m2e_detect_base(now_samps) local(base k age count g0 g1 g2 g3 best best_count)
(
  best = -1;
  best_count = 0;

  base = M2E_BASE_MIN;
  while (base <= M2E_BASE_MAX) (
    count = 0;
    g0 = 0; g1 = 0; g2 = 0; g3 = 0;

    k = 0;
    while (k < M2E_LANE_COUNT) (
      age = now_samps - m2e_cc_age_base[base + k];
      age <= m2e_detect_window_samps ? (
        count += 1;
        k <= 4 ? g0 = 1;
        (k >= 15 && k <= 19) ? g1 = 1;
        (k >= 20 && k <= 28) ? g2 = 1;
        k >= 29 ? g3 = 1;
      );
      k += 1;
    );

    (g0 && g1 && g2 && g3 && (count > best_count)) ? (
      best_count = count;
      best = base;
    );

    base += 1;
  );

  m2e_detect_count = best_count;
  best_count >= M2E_DETECT_MIN ? best : -1;
);

function m2e_reset() local(i)
(
  i = 0;
  while (i < 128) (
    m2e_cc_age_base[i] = -1000000000;
    m2e_cc_val_base[i] = 0;
    i += 1;
  );

  m2e_base = M2E_BASE_FIXED;
  m2e_detect_count = 0;
  m2e_active = 0;
  m2e_last_msg_samps = -1000000000;
  m2e_last_any_cc_samps = -1000000000;
  m2e_target = 0;
  m2e_mix = 0;

  m2e_env_raw = 0.5;
  m2e_rigid_abs_raw = 0;
  m2e_rigid_rel_raw = 0;
  m2e_rigid_raw = 0;
  m2e_impact_raw = 0;
  m2e_pan_raw = 0.5;
  m2e_entropy_raw = 0;
  m2e_axis_v_raw = 0;
  m2e_axis_acc_raw = 0;
  m2e_lat_v_raw = 0;
  m2e_lat_amp_raw = 0;
  m2e_micro_raw = 0;
  m2e_meso_raw = 0;
  m2e_macro_raw = 0;
  m2e_excite_raw = 0;
  m2e_activity_raw = 1;

  m2e_env_s = m2e_env_raw;
  m2e_rigid_s = m2e_rigid_raw;
  m2e_impact_s = m2e_impact_raw;
  m2e_pan_s = m2e_pan_raw;
  m2e_entropy_s = m2e_entropy_raw;
  m2e_axis_v_s = m2e_axis_v_raw;
  m2e_axis_acc_s = m2e_axis_acc_raw;
  m2e_lat_v_s = m2e_lat_v_raw;
  m2e_lat_amp_s = m2e_lat_amp_raw;
  m2e_micro_s = m2e_micro_raw;
  m2e_meso_s = m2e_meso_raw;
  m2e_macro_s = m2e_macro_raw;
  m2e_excite_s = m2e_excite_raw;
  m2e_activity_s = m2e_activity_raw;
);

function mono_frame(ptr nch frame) local(l r)
(
  // SM_PTR stores a runtime sample-pool ID, not a mem[] pointer.
  nch >= 2 ? (
    l = sample_read(bank_pool, ptr, 0, frame);
    r = sample_read(bank_pool, ptr, 1, frame);
    0.5 * (l + r);
  ) : (
    sample_read(bank_pool, ptr, 0, frame);
  );
);

function sample_frame2(ptr nch phase) local(ok l r)
(
  ok = sample_read2_interp(bank_pool, ptr, phase, l, r);
  mono_source ? (
    l = 0.5 * (l + r);
    r = l;
  );
  readL = l;
  readR = r;
  ok;
);

function pt_in(x y w h)
(
  mouse_x >= x && mouse_x <= (x + w) && mouse_y >= y && mouse_y <= (y + h);
);

function recent_penalty(sample_id) local(i pen)
(
  pen = 0;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] == sample_id ? pen += (RECENT_LEN - i);
    i += 1;
  );
  pen;
);

function push_recent(sample_id) local(i)
(
  i = RECENT_LEN - 1;
  while (i > 0) (
    recent_base[i] = recent_base[i-1];
    i -= 1;
  );
  recent_base[0] = sample_id;
);

function grain_hist_clear_voice(vix) local(base j)
(
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] = -1;
    grain_hist_pos_base[base + j] = -1000000;
    grain_hist_phase_base[base + j] = -1;
    j += 1;
  );
);

function reset_grain_histories() local(vix)
(
  vix = 0;
  while (vix < MAX_VOICES) (
    grain_hist_clear_voice(vix);
    vix += 1;
  );
);

function grain_hist_push(vix sid pos lo hi) local(base j span phasebin)
(
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  base = vix * GRAIN_HIST_LEN;
  j = GRAIN_HIST_LEN - 1;
  while (j > 0) (
    grain_hist_sid_base[base + j] = grain_hist_sid_base[base + j - 1];
    grain_hist_pos_base[base + j] = grain_hist_pos_base[base + j - 1];
    grain_hist_phase_base[base + j] = grain_hist_phase_base[base + j - 1];
    j -= 1;
  );
  grain_hist_sid_base[base] = sid;
  grain_hist_pos_base[base] = pos;
  grain_hist_phase_base[base] = phasebin;
);

function grain_sid_penalty(vix sid) local(base j pen)
(
  pen = 0;
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] == sid ? pen += (GRAIN_HIST_LEN - j) * 0.22;
    j += 1;
  );
  pen;
);

function grain_hist_penalty(vix sid pos lo hi) local(base j pen span phasebin hsid hpos hbin near1 near2)
(
  pen = 0;
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  near1 = max(12, floor(span * 0.09));
  near2 = max(24, floor(span * 0.18));
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    hsid = grain_hist_sid_base[base + j] | 0;
    hsid >= 0 ? (
      hpos = grain_hist_pos_base[base + j];
      hbin = grain_hist_phase_base[base + j] | 0;
      hsid == sid ? pen += (GRAIN_HIST_LEN - j) * 0.16;
      hbin == phasebin ? pen += (GRAIN_HIST_LEN - j) * 0.06;
      (hsid == sid && abs(pos - hpos) < near2) ? pen += (GRAIN_HIST_LEN - j) * 0.22;
      (hsid == sid && abs(pos - hpos) < near1) ? pen += (GRAIN_HIST_LEN - j) * 0.38;
      (hsid == sid && hbin == phasebin) ? pen += (GRAIN_HIST_LEN - j) * 0.14;
    );
    j += 1;
  );
  pen;
);


function grain_run_limit(lively truth spice)
(
  // Same-source phrases should be long enough to feel connected but short
  // enough to avoid reconstructing one original take.
  max(4, floor(6 + (1 - spice) * 5 + truth * 3 + (1 - lively) * 2 + granular_event_stretch * (5 + 9 * (1 - spice) + 4 * truth)));
);

function corpus_phrase_targets(v stage lively truth spice) local(gphase arc lift accent rel envbase envlift)
(
  // v32 PhraseTrajectory: hidden per-voice phrase arc. This does not command
  // the selector; it provides a moving descriptor target so Granular can feel
  // like a phrase instead of a sequence of unrelated tiles.
  gphase = clamp01(v[VC_GPHASE]);
  arc = sin(gphase * 3.141592653589793);
  arc = arc * arc;
  accent = clamp01(v[VC_GACCENT]);
  lift = clamp01(arc * lively * (0.42 + 0.58 * v[VC_GDEPTH]) * (0.78 + 0.22 * accent));
  rel = stage == ENV_RELEASE ? 1 : 0;

  stage == ENV_ATTACK || stage == ENV_HOLD ? (
    phrase_bright_t = 0.46 + 0.16 * lively;
    phrase_edge_t   = 0.42 + 0.20 * lively;
    phrase_sal_t    = 0.54 + 0.18 * lively;
    phrase_phase_t  = 0.10 + 0.18 * lift;
    phrase_attack_pull = 0.74;
    phrase_env_t = 0.54 + 0.24 * lively + 0.12 * lift;
    phrase_env_delta_t = 0.16 + 0.18 * lively;
    phrase_env_peak_t = 0.36 + 0.24 * lively;
  ) : rel ? (
    phrase_bright_t = 0.26 + 0.20 * spice + 0.08 * lift;
    phrase_edge_t   = 0.16 + 0.16 * spice + 0.06 * lift;
    phrase_sal_t    = 0.22 + 0.20 * spice + 0.12 * lift;
    phrase_phase_t  = 0.72 + 0.24 * lift;
    phrase_attack_pull = 0.04 + 0.10 * spice;
    phrase_env_t = 0.24 + 0.18 * spice + 0.10 * lift;
    phrase_env_delta_t = -0.22 - 0.08 * (1 - spice);
    phrase_env_peak_t = 0.12 + 0.12 * spice;
  ) : (
    // Body/sustain trajectory: slow material stays coherent and forward;
    // high Lively crests toward brighter/attack-colored grains without hard
    // retriggering attack grains by default.
    phrase_bright_t = 0.30 + 0.22 * lively * lift + 0.08 * spice;
    phrase_edge_t   = 0.20 + 0.24 * lively * lift + 0.06 * spice;
    phrase_sal_t    = 0.30 + 0.26 * lively * lift + 0.10 * spice;
    phrase_phase_t  = 0.30 + 0.50 * gphase;
    phrase_attack_pull = clamp01((lift - 0.58) / 0.42) * lively * (0.30 + 0.40 * spice);
    envbase = 0.32 + 0.12 * (1 - truth) + 0.08 * spice;
    envlift = lift * (0.28 + 0.28 * lively + 0.14 * spice);
    phrase_env_t = envbase + envlift;
    phrase_env_delta_t = (lift - 0.46) * (0.12 + 0.20 * lively + 0.10 * spice);
    phrase_env_peak_t = clamp01((lift - 0.38) / 0.62) * (0.22 + 0.28 * lively);
  );

  phrase_bright_t = clamp01(phrase_bright_t);
  phrase_edge_t = clamp01(phrase_edge_t);
  phrase_sal_t = clamp01(phrase_sal_t);
  phrase_phase_t = clamp01(phrase_phase_t);
  phrase_env_t = clamp01(phrase_env_t);
  phrase_env_delta_t = clamp(phrase_env_delta_t, -1, 1);
  phrase_env_peak_t = clamp01(phrase_env_peak_t);
);

function corpus_snap_soft_point(sm pos lo hi glen region) local(ptr nch frames sr strength radius step p best bestscore score x xm xp dist)
(
  // v32: slow/dark material exposes grain edges. At load time only, snap corpus
  // entry starts toward nearby low-amplitude / low-slope points. Bright noisy
  // squelches keep their raw positions because they already mask boundaries.
  ptr = sm[SM_PTR] | 0;
  nch = max(1, sm[SM_NCH] | 0);
  frames = sm[SM_FRAMES] | 0;
  sr = max(1000, sm[SM_SR]);
  strength = clamp01((0.64 - sm[SM_BRIGHT]) / 0.54) * clamp01((0.46 - sm[SM_EDGE]) / 0.42);
  region == GC_REGION_ATTACK ? strength *= 0.18;
  strength > 0.025 ? (
    radius = min(floor(glen * 0.18), floor(sr * 0.010));
    radius = min(radius, max(2, floor((hi - lo) * 0.18)));
    step = max(1, floor(radius / 14));
    best = clamp(pos, lo, max(lo, hi - 1));
    bestscore = 1000000000;
    p = max(lo + 1, floor(pos - radius));
    while (p <= min(max(lo + 1, hi - 2), floor(pos + radius))) (
      x = mono_frame(ptr, nch, p);
      xm = mono_frame(ptr, nch, p - 1);
      xp = mono_frame(ptr, nch, p + 1);
      dist = abs(p - pos) / max(1, radius);
      score = abs(x) * 0.74 + abs(xp - xm) * 0.22 + dist * (0.012 + 0.060 * (1 - strength));
      score < bestscore ? (
        bestscore = score;
        best = p;
      );
      p += step;
    );
    lerp(pos, best, strength);
  ) : pos;
);


function corpus_region_bounds(sid region) local(sm frames sr gatt ghead gtail alo ahi blo bhi tlo thi)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  frames = sm[SM_FRAMES] | 0;
  sr = max(1000, sm[SM_SR]);

  // Granular has its own Gaussian-style corpus markers, even when the global
  // Onset mode is Classic. Raw/Tape/Hybrid continue to use SM_ATTACK/HEAD/TAIL.
  gatt = sm[SM_GCATTACK];
  ghead = sm[SM_GCHEAD];
  gtail = sm[SM_GCTAIL];
  ghead <= 0 ? ghead = sm[SM_HEADEND];
  gtail <= ghead ? gtail = sm[SM_TAILSTART];

  alo = max(0, floor(gatt - sr * 0.006));
  ahi = clamp(ghead, alo + 1, max(alo + 1, frames - 2));
  blo = clamp(ghead, 0, max(0, frames - 2));
  bhi = clamp(gtail, blo + 1, max(blo + 1, frames - 2));
  tlo = clamp(gtail, 0, max(0, frames - 2));
  thi = max(tlo + 1, frames - 2);

  region == GC_REGION_TAIL ? (
    corpus_lo = tlo;
    corpus_hi = thi;
  ) : region == GC_REGION_ATTACK ? (
    corpus_lo = alo;
    corpus_hi = ahi;
  ) : (
    corpus_lo = blo;
    corpus_hi = bhi;
  );
);

function corpus_measure_at(sm pos win) local(ptr nch sr frames a b i step x ax prev lp hf sumsq sumabs sumdiff sumhf rough n lpcoef rms edge bright sharp sal)
(
  ptr = sm[SM_PTR] | 0;
  nch = max(1, sm[SM_NCH] | 0);
  sr = max(1000, sm[SM_SR]);
  frames = sm[SM_FRAMES] | 0;
  // v35: allow ultra-scale load-time measurements up to ~1.2s.
  // Runtime cost stays low because corpus analysis happens only at load/rescan.
  win = clamp(floor(win), 64, min(floor(sr * 1.20), max(64, frames - 2)));
  a = clamp(floor(pos - win * 0.5), 0, max(0, frames - 2));
  b = clamp(a + win, a + 1, max(a + 1, frames - 1));
  step = max(1, floor((b - a) / 256));

  lpcoef = clamp(1 - exp(-6.283185307179586 * min(1800, sr * 0.45) / max(sr, 1)), 0.001, 0.92);
  lp = 0;
  prev = mono_frame(ptr, nch, a);
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  sumhf = 0;
  rough = 0;
  n = 0;

  i = a;
  while (i < b) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    lp += (x - lp) * lpcoef;
    hf = x - lp;
    sumsq += x * x;
    sumabs += ax;
    sumhf += abs(hf);
    n > 0 ? (
      sumdiff += abs(x - prev);
      rough += abs(hf - (prev - lp));
    );
    prev = x;
    n += 1;
    i += step;
  );

  rms = sqrt(sumsq / max(1, n));
  edge = clamp01((sumdiff / max(sumabs, 0.000000001)) * 0.22);
  bright = clamp01((sumhf / max(sumabs, 0.000000001) - 0.08) * 1.65);
  sharp = clamp01(edge * 0.62 + bright * 0.20 + sm[SM_SHARP] * 0.18);
  sal = clamp01(edge * 0.36 + bright * 0.25 + clamp01(rms / max(sm[SM_RMS] * 2.5, 0.000001)) * 0.25 + sm[SM_SHARP] * 0.14);

  corpus_tmp_rms = clamp01(rms / max(sm[SM_RMS] * 2.85, 0.000001));
  corpus_tmp_bright = bright;
  corpus_tmp_edge = edge;
  corpus_tmp_sharp = sharp;
  corpus_tmp_sal = sal;
);

function corpus_write_entry(sid region pos glen phase) local(
  sm gc frames sr prevpos nextpos span event_id crms cbright cedge csharp csal prms nrms nbright nedge envdir envpeak envlevel
  microwin shortwin midwin longwin ultrawin microrms micbright micedge micsal srms sbright sedge ssal mrms mbright medge msal lrms lbright ledge lsal urms ubright uedge usal
  slowmat stable ultrastable mscont mstrans event_len len_goal minlen maxlen lenmix evtfrac eventscale transscale
)
(
  corpus_count < corpus_capacity ? (
    sm = sample_meta_base + sid * SM_STRIDE;
    frames = sm[SM_FRAMES] | 0;
    sr = max(1000, sm[SM_SR]);
    corpus_region_bounds(sid, region);
    span = max(1, corpus_hi - corpus_lo);
    pos = region == GC_REGION_BODY ? wrap_in_range(pos, corpus_lo, corpus_hi) : clamp(pos, corpus_lo, max(corpus_lo, corpus_hi - 1));
    phase = clamp01((pos - corpus_lo) / max(1, span - 1));
    glen = clamp(floor(glen), 64, max(64, span));

    // v35 EventScaleOLA: evaluate the same corpus point over micro/short/mid/
    // long/ultra windows. Fast grains still use short information; slow coherent
    // events can now request 100ms-1s grains when the source supports it.
    microwin = clamp(floor(sr * 0.0016), 64, min(max(64, span), floor(sr * 0.010)));
    shortwin = clamp(floor(max(glen * 0.36, sr * 0.010)), max(64, floor(sr * 0.006)), min(max(64, span), floor(sr * 0.080)));
    midwin   = clamp(floor(max(glen, sr * 0.030)), max(80, floor(sr * 0.018)), min(max(96, span), floor(sr * 0.220)));
    longwin  = clamp(floor(max(glen * 3.20, sr * 0.110)), max(midwin + 16, floor(sr * 0.075)), min(max(128, span), floor(sr * 0.620)));
    ultrawin = clamp(floor(max(glen * 8.00, sr * 0.320)), max(longwin + 32, floor(sr * 0.220)), min(max(160, span), floor(sr * 1.120)));

    corpus_measure_at(sm, pos, microwin);
    microrms = corpus_tmp_rms;
    micbright = corpus_tmp_bright;
    micedge = corpus_tmp_edge;
    micsal = corpus_tmp_sal;

    corpus_measure_at(sm, pos, shortwin);
    srms = corpus_tmp_rms;
    sbright = corpus_tmp_bright;
    sedge = corpus_tmp_edge;
    ssal = corpus_tmp_sal;

    corpus_measure_at(sm, pos, midwin);
    mrms = corpus_tmp_rms;
    mbright = corpus_tmp_bright;
    medge = corpus_tmp_edge;
    msal = corpus_tmp_sal;

    corpus_measure_at(sm, pos, longwin);
    lrms = corpus_tmp_rms;
    lbright = corpus_tmp_bright;
    ledge = corpus_tmp_edge;
    lsal = corpus_tmp_sal;

    corpus_measure_at(sm, pos, ultrawin);
    urms = corpus_tmp_rms;
    ubright = corpus_tmp_bright;
    uedge = corpus_tmp_edge;
    usal = corpus_tmp_sal;

    slowmat = clamp01((0.70 - mbright) / 0.56) * clamp01((0.44 - medge) / 0.40);
    stable = clamp01(1 - abs(srms - lrms) * 1.38) * clamp01(1 - abs(sbright - lbright) * 1.05) * clamp01(1 - abs(sedge - ledge) * 0.96);
    ultrastable = clamp01(1 - abs(mrms - urms) * 1.20) * clamp01(1 - abs(mbright - ubright) * 0.92) * clamp01(1 - abs(medge - uedge) * 0.84);
    transscale = clamp01(micedge * 0.72 + max(0, microrms - urms) * 0.54 + sm[SM_FLAGS] * 0.18);
    mstrans = clamp01(sedge * 0.56 + micedge * 0.30 + sbright * 0.18 + sm[SM_FLAGS] * 0.18 + max(0, srms - lrms) * 0.36);
    eventscale = clamp01(slowmat * 0.42 + stable * 0.34 + ultrastable * 0.52 + clamp01(urms - 0.035) * 0.18 - transscale * 0.26);
    mscont = clamp01(slowmat * 0.42 + stable * 0.38 + eventscale * 0.58 + clamp01(lrms - 0.05) * 0.10 - mstrans * 0.22);
    region == GC_REGION_ATTACK ? (
      mscont *= 0.24;
      mstrans = max(mstrans, 0.46 + sm[SM_SHARP] * 0.22);
    );
    region == GC_REGION_TAIL ? (
      mscont = clamp01(mscont * 1.12 + clamp01(0.42 - ledge) * 0.08);
      mstrans *= 0.76;
    );

    region == GC_REGION_ATTACK ? (
      len_goal = sr * lerp(0.018, 0.095, clamp01(1 - mstrans + mscont * 0.22));
      maxlen = min(max(96, span), floor(sr * 0.130));
      minlen = max(64, floor(sr * 0.010));
    ) : region == GC_REGION_TAIL ? (
      len_goal = sr * lerp(0.055, 1.180, max(mscont, eventscale) ^ 0.78) * lerp(1.0, 0.58, mstrans);
      maxlen = min(max(128, span), floor(sr * lerp(0.180, 1.250, max(mscont, eventscale))));
      minlen = max(96, floor(sr * 0.030));
    ) : (
      len_goal = sr * lerp(0.030, 1.050, max(mscont, eventscale) ^ 0.74) * lerp(1.0, 0.58, mstrans);
      // If the body region itself is short or behaves like one coherent event,
      // use most of the event rather than chopping it into little tiles.
      span < sr * lerp(0.260, 1.050, eventscale) && mscont > 0.30 ? len_goal = max(len_goal, span * lerp(0.60, 0.94, max(mscont, eventscale)));
      maxlen = min(max(128, span), floor(sr * lerp(0.120, 1.120, max(mscont, eventscale))));
      minlen = max(80, floor(sr * 0.016));
    );

    lenmix = clamp01(0.48 + 0.30 * mscont + 0.34 * eventscale - 0.20 * mstrans);
    event_len = clamp(floor(lerp(glen, len_goal, lenmix)), minlen, maxlen);
    event_len = clamp(event_len, 64, max(64, span));
    evtfrac = clamp01(event_len / max(1, span));

    pos = corpus_snap_soft_point(sm, pos, corpus_lo, corpus_hi, event_len, region);
    phase = clamp01((pos - corpus_lo) / max(1, span - 1));

    gc = grain_corpus_base + corpus_count * GC_STRIDE;
    corpus_measure_at(sm, pos, event_len);
    crms = corpus_tmp_rms;
    cbright = corpus_tmp_bright;
    cedge = corpus_tmp_edge;
    csharp = corpus_tmp_sharp;
    csal = corpus_tmp_sal;

    // v33 EnvTrajectory: learn local energy motion at load time. v34 uses the
    // adaptive event length for this motion so the envelope follows the same
    // scale as the grain that will actually be played.
    prevpos = pos - max(16, floor(event_len * 0.62));
    prevpos = clamp(prevpos, corpus_lo, max(corpus_lo, corpus_hi - 1));
    corpus_measure_at(sm, prevpos, max(shortwin, floor(event_len * 0.62)));
    prms = corpus_tmp_rms;

    // Phrase-linear. Do not wrap body-end back to body-start.
    nextpos = pos + max(16, floor(event_len * 0.62));
    nextpos = clamp(nextpos, corpus_lo, max(corpus_lo, corpus_hi - 1));
    corpus_measure_at(sm, nextpos, max(shortwin, floor(event_len * 0.62)));
    nrms = corpus_tmp_rms;
    nbright = corpus_tmp_bright;
    nedge = corpus_tmp_edge;

    envdir = clamp(nrms - prms, -1, 1);
    envpeak = clamp01((crms - max(prms, nrms)) * 2.8 + max(0, mrms - lrms) * 0.28);
    envlevel = clamp01((prms + crms * 2 + nrms + lrms) * 0.20);

    gc[GC_SID] = sid;
    gc[GC_POS] = pos;
    gc[GC_LEN] = event_len;
    gc[GC_REGION] = region;
    gc[GC_PHASE] = phase;
    gc[GC_RMS] = crms;
    gc[GC_BRIGHT] = cbright;
    gc[GC_EDGE] = cedge;
    gc[GC_SHARP] = csharp;
    gc[GC_SAL] = csal;
    gc[GC_NRMS] = nrms;
    gc[GC_NBRIGHT] = nbright;
    gc[GC_NEDGE] = nedge;

    // Event id is now adaptive: longer coherent grains create wider event cells,
    // short transient grains keep finer cells.
    event_id = floor(pos / max(1, max(sr * 0.090, event_len * 1.30)));
    gc[GC_EVENT] = sid * 1000000 + event_id;
    gc[GC_PRMS] = prms;
    gc[GC_EDIR] = envdir;
    gc[GC_EPEAK] = envpeak;
    gc[GC_ELEVEL] = envlevel;
    gc[GC_MSCONT] = mscont;
    gc[GC_MSTRANS] = mstrans;
    gc[GC_LRMS] = lrms;
    gc[GC_EVTFRAC] = evtfrac;
    gc[GC_XCONT] = eventscale;
    gc[GC_URMS] = urms;
    gc[GC_UEDGE] = uedge;

    sm[SM_GCCOUNT] += 1;
    corpus_count += 1;
    1;
  ) : 0;
);


function estimate_granular_corpus_markers(sm) local(
  ptr nch sr frames onset_scan hop onset_lpcoef nov_count i j x ax lp hf env_prev hf_prev env_now hf_now cnt nov novsum
  peaki peakv mean_nov smoothv starti peakthr lowthr onset_conf attack onset_rise onset_rise_ms head_ms head_end tail_start fallback_attack fallback_scan fallback_peak fallback_sumsq fallback_rms thresh
)
(
  // v32: Granular prefers Gaussian/novelty markers. This is corpus-only and
  // does not rewrite the playback markers used by Raw/Tape/Hybrid.
  ptr = sm[SM_PTR] | 0;
  nch = max(1, sm[SM_NCH] | 0);
  sr = max(1000, sm[SM_SR]);
  frames = sm[SM_FRAMES] | 0;

  attack = sm[SM_ATTACK];
  head_end = sm[SM_HEADEND];
  tail_start = sm[SM_TAILSTART];

  frames > 256 ? (
    onset_scan = min(frames, max(4096, floor(sr * 1.50)));
    hop = max(1, floor(sr * 0.00075));
    hop = max(hop, floor((onset_scan + ONSET_SCRATCH_MAX - 1) / max(1, ONSET_SCRATCH_MAX)));
    onset_lpcoef = clamp(2200 / max(sr, 1), 0.015, 0.40);

    lp = 0; env_prev = 0; hf_prev = 0; nov_count = 0; novsum = 0; i = 0;
    while (i < onset_scan && nov_count < ONSET_SCRATCH_MAX) (
      env_now = 0; hf_now = 0; cnt = 0; j = 0;
      while (j < hop && (i + j) < onset_scan) (
        x = mono_frame(ptr, nch, i + j);
        ax = abs(x);
        lp += (x - lp) * onset_lpcoef;
        hf = x - lp;
        env_now += ax;
        hf_now += abs(hf);
        cnt += 1;
        j += 1;
      );
      env_now /= max(cnt, 1);
      hf_now /= max(cnt, 1);
      nov = max(0, hf_now - hf_prev * 0.90) + 0.32 * max(0, env_now - env_prev * 0.94);
      nov += 0.10 * max(0, hf_now - env_now * 0.22);
      onset_raw_base[nov_count] = nov;
      novsum += nov;
      env_prev = env_now;
      hf_prev = hf_now;
      nov_count += 1;
      i += hop;
    );

    peaki = 0; peakv = 0; i = 0;
    while (i < nov_count) (
      smoothv = (
        onset_raw_base[clamp(i - 3, 0, max(0, nov_count - 1))] +
        onset_raw_base[clamp(i - 2, 0, max(0, nov_count - 1))] * 6 +
        onset_raw_base[clamp(i - 1, 0, max(0, nov_count - 1))] * 15 +
        onset_raw_base[i] * 20 +
        onset_raw_base[clamp(i + 1, 0, max(0, nov_count - 1))] * 15 +
        onset_raw_base[clamp(i + 2, 0, max(0, nov_count - 1))] * 6 +
        onset_raw_base[clamp(i + 3, 0, max(0, nov_count - 1))]
      ) * 0.015625;
      onset_smooth_base[i] = smoothv;
      smoothv > peakv ? (peakv = smoothv; peaki = i;);
      i += 1;
    );

    fallback_scan = min(frames, onset_scan);
    fallback_peak = 0; fallback_sumsq = 0; i = 0;
    while (i < fallback_scan) (
      x = mono_frame(ptr, nch, i);
      ax = abs(x);
      fallback_peak = max(fallback_peak, ax);
      fallback_sumsq += x * x;
      i += 1;
    );
    fallback_rms = sqrt(fallback_sumsq / max(fallback_scan, 1));
    thresh = max(fallback_peak * 0.12, fallback_rms * 1.8);
    fallback_attack = -1; i = 0;
    while (i < fallback_scan && fallback_attack < 0) (
      abs(mono_frame(ptr, nch, i)) >= thresh ? fallback_attack = i;
      i += 1;
    );
    fallback_attack < 0 ? fallback_attack = 0;

    mean_nov = nov_count > 0 ? (novsum / nov_count) : 0;
    onset_conf = peakv > 0 ? clamp01((peakv - mean_nov * 1.35) / max(peakv, 0.000001)) : 0;
    starti = peaki;
    peakthr = peakv * (0.18 + 0.08 * (1 - onset_conf));
    while (starti > 0 && onset_smooth_base[starti - 1] >= peakthr) (starti -= 1;);
    lowthr = peakv * 0.10;
    while (starti > 0 && onset_smooth_base[starti - 1] > lowthr && (peaki - starti) < 8) (starti -= 1;);

    onset_conf >= 0.10 && peakv > 0.00001 ? attack = floor(starti * hop) : attack = fallback_attack;
    attack = clamp(attack, 0, max(0, frames - 2));
    onset_rise = max(hop, (peaki - starti) * hop);
    onset_rise_ms = 1000 * onset_rise / max(sr, 1);

    head_ms = 5 + clamp01(sm[SM_FLAGS]) * 34 + min(15, onset_rise_ms * 0.34);
    head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
    tail_start = clamp(sm[SM_TAILSTART], head_end + 1, max(head_end + 1, frames - 2));
  );

  sm[SM_GCATTACK] = attack;
  sm[SM_GCHEAD] = head_end;
  sm[SM_GCTAIL] = tail_start;
);

function build_sample_corpus_region(sid region lo hi cnt) local(sm sr span j phase pos cell jitter glen seed_slow)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  sr = max(1000, sm[SM_SR]);
  span = max(1, hi - lo);
  cnt = min(cnt | 0, max(0, corpus_capacity - corpus_count));
  cnt > 0 && span > 8 ? (
    j = 0;
    while (j < cnt && corpus_count < corpus_capacity) (
      phase = (j + 0.5) / max(1, cnt);
      cell = span / max(1, cnt);
      jitter = (rand(1) - 0.5) * cell * 0.46;
      pos = lo + phase * span + jitter;
      region == GC_REGION_BODY ? pos = wrap_in_range(pos, lo, hi) : pos = clamp(pos, lo, max(lo, hi - 1));
      seed_slow = clamp01((0.70 - sm[SM_BRIGHT]) / 0.56) * clamp01((0.44 - sm[SM_EDGE]) / 0.40);
      glen = region == GC_REGION_ATTACK ? floor(sr * lerp(0.020, 0.048, 1 - seed_slow)) : region == GC_REGION_TAIL ? floor(sr * lerp(0.070, 0.180, seed_slow)) : floor(sr * lerp(0.042, 0.145, seed_slow));
      // v34: this is only the seed window. corpus_write_entry() expands or
      // contracts it using multi-scale descriptor stability.
      glen = clamp(glen, 80, min(8192, max(96, floor(span * 0.88))));
      corpus_write_entry(sid, region, pos, glen, phase);
      j += 1;
    );
  );
);

function build_grain_corpus() local(total_frames i sm frames sr lenms target share cnt remain avail reserve atkcnt tailcnt bodycnt alo ahi blo bhi tlo thi span)
(
  corpus_count = 0;
  total_frames = 0;
  i = 0;
  while (i < sample_count) (
    sm = sample_meta_base + i * SM_STRIDE;
    sm[SM_GCSTART] = 0;
    sm[SM_GCCOUNT] = 0;
    total_frames += max(1, sm[SM_FRAMES]);
    i += 1;
  );

  i = 0;
  while (i < sample_count && corpus_count < corpus_capacity) (
    sm = sample_meta_base + i * SM_STRIDE;
    // v37 PerfGate: Granular Gaussian corpus markers are calculated lazily
    // while building the corpus, not during non-Granular bank analysis.
    estimate_granular_corpus_markers(sm);
    frames = sm[SM_FRAMES] | 0;
    sr = max(1000, sm[SM_SR]);
    lenms = sm[SM_LENMS];
    sm[SM_GCSTART] = corpus_count;
    sm[SM_GCCOUNT] = 0;

    target = clamp(floor(lenms / 55) + 8, 8, 512);
    sample_count <= 1 ? target = clamp(floor(lenms / 38) + 24, 64, 2048);
    share = floor((frames / max(1, total_frames)) * corpus_capacity * 0.96) + 4;
    cnt = min(target, max(6, share));
    remain = max(0, sample_count - i - 1);
    avail = max(0, corpus_capacity - corpus_count);
    reserve = remain * 4;
    cnt = min(cnt, max(0, avail - reserve));

    cnt > 0 ? (
      alo = max(0, floor(sm[SM_GCATTACK] - sr * 0.006));
      ahi = clamp(sm[SM_GCHEAD], alo + 1, max(alo + 1, frames - 2));
      blo = clamp(sm[SM_GCHEAD], 0, max(0, frames - 2));
      bhi = clamp(sm[SM_GCTAIL], blo + 1, max(blo + 1, frames - 2));
      tlo = clamp(sm[SM_GCTAIL], 0, max(0, frames - 2));
      thi = max(tlo + 1, frames - 2);

      atkcnt = cnt >= 10 ? clamp(floor(cnt * 0.14), 1, 24) : 1;
      tailcnt = cnt >= 10 ? clamp(floor(cnt * 0.18), 1, 48) : 1;
      bodycnt = max(0, cnt - atkcnt - tailcnt);

      // Long single sources need the corpus concentrated in the continuous body,
      // not in one global attack/tail pair.
      sample_count <= 1 ? (
        atkcnt = min(atkcnt, 12);
        tailcnt = min(tailcnt, 24);
        bodycnt = max(0, cnt - atkcnt - tailcnt);
      );

      (ahi - alo) > 8 ? build_sample_corpus_region(i, GC_REGION_ATTACK, alo, ahi, atkcnt);
      (bhi - blo) > 8 ? build_sample_corpus_region(i, GC_REGION_BODY, blo, bhi, bodycnt);
      (thi - tlo) > 8 ? build_sample_corpus_region(i, GC_REGION_TAIL, tlo, thi, tailcnt);

      // If segmentation produced too few usable regions, backfill from the whole file.
      sm[SM_GCCOUNT] < 4 ? (
        span = max(1, frames - 2);
        build_sample_corpus_region(i, GC_REGION_BODY, 0, max(1, frames - 2), max(4, cnt - sm[SM_GCCOUNT]));
      );
    );

    i += 1;
  );
  corpus_dirty = 0;
);

function corpus_consider_candidate(vix v idx want_region gsize lively truth spice stage fallback_sid) local(
  gc csid cpos clen creg cphase crms cbright cedge csharp csal cevent sm sr lo hi span
  lastidx lastgc hasprev prms pbr pedge psid ppos pevent pphase pregion descer phaseerr histpen regionpen saltarget salpen nearwin nearpen runpen regresspen crosspen score runlim force_cross sameevent
  nextgap seqbonus lowrms_min lowrmspen phase_adv target_phase role rolepen motion_slow gstretch cohscore
  trajpen crossneeded loopbackpen phrase_boundary phrase_cross_bonus cedir cepeak celevel penvdir penvpeak envpen envtarget envdeltatarget envpeaktarget cmscont cmstrans clongrms cevtfrac cxcont curms cuedge lenpen
)
(
  (idx >= 0 && idx < corpus_count) ? (
    gc = grain_corpus_base + idx * GC_STRIDE;
    csid = gc[GC_SID] | 0;
    (csid >= 0 && csid < sample_count) ? (
      cpos = gc[GC_POS];
      clen = max(1, gc[GC_LEN]);
      creg = gc[GC_REGION] | 0;
      cphase = clamp01(gc[GC_PHASE]);
      crms = gc[GC_RMS];
      cbright = gc[GC_BRIGHT];
      cedge = gc[GC_EDGE];
      csharp = gc[GC_SHARP];
      csal = gc[GC_SAL];
      cevent = gc[GC_EVENT];
      cedir = gc[GC_EDIR];
      cepeak = gc[GC_EPEAK];
      celevel = gc[GC_ELEVEL];
      cmscont = gc[GC_MSCONT];
      cmstrans = gc[GC_MSTRANS];
      clongrms = gc[GC_LRMS];
      cevtfrac = gc[GC_EVTFRAC];
      cxcont = gc[GC_XCONT];
      curms = gc[GC_URMS];
      cuedge = gc[GC_UEDGE];

      corpus_region_bounds(csid, creg);
      lo = corpus_lo;
      hi = corpus_hi;
      span = max(1, hi - lo);

      lastidx = v[VC_LGCIDX] | 0;
      hasprev = (lastidx >= 0 && lastidx < corpus_count) ? 1 : 0;
      hasprev ? (
        lastgc = grain_corpus_base + lastidx * GC_STRIDE;
        psid = lastgc[GC_SID] | 0;
        ppos = lastgc[GC_POS];
        pevent = lastgc[GC_EVENT];
        pphase = clamp01(lastgc[GC_PHASE]);
        pregion = lastgc[GC_REGION] | 0;
        prms = lastgc[GC_NRMS];
        pbr = lastgc[GC_NBRIGHT];
        pedge = lastgc[GC_NEDGE];
        penvdir = lastgc[GC_EDIR];
        penvpeak = lastgc[GC_EPEAK];
        nextgap = (csid == psid && creg == pregion) ? (idx - lastidx) : 9999;
        phase_adv = clamp((clen * 0.32 + abs(v[VC_SRCHOP]) * 0.58) / max(1, span), 0.010, 0.185);
        target_phase = clamp01(pphase + phase_adv);
        descer = abs(crms - prms) * 0.72 + abs(cbright - pbr) * 1.12 + abs(cedge - pedge) * 0.92;
        phaseerr = abs(cphase - target_phase);
      ) : (
        psid = fallback_sid;
        ppos = v[VC_LGPOS];
        pevent = -999999;
        pphase = 0.5;
        pregion = -1;
        nextgap = 9999;
        descer = 0;
        phaseerr = 0;
        penvdir = 0;
        penvpeak = 0;
      );

      corpus_phrase_targets(v, stage, lively, truth, spice);

      want_region == GC_REGION_TAIL ? (
        regionpen = creg == GC_REGION_TAIL ? 0 : 4.5;
      ) : (
        (stage == ENV_ATTACK || stage == ENV_HOLD) ? (
          regionpen = creg == GC_REGION_ATTACK ? -0.15 : (creg == GC_REGION_BODY ? 0.36 : 2.8);
        ) : (
          regionpen = creg == GC_REGION_BODY ? 0 : (creg == GC_REGION_ATTACK ? (0.95 + 1.25 * (1 - lively) - 1.10 * phrase_attack_pull) : 2.0);
        );
      );

      histpen = grain_hist_penalty(vix, csid, cpos, lo, hi) * (0.20 + 0.28 * lively + 0.14 * (1 - truth));
      sm = sample_meta_base + csid * SM_STRIDE;
      sr = max(1000, sm[SM_SR]);
      nearwin = max(gsize * (1.20 + 0.62 * lively), sr * 0.082);
      // v30: adjacent corpus entries are not "repeats"; they are the coherent
      // continuation stream. Penalize only stalling/regression/re-hitting.
      nearpen = (hasprev && csid == psid && abs(cpos - ppos) < nearwin) ? (
        (nextgap >= 1 && nextgap <= 5) ? (0.08 + 0.14 * lively) : (3.2 + 3.6 * lively + 0.85 * (1 - truth))
      ) : 0;
      idx == lastidx ? nearpen += 1000;

      runlim = grain_run_limit(lively, truth, spice);
      force_cross = (sample_count > 1 && hasprev && v[VC_LGRUN] >= runlim) ? 1 : 0;
      crosspen = (force_cross && csid == psid) ? 1000 : 0;
      runpen = (hasprev && csid == psid) ? max(0, v[VC_LGRUN] - runlim * 0.72) * (0.22 + 0.34 * lively) : (-0.045 * spice);

      sameevent = hasprev && csid == psid && cevent == pevent;
      seqbonus = (hasprev && csid == psid && nextgap >= 1 && nextgap <= 5) ? (-(0.72 - nextgap * 0.085) * (0.52 + 0.34 * (1 - spice) + 0.20 * (1 - truth))) : 0;
      sample_count <= 1 && sameevent ? (
        (nextgap >= 1 && nextgap <= 5) ? nearpen += 0.04 * lively : nearpen += 2.2 + 2.2 * lively
      );
      regresspen = (hasprev && csid == psid && cphase < pphase - 0.14) ? (1.9 + 2.1 * lively) : 0;

      saltarget = (stage == ENV_ATTACK || stage == ENV_HOLD) ? 0.58 : (stage == ENV_RELEASE ? (0.28 + 0.22 * spice) : (0.34 + 0.18 * lively + 0.08 * spice));
      salpen = abs(csal - saltarget) * 0.50 + max(0, csal - saltarget - 0.30) * (0.78 + 0.82 * lively);
      lowrms_min = want_region == GC_REGION_TAIL ? 0.016 : (creg == GC_REGION_ATTACK ? 0.030 : 0.046);
      lowrmspen = max(0, lowrms_min - crms) * (17 + 10 * (1 - truth) + 5 * lively);

      // v32 ThreeStream/PhraseTrajectory: one stream carries continuity, one fills low-salience
      // texture, and a rare spice stream is allowed to be more salient. This is a
      // lightweight role bias over the same corpus selector, not a separate engine.
      role = corpus_pick_role | 0;
      motion_slow = max(clamp01((0.58 - cbright) / 0.48) * clamp01((0.34 - cedge) / 0.30), max(cmscont * 0.82 - cmstrans * 0.18, cxcont * 0.95 - cmstrans * 0.10));
      // v36 GranStretch: higher Stretch in Granular biases selection toward
      // coherent event playback. At 1x this is exactly zero, preserving v35.
      gstretch = granular_event_stretch * ((stage == ENV_ATTACK || stage == ENV_HOLD) ? 0.30 : 1.0);
      cohscore = clamp01(max(cmscont, cxcont) - cmstrans * 0.20 + motion_slow * 0.28);
      rolepen = 0;
      role == 0 ? (
        // Anchor: prefer same-source/event forward motion and penalize jumpy tiles.
        rolepen += (hasprev && csid == psid && creg == pregion && nextgap >= 1 && nextgap <= 6) ? -0.52 : 0.38;
        rolepen += (hasprev && csid != psid) ? (0.45 + 0.34 * (1 - spice)) : 0;
        rolepen += abs(csal - (0.30 + 0.10 * lively)) * 0.20;
        rolepen -= cmscont * (0.22 + 0.22 * motion_slow);
        rolepen += cmstrans * 0.10;
      ) : role == 1 ? (
        // Texture: prefer filler that masks seams without becoming a hero grain.
        rolepen += max(0, csal - (0.34 + 0.10 * lively)) * (1.10 + 0.55 * lively);
        rolepen += sameevent ? 0.18 : -0.08;
        rolepen += motion_slow * -0.18;
        rolepen -= cmscont * 0.16;
      ) : (
        // Spice: rare high-character grains are allowed, but still scored.
        rolepen += -csal * (0.42 + 0.42 * spice + 0.32 * lively);
        rolepen += creg == GC_REGION_ATTACK ? -0.12 * lively : 0;
        rolepen += sameevent ? 0.36 : -0.08;
        rolepen -= cmstrans * (0.14 + 0.18 * lively);
        salpen *= 0.42;
        regionpen *= 0.62;
      );

      gstretch > 0 && hasprev ? (
        // Slow-event Stretch should sound like a plausible continuation of the
        // same source/event when possible, not a fresh patchwork tile.
        csid != psid ? rolepen += gstretch * cohscore * (0.62 + 0.48 * (1 - spice)) * (role == 0 ? 1.0 : 0.48);
        (csid == psid && creg == pregion && nextgap >= 1 && nextgap <= 12) ? seqbonus -= gstretch * cohscore * (0.30 + 0.34 * (1 - truth));
        (csid == psid && nextgap > 12) ? nearpen += gstretch * cohscore * 0.40;
      );

      phrase_boundary = hasprev && csid == psid && pphase > (0.72 - 0.14 * lively) ? clamp01((pphase - (0.72 - 0.14 * lively)) / max(0.05, 0.28 + 0.14 * lively)) : 0;
      crossneeded = (sample_count > 1 && phrase_boundary > 0.55 && v[VC_LGRUN] >= max(3, floor(runlim * 0.52))) ? 1 : 0;
      phrase_cross_bonus = crossneeded && csid != psid ? -(0.35 + 0.35 * spice + 0.20 * lively) : 0;
      loopbackpen = (hasprev && csid == psid && cphase < pphase - (0.07 + 0.06 * lively)) ? (1.6 + 2.4 * lively + 1.2 * motion_slow) : 0;
      trajpen = abs(cbright - phrase_bright_t) * (0.18 + 0.42 * lively)
              + abs(cedge - phrase_edge_t) * (0.16 + 0.40 * lively)
              + abs(csal - phrase_sal_t) * (0.14 + 0.28 * lively);

      // v33 EnvTrajectory: phrase target and learned corpus envelope must agree.
      // This is the first pass at co-determining phrase and amplitude motion.
      envtarget = phrase_env_t;
      envdeltatarget = phrase_env_delta_t;
      envpeaktarget = phrase_env_peak_t;
      hasprev ? (
        // Prefer grains whose current energy plausibly follows the previous
        // grain's learned next energy, then blend toward the phrase envelope.
        envtarget = lerp(prms, phrase_env_t, 0.28 + 0.26 * lively + 0.18 * spice);
        envdeltatarget = lerp(penvdir, phrase_env_delta_t, 0.35 + 0.30 * lively);
        envpeaktarget = lerp(penvpeak, phrase_env_peak_t, 0.42 + 0.24 * lively);
      );
      envpen = abs(celevel - envtarget) * (0.72 + 0.55 * (1 - truth) + 0.45 * motion_slow)
             + abs(cedir - envdeltatarget) * (0.42 + 0.48 * lively + 0.30 * motion_slow)
             + abs(cepeak - envpeaktarget) * (0.20 + 0.34 * lively);
      role == 0 ? ( envpen *= 1.18; ); // anchor owns the prosody
      role == 1 ? ( envpen *= 0.72; ); // texture can be flatter as seam glue
      role == 2 ? ( envpen *= 0.52; ); // spice can violate the curve
      motion_slow > 0.18 && hasprev ? (
        // Slow/bassy material needs continuity more than novelty. Bright squelch
        // can jump around; low-motion material must flow.
        csid != psid ? trajpen += motion_slow * (0.55 + 0.45 * (1 - spice)) * (1 - 0.55 * phrase_boundary);
        (csid == psid && nextgap >= 1 && nextgap <= 8) ? seqbonus -= motion_slow * (0.38 + 0.30 * (1 - truth));
      );

      // v34: prefer event-scale grains when the multi-scale analysis says this
      // point wants continuity, but do not force huge windows on bright attacks.
      lenpen = 0;
      cmscont > 0.30 ? lenpen -= cmscont * clamp01(cevtfrac * 2.2) * (0.20 + 0.22 * (1 - truth));
      cxcont > 0.35 ? lenpen -= cxcont * clamp01(cevtfrac * 1.65) * (0.18 + 0.30 * (1 - truth));
      gstretch > 0 ? lenpen -= gstretch * cohscore * clamp01(cevtfrac * 2.35) * (0.30 + 0.42 * (1 - truth));
      cmstrans > 0.55 ? lenpen += max(0, cevtfrac - lerp(0.36, 0.56, gstretch)) * cmstrans * (0.48 + 0.40 * lively) * (1 - 0.35 * gstretch);

      score = regionpen + descer * (1.28 + 0.52 * (1 - truth) + 0.55 * motion_slow + 0.34 * gstretch * cohscore) + phaseerr * (0.62 + 0.46 * (1 - spice) + 0.38 * motion_slow + 0.44 * gstretch * cohscore);
      score += histpen + nearpen + runpen + regresspen + crosspen + salpen + lowrmspen + seqbonus + rolepen + trajpen + envpen + lenpen + loopbackpen + phrase_cross_bonus;
      csid == fallback_sid ? score -= 0.030 * (1 - spice);
      score < corpus_best_score ? (
        corpus_best_score = score;
        corpus_best_idx = idx;
        corpus_best_sid = csid;
        corpus_best_pos = cpos;
        corpus_best_lo = lo;
        corpus_best_hi = hi;
        corpus_best_len = clen;
      );
    );
  );
);

function corpus_pick_grain(vix v want_region fallback_sid fallback_pos fallback_lo fallback_hi gsize lively truth spice stage) local(
  tries idx sm start count r lastidx lastgc psid pstart pcount nearidx k phase idx2
)
(
  corpus_best_idx = -1;
  corpus_best_sid = -1;
  corpus_best_pos = fallback_pos;
  corpus_best_lo = fallback_lo;
  corpus_best_hi = fallback_hi;
  corpus_best_len = gsize;
  corpus_best_score = 1000000000;

  corpus_count > 0 ? (
    // Seed the search with candidates around the anchor sample so Granular still
    // feels related to the triggered note, then add corpus-wide candidates so a
    // single long file or mixed bank can transform instead of merely replay.
    (fallback_sid >= 0 && fallback_sid < sample_count) ? (
      sm = sample_meta_base + fallback_sid * SM_STRIDE;
      start = sm[SM_GCSTART] | 0;
      count = sm[SM_GCCOUNT] | 0;
      count > 0 ? (
        k = 0;
        while (k < 5) (
          idx = start + floor(rand(count));
          corpus_consider_candidate(vix, v, idx, want_region, gsize, lively, truth, spice, stage, fallback_sid);
          k += 1;
        );
      );
    );

    lastidx = v[VC_LGCIDX] | 0;
    (lastidx >= 0 && lastidx < corpus_count) ? (
      lastgc = grain_corpus_base + lastidx * GC_STRIDE;
      psid = lastgc[GC_SID] | 0;
      (psid >= 0 && psid < sample_count) ? (
        sm = sample_meta_base + psid * SM_STRIDE;
        pstart = sm[SM_GCSTART] | 0;
        pcount = sm[SM_GCCOUNT] | 0;
        pcount > 0 ? (
          // v30: feed the selector actual forward continuations before random
          // candidates. This makes the corpus behave like plausible motion, not
          // disconnected tiles. No wrap is used at the end.
          k = 1;
          while (k <= (16 + floor(24 * granular_event_stretch))) (
            nearidx = lastidx + k;
            (nearidx >= pstart && nearidx < pstart + pcount) ? (
              corpus_consider_candidate(vix, v, nearidx, want_region, gsize, lively, truth, spice, stage, fallback_sid);
            );
            k += 1;
          );
          k = 0;
          while (k < 4) (
            idx = pstart + floor(rand(pcount));
            corpus_consider_candidate(vix, v, idx, want_region, gsize, lively, truth, spice, stage, fallback_sid);
            k += 1;
          );
        );
      );
    );

    tries = floor((22 + floor(20 * lively) + floor(10 * spice)) * lerp(1.0, 0.58, granular_event_stretch));
    tries = max(10, tries);
    while (tries > 0) (
      idx = floor(rand(corpus_count));
      corpus_consider_candidate(vix, v, idx, want_region, gsize, lively, truth, spice, stage, fallback_sid);
      tries -= 1;
    );
  );
);


function update_sample_cluster(sm) local(br sh tr len pitch len_norm pitch_norm)
(
  // Compact descriptor-bin cluster for Walk mode.
  // It is intentionally cheap: brightness, attack focus, transient richness, length, and pitch bin.
  br = min(3, max(0, floor(clamp01(sm[SM_BRIGHT]) * 4)));
  sh = min(3, max(0, floor(clamp01(sm[SM_SHARP]) * 4)));
  tr = min(3, max(0, floor(clamp01(sm[SM_FLAGS]) * 4)));
  len_norm = clamp01(log(sm[SM_LENMS] + 1) / log(5001));
  len = min(4, max(0, floor(len_norm * 5)));
  pitch_norm = clamp01((sm[SM_ROOT] - ROOT_LOW) / max(ROOT_HIGH - ROOT_LOW, 1));
  pitch = sm[SM_PITCHCONF] > 0.42 ? min(5, max(0, floor(pitch_norm * 6))) : 0;

  sm[SM_CLUSTER] = br + sh * 4 + tr * 16 + len * 64 + pitch * 320;
);

function walk_cluster_distance(a b) local(
  ca cb
  abr ash atr alen apit
  bbr bsh btr blen bpit
)
(
  ca = a[SM_CLUSTER] | 0;
  cb = b[SM_CLUSTER] | 0;

  abr = ca % 4; ca = floor(ca / 4);
  ash = ca % 4; ca = floor(ca / 4);
  atr = ca % 4; ca = floor(ca / 4);
  alen = ca % 5; ca = floor(ca / 5);
  apit = ca % 6;

  bbr = cb % 4; cb = floor(cb / 4);
  bsh = cb % 4; cb = floor(cb / 4);
  btr = cb % 4; cb = floor(cb / 4);
  blen = cb % 5; cb = floor(cb / 5);
  bpit = cb % 6;

  abs(abr - bbr) * 0.12
  + abs(ash - bsh) * 0.13
  + abs(atr - btr) * 0.10
  + abs(alen - blen) * 0.10
  + abs(apit - bpit) * (bank_pitchiness > 0.35 ? 0.055 : 0.018);
);

function sample_descriptor_distance(a b region_mode) local(
  brighterr sharperr transerr lenerr pitcherr regionerr clustererr
  aspan bspan
)
(
  brighterr = abs(a[SM_BRIGHT] - b[SM_BRIGHT]);
  sharperr  = abs(a[SM_SHARP] - b[SM_SHARP]);
  transerr  = abs(a[SM_FLAGS] - b[SM_FLAGS]);
  lenerr    = min(1.8, abs(log((a[SM_LENMS] + 1) / (b[SM_LENMS] + 1))));

  pitcherr = 0;
  (a[SM_PITCHCONF] > 0.38 && b[SM_PITCHCONF] > 0.38) ? (
    pitcherr = min(1.5, abs(a[SM_ROOT] - b[SM_ROOT]) / 24);
  );

  region_mode ? (
    aspan = max(1, a[SM_FRAMES] - a[SM_TAILSTART]) / max(1, a[SM_FRAMES]);
    bspan = max(1, b[SM_FRAMES] - b[SM_TAILSTART]) / max(1, b[SM_FRAMES]);
  ) : (
    aspan = max(1, a[SM_TAILSTART] - a[SM_HEADEND]) / max(1, a[SM_FRAMES]);
    bspan = max(1, b[SM_TAILSTART] - b[SM_HEADEND]) / max(1, b[SM_FRAMES]);
  );
  regionerr = abs(aspan - bspan);

  clustererr = walk_cluster_distance(a, b);

  brighterr * 0.80
  + sharperr * 0.88
  + transerr * 0.66
  + lenerr * 0.22
  + regionerr * 0.55
  + pitcherr * (0.10 + 0.36 * bank_pitchiness)
  + clustererr * 0.38;
);

function choose_random_sample(note velnorm) local(
  i sm sid score bright_t brighterr sharp_t sharperr
  rep rep_scale totalw pick accum weight temp
)
(
  sample_count <= 0 ? 0 : (
    bright_t = clamp01(0.5 + slider6 * 0.20 + (velnorm - 0.5) * 0.06);
    sharp_t  = clamp01(0.48 + slider7 * 0.22 + (velnorm - 0.5) * 0.10);
    rep_scale = 0.30 + slider9 * 1.45;
    temp = lerp(4.0, 1.4, slider9);
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      sm = sample_meta_base + i * SM_STRIDE;
      brighterr = abs(sm[SM_BRIGHT] - bright_t);
      sharperr  = abs(sm[SM_SHARP] - sharp_t);
      score = brighterr * 0.95 + sharperr * 1.10;
      score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
      weight = 0.15 + exp(-score * temp);
      totalw += weight;
      i += 1;
    );

    totalw <= 0 ? (
      floor(rand(max(sample_count, 1)));
    ) : (
      pick = rand(totalw);
      accum = 0;
      sid = sample_count - 1;
      i = 0;
      while (i < sample_count) (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - bright_t);
        sharperr  = abs(sm[SM_SHARP] - sharp_t);
        score = brighterr * 0.95 + sharperr * 1.10;
        score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
        weight = 0.15 + exp(-score * temp);
        accum += weight;
        accum >= pick ? (
          sid = i;
          i = sample_count;
        ) : i += 1;
      );
      sid;
    );
  );
);

function choose_walk_sample(note velnorm) local(
  i sm sid lastsm prevsm
  score bright_t sharperr brighterr toneerr
  dlast dprev clustererr target jump too_close prev_bounce
  rep rep_scale totalw pick accum weight temp
)
(
  sample_count <= 0 ? 0 : (
    (walk_last_sid < 0 || walk_last_sid >= sample_count || sample_count <= 1) ? (
      choose_random_sample(note, velnorm);
    ) : (
      lastsm = sample_meta_base + walk_last_sid * SM_STRIDE;
      prevsm = (walk_prev_sid >= 0 && walk_prev_sid < sample_count) ? (sample_meta_base + walk_prev_sid * SM_STRIDE) : lastsm;

      bright_t = clamp01(0.5 + slider6 * 0.18 + (velnorm - 0.5) * 0.05);
      target = 0.16 + slider9 * 0.30 + truth_mix * 0.06;
      rep_scale = 0.45 + slider9 * 1.30;
      temp = lerp(7.2, 2.0, slider9);
      totalw = 0;

      i = 0;
      while (i < sample_count) (
        i != walk_last_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;

          dlast = sample_descriptor_distance(lastsm, sm, 0);
          dprev = sample_descriptor_distance(prevsm, sm, 0);
          clustererr = walk_cluster_distance(lastsm, sm);

          brighterr = abs(sm[SM_BRIGHT] - bright_t);
          sharperr  = abs(sm[SM_SHARP] - clamp01(lastsm[SM_SHARP] * 0.72 + slider7 * 0.12 + 0.18));
          toneerr = brighterr * 0.36 + sharperr * 0.28;

          jump = max(0, dlast - (0.44 + slider9 * 0.38));
          too_close = max(0, (0.035 + (1 - slider9) * 0.045) - dlast);
          prev_bounce = (walk_prev_sid >= 0 && i == walk_prev_sid && sample_count > 2) ? 0.42 : 0;
          (dprev < 0.055 && sample_count > 3) ? prev_bounce += 0.18;

          score = abs(dlast - target) * 2.15;
          score += jump * 3.20;
          score += too_close * 4.60;
          score += clustererr * (0.18 + 0.24 * (1 - slider9));
          score += toneerr;
          score += prev_bounce;
          score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);

          weight = 0.002 + exp(-score * temp);
          totalw += weight;
        );
        i += 1;
      );

      totalw <= 0 ? (
        choose_random_sample(note, velnorm);
      ) : (
        pick = rand(totalw);
        accum = 0;
        sid = walk_last_sid;
        i = 0;
        while (i < sample_count) (
          i != walk_last_sid ? (
            sm = sample_meta_base + i * SM_STRIDE;

            dlast = sample_descriptor_distance(lastsm, sm, 0);
            dprev = sample_descriptor_distance(prevsm, sm, 0);
            clustererr = walk_cluster_distance(lastsm, sm);

            brighterr = abs(sm[SM_BRIGHT] - bright_t);
            sharperr  = abs(sm[SM_SHARP] - clamp01(lastsm[SM_SHARP] * 0.72 + slider7 * 0.12 + 0.18));
            toneerr = brighterr * 0.36 + sharperr * 0.28;

            jump = max(0, dlast - (0.44 + slider9 * 0.38));
            too_close = max(0, (0.035 + (1 - slider9) * 0.045) - dlast);
            prev_bounce = (walk_prev_sid >= 0 && i == walk_prev_sid && sample_count > 2) ? 0.42 : 0;
            (dprev < 0.055 && sample_count > 3) ? prev_bounce += 0.18;

            score = abs(dlast - target) * 2.15;
            score += jump * 3.20;
            score += too_close * 4.60;
            score += clustererr * (0.18 + 0.24 * (1 - slider9));
            score += toneerr;
            score += prev_bounce;
            score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);

            weight = 0.002 + exp(-score * temp);
            accum += weight;
            accum >= pick ? (
              sid = i;
              i = sample_count;
            ) : i += 1;
          ) : i += 1;
        );
        sid == walk_last_sid ? choose_random_sample(note, velnorm) : sid;
      );
    );
  );
);

function choose_region_donor(src_sid region_mode wideness vix) local(
  src sm i pick accum totalw sid temp minspan
  src_lo src_hi src_span lo hi span
  brighterr sharperr transerr lenerr pitcherr regionerr histpen walkerr score weight
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    region_mode ? (
      src_lo = clamp(src[SM_TAILSTART], 0, max(0, src[SM_FRAMES] - 2));
      src_hi = max(src_lo + 1, src[SM_FRAMES] - 2);
      minspan = max(24, floor(hybrid_grain_samps * 0.22));
    ) : (
      src_lo = clamp(src[SM_HEADEND], 0, max(0, src[SM_TAILSTART] - 1));
      src_hi = clamp(src[SM_TAILSTART], src_lo + 1, max(src_lo + 1, src[SM_FRAMES] - 2));
      minspan = max(48, floor(hybrid_grain_samps * 0.36));
    );
    src_span = max(1, src_hi - src_lo);
    temp = lerp(10.0, 1.25, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        region_mode ? (
          lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
          hi = max(lo + 1, sm[SM_FRAMES] - 2);
        ) : (
          lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
          hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
        );
        span = max(1, hi - lo);

        span >= minspan ? (
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          regionerr = abs(log((span + 1) / (src_span + 1)));

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.38 && sm[SM_PITCHCONF] > 0.38) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          histpen = grain_sid_penalty(vix, i);
          score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
          score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
          score += histpen * 0.24;
          walk_mode ? (
            walkerr = sample_descriptor_distance(src, sm, region_mode);
            score += walkerr * (0.16 + 0.34 * (1 - clamp01(wideness)));
          );

          weight = 0.0005 + exp(-score * temp);
          totalw += weight;
        );
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          region_mode ? (
            lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
            hi = max(lo + 1, sm[SM_FRAMES] - 2);
          ) : (
            lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
            hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
          );
          span = max(1, hi - lo);

          span >= minspan ? (
            brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
            sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
            transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
            lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
            regionerr = abs(log((span + 1) / (src_span + 1)));

            pitcherr = 0;
            (src[SM_PITCHCONF] > 0.38 && sm[SM_PITCHCONF] > 0.38) ? (
              pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
            );

            histpen = grain_sid_penalty(vix, i);
            score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
            score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
            score += histpen * 0.24;
            walk_mode ? (
              walkerr = sample_descriptor_distance(src, sm, region_mode);
              score += walkerr * (0.16 + 0.34 * (1 - clamp01(wideness)));
            );

            weight = 0.0005 + exp(-score * temp);
            accum += weight;
            accum >= pick ? (
              sid = i;
              i = sample_count;
            ) : i += 1;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);

function choose_region_pos(vix sid region_mode phase01 jitter_norm) local(
  sm lo hi span center pos jitter scale
  best bestscore score dist try limit
)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  region_mode ? (
    lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
    hi = max(lo + 1, sm[SM_FRAMES] - 2);
    limit = hybrid_tail_jitter;
  ) : (
    lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
    hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
    limit = hybrid_body_jitter;
  );
  span = max(1, hi - lo);
  center = lo + clamp01(phase01) * max(1, span - 1);
  best = clamp(center, lo, max(lo, hi - 1));
  bestscore = 1000000000;

  try = 0;
  while (try < GRAIN_CAND_TRIES) (
    scale = min(span * lerp(0.16, 0.52, clamp01(jitter_norm)), limit);
    jitter = (rand(1) - 0.5) * scale * 2;
    pos = center + jitter;
    region_mode ? (
      pos = clamp(pos, lo, max(lo, hi - 1));
    ) : (
      pos = wrap_in_range(pos, lo, hi);
    );
    dist = abs(pos - center) / max(1, span);
    score = grain_hist_penalty(vix, sid, pos, lo, hi) + dist * (region_mode ? 0.12 : 0.16);
    score < bestscore ? (
      bestscore = score;
      best = pos;
    );
    try += 1;
  );

  best;
);


function source_phase_jitter_samples(sid region_mode lively truth spice) local(sm sr conf note hz period amt maxms off)
(
  (sid < 0 || sid >= sample_count) ? 0 : (
    sm = sample_meta_base + sid * SM_STRIDE;
    sr = max(1, sm[SM_SR]);
    conf = clamp01(sm[SM_PITCHCONF] * bank_pitchiness);

    // Pitched material: source offset up to roughly +/- half a pitch period.
    // Noisy material: small millisecond dephasing. This avoids hard polarity flips.
    conf > 0.38 ? (
      note = sm[SM_ROOT];
      hz = 440 * exp((note - 69) * 0.0577622650466621);
      period = sr / max(20, hz);
      amt = clamp01(lively) * lerp(0.22, 0.82, 1 - truth) * lerp(0.82, 1.10, spice);
      off = (rand(1) - 0.5) * period * amt;
    ) : (
      maxms = lerp(0.00025, 0.00280, clamp01(lively)) * lerp(1.00, 0.66, truth) * lerp(0.84, 1.16, spice);
      off = (rand(1) - 0.5) * 2 * sr * maxms;
    );

    region_mode ? off *= 0.82 : off *= 0.70;
    off;
  );
);


function wrap01(x) local(y)
(
  y = x - floor(x);
  y < 0 ? y += 1;
  y;
);

function phase_lerp_region(a b amt region_mode) local(t)
(
  // v13: phase is no longer circular for body grains. Circular interpolation was
  // one reason learned-flow could rebuild a source phrase, hit the end, wrap to
  // the beginning, and make the same take audible again.
  t = clamp01(amt);
  lerp(clamp01(a), clamp01(b), t);
);

function grain_region_lo(sid region_mode) local(sm)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  region_mode ? (
    clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
  ) : (
    clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
  );
);

function grain_region_hi(sid region_mode) local(sm lo)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  region_mode ? (
    lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
    max(lo + 1, sm[SM_FRAMES] - 2);
  ) : (
    lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
    clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
  );
);

function grain_follow_phase(v region_mode) local(lo hi span ph step f)
(
  (v[VC_LGSID] < 0 || v[VC_LGREG] != region_mode) ? -1 : (
    lo = v[VC_LGLO];
    hi = max(lo + 1, v[VC_LGHI]);
    span = max(1, hi - lo);
    ph = clamp01((v[VC_LGPOS] - lo) / max(1, span - 1));
    step = clamp(abs(v[VC_SRCHOP]) / max(1, span), 0.006, 0.24);
    f = ph + step * (0.78 + 0.20 * rand(1));
    // No wrap. Reaching the end of a body phrase should cause cross-sample
    // continuation, not restart the same take.
    clamp01(f);
  );
);


function grain_follow_strength(v lively truth spice) local(runw runlim)
(
  // Strong at the start of a phrase, then fades hard as the same source repeats.
  // v12 faded too slowly, causing take-sized loops.
  runlim = max(1, grain_run_limit(lively, truth, spice));
  runw = clamp01(v[VC_LGRUN] / runlim);
  clamp01(0.82 + 0.08 * (1 - lively) + 0.05 * (1 - truth) - 0.10 * spice - 0.58 * runw);
);


function flow_slot(region_mode bin feat)
(
  SM_FLOWBASE + ((clamp(region_mode, 0, 1) | 0) * FLOW_BINS + clamp(bin | 0, 0, FLOW_BINS - 1)) * FLOW_FEATS + clamp(feat | 0, 0, FLOW_FEATS - 1);
);

function flow_weight_slot(region_mode outfeat infeat)
(
  flow_model_base + ((clamp(region_mode, 0, 1) | 0) * FLOW_FEATS + clamp(outfeat | 0, 0, FLOW_FEATS - 1)) * FLOW_IN + clamp(infeat | 0, 0, FLOW_IN - 1);
);

function flow_region_bounds(sm region_mode) local(lo hi)
(
  region_mode ? (
    flow_lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
    flow_hi = max(flow_lo + 1, sm[SM_FRAMES] - 2);
  ) : (
    flow_lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
    flow_hi = clamp(sm[SM_TAILSTART], flow_lo + 1, max(flow_lo + 1, sm[SM_FRAMES] - 2));
  );
);

function analyze_sample_flow(sm) local(
  ptr nch sr frames region bin lo hi span center win a b n i x ax prev sumsq sumabs sumdiff
  frms fbright fedge relrms slot fallback_rms
)
(
  ptr    = sm[SM_PTR] | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;
  fallback_rms = max(sm[SM_RMS], 0.000001);

  region = 0;
  while (region < 2) (
    flow_region_bounds(sm, region);
    lo = flow_lo;
    hi = flow_hi;
    span = max(1, hi - lo);

    bin = 0;
    while (bin < FLOW_BINS) (
      center = lo + (bin + 0.5) * span / FLOW_BINS;
      win = clamp(floor(sr * 0.0065), 48, 512);
      win = min(win, max(32, floor(span * 0.45)));
      a = clamp(floor(center - win * 0.5), 0, max(0, frames - 2));
      b = clamp(a + win, a + 1, max(a + 1, frames - 1));

      n = 0;
      sumsq = 0;
      sumabs = 0;
      sumdiff = 0;
      prev = mono_frame(ptr, nch, a);
      i = a;
      while (i < b) (
        x = mono_frame(ptr, nch, i);
        ax = abs(x);
        sumsq += x * x;
        sumabs += ax;
        i > a ? sumdiff += abs(x - prev);
        prev = x;
        n += 1;
        i += 1;
      );

      frms = sqrt(sumsq / max(n, 1));
      relrms = clamp01(frms / max(fallback_rms * 2.85, 0.000001));
      fedge = clamp01((sumdiff / max(sumabs, 0.000001)) * 0.20);
      fbright = clamp01(sm[SM_BRIGHT] * 0.42 + fedge * 0.58 + sm[SM_SHARP] * 0.08);

      slot = flow_slot(region, bin, 0); sm[slot] = relrms;
      slot = flow_slot(region, bin, 1); sm[slot] = fbright;
      slot = flow_slot(region, bin, 2); sm[slot] = clamp01(fedge * 0.70 + sm[SM_FLAGS] * 0.20 + sm[SM_SHARP] * 0.10);

      bin += 1;
    );

    region += 1;
  );
);

function init_flow_model() local(region o inn widx)
(
  region = 0;
  while (region < 2) (
    o = 0;
    while (o < FLOW_FEATS) (
      inn = 0;
      while (inn < FLOW_IN) (
        widx = flow_weight_slot(region, o, inn);
        flow_model_base[widx - flow_model_base] = 0;
        inn += 1;
      );
      // Identity-biased one-layer predictor. Training nudges this toward the
      // corpus' actual next-grain statistics, but it starts safe.
      widx = flow_weight_slot(region, o, o);
      flow_model_base[widx - flow_model_base] = 0.86;
      widx = flow_weight_slot(region, o, 4);
      flow_model_base[widx - flow_model_base] = 0.04;
      o += 1;
    );
    region += 1;
  );
  flow_model_trained = 0;
);

function flow_predict(region_mode outfeat x0 x1 x2 phase) local(wbase y)
(
  wbase = flow_weight_slot(region_mode, outfeat, 0);
  y = flow_model_base[wbase - flow_model_base] * x0
    + flow_model_base[wbase - flow_model_base + 1] * x1
    + flow_model_base[wbase - flow_model_base + 2] * x2
    + flow_model_base[wbase - flow_model_base + 3] * phase
    + flow_model_base[wbase - flow_model_base + 4];
  clamp01(y);
);

function train_flow_model() local(
  region o inn epoch i sm bin slot0 slot1 x0 x1 x2 ph y0 y1 y2 p0 p1 p2 err lr widx
)
(
  init_flow_model();
  sample_count > 0 ? (
    epoch = 0;
    while (epoch < 2) (
      lr = epoch == 0 ? 0.030 : 0.014;
      region = 0;
      while (region < 2) (
        i = 0;
        while (i < sample_count) (
          sm = sample_meta_base + i * SM_STRIDE;
          bin = 0;
          while (bin < FLOW_BINS - 1) (
            slot0 = flow_slot(region, bin, 0);
            slot1 = flow_slot(region, bin + 1, 0);
            x0 = sm[slot0];
            x1 = sm[slot0 + 1];
            x2 = sm[slot0 + 2];
            ph = bin / max(1, FLOW_BINS - 1);
            y0 = sm[slot1];
            y1 = sm[slot1 + 1];
            y2 = sm[slot1 + 2];

            o = 0;
            while (o < FLOW_FEATS) (
              p0 = flow_predict(region, o, x0, x1, x2, ph);
              err = (o == 0 ? y0 : (o == 1 ? y1 : y2)) - p0;
              widx = flow_weight_slot(region, o, 0);
              flow_model_base[widx - flow_model_base]     = clamp(flow_model_base[widx - flow_model_base]     + lr * err * x0, -1.8, 1.8);
              flow_model_base[widx - flow_model_base + 1] = clamp(flow_model_base[widx - flow_model_base + 1] + lr * err * x1, -1.8, 1.8);
              flow_model_base[widx - flow_model_base + 2] = clamp(flow_model_base[widx - flow_model_base + 2] + lr * err * x2, -1.8, 1.8);
              flow_model_base[widx - flow_model_base + 3] = clamp(flow_model_base[widx - flow_model_base + 3] + lr * err * ph, -1.8, 1.8);
              flow_model_base[widx - flow_model_base + 4] = clamp(flow_model_base[widx - flow_model_base + 4] + lr * err, -1.8, 1.8);
              o += 1;
            );

            bin += 1;
          );
          i += 1;
        );
        region += 1;
      );
      epoch += 1;
    );
    flow_model_trained = 1;
  );
);

function flow_bin_from_pos(sid region_mode pos) local(lo hi span phase)
(
  lo = grain_region_lo(sid, region_mode);
  hi = grain_region_hi(sid, region_mode);
  span = max(1, hi - lo);
  phase = clamp01((pos - lo) / max(1, span - 1));
  clamp(floor(phase * FLOW_BINS), 0, FLOW_BINS - 1) | 0;
);

function flow_feat_sid(sid region_mode bin feat) local(sm slot)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  slot = flow_slot(region_mode, bin, feat);
  sm[slot];
);

function flow_phase_distance(a b region_mode) local(d)
(
  // v13: learned flow is phrase-linear. Do not score body phase as circular,
  // because circular distance rewards wraparound into the same take.
  d = abs(a - b);
  d;
);

function learned_flow_score(vix prev_sid prev_pos region_mode cand_sid cand_pos cand_lo cand_hi target_phase gsize lively truth spice same_run force_cross) local(
  pbin cbin x0 x1 x2 ph pred0 pred1 pred2 c0 c1 c2 err phase cand_phase hist near same_current same_sid nextbin local_mix
  prev_phase runlim same_run_norm same_sid_pen regression end_rehit cross_bonus
)
(
  (prev_sid < 0 || prev_sid >= sample_count || cand_sid < 0 || cand_sid >= sample_count || flow_model_trained <= 0) ? (
    1000000;
  ) : (
    pbin = flow_bin_from_pos(prev_sid, region_mode, prev_pos);
    cbin = flow_bin_from_pos(cand_sid, region_mode, cand_pos);
    x0 = flow_feat_sid(prev_sid, region_mode, pbin, 0);
    x1 = flow_feat_sid(prev_sid, region_mode, pbin, 1);
    x2 = flow_feat_sid(prev_sid, region_mode, pbin, 2);
    ph = pbin / max(1, FLOW_BINS - 1);
    prev_phase = ph;

    // Use the trained corpus predictor as the target. v12 mixed in the actual
    // same-source successor too strongly, making the system rebuild and loop the
    // take it came from.
    pred0 = flow_predict(region_mode, 0, x0, x1, x2, ph);
    pred1 = flow_predict(region_mode, 1, x0, x1, x2, ph);
    pred2 = flow_predict(region_mode, 2, x0, x1, x2, ph);
    nextbin = min(FLOW_BINS - 1, pbin + 1);
    local_mix = clamp01(0.035 + 0.075 * (1 - truth) - 0.030 * spice);
    pred0 = lerp(pred0, flow_feat_sid(prev_sid, region_mode, nextbin, 0), local_mix);
    pred1 = lerp(pred1, flow_feat_sid(prev_sid, region_mode, nextbin, 1), local_mix);
    pred2 = lerp(pred2, flow_feat_sid(prev_sid, region_mode, nextbin, 2), local_mix);

    c0 = flow_feat_sid(cand_sid, region_mode, cbin, 0);
    c1 = flow_feat_sid(cand_sid, region_mode, cbin, 1);
    c2 = flow_feat_sid(cand_sid, region_mode, cbin, 2);
    err = abs(c0 - pred0) * 0.78 + abs(c1 - pred1) * 1.14 + abs(c2 - pred2) * 0.92;

    cand_phase = clamp01((cand_pos - cand_lo) / max(1, cand_hi - cand_lo - 1));
    phase = flow_phase_distance(cand_phase, target_phase, region_mode);
    hist = grain_hist_penalty(vix, cand_sid, cand_pos, cand_lo, cand_hi) * (0.25 + 0.34 * (1 - truth) + 0.16 * lively);

    same_current = (cand_sid == prev_sid && abs(cand_pos - prev_pos) < max(16, floor(gsize * 0.50))) ? 1 : 0;
    same_sid = cand_sid == prev_sid ? 1 : 0;
    near = same_current ? (5.8 + 2.8 * lively) : 0;

    runlim = max(1, grain_run_limit(lively, truth, spice));
    same_run_norm = clamp01((same_run - 2) / max(1, runlim - 2));
    same_sid_pen = same_sid ? (same_run_norm * (1.55 + 1.35 * lively + 0.85 * (1 - truth)) - (1 - same_run_norm) * 0.045 * (1 - spice)) : 0;
    force_cross && same_sid ? same_sid_pen += 1000;

    // Regression is the real take-loop tell: same sample, phase jumps backward.
    regression = (!region_mode && same_sid && cand_phase < prev_phase - 0.10) ? 1 : 0;
    end_rehit = (!region_mode && same_sid && prev_phase > 0.72 && cand_phase > 0.68) ? clamp01((prev_phase - 0.72) / 0.28) : 0;
    cross_bonus = same_sid ? 0 : (-0.08 - 0.10 * spice - 0.07 * lively);

    err * (1.24 + 0.36 * (1 - truth))
    + phase * (0.72 + 0.22 * (1 - spice))
    + hist
    + near
    + same_sid_pen
    + regression * (3.4 + 2.2 * lively)
    + end_rehit * (1.5 + 1.4 * lively)
    + cross_bonus;
  );
);

function learned_flow_consider(vix prev_sid prev_pos region_mode cand_sid cand_phase gsize lively truth spice same_run force_cross) local(
  lo hi span pos score
)
(
  cand_sid >= 0 && cand_sid < sample_count ? (
    lo = grain_region_lo(cand_sid, region_mode);
    hi = grain_region_hi(cand_sid, region_mode);
    span = max(1, hi - lo);
    span > max(32, floor(gsize * 0.36)) ? (
      pos = choose_region_pos(vix, cand_sid, region_mode, cand_phase, 0.06 + 0.16 * lively + 0.07 * spice);
      score = learned_flow_score(vix, prev_sid, prev_pos, region_mode, cand_sid, pos, lo, hi, cand_phase, gsize, lively, truth, spice, same_run, force_cross);
      score < learned_best_score ? (
        learned_best_score = score;
        learned_sid = cand_sid;
        learned_pos = pos;
        learned_lo = lo;
        learned_hi = hi;
      );
    );
  );
);

function learned_flow_pick(vix v region_mode fallback_sid fallback_pos fallback_lo fallback_hi gsize lively truth spice) local(
  prev_sid prev_pos target_phase fallback_score strength tries donor sid_anchor cand_phase
  same_run runlim prev_lo prev_hi prev_phase boundary_thr end_pressure force_cross donor2
)
(
  learned_sid = fallback_sid;
  learned_pos = fallback_pos;
  learned_lo = fallback_lo;
  learned_hi = fallback_hi;
  learned_best_score = 1000000;

  (flow_model_trained > 0 && v[VC_LGSID] >= 0 && v[VC_LGREG] == region_mode) ? (
    prev_sid = v[VC_LGSID] | 0;
    prev_pos = v[VC_LGPOS];
    same_run = max(0, v[VC_LGRUN]);
    runlim = grain_run_limit(lively, truth, spice);

    target_phase = grain_follow_phase(v, region_mode);
    target_phase < 0 ? target_phase = clamp01((fallback_pos - fallback_lo) / max(1, fallback_hi - fallback_lo - 1));

    prev_lo = grain_region_lo(prev_sid, region_mode);
    prev_hi = grain_region_hi(prev_sid, region_mode);
    prev_phase = clamp01((prev_pos - prev_lo) / max(1, prev_hi - prev_lo - 1));
    boundary_thr = region_mode ? 0.92 : clamp(0.76 + 0.10 * spice - 0.12 * lively, 0.58, 0.88);
    end_pressure = (!region_mode && prev_phase > boundary_thr) ? clamp01((prev_phase - boundary_thr) / max(0.02, 1 - boundary_thr)) : 0;
    force_cross = (sample_count > 1 && ((same_run >= runlim) || end_pressure > 0.50)) ? 1 : 0;

    // At a phrase boundary, the next event may start early in another sample.
    // That is a cross-sample continuation, not same-sample wraparound.
    end_pressure > 0 ? (
      target_phase = phase_lerp_region(target_phase, 0.06 + 0.32 * rand(1), clamp01(end_pressure * 0.90), region_mode);
    );

    fallback_score = learned_flow_score(vix, prev_sid, prev_pos, region_mode, fallback_sid, fallback_pos, fallback_lo, fallback_hi, target_phase, gsize, lively, truth, spice, same_run, force_cross);
    learned_best_score = fallback_score;

    // Same-source continuation is allowed only as a short phrase. v12 always
    // considered prev_sid first; this was the main same-take reconstruction bug.
    !force_cross ? (
      learned_flow_consider(vix, prev_sid, prev_pos, region_mode, prev_sid, target_phase, gsize, lively, truth, spice, same_run, force_cross);
    );

    sid_anchor = v[VC_SAMPLE] | 0;
    sid_anchor != prev_sid ? learned_flow_consider(vix, prev_sid, prev_pos, region_mode, sid_anchor, target_phase, gsize, lively, truth, spice, same_run, force_cross);
    fallback_sid != prev_sid && fallback_sid != sid_anchor ? learned_flow_consider(vix, prev_sid, prev_pos, region_mode, fallback_sid, target_phase, gsize, lively, truth, spice, same_run, force_cross);

    tries = 0;
    while (tries < 7) (
      donor = choose_region_donor(prev_sid, region_mode, clamp01(0.12 + 0.20 * lively + 0.34 * spice + 0.10 * tries + 0.30 * end_pressure), vix);
      donor != prev_sid ? (
        cand_phase = phase_lerp_region(target_phase, rand(1), 0.035 + 0.10 * spice + 0.15 * end_pressure, region_mode);
        learned_flow_consider(vix, prev_sid, prev_pos, region_mode, donor, cand_phase, gsize, lively, truth, spice, same_run, force_cross);
      );
      tries += 1;
    );

    // Hard escape valve: if we must cross but the weighted donor search came
    // back empty, ask from the original anchor too. Still never accept prev_sid.
    (force_cross && learned_sid == prev_sid && sample_count > 1) ? (
      donor2 = choose_region_donor(sid_anchor, region_mode, 1, vix);
      donor2 != prev_sid ? (
        learned_flow_consider(vix, prev_sid, prev_pos, region_mode, donor2, 0.06 + 0.36 * rand(1), gsize, lively, truth, spice, same_run, 0);
      );
    );

    strength = clamp01(0.16 + 0.46 * lively + 0.16 * (1 - truth) - 0.06 * spice);
    // Bias, don't command, unless we are escaping a same-take phrase boundary.
    (!force_cross && learned_best_score > fallback_score + (0.48 + 1.10 * strength)) ? (
      learned_sid = fallback_sid;
      learned_pos = fallback_pos;
      learned_lo = fallback_lo;
      learned_hi = fallback_hi;
    );
  );
);

function voices_busy() local(i v busy)
(
  busy = 0;
  i = 0;
  while (i < MAX_VOICES && !busy) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? busy = 1;
    i += 1;
  );
  busy;
);

function count_active_voices() local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? cnt += 1;
    i += 1;
  );
  cnt;
);

function estimate_pitch(sm) local(
  ptr nch sr frames attack head tail
  decim effsr win minlag maxlag cand start maxstart
  i j lag endn x lp hp sumsq rms diff cumdiff cmndf
  best_note best_conf best_score cand_bestlag cand_bestcm cand_note cand_conf cand_score
  fallback_lag fallback_cm fallback_val val lagf y0 y1 y2 den delta
  sumxy sumx2 sumy2 x0 y0s corr freq cycles energy_ok transient_bias
)
(
  // v14 PitchSnap: replace brittle zero-cross pitch with a cheap YIN-style
  // normalized difference pass on stable post-onset windows. This intentionally
  // looks for pitched/ringing body content, not the noisy transient itself.
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = max(1000, sm[SM_SR]);
  frames = sm[SM_FRAMES] | 0;
  attack = clamp(sm[SM_ATTACK] | 0, 0, max(0, frames - 2));
  head   = clamp(sm[SM_HEADEND] | 0, attack, max(attack, frames - 2));
  tail   = clamp(sm[SM_TAILSTART] | 0, head + 1, max(head + 1, frames - 2));

  best_note = 60;
  best_conf = 0;
  best_score = -1000000;

  frames > 320 ? (
    // Decimate to keep bank scan cheap while still covering musical pitch.
    decim = max(1, floor(sr / 12000));
    effsr = sr / decim;
    win = clamp(floor(effsr * 0.055), 320, min(896, ONSET_SCRATCH_MAX));
    win = min(win, max(64, floor((frames - 2) / decim)));
    minlag = max(3, floor(effsr / 2600));
    maxlag = min(floor(effsr / 42), floor(win * 0.58));

    (win > 96 && maxlag > minlag + 4) ? (
      cand = 0;
      while (cand < 3) (
        cand == 0 ? start = head + floor(sr * 0.006)
        : cand == 1 ? start = attack + floor(sr * 0.026)
        : start = head + floor(max(0, tail - head) * 0.42);

        maxstart = max(0, frames - 2 - win * decim);
        start = clamp(floor(start), 0, maxstart);

        lp = mono_frame(ptr, nch, start);
        sumsq = 0;
        i = 0;
        while (i < win) (
          x = mono_frame(ptr, nch, start + i * decim);
          lp += (x - lp) * 0.038;
          hp = x - lp;
          onset_raw_base[i] = hp;
          sumsq += hp * hp;
          i += 1;
        );

        rms = sqrt(sumsq / max(1, win));
        energy_ok = rms > max(0.000003, sm[SM_RMS] * 0.045);
        energy_ok ? (
          cumdiff = 0;
          lag = 1;
          while (lag <= maxlag) (
            diff = 0;
            endn = win - lag;
            j = 0;
            while (j < endn) (
              x0 = onset_raw_base[j];
              y0s = onset_raw_base[j + lag];
              diff += (x0 - y0s) * (x0 - y0s);
              j += 1;
            );

            cumdiff += diff;
            onset_smooth_base[lag] = diff * lag / max(cumdiff, 0.00000000000000000001);
            lag += 1;
          );

          cand_bestlag = -1;
          cand_bestcm = 1000000;
          fallback_lag = -1;
          fallback_cm = 1000000;
          fallback_val = 1000000;

          lag = minlag + 1;
          while (lag < maxlag) (
            cmndf = onset_smooth_base[lag];
            val = cmndf + (lag / max(1, maxlag)) * 0.035;
            val < fallback_val ? (
              fallback_val = val;
              fallback_cm = cmndf;
              fallback_lag = lag;
            );

            // First credible local minimum. This avoids octave/subharmonic creep
            // where a later repeated period looks slightly cleaner.
            (cand_bestlag < 0 && cmndf < 0.28 && cmndf <= onset_smooth_base[lag - 1] && cmndf < onset_smooth_base[lag + 1]) ? (
              cand_bestlag = lag;
              cand_bestcm = cmndf;
            );
            lag += 1;
          );

          cand_bestlag < 0 ? (
            cand_bestlag = fallback_lag;
            cand_bestcm = fallback_cm;
          );

          cand_bestlag > 0 ? (
            lagf = cand_bestlag;
            (cand_bestlag > 1 && cand_bestlag < maxlag) ? (
              y0 = onset_smooth_base[cand_bestlag - 1];
              y1 = onset_smooth_base[cand_bestlag];
              y2 = onset_smooth_base[cand_bestlag + 1];
              den = y0 - 2 * y1 + y2;
              abs(den) > 0.000000000001 ? (
                delta = 0.5 * (y0 - y2) / den;
                abs(delta) <= 0.5 ? lagf = cand_bestlag + delta;
              );
            );

            sumxy = 0;
            sumx2 = 0;
            sumy2 = 0;
            endn = win - cand_bestlag;
            j = 0;
            while (j < endn) (
              x0 = onset_raw_base[j];
              y0s = onset_raw_base[j + cand_bestlag];
              sumxy += x0 * y0s;
              sumx2 += x0 * x0;
              sumy2 += y0s * y0s;
              j += 1;
            );

            corr = sumxy / sqrt(max(sumx2 * sumy2, 0.00000000000000000001));
            corr = clamp(corr, -1, 1);
            freq = effsr / max(1, lagf);

            (freq >= 35 && freq <= 2600) ? (
              cycles = win / max(1, lagf);
              cand_note = 69 + 17.31234049066756 * log(freq / 440);
              transient_bias = clamp01(sm[SM_FLAGS]);
              cand_conf = clamp01((0.62 - cand_bestcm) / 0.54);
              cand_conf *= clamp01((corr - 0.06) / 0.70);
              cand_conf *= clamp01((cycles - 1.45) / 4.30);
              // Transient-rich impacts can have a valid ring, but do not let the
              // detector hallucinate a huge confidence from the click itself.
              cand_conf *= lerp(1.00, 0.76, transient_bias * (1 - clamp01(corr)));
              cand_conf = clamp01(cand_conf);
              cand_score = cand_conf + corr * 0.11 - cand_bestcm * 0.06;

              cand_score > best_score ? (
                best_score = cand_score;
                best_note = cand_note;
                best_conf = cand_conf;
              );
            );
          );
        );

        cand += 1;
      );
    );
  );

  sm[SM_PITCHNOTE] = best_note;
  sm[SM_PITCHCONF] = best_conf;
);


function estimate_brightness_metric(ptr nch sr start scan) local(
  i endp x ax
  c250 c1000 c3500 c8500
  lp250 lp1000 lp3500 lp8500
  b0 b1 b2 b3 b4
  e0 e1 e2 e3 e4 total centroid rawbright highratio airratio br
  warmup
)
(
  // Robust brightness proxy: cheap filterbank spectral-centroid estimate.
  // The previous metric was a single high-pass residual ratio, which saturates
  // on clicks/noise and made the bank brightness meter sit near 1.0.
  start = clamp(floor(start), 0, max(0, sample_len(bank_pool, ptr) - 2));
  scan = max(64, floor(scan));
  endp = min(sample_len(bank_pool, ptr) | 0, start + scan);

  c250  = clamp(1 - exp(-6.283185307179586 * min(250,  sr * 0.45) / max(sr, 1)), 0.0001, 0.70);
  c1000 = clamp(1 - exp(-6.283185307179586 * min(1000, sr * 0.45) / max(sr, 1)), 0.0001, 0.82);
  c3500 = clamp(1 - exp(-6.283185307179586 * min(3500, sr * 0.45) / max(sr, 1)), 0.0001, 0.90);
  c8500 = clamp(1 - exp(-6.283185307179586 * min(8500, sr * 0.45) / max(sr, 1)), 0.0001, 0.96);

  lp250 = 0; lp1000 = 0; lp3500 = 0; lp8500 = 0;
  e0 = 0; e1 = 0; e2 = 0; e3 = 0; e4 = 0;

  i = start;
  warmup = min(max(16, floor(sr * 0.0015)), max(16, endp - start));
  while (i < endp) (
    x = mono_frame(ptr, nch, i);
    lp250  += (x - lp250)  * c250;
    lp1000 += (x - lp1000) * c1000;
    lp3500 += (x - lp3500) * c3500;
    lp8500 += (x - lp8500) * c8500;

    (i - start) >= warmup ? (
      b0 = lp250;
      b1 = lp1000 - lp250;
      b2 = lp3500 - lp1000;
      b3 = lp8500 - lp3500;
      b4 = x - lp8500;

      // Power energy. This damps click-only maxing compared with abs(highpass).
      e0 += b0 * b0;
      e1 += b1 * b1;
      e2 += b2 * b2;
      e3 += b3 * b3;
      e4 += b4 * b4;
    );
    i += 1;
  );

  total = e0 + e1 + e2 + e3 + e4 + 0.00000000000000000001;
  centroid = (e0 * 170 + e1 * 700 + e2 * 2200 + e3 * 5200 + e4 * 10500) / total;

  // Log-frequency normalization is closer to perceived brightness than linear Hz.
  rawbright = clamp01((log(max(centroid, 80) / 180) / log(10500 / 180)));
  highratio = clamp01((e3 + e4) / total);
  airratio = clamp01(e4 / total);

  // Blend centroid with high-band occupancy, then re-scale conservatively so
  // normal banks land around the middle instead of pegging at 1.0.
  br = rawbright * 0.78 + sqrt(highratio) * 0.17 + sqrt(airratio) * 0.05;
  br = clamp01((br - 0.16) / 0.78);
  br = br ^ 1.16;
  br;
);


function estimate_sample_tail_grace(sm) local(
  ptr nch sr frames head tail span len_ms tail_ms
  chunks chunk_len stride c a b i x ax n e first_e last_e mean_e max_e prev_e rise_e
  end_ratio rms_ratio tail_presence end_hot end_rise trans bright focus auto_ms fade_ms short_guard hot
)
(
  // v19 AutoRelease: per-sample ending analysis. The goal is not to make every
  // sample long; it is to stop energetic or room-like endings from being hard-cut
  // by a short MIDI Release or by reaching EOF before the envelope has time to land.
  ptr    = sm[SM_PTR] | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = max(1000, sm[SM_SR]);
  frames = sm[SM_FRAMES] | 0;
  head   = clamp(sm[SM_HEADEND] | 0, 0, max(0, frames - 2));
  tail   = clamp(sm[SM_TAILSTART] | 0, head + 1, max(head + 1, frames - 2));

  len_ms = 1000 * frames / max(sr, 1);
  span = max(1, frames - tail);
  tail_ms = 1000 * span / max(sr, 1);

  chunks = clamp(floor(tail_ms / 22), 4, 12);
  chunk_len = max(32, floor(span / chunks));
  stride = max(1, floor(chunk_len / 192));

  first_e = 0;
  last_e = 0;
  mean_e = 0;
  max_e = 0;
  prev_e = 0;
  rise_e = 0;

  c = 0;
  while (c < chunks) (
    a = clamp(tail + c * chunk_len, tail, max(tail, frames - 2));
    b = c == chunks - 1 ? frames - 1 : clamp(a + chunk_len, a + 1, frames - 1);
    e = 0;
    n = 0;
    i = a;
    while (i < b) (
      x = mono_frame(ptr, nch, i);
      ax = abs(x);
      e += ax;
      n += 1;
      i += stride;
    );
    e /= max(1, n);

    c == 0 ? first_e = e;
    c == chunks - 1 ? last_e = e;
    c > 0 ? rise_e = max(rise_e, e - prev_e);
    prev_e = e;
    mean_e += e;
    max_e = max(max_e, e);
    c += 1;
  );

  mean_e /= max(1, chunks);
  trans = clamp01(sm[SM_FLAGS]);
  bright = clamp01(sm[SM_BRIGHT]);
  focus = clamp01(sm[SM_SHARP]);

  end_ratio = clamp01(last_e / max(mean_e, 0.000000001));
  rms_ratio = clamp01(last_e / max(sm[SM_RMS], 0.000000001));
  tail_presence = clamp01((tail_ms - 35) / 520);
  end_hot = clamp01((rms_ratio - 0.020) / 0.22);
  end_rise = clamp01(rise_e / max(mean_e, 0.000000001));
  short_guard = clamp01((len_ms - 38) / 220);

  // "Hot" means the end is not safely silent. It can be an abrupt chopped hit,
  // a room tail, a noisy sustain, or a pitched decay that is still audible.
  hot = clamp01(end_hot * 0.62 + end_ratio * 0.28 + end_rise * 0.10);

  auto_ms = 18
    + tail_presence * (36 + 90 * (1 - trans) + 28 * bright)
    + hot * (52 + 210 * tail_presence + 45 * focus)
    + end_rise * 70;
  auto_ms *= lerp(0.42, 1.0, short_guard);
  auto_ms = clamp(auto_ms, 10, min(900, max(24, len_ms * 0.65)));

  fade_ms = 8
    + tail_presence * (24 + 76 * (1 - trans))
    + hot * (34 + 165 * tail_presence + 32 * bright)
    + end_rise * 72;
  fade_ms *= lerp(0.48, 1.0, short_guard);
  fade_ms = clamp(fade_ms, 6, min(650, max(12, len_ms * 0.42)));

  sm[SM_AUTOREL] = auto_ms;
  sm[SM_ENDFADE] = fade_ms;
  sm[SM_TAILHOT] = hot;
);

function analyze_sample_classic(sm) local(
  ptr nch sr frames scan i x ax prev lp hf prevhf
  peak sumsq sumabs sumdiff brightsum roughsum rms bright edge
  thresh attack attack_ms sharp transrich
  target_rms norm lpcoef
  head_ms head_end tail_start tail_thresh tail_minlen
  step chunkabs cnt j found
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;

  peak = 0;
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  brightsum = 0;
  roughsum = 0;
  prev = 0;
  prevhf = 0;
  lp = 0;

  scan = min(frames, max(256, floor(sr * 0.16)));
  lpcoef = clamp(1400 / max(sr, 1), 0.01, 0.35);

  i = 0;
  while (i < scan) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    peak = max(peak, ax);
    sumsq += x * x;
    sumabs += ax;
    i > 0 ? sumdiff += abs(x - prev);

    lp += (x - lp) * lpcoef;
    hf = x - lp;
    brightsum += abs(hf);
    i > 0 ? roughsum += abs(hf - prevhf);

    prev = x;
    prevhf = hf;
    i += 1;
  );

  rms = sqrt(sumsq / max(scan, 1));
  edge = clamp01((roughsum / max(brightsum, 0.000001)) * 0.34);

  thresh = max(peak * 0.12, rms * 1.8);
  attack = -1;
  i = 0;
  while (i < scan && attack < 0) (
    abs(mono_frame(ptr, nch, i)) >= thresh ? attack = i;
    i += 1;
  );
  attack < 0 ? attack = 0;

  bright = estimate_brightness_metric(ptr, nch, sr, attack, min(frames - attack, max(384, floor(sr * 0.20))));

  attack_ms = 1000 * attack / max(sr, 1);
  sharp = clamp01((1 - min(1, attack_ms / 70)) * 0.72 + edge * 0.28);
  transrich = clamp01(sharp * 0.64 + edge * 0.18 + (1 - min(1, attack_ms / 55)) * 0.24 + bright * 0.06);

  head_ms = 8 + transrich * 48;
  head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
  head_end = clamp(head_end, 0, max(0, frames - 2));

  tail_thresh = max(rms * (0.46 + 0.22 * transrich), peak * (0.040 + 0.020 * bright));
  step = max(1, floor(frames / 1024));
  tail_start = max(head_end + 16, frames - 2);
  found = 0;
  i = frames - 1;
  while (i > head_end + step && !found) (
    chunkabs = 0;
    cnt = 0;
    j = 0;
    while (j < step && (i - j) >= 0) (
      chunkabs += abs(mono_frame(ptr, nch, i - j));
      cnt += 1;
      j += 1;
    );
    (chunkabs / max(cnt, 1)) > tail_thresh ? (
      tail_start = clamp(i + step * 2, head_end + 16, max(head_end + 16, frames - 2));
      found = 1;
    );
    i -= step;
  );

  tail_minlen = min(max(floor(sr * (0.08 + 0.04 * (1 - transrich))), 192), max(192, floor(frames * 0.34)));
  !found ? tail_start = clamp(floor(frames * (0.60 + 0.14 * (1 - transrich))), head_end + 16, max(head_end + 16, frames - 2));
  tail_start = min(tail_start, max(head_end + 16, frames - tail_minlen));
  tail_start <= (head_end + 8) ? tail_start = min(max(head_end + 24, floor(frames * 0.72)), max(head_end + 24, frames - 2));
  tail_start = clamp(tail_start, min(head_end + 1, max(0, frames - 2)), max(0, frames - 2));

  target_rms = 0.12;
  norm = clamp(target_rms / max(rms, 0.000001), 0.25, 4.0);

  sm[SM_RMS]    = rms;
  sm[SM_PEAK]   = peak;
  sm[SM_EDGE]   = edge;
  sm[SM_ATTACK] = attack;
  sm[SM_SHARP]  = sharp;
  sm[SM_NORM]   = norm;
  sm[SM_LENMS]  = 1000 * frames / max(sr, 1);
  sm[SM_BRIGHT] = bright;
  sm[SM_FLAGS]  = transrich;
  sm[SM_HEADEND] = head_end;
  sm[SM_TAILSTART] = tail_start;

  estimate_pitch(sm);
);

function analyze_sample_gauss(sm) local(
  ptr nch sr frames
  onset_scan hop onset_lpcoef nov_count i j x ax lp hf env_prev hf_prev env_now hf_now cnt nov novsum
  peaki peakv mean_nov smoothv starti peakthr lowthr onset_conf onset_rise onset_rise_ms
  fallback_scan fallback_peak fallback_sumsq fallback_rms thresh attack fallback_attack
  feat_lo feat_hi scan prev prevhf lpcoef
  peak sumsq sumabs sumdiff brightsum roughsum rms bright edge
  sharp transrich
  target_rms norm head_ms head_end tail_start tail_thresh tail_minlen
  step chunkabs found
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;

  onset_scan = min(frames, max(4096, floor(sr * 2.00)));
  hop = max(1, floor(sr * 0.00075));
  hop = max(hop, floor((onset_scan + ONSET_SCRATCH_MAX - 1) / max(1, ONSET_SCRATCH_MAX)));
  onset_lpcoef = clamp(2200 / max(sr, 1), 0.015, 0.40);

  lp = 0;
  env_prev = 0;
  hf_prev = 0;
  nov_count = 0;
  novsum = 0;

  i = 0;
  while (i < onset_scan && nov_count < ONSET_SCRATCH_MAX) (
    env_now = 0;
    hf_now = 0;
    cnt = 0;
    j = 0;
    while (j < hop && (i + j) < onset_scan) (
      x = mono_frame(ptr, nch, i + j);
      ax = abs(x);
      lp += (x - lp) * onset_lpcoef;
      hf = x - lp;
      env_now += ax;
      hf_now += abs(hf);
      cnt += 1;
      j += 1;
    );
    env_now /= max(cnt, 1);
    hf_now /= max(cnt, 1);
    nov = max(0, hf_now - hf_prev * 0.90) + 0.32 * max(0, env_now - env_prev * 0.94);
    nov += 0.10 * max(0, hf_now - env_now * 0.22);
    onset_raw_base[nov_count] = nov;
    novsum += nov;
    env_prev = env_now;
    hf_prev = hf_now;
    nov_count += 1;
    i += hop;
  );

  peaki = 0;
  peakv = 0;
  i = 0;
  while (i < nov_count) (
    smoothv = (
      onset_raw_base[clamp(i - 3, 0, max(0, nov_count - 1))] +
      onset_raw_base[clamp(i - 2, 0, max(0, nov_count - 1))] * 6 +
      onset_raw_base[clamp(i - 1, 0, max(0, nov_count - 1))] * 15 +
      onset_raw_base[i] * 20 +
      onset_raw_base[clamp(i + 1, 0, max(0, nov_count - 1))] * 15 +
      onset_raw_base[clamp(i + 2, 0, max(0, nov_count - 1))] * 6 +
      onset_raw_base[clamp(i + 3, 0, max(0, nov_count - 1))]
    ) * 0.015625;
    onset_smooth_base[i] = smoothv;
    smoothv > peakv ? (
      peakv = smoothv;
      peaki = i;
    );
    i += 1;
  );

  fallback_scan = min(frames, onset_scan);
  fallback_peak = 0;
  fallback_sumsq = 0;
  i = 0;
  while (i < fallback_scan) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    fallback_peak = max(fallback_peak, ax);
    fallback_sumsq += x * x;
    i += 1;
  );
  fallback_rms = sqrt(fallback_sumsq / max(fallback_scan, 1));
  thresh = max(fallback_peak * 0.12, fallback_rms * 1.8);
  fallback_attack = -1;
  i = 0;
  while (i < fallback_scan && fallback_attack < 0) (
    abs(mono_frame(ptr, nch, i)) >= thresh ? fallback_attack = i;
    i += 1;
  );
  fallback_attack < 0 ? fallback_attack = 0;

  mean_nov = nov_count > 0 ? (novsum / nov_count) : 0;
  onset_conf = peakv > 0 ? clamp01((peakv - mean_nov * 1.35) / max(peakv, 0.000001)) : 0;
  starti = peaki;
  peakthr = peakv * (0.18 + 0.08 * (1 - onset_conf));
  while (starti > 0 && onset_smooth_base[starti - 1] >= peakthr) (
    starti -= 1;
  );
  lowthr = peakv * 0.10;
  while (starti > 0 && onset_smooth_base[starti - 1] > lowthr && (peaki - starti) < 8) (
    starti -= 1;
  );

  attack = floor(starti * hop);
  (onset_conf < 0.12 || peakv <= 0.00001) ? attack = fallback_attack;
  attack = clamp(attack, 0, max(0, frames - 2));

  onset_rise = max(hop, (peaki - starti) * hop);
  onset_rise_ms = 1000 * onset_rise / max(sr, 1);

  feat_lo = max(0, attack - min(attack, floor(sr * 0.008)));
  feat_hi = min(frames, attack + max(256, floor(sr * 0.18)));
  scan = max(1, feat_hi - feat_lo);
  lpcoef = clamp(1400 / max(sr, 1), 0.01, 0.35);

  peak = 0;
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  brightsum = 0;
  roughsum = 0;
  lp = 0;
  prev = mono_frame(ptr, nch, feat_lo);
  prevhf = 0;

  i = feat_lo;
  while (i < feat_hi) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    peak = max(peak, ax);
    sumsq += x * x;
    sumabs += ax;
    i > feat_lo ? sumdiff += abs(x - prev);

    lp += (x - lp) * lpcoef;
    hf = x - lp;
    brightsum += abs(hf);
    i > feat_lo ? roughsum += abs(hf - prevhf);

    prev = x;
    prevhf = hf;
    i += 1;
  );

  rms = sqrt(sumsq / max(scan, 1));
  edge = clamp01((roughsum / max(brightsum, 0.000001)) * 0.34);
  bright = estimate_brightness_metric(ptr, nch, sr, feat_lo, scan);

  sharp = clamp01((1 - min(1, onset_rise_ms / 18)) * 0.58 + edge * 0.24 + onset_conf * 0.18);
  transrich = clamp01(sharp * 0.58 + edge * 0.14 + onset_conf * 0.18 + bright * 0.10);

  head_ms = 4 + transrich * 30 + min(14, onset_rise_ms * 0.32);
  head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
  head_end = clamp(head_end, 0, max(0, frames - 2));

  tail_thresh = max(rms * (0.46 + 0.22 * transrich), peak * (0.040 + 0.020 * bright));
  step = max(1, floor(frames / 1024));
  tail_start = max(head_end + 16, frames - 2);
  found = 0;
  i = frames - 1;
  while (i > head_end + step && !found) (
    chunkabs = 0;
    cnt = 0;
    j = 0;
    while (j < step && (i - j) >= 0) (
      chunkabs += abs(mono_frame(ptr, nch, i - j));
      cnt += 1;
      j += 1;
    );
    (chunkabs / max(cnt, 1)) > tail_thresh ? (
      tail_start = clamp(i + step * 2, head_end + 16, max(head_end + 16, frames - 2));
      found = 1;
    );
    i -= step;
  );

  tail_minlen = min(max(floor(sr * (0.08 + 0.04 * (1 - transrich))), 192), max(192, floor(frames * 0.34)));
  !found ? tail_start = clamp(floor(frames * (0.60 + 0.14 * (1 - transrich))), head_end + 16, max(head_end + 16, frames - 2));
  tail_start = min(tail_start, max(head_end + 16, frames - tail_minlen));
  tail_start <= (head_end + 8) ? tail_start = min(max(head_end + 24, floor(frames * 0.72)), max(head_end + 24, frames - 2));
  tail_start = clamp(tail_start, min(head_end + 1, max(0, frames - 2)), max(0, frames - 2));

  target_rms = 0.12;
  norm = clamp(target_rms / max(rms, 0.000001), 0.25, 4.0);

  sm[SM_RMS]    = rms;
  sm[SM_PEAK]   = peak;
  sm[SM_EDGE]   = edge;
  sm[SM_ATTACK] = attack;
  sm[SM_SHARP]  = sharp;
  sm[SM_NORM]   = norm;
  sm[SM_LENMS]  = 1000 * frames / max(sr, 1);
  sm[SM_BRIGHT] = bright;
  sm[SM_FLAGS]  = transrich;
  sm[SM_HEADEND] = head_end;
  sm[SM_TAILSTART] = tail_start;

  estimate_pitch(sm);
);


function analyze_sample(sm)
(
  onset_mode_active ? analyze_sample_gauss(sm) : analyze_sample_classic(sm);
  estimate_sample_tail_grace(sm);
  // v37 PerfGate: skip Granular-only corpus markers and obsolete learned-flow
  // extraction during normal bank analysis. Corpus markers are computed lazily
  // inside build_grain_corpus(), only when Granular mode needs them.
);


function reset_voices() local(i j v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    v[VC_STAGE] = ENV_OFF;
    i += 1;
  );
);

function note_gate_idx(note chan)
(
  (clamp(chan, 0, 15) | 0) * 128 + (clamp(note, 0, 127) | 0);
);

function reset_note_gates() local(i)
(
  i = 0;
  while (i < NOTE_GATE_CELLS) (
    note_gate_base[i] = 0;
    i += 1;
  );
);

function note_gate_on(note chan) local(idx)
(
  idx = note_gate_idx(note, chan);
  note_gate_base[idx] = min(32, note_gate_base[idx] + 1);
);

function note_gate_off(note chan) local(idx)
(
  idx = note_gate_idx(note, chan);
  note_gate_base[idx] = max(0, note_gate_base[idx] - 1);
);

function note_gate_forget_voice(v) local(idx)
(
  (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] <= 0 && v[VC_STAGE] != ENV_RELEASE) ? (
    idx = note_gate_idx(v[VC_NOTE], v[VC_CHAN]);
    note_gate_base[idx] = max(0, note_gate_base[idx] - 1);
  );
);

function count_held_note_voices(note chan) local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] <= 0 && v[VC_NOTE] == note && v[VC_CHAN] == chan && v[VC_STAGE] != ENV_RELEASE) ? cnt += 1;
    i += 1;
  );
  cnt;
);

function reset_weight_buffers() local(i)
(
  weight_ap1_pos = 0;
  weight_ap2_pos = 0;
  weight_er_pos = 0;
  weight_in_lp_l = 0;
  weight_in_lp_r = 0;
  weight_wet_lp_l = 0;
  weight_wet_lp_r = 0;

  i = 0;
  while (i < AP_BUF_LEN) (
    weight_ap1_l_base[i] = 0;
    weight_ap1_r_base[i] = 0;
    weight_ap2_l_base[i] = 0;
    weight_ap2_r_base[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < ER_BUF_LEN) (
    weight_er_l_base[i] = 0;
    weight_er_r_base[i] = 0;
    i += 1;
  );
);

function decrust_zap(x)
(
  abs(x) < DENORM_CUT ? 0 : x;
);

function cubic_mid(a b d e)
(
  // DeCrust curvature assist predictor. Must live before apply_clean_decrust()
  // because JSFX/EEL2 function resolution is top-down.
  (-a + 9 * b + 9 * d - e) / 16;
);

function decrust_clear_state() 
(
  memset(dc_inl_base, 0, DECRUST_RING);
  memset(dc_inr_base, 0, DECRUST_RING);
  memset(dc_outl_base, 0, DECRUST_RING);
  memset(dc_outr_base, 0, DECRUST_RING);
  memset(dc_mag_base, 0, DECRUST_BINS);
  memset(dc_base_base, 0, DECRUST_BINS);
  memset(dc_prev_base, 0, DECRUST_BINS);
  memset(dc_m1_base, 0, DECRUST_BINS);
  memset(dc_m2_base, 0, DECRUST_BINS);
  memset(dc_m3_base, 0, DECRUST_BINS);
  memset(dc_m4_base, 0, DECRUST_BINS);
  memset(dc_gain_base, 0, DECRUST_BINS);

  dc_fft_ready = 0;
  dc_ringpos = 0;
  dc_hop_ctr = 0;
  dc_last_detect = 0;
  dc_tdl0 = 0; dc_tdl1 = 0; dc_tdl2 = 0; dc_tdl3 = 0; dc_tdl4 = 0;
  dc_tdr0 = 0; dc_tdr1 = 0; dc_tdr2 = 0; dc_tdr3 = 0; dc_tdr4 = 0;
);

function decrust_build_windows() local(i j idx w sum overlaps)
(
  i = 0;
  while (i < DECRUST_FFT) (
    w = 0.5 - 0.5 * cos(6.283185307179586 * i / max(1, DECRUST_FFT - 1));
    dc_win_base[i] = w;
    i += 1;
  );

  overlaps = max(1, floor(DECRUST_FFT / DECRUST_HOP));
  i = 0;
  while (i < DECRUST_FFT) (
    sum = 0;
    j = 0;
    idx = i;
    while (j < overlaps) (
      sum += dc_win_base[idx] * dc_win_base[idx];
      idx += DECRUST_HOP;
      idx >= DECRUST_FFT ? idx -= DECRUST_FFT;
      j += 1;
    );
    dc_syn_base[i] = sum > 0.000000000001 ? dc_win_base[i] / sum : dc_win_base[i];
    i += 1;
  );
  dc_fft_ready = 1;
);

function decrust_update_params() local(drive stage extreme sens_eff)
(
  drive = clamp01(clean_decrust_amt);
  stage = clamp01(drive * 2.0);
  extreme = clamp01((drive - 0.5) * 2.0);
  sens_eff = min(1.55, 0.18 + 1.12 * stage + 0.45 * extreme);

  dc_stage = stage;
  dc_extreme = extreme;
  dc_neighbor = lerp(0.65, 0.88, extreme);
  dc_curve_amt = min(1.85, stage + 0.85 * extreme);
  dc_kurt_thr = max(0.10, 4.0 - 3.25 * sens_eff - 1.15 * extreme);
  dc_peak_thr = max(0.12, 2.6 - 1.4 * sens_eff - 0.55 * extreme);
  dc_flux_thr = max(0.08, 1.6 - 1.2 * sens_eff - 0.48 * extreme);
  dc_ceiling_mult = max(0.28, 2.1 - 0.9 * sens_eff - 0.58 * extreme);
  dc_tau_m = max(0.040, 0.250 * lerp(1.0, 0.62, extreme));
  dc_tau_b = max(0.060, dc_tau_m * 1.5);
  dc_am = exp(-DECRUST_HOP / max(1, dc_tau_m * srate));
  dc_bm = 1 - dc_am;
  dc_ab = exp(-DECRUST_HOP / max(1, dc_tau_b * srate));
  dc_bb = 1 - dc_ab;
  dc_focus_hz = 6000;
  dc_fft_ready <= 0 ? decrust_build_windows();
);

function decrust_process_frame() local(
  i k idx srcidx outidx reL imL reR imR mag2L mag2R magbin base_old x x2 x3 x4
  m1v m2v m3v m4v mu2 mu4 exk flux n1 n2 n3 n4 neigh peak dk dp df fw control
  repair_ref hard_gain raw_gain sm_gain g0 g1 g2 scale avg_red strength
)
(
  srcidx = (dc_ringpos - DECRUST_FFT + 1) & DECRUST_RINGMASK;

  i = 0;
  while (i < DECRUST_FFT) (
    idx = 2 * i;
    dc_fftl_base[idx] = dc_inl_base[srcidx] * dc_win_base[i];
    dc_fftl_base[idx + 1] = 0;
    dc_fftr_base[idx] = dc_inr_base[srcidx] * dc_win_base[i];
    dc_fftr_base[idx + 1] = 0;
    srcidx = (srcidx + 1) & DECRUST_RINGMASK;
    i += 1;
  );

  fft(dc_fftl_base, DECRUST_FFT);
  fft(dc_fftr_base, DECRUST_FFT);
  fft_permute(dc_fftl_base, DECRUST_FFT);
  fft_permute(dc_fftr_base, DECRUST_FFT);

  k = 0;
  while (k < DECRUST_BINS) (
    idx = 2 * k;
    reL = dc_fftl_base[idx]; imL = dc_fftl_base[idx + 1];
    reR = dc_fftr_base[idx]; imR = dc_fftr_base[idx + 1];
    mag2L = max(0, reL * reL + imL * imL);
    mag2R = max(0, reR * reR + imR * imR);
    dc_mag_base[k] = sqrt(0.5 * (mag2L + mag2R));
    k += 1;
  );

  dc_gain_base[0] = 1;
  dc_gain_base[DECRUST_BINS - 1] = 1;
  avg_red = 0;

  k = 1;
  while (k < (DECRUST_BINS - 1)) (
    magbin = dc_mag_base[k];
    base_old = dc_base_base[k];
    base_old < 0.000000000000000001 ? base_old = max(magbin, 0.000000000000000001);

    x = min(10, magbin / (base_old + 0.000000000000000001));
    x2 = x * x; x3 = x2 * x; x4 = x2 * x2;

    m1v = dc_m1_base[k] = decrust_zap(dc_am * dc_m1_base[k] + dc_bm * x);
    m2v = dc_m2_base[k] = decrust_zap(dc_am * dc_m2_base[k] + dc_bm * x2);
    m3v = dc_m3_base[k] = decrust_zap(dc_am * dc_m3_base[k] + dc_bm * x3);
    m4v = dc_m4_base[k] = decrust_zap(dc_am * dc_m4_base[k] + dc_bm * x4);

    dc_base_base[k] = decrust_zap(dc_ab * base_old + dc_bb * magbin);

    mu2 = m2v - m1v * m1v;
    mu2 < 0.0000000001 ? (
      exk = 0;
    ) : (
      mu4 = m4v - 4 * m1v * m3v + 6 * m1v * m1v * m2v - 3 * m1v * m1v * m1v * m1v;
      exk = clamp(mu4 / (mu2 * mu2 + 0.000000000000000001) - 3, 0, 30);
    );

    flux = max(0, magbin - dc_prev_base[k]) / (base_old + 0.000000000000000001);
    dc_prev_base[k] = magbin;

    n1 = dc_mag_base[max(0, k - 2)];
    n2 = dc_mag_base[k - 1];
    n3 = dc_mag_base[k + 1];
    n4 = dc_mag_base[min(DECRUST_BINS - 1, k + 2)];
    neigh = 0.25 * (n1 + n2 + n3 + n4);
    neigh < 0.000000000000000001 ? neigh = base_old;

    peak = magbin / (neigh + 0.000000000000000001);
    dk = clamp01((exk - dc_kurt_thr) / max(0.25, dc_kurt_thr + 1));
    dp = clamp01((peak - dc_peak_thr) / max(0.18, dc_peak_thr));
    df = clamp01((flux - dc_flux_thr) / max(0.14, dc_flux_thr));

    fw = clamp01((k * srate / DECRUST_FFT) / max(100, dc_focus_hz));
    fw = fw * fw;

    strength = clamp01((0.55 * dk + 0.30 * dp + 0.15 * df) * (1 + 0.95 * dc_extreme));
    control = dc_stage * strength * (0.2 + 0.8 * fw);

    repair_ref = dc_neighbor * neigh + (1 - dc_neighbor) * base_old;
    hard_gain = min(1, (dc_ceiling_mult * repair_ref + 0.000000000000000001) / (magbin + 0.000000000000000001));
    raw_gain = 1 - control * (1 - hard_gain);
    dc_extreme > 0 ? raw_gain = min(raw_gain, 1 - clamp01(control * (1.0 + 0.55 * dc_extreme)) * (1 - hard_gain));
    raw_gain = clamp(raw_gain, 0.025, 1);
    dc_gain_base[k] = raw_gain;
    avg_red += 1 - raw_gain;
    k += 1;
  );

  dc_last_detect = denorm_zap(dc_last_detect * 0.92 + 0.08 * (avg_red / max(1, DECRUST_BINS - 2)));

  k = 1;
  while (k < (DECRUST_BINS - 1)) (
    g0 = dc_gain_base[k - 1];
    g1 = dc_gain_base[k];
    g2 = dc_gain_base[k + 1];
    sm_gain = 0.16 * g0 + 0.68 * g1 + 0.16 * g2;
    dc_gain_base[k] = sm_gain;

    idx = 2 * k;
    dc_fftl_base[idx] *= sm_gain;
    dc_fftl_base[idx + 1] *= sm_gain;
    dc_fftr_base[idx] *= sm_gain;
    dc_fftr_base[idx + 1] *= sm_gain;

    idx = 2 * (DECRUST_FFT - k);
    dc_fftl_base[idx] *= sm_gain;
    dc_fftl_base[idx + 1] *= sm_gain;
    dc_fftr_base[idx] *= sm_gain;
    dc_fftr_base[idx + 1] *= sm_gain;
    k += 1;
  );

  fft_ipermute(dc_fftl_base, DECRUST_FFT);
  fft_ipermute(dc_fftr_base, DECRUST_FFT);
  ifft(dc_fftl_base, DECRUST_FFT);
  ifft(dc_fftr_base, DECRUST_FFT);

  scale = 1 / DECRUST_FFT;
  outidx = (dc_ringpos + 1) & DECRUST_RINGMASK;
  i = 0;
  while (i < DECRUST_FFT) (
    idx = 2 * i;
    dc_outl_base[outidx] += dc_fftl_base[idx] * scale * dc_syn_base[i];
    dc_outr_base[outidx] += dc_fftr_base[idx] * scale * dc_syn_base[i];
    outidx = (outidx + 1) & DECRUST_RINGMASK;
    i += 1;
  );
);

function apply_clean_decrust() local(
  dryidx dryL dryR rawL rawR predL predR envL envR oddL oddR bendL bendR metricL metricR
  curve_gate ctrl_mid mid_in side_in mid_pred side_pred mid_wet side_wet wetL wetR deltaL deltaR wetmix
)
(
  // v46 CleanDeCrust: FFT-512 spectral-kurtosis crust repair. This is the
  // hidden Shift+Clean mode and the only place the FFT runs. Amount 0.5 roughly
  // matches the standalone DeCrust settings shown by the user; above that goes
  // intentionally fail-fast and more extreme.
  clean_decrust_amt > 0.0001 ? (
    dc_fft_ready <= 0 ? decrust_update_params();

    dc_inl_base[dc_ringpos] = outL;
    dc_inr_base[dc_ringpos] = outR;

    rawL = dc_outl_base[dc_ringpos];
    rawR = dc_outr_base[dc_ringpos];
    dc_outl_base[dc_ringpos] = 0;
    dc_outr_base[dc_ringpos] = 0;

    dc_hop_ctr += 1;
    dc_hop_ctr >= DECRUST_HOP ? (
      dc_hop_ctr = 0;
      decrust_process_frame();
    );

    dryidx = (dc_ringpos - DECRUST_LATENCY) & DECRUST_RINGMASK;
    dryL = dc_inl_base[dryidx];
    dryR = dc_inr_base[dryidx];

    dc_tdl0 = dc_tdl1; dc_tdl1 = dc_tdl2; dc_tdl2 = dc_tdl3; dc_tdl3 = dc_tdl4; dc_tdl4 = rawL;
    dc_tdr0 = dc_tdr1; dc_tdr1 = dc_tdr2; dc_tdr2 = dc_tdr3; dc_tdr3 = dc_tdr4; dc_tdr4 = rawR;

    predL = cubic_mid(dc_tdl0, dc_tdl1, dc_tdl3, dc_tdl4);
    predR = cubic_mid(dc_tdr0, dc_tdr1, dc_tdr3, dc_tdr4);
    envL = abs(dc_tdl1) + abs(dc_tdl2) + abs(dc_tdl3) + 0.000000000000000001;
    envR = abs(dc_tdr1) + abs(dc_tdr2) + abs(dc_tdr3) + 0.000000000000000001;
    oddL = abs(dc_tdl2 - predL) / (abs(predL) + envL + 0.000000000000000001);
    oddR = abs(dc_tdr2 - predR) / (abs(predR) + envR + 0.000000000000000001);
    bendL = abs(dc_tdl1 - 2 * dc_tdl2 + dc_tdl3) / envL;
    bendR = abs(dc_tdr1 - 2 * dc_tdr2 + dc_tdr3) / envR;
    metricL = clamp01(0.7 * clamp01((oddL - 0.04) / 0.16) + 0.3 * clamp01((bendL - 0.01) / 0.08));
    metricR = clamp01(0.7 * clamp01((oddR - 0.04) / 0.16) + 0.3 * clamp01((bendR - 0.01) / 0.08));
    curve_gate = clamp01((dc_last_detect - 0.001) * 80);
    ctrl_mid = dc_curve_amt * curve_gate * max(metricL, metricR);

    mid_in = 0.5 * (dc_tdl2 + dc_tdr2);
    side_in = 0.5 * (dc_tdl2 - dc_tdr2);
    mid_pred = 0.5 * (predL + predR);
    side_pred = 0.5 * (predL - predR);
    mid_wet = mid_in + ctrl_mid * (mid_pred - mid_in);
    side_wet = side_in; // stereo-safe default: no side curvature in the sampler mode.
    wetL = mid_wet + side_wet;
    wetR = mid_wet - side_wet;

    deltaL = wetL - dryL;
    deltaR = wetR - dryR;
    wetmix = dc_stage;
    outL = decrust_zap(dryL + wetmix * deltaL);
    outR = decrust_zap(dryR + wetmix * deltaR);

    dc_ringpos = (dc_ringpos + 1) & DECRUST_RINGMASK;
  );
);

function reset_clean_buffers() local(i)
(
  clean_lp1_l = 0;
  clean_lp2_l = 0;
  clean_lp3_l = 0;
  clean_lp4_l = 0;
  clean_lp1_r = 0;
  clean_lp2_r = 0;
  clean_lp3_r = 0;
  clean_lp4_r = 0;
  clean_head_bus = 0;
  clean_tail_bus = 0;

  i = 0;
  while (i < CLEAN_BANDS) (
    clean_env_base[i] = 0;
    clean_floor_base[i] = 0;
    clean_slow_base[i] = 0;
    clean_gain_base[i] = 1;
    i += 1;
  );

  decrust_clear_state();
);

function reset_room_buffers()
(
  room_lp1_l = 0;
  room_lp2_l = 0;
  room_lp3_l = 0;
  room_lp4_l = 0;
  room_lp1_r = 0;
  room_lp2_r = 0;
  room_lp3_r = 0;
  room_lp4_r = 0;

  room_fast_env = 0;
  room_slow_env = 0;
  room_late_s = 0;
  room_diffuse_s = 0;
  room_side_g = 1;

  room_b0_fast = 0; room_b1_fast = 0; room_b2_fast = 0; room_b3_fast = 0; room_b4_fast = 0;
  room_b0_slow = 0; room_b1_slow = 0; room_b2_slow = 0; room_b3_slow = 0; room_b4_slow = 0;

  room_g0 = 1;
  room_g1 = 1;
  room_g2 = 1;
  room_g3 = 1;
  room_g4 = 1;

  room_head_bus = 0;
  room_tail_bus = 0;
);

function reset_push_buffers()
(
  push_m_lp15 = 0;
  push_m_lp32 = 0;
  push_m_lp55 = 0;
  push_s_lp15 = 0;
  push_s_lp32 = 0;
  push_s_lp55 = 0;

  push_bodyE = 0;
  push_formE = 0;
  push_edgeE = 0;
  push_airE = 0;
  push_srcE = 0;
  push_m_hiE = 0;
  push_s_hiE = 0;
  push_click_fastE = 0;
  push_click_slowE = 0;

  push_common_dB = 0;
  push_side_dB = 0;
  push_hot_dB = -150;
  push_click_dB = 0;
  push_side_rel_dB = -150;
);



function reset_formant_buffers()
(
  form_lp1_l = 0; form_lp2_l = 0; form_lp3_l = 0; form_lp4_l = 0; form_lp5_l = 0;
  form_lp1_r = 0; form_lp2_r = 0; form_lp3_r = 0; form_lp4_r = 0; form_lp5_r = 0;

  form_env0 = 0; form_env1 = 0; form_env2 = 0; form_env3 = 0; form_env4 = 0; form_env5 = 0;
  form_g0 = 1; form_g1 = 1; form_g2 = 1; form_g3 = 1; form_g4 = 1; form_g5 = 1;
  form_level = 1;
);

function reset_focus_peak_buffers() local(i base)
(
  fpk_lp1_l = 0; fpk_lp2_l = 0; fpk_lp3_l = 0; fpk_lp4_l = 0;
  fpk_lp1_r = 0; fpk_lp2_r = 0; fpk_lp3_r = 0; fpk_lp4_r = 0;
  fpk_env0 = 0; fpk_env1 = 0; fpk_env2 = 0; fpk_env3 = 0; fpk_env4 = 0;
  fpk_g0 = 1; fpk_g1 = 1; fpk_g2 = 1; fpk_g3 = 1; fpk_g4 = 1;
  fpk_level = 1;

  i = 0;
  while (i < FPK_BANDS) (
    fpk_env_base[i] = 0;
    fpk_gain_base[i] = 0;
    fpk_band_l_base[i] = 0;
    fpk_band_r_base[i] = 0;
    base = i * FPK_BQ_STRIDE;
    fpk_bq_base[base + 5] = 0;
    fpk_bq_base[base + 6] = 0;
    fpk_bq_base[base + 7] = 0;
    fpk_bq_base[base + 8] = 0;
    i += 1;
  );
);


function reset_processing_buffers() local(i total)
(
  proc_hpf1_l = 0; proc_hpf2_l = 0;
  proc_hpf1_r = 0; proc_hpf2_r = 0;
  proc_lpf1_l = 0; proc_lpf2_l = 0;
  proc_lpf1_r = 0; proc_lpf2_r = 0;

  posteq_solo_z1_l = 0; posteq_solo_z2_l = 0;
  posteq_solo_z1_r = 0; posteq_solo_z2_r = 0;
  posteq_solo_mix = 0;
  posteq_solo_mode_latched = 0;

  i = 0;
  while (i < POSTEQ_SPEC_BINS) (
    posteq_spec_lp_base[i] = 0;
    posteq_spec_z2_base[i] = 0;
    posteq_spec_env_base[i] = 0;
    posteq_post_z1_base[i] = 0;
    posteq_post_z2_base[i] = 0;
    posteq_post_env_base[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < POSTEQ_BQ_COUNT) (
    posteq_bq_base[i * POSTEQ_BQ_STRIDE + 5] = 0;
    posteq_bq_base[i * POSTEQ_BQ_STRIDE + 6] = 0;
    posteq_bq_base[i * POSTEQ_BQ_STRIDE + 7] = 0;
    posteq_bq_base[i * POSTEQ_BQ_STRIDE + 8] = 0;
    i += 1;
  );
);

function posteq_slope_db(idx)
(
  idx <= 0 ? 6 : idx * 12;
);

function posteq_cut_q_norm(q)
(
  clamp01((clamp(q, 0.35, 4.0) - 0.707) / max(0.000001, 4.0 - 0.707));
);

function posteq_cut_filter_q(q)
(
  // Keep cascaded HPF/LPF stages stable. Resonance is handled by the explicit
  // cutoff-peak stage below, so high Q no longer turns steep filters brittle.
  q = clamp(q, 0.35, 4.0);
  q <= 0.707 ? q : clamp(0.707 + (q - 0.707) * 0.12, 0.707, 1.10);
);

function posteq_cut_res_gain_db(q) local(n)
(
  n = posteq_cut_q_norm(q);
  n <= 0 ? 0 : 12.0 * (n ^ 0.72);
);

function posteq_cut_res_peak_q(q) local(n)
(
  n = posteq_cut_q_norm(q);
  clamp(0.55 + n * 5.25, 0.55, 5.80);
);

function posteq_cut_res_resp_db(freq cf q) local(n amt width octv)
(
  // Visual model for HPF/LPF resonance. This is deliberately the same concept
  // as the DSP: Q raises a narrow-ish peak at the cutoff instead of silently
  // changing a hidden biquad parameter.
  amt = posteq_cut_res_gain_db(q);
  amt <= 0.0001 ? 0 : (
    n = posteq_cut_q_norm(q);
    octv = log(max(20, freq) / max(20, cf)) / log(2);
    width = lerp(0.72, 0.16, n);
    amt * exp(-(octv * octv) / max(0.000001, 2 * width * width));
  );
);

function posteq_bq_identity(slot) local(base)
(
  base = slot * POSTEQ_BQ_STRIDE;
  posteq_bq_base[base + 0] = 1;
  posteq_bq_base[base + 1] = 0;
  posteq_bq_base[base + 2] = 0;
  posteq_bq_base[base + 3] = 0;
  posteq_bq_base[base + 4] = 0;
);

function posteq_bq_set_peak(slot freq q gain_db) local(base A w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  base = slot * POSTEQ_BQ_STRIDE;
  abs(gain_db) < 0.000001 ? (
    posteq_bq_identity(slot);
  ) : (
    freq = clamp(freq, 20, min(20000, srate * 0.49));
    q = clamp(q, 0.35, 8);
    A = exp(gain_db * 0.05756462732485114); // 10^(dB/40)
    w0 = 6.283185307179586 * freq / max(srate, 1);
    sn = sin(w0);
    cs = cos(w0);
    alpha = sn / max(0.000001, 2 * q);

    b0 = 1 + alpha * A;
    b1 = -2 * cs;
    b2 = 1 - alpha * A;
    a0 = 1 + alpha / A;
    a1 = -2 * cs;
    a2 = 1 - alpha / A;

    posteq_bq_base[base + 0] = b0 / a0;
    posteq_bq_base[base + 1] = b1 / a0;
    posteq_bq_base[base + 2] = b2 / a0;
    posteq_bq_base[base + 3] = a1 / a0;
    posteq_bq_base[base + 4] = a2 / a0;
  );
);

function posteq_bq_set_highpass(slot freq q) local(base w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  base = slot * POSTEQ_BQ_STRIDE;
  freq = clamp(freq, 20, min(20000, srate * 0.49));
  q = clamp(q, 0.35, 4.0);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = (1 + cs) * 0.5;
  b1 = -(1 + cs);
  b2 = (1 + cs) * 0.5;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  posteq_bq_base[base + 0] = b0 / a0;
  posteq_bq_base[base + 1] = b1 / a0;
  posteq_bq_base[base + 2] = b2 / a0;
  posteq_bq_base[base + 3] = a1 / a0;
  posteq_bq_base[base + 4] = a2 / a0;
);

function posteq_bq_set_lowpass(slot freq q) local(base w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  base = slot * POSTEQ_BQ_STRIDE;
  freq = clamp(freq, 20, min(20000, srate * 0.49));
  q = clamp(q, 0.35, 4.0);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = (1 - cs) * 0.5;
  b1 = 1 - cs;
  b2 = (1 - cs) * 0.5;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  posteq_bq_base[base + 0] = b0 / a0;
  posteq_bq_base[base + 1] = b1 / a0;
  posteq_bq_base[base + 2] = b2 / a0;
  posteq_bq_base[base + 3] = a1 / a0;
  posteq_bq_base[base + 4] = a2 / a0;
);

function posteq_bq_process_l(slot x) local(base y)
(
  base = slot * POSTEQ_BQ_STRIDE;
  y = posteq_bq_base[base + 0] * x + posteq_bq_base[base + 5];
  posteq_bq_base[base + 5] = denorm_zap(posteq_bq_base[base + 1] * x - posteq_bq_base[base + 3] * y + posteq_bq_base[base + 6]);
  posteq_bq_base[base + 6] = denorm_zap(posteq_bq_base[base + 2] * x - posteq_bq_base[base + 4] * y);
  denorm_zap(y);
);

function posteq_bq_process_r(slot x) local(base y)
(
  base = slot * POSTEQ_BQ_STRIDE;
  y = posteq_bq_base[base + 0] * x + posteq_bq_base[base + 7];
  posteq_bq_base[base + 7] = denorm_zap(posteq_bq_base[base + 1] * x - posteq_bq_base[base + 3] * y + posteq_bq_base[base + 8]);
  posteq_bq_base[base + 8] = denorm_zap(posteq_bq_base[base + 2] * x - posteq_bq_base[base + 4] * y);
  denorm_zap(y);
);

function posteq_spec_bq_set_band(bin freq q) local(base w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  // Analyzer-only constant-peak bandpass. This replaces the old adjacent
  // lowpass-difference display, which was broad enough to read as one fat blob.
  base = (bin | 0) * POSTEQ_SPEC_COEFFS;
  freq = clamp(freq, 28, min(19000, srate * 0.49));
  q = clamp(q, 1.0, 10.0);

  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);

  b0 = alpha;
  b1 = 0;
  b2 = -alpha;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;

  posteq_spec_coeff_base[base + 0] = b0 / a0;
  posteq_spec_coeff_base[base + 1] = b1 / a0;
  posteq_spec_coeff_base[base + 2] = b2 / a0;
  posteq_spec_coeff_base[base + 3] = a1 / a0;
  posteq_spec_coeff_base[base + 4] = a2 / a0;
);

function posteq_update_coeffs() local(i norm cf specq cutq)
(
  cutq = posteq_cut_filter_q(proc_hpf_q);
  posteq_bq_set_highpass(0, proc_hpf_hz, cutq);
  posteq_bq_set_highpass(1, proc_hpf_hz, cutq);
  posteq_bq_set_highpass(2, proc_hpf_hz, cutq);
  posteq_bq_set_highpass(3, proc_hpf_hz, cutq);

  posteq_bq_set_peak(4, proc_eq_band1_hz, proc_eq_band1_q, proc_eq_band1_db);
  posteq_bq_set_peak(5, proc_eq_band2_hz, proc_eq_band2_q, proc_eq_band2_db);
  posteq_bq_set_peak(6, proc_eq_band3_hz, proc_eq_band3_q, proc_eq_band3_db);

  cutq = posteq_cut_filter_q(proc_lpf_q);
  posteq_bq_set_lowpass(7, proc_lpf_hz, cutq);
  posteq_bq_set_lowpass(8, proc_lpf_hz, cutq);
  posteq_bq_set_lowpass(9, proc_lpf_hz, cutq);
  posteq_bq_set_lowpass(10, proc_lpf_hz, cutq);

  posteq_hpf_res_db = (proc_hpf_hz > 22) ? posteq_cut_res_gain_db(proc_hpf_q) : 0;
  posteq_lpf_res_db = (proc_lpf_hz < min(19000, srate * 0.47)) ? posteq_cut_res_gain_db(proc_lpf_q) : 0;
  posteq_bq_set_peak(11, proc_hpf_hz, posteq_cut_res_peak_q(proc_hpf_q), posteq_hpf_res_db);
  posteq_bq_set_peak(12, proc_lpf_hz, posteq_cut_res_peak_q(proc_lpf_q), posteq_lpf_res_db);

  i = 0;
  while (i < POSTEQ_SPEC_BINS) (
    norm = i / max(1, POSTEQ_SPEC_BINS - 1);
    cf = exp(log(32) + norm * (log(19000) - log(32)));
    // Wider lows, tighter highs. Enough resolution to show useful pockets,
    // not so much that the tiny panel becomes a nervous FFT waterfall.
    specq = lerp(2.20, 6.25, norm ^ 0.72);
    posteq_spec_bq_set_band(i, cf, specq);
    i += 1;
  );
);

function posteq_zero_pre_spectrum() local(i)
(
  i = 0;
  while (i < POSTEQ_SPEC_BINS) (
    posteq_spec_lp_base[i] = 0;
    posteq_spec_z2_base[i] = 0;
    posteq_spec_env_base[i] = 0;
    i += 1;
  );
);

function posteq_zero_post_spectrum() local(i)
(
  i = 0;
  while (i < POSTEQ_SPEC_BINS) (
    posteq_post_z1_base[i] = 0;
    posteq_post_z2_base[i] = 0;
    posteq_post_env_base[i] = 0;
    i += 1;
  );
);

function posteq_zero_filter_states() local(i base)
(
  proc_hpf1_l = 0; proc_hpf2_l = 0;
  proc_hpf1_r = 0; proc_hpf2_r = 0;
  proc_lpf1_l = 0; proc_lpf2_l = 0;
  proc_lpf1_r = 0; proc_lpf2_r = 0;
  i = 0;
  while (i < POSTEQ_BQ_COUNT) (
    base = i * POSTEQ_BQ_STRIDE;
    posteq_bq_base[base + 5] = 0;
    posteq_bq_base[base + 6] = 0;
    posteq_bq_base[base + 7] = 0;
    posteq_bq_base[base + 8] = 0;
    i += 1;
  );
);

function posteq_analyze_spectrum(l r) local(src i base y z1 z2 det env)
(
  // Pre-PostEQ analyzer. Silence is gated so the 96 visual-only resonant
  // bandpass states cannot decay into denormals across parallel instances.
  src = 0.5 * (l + r);
  abs(src) < DENORM_AUDIO_FLOOR ? (
    posteq_pre_silent += 1;
    posteq_pre_silent >= DENORM_ANALYZER_HOLD ? (
      posteq_zero_pre_spectrum();
      posteq_pre_silent = DENORM_ANALYZER_HOLD;
    );
  ) : (
    posteq_pre_silent = 0;
    i = 0;
    while (i < POSTEQ_SPEC_BINS) (
      base = i * POSTEQ_SPEC_COEFFS;

      z1 = posteq_spec_lp_base[i];
      z2 = posteq_spec_z2_base[i];
      y = posteq_spec_coeff_base[base + 0] * src + z1;
      z1 = posteq_spec_coeff_base[base + 1] * src - posteq_spec_coeff_base[base + 3] * y + z2;
      z2 = posteq_spec_coeff_base[base + 2] * src - posteq_spec_coeff_base[base + 4] * y;

      posteq_spec_lp_base[i] = denorm_zap(z1);
      posteq_spec_z2_base[i] = denorm_zap(z2);

      det = abs(y);
      env = posteq_spec_env_base[i];
      env += (det - env) * (det > env ? posteq_spec_att_coeff : posteq_spec_rel_coeff);
      posteq_spec_env_base[i] = denorm_zap(env);
      i += 1;
    );
  );
);

function posteq_analyze_post_spectrum(l r) local(src i base y z1 z2 det env)
(
  // Post-PostEQ analyzer. Same silence gate as the pre analyzer.
  src = 0.5 * (l + r);
  abs(src) < DENORM_AUDIO_FLOOR ? (
    posteq_post_silent += 1;
    posteq_post_silent >= DENORM_ANALYZER_HOLD ? (
      posteq_zero_post_spectrum();
      posteq_post_silent = DENORM_ANALYZER_HOLD;
    );
  ) : (
    posteq_post_silent = 0;
    i = 0;
    while (i < POSTEQ_SPEC_BINS) (
      base = i * POSTEQ_SPEC_COEFFS;

      z1 = posteq_post_z1_base[i];
      z2 = posteq_post_z2_base[i];
      y = posteq_spec_coeff_base[base + 0] * src + z1;
      z1 = posteq_spec_coeff_base[base + 1] * src - posteq_spec_coeff_base[base + 3] * y + z2;
      z2 = posteq_spec_coeff_base[base + 2] * src - posteq_spec_coeff_base[base + 4] * y;

      posteq_post_z1_base[i] = denorm_zap(z1);
      posteq_post_z2_base[i] = denorm_zap(z2);

      det = abs(y);
      env = posteq_post_env_base[i];
      env += (det - env) * (det > env ? posteq_spec_att_coeff : posteq_spec_rel_coeff);
      posteq_post_env_base[i] = denorm_zap(env);
      i += 1;
    );
  );
);


function posteq_solo_zero()
(
  posteq_solo_z1_l = 0; posteq_solo_z2_l = 0;
  posteq_solo_z1_r = 0; posteq_solo_z2_r = 0;
);

function posteq_solo_set_identity()
(
  posteq_solo_b0 = 1;
  posteq_solo_b1 = 0;
  posteq_solo_b2 = 0;
  posteq_solo_a1 = 0;
  posteq_solo_a2 = 0;
);

function posteq_solo_set_lowpass(freq q) local(w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  freq = clamp(freq, 20, min(20000, srate * 0.49));
  q = clamp(q, 0.45, 4.0);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = (1 - cs) * 0.5;
  b1 = 1 - cs;
  b2 = (1 - cs) * 0.5;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  posteq_solo_b0 = b0 / a0;
  posteq_solo_b1 = b1 / a0;
  posteq_solo_b2 = b2 / a0;
  posteq_solo_a1 = a1 / a0;
  posteq_solo_a2 = a2 / a0;
);

function posteq_solo_set_highpass(freq q) local(w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  freq = clamp(freq, 20, min(20000, srate * 0.49));
  q = clamp(q, 0.45, 4.0);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = (1 + cs) * 0.5;
  b1 = -(1 + cs);
  b2 = (1 + cs) * 0.5;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  posteq_solo_b0 = b0 / a0;
  posteq_solo_b1 = b1 / a0;
  posteq_solo_b2 = b2 / a0;
  posteq_solo_a1 = a1 / a0;
  posteq_solo_a2 = a2 / a0;
);

function posteq_solo_set_bandpass(freq q) local(w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  freq = clamp(freq, 20, min(20000, srate * 0.49));
  q = clamp(q, 0.45, 12.0);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = alpha;
  b1 = 0;
  b2 = -alpha;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  posteq_solo_b0 = b0 / a0;
  posteq_solo_b1 = b1 / a0;
  posteq_solo_b2 = b2 / a0;
  posteq_solo_a1 = a1 / a0;
  posteq_solo_a2 = a2 / a0;
);

function posteq_solo_refresh() local(mode freq q kind)
(
  mode = posteq_solo_target > 0 ? posteq_solo_target : posteq_solo_mode_latched;
  mode = clamp(mode | 0, 0, 5);
  mode > 0 ? posteq_solo_mode_latched = mode;

  mode <= 0 ? (
    posteq_solo_set_identity();
  ) : (
    mode == 1 ? (
      kind = 1; freq = slider38; q = max(0.60, slider45);
    ) : mode == 2 ? (
      kind = 2; freq = slider35; q = slider40;
    ) : mode == 3 ? (
      kind = 2; freq = slider36; q = slider41;
    ) : mode == 4 ? (
      kind = 2; freq = slider37; q = slider42;
    ) : (
      kind = 3; freq = slider39; q = max(0.60, slider46);
    );

    (kind != posteq_solo_kind_last || abs(freq - posteq_solo_freq_last) > 0.01 || abs(q - posteq_solo_q_last) > 0.0001) ? (
      kind == 1 ? posteq_solo_set_lowpass(freq, q)
      : kind == 3 ? posteq_solo_set_highpass(freq, q)
      : posteq_solo_set_bandpass(freq, q);
      posteq_solo_kind_last = kind;
      posteq_solo_freq_last = freq;
      posteq_solo_q_last = q;
    );
  );
);

function posteq_solo_process_l(x) local(y)
(
  y = posteq_solo_b0 * x + posteq_solo_z1_l;
  posteq_solo_z1_l = denorm_zap(posteq_solo_b1 * x - posteq_solo_a1 * y + posteq_solo_z2_l);
  posteq_solo_z2_l = denorm_zap(posteq_solo_b2 * x - posteq_solo_a2 * y);
  denorm_zap(y);
);

function posteq_solo_process_r(x) local(y)
(
  y = posteq_solo_b0 * x + posteq_solo_z1_r;
  posteq_solo_z1_r = denorm_zap(posteq_solo_b1 * x - posteq_solo_a1 * y + posteq_solo_z2_r);
  posteq_solo_z2_r = denorm_zap(posteq_solo_b2 * x - posteq_solo_a2 * y);
  denorm_zap(y);
);

function apply_posteq_solo() local(target coeff soloL soloR gain mode)
(
  target = posteq_solo_target > 0 ? 1 : 0;
  coeff = target ? 0.085 : 0.045;
  posteq_solo_mix += (target - posteq_solo_mix) * coeff;
  posteq_solo_mix = clamp01(posteq_solo_mix);

  (posteq_solo_mix > 0.0001 || target > 0) ? (
    posteq_solo_refresh();
    soloL = posteq_solo_process_l(outL + denorm_guard);
    soloR = posteq_solo_process_r(outR - denorm_guard);
    mode = posteq_solo_mode_latched | 0;
    gain = (mode == 1 || mode == 5) ? 1.65 : 2.35;
    outL = denorm_zap(lerp(outL, soloL * gain, posteq_solo_mix));
    outR = denorm_zap(lerp(outR, soloR * gain, posteq_solo_mix));
  ) : (
    posteq_solo_mix = 0;
    posteq_solo_mode_latched = 0;
    posteq_solo_zero();
  );
);

function apply_posteq_filter() local(xL xR idx count)
(
  xL = outL + denorm_guard;
  xR = outR - denorm_guard;

  proc_hpf_hz > 22 ? (
    proc_hpf_slope_idx <= 0 ? (
      proc_hpf1_l = denorm_zap(proc_hpf1_l + (xL - proc_hpf1_l) * proc_hpf_coeff);
      proc_hpf1_r = denorm_zap(proc_hpf1_r + (xR - proc_hpf1_r) * proc_hpf_coeff);
      xL = xL - proc_hpf1_l;
      xR = xR - proc_hpf1_r;
    ) : (
      count = min(4, proc_hpf_slope_idx);
      idx = 0;
      while (idx < count) (
        xL = posteq_bq_process_l(idx, xL);
        xR = posteq_bq_process_r(idx, xR);
        idx += 1;
      );
    );
    posteq_hpf_res_db > 0.0001 ? (
      xL = posteq_bq_process_l(11, xL);
      xR = posteq_bq_process_r(11, xR);
    );
  );

  abs(proc_eq_band1_db) > 0.000001 ? (
    xL = posteq_bq_process_l(4, xL);
    xR = posteq_bq_process_r(4, xR);
  );
  abs(proc_eq_band2_db) > 0.000001 ? (
    xL = posteq_bq_process_l(5, xL);
    xR = posteq_bq_process_r(5, xR);
  );
  abs(proc_eq_band3_db) > 0.000001 ? (
    xL = posteq_bq_process_l(6, xL);
    xR = posteq_bq_process_r(6, xR);
  );

  proc_lpf_hz < min(19000, srate * 0.47) ? (
    posteq_lpf_res_db > 0.0001 ? (
      xL = posteq_bq_process_l(12, xL);
      xR = posteq_bq_process_r(12, xR);
    );
    proc_lpf_slope_idx <= 0 ? (
      proc_lpf1_l = denorm_zap(proc_lpf1_l + (xL - proc_lpf1_l) * proc_lpf_coeff);
      proc_lpf1_r = denorm_zap(proc_lpf1_r + (xR - proc_lpf1_r) * proc_lpf_coeff);
      xL = proc_lpf1_l;
      xR = proc_lpf1_r;
    ) : (
      count = min(4, proc_lpf_slope_idx);
      idx = 0;
      while (idx < count) (
        xL = posteq_bq_process_l(7 + idx, xL);
        xR = posteq_bq_process_r(7 + idx, xR);
        idx += 1;
      );
    );
  );

  outL = denorm_zap(xL);
  outR = denorm_zap(xR);
  denorm_near_silence(outL, outR) ? (
    posteq_filter_silent += 1;
    posteq_filter_silent == DENORM_ANALYZER_HOLD ? posteq_zero_filter_states();
    posteq_filter_silent > DENORM_ANALYZER_HOLD ? posteq_filter_silent = DENORM_ANALYZER_HOLD;
  ) : (
    posteq_filter_silent = 0;
  );
);

function apply_processing_strip()
(
  (proc_hpf_hz > 22 || proc_lpf_hz < min(19000, srate * 0.47) || abs(proc_eq_band1_db) > 0.0001 || abs(proc_eq_band2_db) > 0.0001 || abs(proc_eq_band3_db) > 0.0001) ? apply_posteq_filter();
  (posteq_solo_target > 0 || posteq_solo_mix > 0.0001) ? apply_posteq_solo();
);


function clean_scrub_gain(idx det amount bias) local(
  fast slow floorv floor_target noise snr_margin clear under stable bed
  noise_cut bed_cut min_g tgt g upc
)
(
  // v40 CleanScrub: SNR-aware per-band noise/bed suppression.
  // The old Clean was a polite expander. This version distinguishes clear signal
  // from sustained low-SNR bed/hiss and becomes intentionally obvious near max.
  det = max(det, 0);

  fast = clean_env_base[idx];
  fast += (det - fast) * (det > fast ? clean_env_att_coeff : clean_env_rel_coeff);
  fast = denorm_zap(fast);
  clean_env_base[idx] = fast;

  slow = clean_slow_base[idx];
  slow += (det - slow) * (det > slow ? clean_slow_att_coeff : clean_slow_rel_coeff);
  slow = denorm_zap(slow);
  clean_slow_base[idx] = slow;

  // Adaptive noise floor: rises slowly with sustained bed, falls faster so stale
  // floor estimates do not eat new dry hits. It is capped below the live envelope.
  floor_target = min(slow * 0.92 + det * 0.08, fast * 0.78 + clean_abs_floor);
  floorv = clean_floor_base[idx];
  floorv += (floor_target - floorv) * (floor_target > floorv ? clean_floor_up_coeff : clean_floor_down_coeff);
  floorv = denorm_zap(clamp(floorv, clean_abs_floor, fast * 0.86 + clean_abs_floor));
  clean_floor_base[idx] = floorv;

  noise = max(floorv, clean_abs_floor);
  snr_margin = lerp(3.60, 1.22, amount);
  clear = clamp01((fast - noise * snr_margin) / max(fast + noise * snr_margin, 0.000000000001));
  under = 1 - clear;

  // Stable/sustained bands are more likely to be room bed, hiss, or static.
  // Transients have fast >> slow and are protected by both clear and global protect.
  stable = clamp01(slow / max(fast + 0.000000000001, clean_abs_floor));
  bed = clamp01((stable - lerp(0.82, 0.46, amount)) / max(0.0001, lerp(0.30, 0.48, amount)));

  min_g = clean_min_gain;
  noise_cut = amount * bias * under * (0.36 + 0.88 * amount);
  bed_cut   = amount * bias * bed   * (0.12 + 0.76 * amount);

  tgt = 1 - noise_cut - bed_cut;
  // If the band is clearly above its floor, preserve it. This prevents Clean from
  // acting like a crude static EQ on healthy signal.
  tgt = lerp(tgt, 1, clear * lerp(0.28, 0.64, 1 - amount));
  tgt = clamp(tgt, min_g, 1);

  g = clean_gain_base[idx];
  upc = amount < 0.02 ? clean_gain_protect_coeff : clean_gain_up_coeff;
  g += (tgt - g) * (tgt < g ? clean_gain_down_coeff : upc);
  g = denorm_zap(clamp(g, min_g, 1));
  clean_gain_base[idx] = g;
  g;
);

function apply_cleaner() local(
  inL inR dryL dryR
  b0l b1l b2l b3l b4l b0r b1r b2r b3r b4r
  d0 d1 d2 d3 d4 totalD hf_ratio air_ratio hiss_bias
  protect amount tail_region clean_power
  g0 g1 g2 g3 g4 air_trim pres_trim wetL wetR wetmix dryE wetE level
)
(
  // v40 CleanScrub: transient-safe de-noise/de-bed. It targets sustained low-SNR
  // material, top hiss, and static tail beds harder than the old broad expander.
  inL = outL;
  inR = outR;
  dryL = inL;
  dryR = inR;

  inL += denorm_guard;
  inR -= denorm_guard;

  clean_lp1_l = denorm_zap(clean_lp1_l + (inL - clean_lp1_l) * clean_lp_c1);
  clean_lp2_l = denorm_zap(clean_lp2_l + (inL - clean_lp2_l) * clean_lp_c2);
  clean_lp3_l = denorm_zap(clean_lp3_l + (inL - clean_lp3_l) * clean_lp_c3);
  clean_lp4_l = denorm_zap(clean_lp4_l + (inL - clean_lp4_l) * clean_lp_c4);

  clean_lp1_r = denorm_zap(clean_lp1_r + (inR - clean_lp1_r) * clean_lp_c1);
  clean_lp2_r = denorm_zap(clean_lp2_r + (inR - clean_lp2_r) * clean_lp_c2);
  clean_lp3_r = denorm_zap(clean_lp3_r + (inR - clean_lp3_r) * clean_lp_c3);
  clean_lp4_r = denorm_zap(clean_lp4_r + (inR - clean_lp4_r) * clean_lp_c4);

  b0l = clean_lp1_l;
  b1l = clean_lp2_l - clean_lp1_l;
  b2l = clean_lp3_l - clean_lp2_l;
  b3l = clean_lp4_l - clean_lp3_l;
  b4l = inL - clean_lp4_l;

  b0r = clean_lp1_r;
  b1r = clean_lp2_r - clean_lp1_r;
  b2r = clean_lp3_r - clean_lp2_r;
  b3r = clean_lp4_r - clean_lp3_r;
  b4r = inR - clean_lp4_r;

  d0 = max(abs(b0l), abs(b0r)) * 0.62 + abs(0.5 * (b0l + b0r)) * 0.38;
  d1 = max(abs(b1l), abs(b1r)) * 0.62 + abs(0.5 * (b1l + b1r)) * 0.38;
  d2 = max(abs(b2l), abs(b2r)) * 0.62 + abs(0.5 * (b2l + b2r)) * 0.38;
  d3 = max(abs(b3l), abs(b3r)) * 0.62 + abs(0.5 * (b3l + b3r)) * 0.38;
  d4 = max(abs(b4l), abs(b4r)) * 0.62 + abs(0.5 * (b4l + b4r)) * 0.38;

  protect = clamp01(transient_guard_s * (0.92 + 0.08 * trans_mode_mix) + clean_head_bus * 0.95);
  tail_region = clamp01(clean_tail_bus * 0.92 + room_tail_bus * 0.18);
  amount = clamp01(clean_amt * (1 - protect));
  amount = clamp01(amount * (1 + tail_region * (0.34 + 0.42 * clean_amt)));
  clean_power = clean_amt ^ 1.35;

  totalD = d0 + d1 + d2 + d3 + d4 + 0.000000000001;
  hf_ratio = clamp01((d3 + d4) / totalD);
  air_ratio = clamp01(d4 / max(d2 + d3 + d4 + 0.000000000001, 0.000000000001));
  hiss_bias = clamp01((hf_ratio - 0.30) / 0.55) * clamp01((air_ratio - 0.34) / 0.46);

  // Lows are deliberately conservative; upper bands are allowed to scrub hard.
  g0 = clean_scrub_gain(0, d0, amount, 0.16);
  g1 = clean_scrub_gain(1, d1, amount, 0.48);
  g2 = clean_scrub_gain(2, d2, amount, 0.86);
  g3 = clean_scrub_gain(3, d3, amount, 1.22 + hiss_bias * 0.22);
  g4 = clean_scrub_gain(4, d4, amount, 1.58 + hiss_bias * 0.42);

  // Extra hiss/static trim only when the spectrum actually looks top-heavy and
  // the user is asking for strong cleanup. This keeps ordinary dark material safe.
  air_trim = 1 - hiss_bias * amount * (0.10 + 0.62 * clean_power);
  pres_trim = 1 - hiss_bias * amount * (0.04 + 0.26 * clean_power);
  g3 = clamp(g3 * pres_trim, clean_min_gain, 1);
  g4 = clamp(g4 * air_trim, clean_min_gain, 1);

  wetL = b0l * g0 + b1l * g1 + b2l * g2 + b3l * g3 + b4l * g4;
  wetR = b0r * g0 + b1r * g1 + b2r * g2 + b3r * g3 + b4r * g4;

  // Keep the correction from becoming only a volume drop. This is deliberately
  // mild; high Clean should still sound obviously cleaned, not normalized away.
  dryE = dryL*dryL + dryR*dryR + 0.000000000001;
  wetE = wetL*wetL + wetR*wetR + 0.000000000001;
  level = clamp(sqrt(dryE / wetE), 0.76, 1.12);
  level = lerp(1, level, 0.24 + 0.18 * clean_amt);
  wetL *= level;
  wetR *= level;

  wetmix = amount <= 0.0001 ? 0 : clamp01(0.30 + 0.70 * amount);
  outL = denorm_zap(lerp(dryL, wetL, wetmix));
  outR = denorm_zap(lerp(dryR, wetR, wetmix));
);

function apply_room_tame() local(
  inL inR det eps
  b0l b1l b2l b3l b4l b0r b1r b2r b3r b4r
  d0 d1 d2 d3 d4
  late0 late1 late2 late3 late4 late_raw late_s
  mid1 side1 mid2 side2 mid3 side3 side4 sideE midE side_rel diffuse diffuse_s
  protect tail_region amount base_amt room_power
  a0 a1 a2 a3 a4
  target0 target1 target2 target3 target4 side_target side_trim
  dryL dryR wetL wetR wetmix artifact_guard
)
(
  // v39 RoomScrub: transient-protected multiband de-room/de-smear.
  // The old path was deliberately mild. This one detects late/diffuse energy per band,
  // trims low-mid/presence room wash harder, narrows roomy side smear, and backs off
  // quickly around attacks. High values are intentionally obvious rather than subtle.
  inL = outL;
  inR = outR;
  eps = 0.000000000001;

  room_lp1_l = denorm_zap(room_lp1_l + (inL - room_lp1_l) * room_lp_c1);
  room_lp2_l = denorm_zap(room_lp2_l + (inL - room_lp2_l) * room_lp_c2);
  room_lp3_l = denorm_zap(room_lp3_l + (inL - room_lp3_l) * room_lp_c3);
  room_lp4_l = denorm_zap(room_lp4_l + (inL - room_lp4_l) * room_lp_c4);

  room_lp1_r = denorm_zap(room_lp1_r + (inR - room_lp1_r) * room_lp_c1);
  room_lp2_r = denorm_zap(room_lp2_r + (inR - room_lp2_r) * room_lp_c2);
  room_lp3_r = denorm_zap(room_lp3_r + (inR - room_lp3_r) * room_lp_c3);
  room_lp4_r = denorm_zap(room_lp4_r + (inR - room_lp4_r) * room_lp_c4);

  b0l = room_lp1_l;
  b1l = room_lp2_l - room_lp1_l;
  b2l = room_lp3_l - room_lp2_l;
  b3l = room_lp4_l - room_lp3_l;
  b4l = inL - room_lp4_l;

  b0r = room_lp1_r;
  b1r = room_lp2_r - room_lp1_r;
  b2r = room_lp3_r - room_lp2_r;
  b3r = room_lp4_r - room_lp3_r;
  b4r = inR - room_lp4_r;

  d0 = max(abs(b0l), abs(b0r)) * 0.58 + abs(0.5 * (b0l + b0r)) * 0.42;
  d1 = max(abs(b1l), abs(b1r)) * 0.58 + abs(0.5 * (b1l + b1r)) * 0.42;
  d2 = max(abs(b2l), abs(b2r)) * 0.58 + abs(0.5 * (b2l + b2r)) * 0.42;
  d3 = max(abs(b3l), abs(b3r)) * 0.58 + abs(0.5 * (b3l + b3r)) * 0.42;
  d4 = max(abs(b4l), abs(b4r)) * 0.58 + abs(0.5 * (b4l + b4r)) * 0.42;

  det = max(abs(inL), abs(inR)) * 0.54 + abs(0.5 * (inL + inR)) * 0.46;
  room_fast_env = denorm_zap(room_fast_env + (det - room_fast_env) * (det > room_fast_env ? room_env_att_coeff : room_env_fast_rel_coeff));
  room_slow_env = denorm_zap(room_slow_env + (det - room_slow_env) * (det > room_slow_env ? room_env_slow_att_coeff : room_env_slow_rel_coeff));

  room_b0_fast = denorm_zap(room_b0_fast + (d0 - room_b0_fast) * (d0 > room_b0_fast ? room_band_att_coeff : room_band_fast_rel_coeff));
  room_b1_fast = denorm_zap(room_b1_fast + (d1 - room_b1_fast) * (d1 > room_b1_fast ? room_band_att_coeff : room_band_fast_rel_coeff));
  room_b2_fast = denorm_zap(room_b2_fast + (d2 - room_b2_fast) * (d2 > room_b2_fast ? room_band_att_coeff : room_band_fast_rel_coeff));
  room_b3_fast = denorm_zap(room_b3_fast + (d3 - room_b3_fast) * (d3 > room_b3_fast ? room_band_att_coeff : room_band_fast_rel_coeff));
  room_b4_fast = denorm_zap(room_b4_fast + (d4 - room_b4_fast) * (d4 > room_b4_fast ? room_band_att_coeff : room_band_fast_rel_coeff));

  room_b0_slow = denorm_zap(room_b0_slow + (d0 - room_b0_slow) * (d0 > room_b0_slow ? room_band_slow_att_coeff : room_band_slow_rel_coeff));
  room_b1_slow = denorm_zap(room_b1_slow + (d1 - room_b1_slow) * (d1 > room_b1_slow ? room_band_slow_att_coeff : room_band_slow_rel_coeff));
  room_b2_slow = denorm_zap(room_b2_slow + (d2 - room_b2_slow) * (d2 > room_b2_slow ? room_band_slow_att_coeff : room_band_slow_rel_coeff));
  room_b3_slow = denorm_zap(room_b3_slow + (d3 - room_b3_slow) * (d3 > room_b3_slow ? room_band_slow_att_coeff : room_band_slow_rel_coeff));
  room_b4_slow = denorm_zap(room_b4_slow + (d4 - room_b4_slow) * (d4 > room_b4_slow ? room_band_slow_att_coeff : room_band_slow_rel_coeff));

  late0 = clamp01((room_b0_slow - room_b0_fast) / max(room_b0_slow, eps));
  late1 = clamp01((room_b1_slow - room_b1_fast) / max(room_b1_slow, eps));
  late2 = clamp01((room_b2_slow - room_b2_fast) / max(room_b2_slow, eps));
  late3 = clamp01((room_b3_slow - room_b3_fast) / max(room_b3_slow, eps));
  late4 = clamp01((room_b4_slow - room_b4_fast) / max(room_b4_slow, eps));
  late_raw = clamp01((room_slow_env - room_fast_env) / max(room_slow_env, eps));
  late_raw = clamp01(max(late_raw, late1 * 0.70 + late2 * 0.85 + late3 * 0.48 + late4 * 0.20));
  room_late_s = denorm_zap(room_late_s + (late_raw - room_late_s) * (late_raw > room_late_s ? room_late_att_coeff : room_late_rel_coeff));
  late_s = room_late_s;

  mid1 = 0.5 * (b1l + b1r); side1 = 0.5 * (b1l - b1r);
  mid2 = 0.5 * (b2l + b2r); side2 = 0.5 * (b2l - b2r);
  mid3 = 0.5 * (b3l + b3r); side3 = 0.5 * (b3l - b3r);
  side4 = 0.5 * (b4l - b4r);
  sideE = side1*side1 + side2*side2 + side3*side3 + side4*side4;
  midE = mid1*mid1 + mid2*mid2 + mid3*mid3 + eps;
  side_rel = sideE / max(sideE + midE, eps);
  diffuse = clamp01((side_rel - 0.16) / 0.62);
  room_diffuse_s = denorm_zap(room_diffuse_s + (diffuse - room_diffuse_s) * (diffuse > room_diffuse_s ? room_late_att_coeff : room_late_rel_coeff));
  diffuse_s = room_diffuse_s;

  protect = clamp01(transient_guard_s * (0.98 + 0.12 * trans_mode_mix) + room_head_bus * 1.10);
  tail_region = clamp01(room_tail_bus * 0.92 + late_s * (0.42 + 0.45 * room_amt) + diffuse_s * late_s * 0.42);
  room_power = room_amt ^ 0.78;
  base_amt = room_power * (1 - protect) * tail_region;
  // fail-fast: above the midpoint, the knob moves from useful restraint into obvious de-rooming.
  amount = clamp01(base_amt * (0.82 + 0.55 * room_amt + 0.70 * max(0, room_amt - 0.50)));

  a0 = clamp01(amount * (0.20 + 0.52 * late0 + 0.10 * diffuse_s));
  a1 = clamp01(amount * (0.42 + 1.38 * late1 + 0.44 * diffuse_s + 0.12 * late_s));
  a2 = clamp01(amount * (0.36 + 1.30 * late2 + 0.38 * diffuse_s + 0.10 * late_s));
  a3 = clamp01(amount * (0.22 + 0.86 * late3 + 0.30 * diffuse_s));
  a4 = clamp01(amount * (0.10 + 0.48 * late4 + 0.14 * diffuse_s));

  target0 = max(room_min_gain0, db2amp(-(0.8 + 4.6 * room_amt) * a0));
  target1 = max(room_min_gain1, db2amp(-(2.2 + 18.0 * room_amt) * a1));
  target2 = max(room_min_gain2, db2amp(-(1.8 + 15.5 * room_amt) * a2));
  target3 = max(room_min_gain3, db2amp(-(0.9 + 9.8 * room_amt) * a3));
  target4 = max(room_min_gain4, db2amp(-(0.4 + 5.4 * room_amt) * a4));

  room_g0 = denorm_zap(room_g0 + (target0 - room_g0) * (target0 < room_g0 ? room_gain_down_coeff : room_gain_up_coeff));
  room_g1 = denorm_zap(room_g1 + (target1 - room_g1) * (target1 < room_g1 ? room_gain_down_coeff : room_gain_up_coeff));
  room_g2 = denorm_zap(room_g2 + (target2 - room_g2) * (target2 < room_g2 ? room_gain_down_coeff : room_gain_up_coeff));
  room_g3 = denorm_zap(room_g3 + (target3 - room_g3) * (target3 < room_g3 ? room_gain_down_coeff : room_gain_up_coeff));
  room_g4 = denorm_zap(room_g4 + (target4 - room_g4) * (target4 < room_g4 ? room_gain_down_coeff : room_gain_up_coeff));

  side_target = db2amp(-(1.0 + 11.0 * room_amt) * clamp01(amount * (0.16 + 0.92 * diffuse_s + 0.45 * late_s)));
  side_target = clamp(side_target, db2amp(-(1.0 + 12.0 * room_amt)), 1);
  room_side_g = denorm_zap(room_side_g + (side_target - room_side_g) * (side_target < room_side_g ? room_gain_down_coeff : room_gain_up_coeff));
  side_trim = clamp01(1 - room_side_g);

  side1 *= room_side_g * (1 - side_trim * 0.28);
  side2 *= room_side_g;
  side3 *= room_side_g * (1 - side_trim * 0.18);

  wetL = b0l * room_g0 + (mid1 + side1) * room_g1 + (mid2 + side2) * room_g2 + (mid3 + side3) * room_g3 + b4l * room_g4;
  wetR = b0r * room_g0 + (mid1 - side1) * room_g1 + (mid2 - side2) * room_g2 + (mid3 - side3) * room_g3 + b4r * room_g4;

  // Keep high settings obvious, but avoid turning uncertain full-range material into gated rubble.
  artifact_guard = clamp01(0.30 + late_s * 0.44 + diffuse_s * 0.22 + room_tail_bus * 0.24 + room_amt * 0.22);
  wetmix = clamp01(0.52 + room_amt * 0.48);
  wetmix *= artifact_guard;
  outL = denorm_zap(lerp(inL, wetL, wetmix));
  outR = denorm_zap(lerp(inR, wetR, wetmix));
);

function apply_push() local(
  inL inR M S
  M_body M_form M_edge M_air S_body S_form S_edge S_air
  body_inst form_inst edge_inst air_inst src_inst M_hi S_hi
  src_dB src_w self_allow trans_allow side_allow
  ex_self ex_trans ex_side level_want common_want side_want
  head_damp cC cS g_form g_edge g_air g_side g_broad
  formW edgeW airW broadW broad_dB
)
(
  // Single-knob salience budget. Derived from the separate Salience Push idea,
  // but self-keyed only: it trims presence/air, reins in pokey upper spikes,
  // narrows bright side wash, and adds broadband distance at high settings.
  inL = outL;
  inR = outR;

  M = 0.5 * (inL + inR);
  S = 0.5 * (inL - inR);

  push_m_lp15 += (M - push_m_lp15) * push_lp15_c;
  push_m_lp32 += (M - push_m_lp32) * push_lp32_c;
  push_m_lp55 += (M - push_m_lp55) * push_lp55_c;
  push_s_lp15 += (S - push_s_lp15) * push_lp15_c;
  push_s_lp32 += (S - push_s_lp32) * push_lp32_c;
  push_s_lp55 += (S - push_s_lp55) * push_lp55_c;

  M_body = push_m_lp15;
  M_form = push_m_lp32 - push_m_lp15;
  M_edge = push_m_lp55 - push_m_lp32;
  M_air  = M - push_m_lp55;

  S_body = push_s_lp15;
  S_form = push_s_lp32 - push_s_lp15;
  S_edge = push_s_lp55 - push_s_lp32;
  S_air  = S - push_s_lp55;

  body_inst = M_body*M_body + S_body*S_body;
  form_inst = M_form*M_form + S_form*S_form;
  edge_inst = M_edge*M_edge + S_edge*S_edge;
  air_inst  = M_air*M_air   + S_air*S_air;
  src_inst  = 0.5 * (inL*inL + inR*inR);

  M_hi = M_edge + M_air;
  S_hi = S_edge + S_air;

  push_bodyE += push_a_lev * (body_inst - push_bodyE);
  push_formE += push_a_lev * (form_inst - push_formE);
  push_edgeE += push_a_lev * (edge_inst - push_edgeE);
  push_airE  += push_a_lev * (air_inst  - push_airE);
  push_srcE  += push_a_src * (src_inst  - push_srcE);
  push_m_hiE += push_a_lev * (M_hi*M_hi - push_m_hiE);
  push_s_hiE += push_a_lev * (S_hi*S_hi - push_s_hiE);

  push_click_fastE += push_a_fast * ((edge_inst + 0.62*air_inst) - push_click_fastE);
  push_click_slowE += push_a_slow * ((edge_inst + 0.62*air_inst) - push_click_slowE);

  push_hot_dB = 10 * log((0.35*push_formE + 1.00*push_edgeE + 1.18*push_airE + PUSH_EPS) / (push_bodyE + 0.55*push_formE + PUSH_EPS)) * LOG10_INV;
  push_click_dB = 10 * log((push_click_fastE + PUSH_EPS) / (push_click_slowE + PUSH_EPS)) * LOG10_INV;
  push_side_rel_dB = 10 * log((push_s_hiE + PUSH_EPS) / (push_m_hiE + PUSH_EPS)) * LOG10_INV;
  src_dB = 10 * log(push_srcE + PUSH_EPS) * LOG10_INV;

  src_w = clamp01((src_dB + 72) / 20);

  self_allow  = -5.0 - 6.5 * push_amt + 4.0 * push_preserve - 1.5;
  trans_allow = clamp(6.5 - 3.2 * push_amt + 2.0 * push_preserve + 0.7, 1.0, 10.0);
  side_allow  = clamp(3.0 - 2.0 * push_amt + 3.0 * push_preserve - 2.3, -3.0, 8.0);

  ex_self = max(0, push_hot_dB - self_allow);
  ex_trans = max(0, push_click_dB - trans_allow);
  ex_side = max(0, push_side_rel_dB - side_allow);

  level_want = src_w * ex_self * (0.18 + 0.92 * push_amt);
  common_want = level_want + src_w * ex_trans * push_trans_w;
  common_want = min(common_want, push_max_common_dB);

  side_want = src_w * ex_side * push_side_w;
  side_want = min(side_want, push_max_side_dB);

  // Keep hit identity, but do not let attacks punch all the way forward at high Push.
  head_damp = clamp01(transient_guard_s * (0.38 - 0.18 * push_amt));
  common_want *= 1 - head_damp;
  side_want *= 1 - head_damp * 0.55;

  cC = common_want > push_common_dB ? push_common_att_coeff : push_common_rel_coeff;
  push_common_dB += (common_want - push_common_dB) * cC;

  cS = side_want > push_side_dB ? push_side_att_coeff : push_side_rel_coeff;
  push_side_dB += (side_want - push_side_dB) * cS;

  formW = clamp((0.50 - 0.24 * push_preserve), 0.12, 0.80);
  edgeW = clamp((0.98 - 0.10 * push_preserve), 0.68, 1.18);
  airW  = clamp((1.20 - 0.34 * push_preserve), 0.54, 1.36);
  broadW = clamp(0.05 + 0.22 * push_amt * (1 - 0.35 * push_preserve), 0, 0.30);

  g_form = db2amp(-(push_common_dB * formW));
  g_edge = db2amp(-(push_common_dB * edgeW));
  g_air  = db2amp(-(push_common_dB * airW));
  g_side = db2amp(-push_side_dB);
  broad_dB = push_common_dB * broadW + push_broad_static_dB * src_w;
  g_broad = db2amp(-broad_dB);

  M_form *= g_form;  S_form *= g_form;
  M_edge *= g_edge;  S_edge *= g_edge * g_side;
  M_air  *= g_air;   S_air  *= g_air  * g_side;

  M = M_body + M_form + M_edge + M_air;
  S = S_body + S_form + S_edge + S_air;

  outL = (M + S) * g_broad;
  outR = (M - S) * g_broad;
);



function formant_env_lookup(idx)
(
  idx <= 0 ? form_env0
  : idx == 1 ? form_env1
  : idx == 2 ? form_env2
  : idx == 3 ? form_env3
  : idx == 4 ? form_env4
  : form_env5;
);

function formant_env_at(x) local(i t a b)
(
  x = clamp(x, 0, 5);
  i = floor(x);
  t = x - i;
  a = formant_env_lookup(i);
  b = formant_env_lookup(min(5, i + 1));
  lerp(a, b, t);
);

function formant_gain_from_ratio(cur target depth band_depth) local(r g d)
(
  d = clamp01(depth * band_depth);
  r = clamp((target + 0.000000000001) / (cur + 0.000000000001), 0.12, 8.50);
  // v18: v17 used a 0.50 exponent and was too polite. This is still bounded,
  // but the envelope move is now strong enough to A/B at +/-12.
  g = exp(log(r) * 0.92 * d);
  clamp(g, db2amp(-15.0 * d), db2amp(13.0 * d));
);

function apply_formant_shift() local(
  inL inR
  b0l b1l b2l b3l b4l b5l b0r b1r b2r b3r b4r b5r
  e0 e1 e2 e3 e4 e5
  amt protect shift wetL wetR dryE wetE level target0 target1 target2 target3 target4 target5
  g0 g1 g2 g3 g4 g5 coeff fs drive_db bump wetmix
)
(
  // v18 FormantDrive: audible transient-safe spectral-envelope warp.
  // This is deliberately not LPC/voice-only. It shifts the perceived resonance
  // envelope with a cheap log-spaced band model and bypasses hard attacks.
  inL = outL;
  inR = outR;

  form_lp1_l = denorm_zap(form_lp1_l + (inL - form_lp1_l) * form_lp_c1);
  form_lp2_l = denorm_zap(form_lp2_l + (inL - form_lp2_l) * form_lp_c2);
  form_lp3_l = denorm_zap(form_lp3_l + (inL - form_lp3_l) * form_lp_c3);
  form_lp4_l = denorm_zap(form_lp4_l + (inL - form_lp4_l) * form_lp_c4);
  form_lp5_l = denorm_zap(form_lp5_l + (inL - form_lp5_l) * form_lp_c5);

  form_lp1_r = denorm_zap(form_lp1_r + (inR - form_lp1_r) * form_lp_c1);
  form_lp2_r = denorm_zap(form_lp2_r + (inR - form_lp2_r) * form_lp_c2);
  form_lp3_r = denorm_zap(form_lp3_r + (inR - form_lp3_r) * form_lp_c3);
  form_lp4_r = denorm_zap(form_lp4_r + (inR - form_lp4_r) * form_lp_c4);
  form_lp5_r = denorm_zap(form_lp5_r + (inR - form_lp5_r) * form_lp_c5);

  b0l = form_lp1_l;
  b1l = form_lp2_l - form_lp1_l;
  b2l = form_lp3_l - form_lp2_l;
  b3l = form_lp4_l - form_lp3_l;
  b4l = form_lp5_l - form_lp4_l;
  b5l = inL - form_lp5_l;

  b0r = form_lp1_r;
  b1r = form_lp2_r - form_lp1_r;
  b2r = form_lp3_r - form_lp2_r;
  b3r = form_lp4_r - form_lp3_r;
  b4r = form_lp5_r - form_lp4_r;
  b5r = inR - form_lp5_r;

  e0 = b0l*b0l + b0r*b0r;
  e1 = b1l*b1l + b1r*b1r;
  e2 = b2l*b2l + b2r*b2r;
  e3 = b3l*b3l + b3r*b3r;
  e4 = b4l*b4l + b4r*b4r;
  e5 = b5l*b5l + b5r*b5r;

  form_env0 = denorm_zap(form_env0 + (e0 - form_env0) * (e0 > form_env0 ? form_env_att_coeff : form_env_rel_coeff));
  form_env1 = denorm_zap(form_env1 + (e1 - form_env1) * (e1 > form_env1 ? form_env_att_coeff : form_env_rel_coeff));
  form_env2 = denorm_zap(form_env2 + (e2 - form_env2) * (e2 > form_env2 ? form_env_att_coeff : form_env_rel_coeff));
  form_env3 = denorm_zap(form_env3 + (e3 - form_env3) * (e3 > form_env3 ? form_env_att_coeff : form_env_rel_coeff));
  form_env4 = denorm_zap(form_env4 + (e4 - form_env4) * (e4 > form_env4 ? form_env_att_coeff : form_env_rel_coeff));
  form_env5 = denorm_zap(form_env5 + (e5 - form_env5) * (e5 > form_env5 ? form_env_att_coeff : form_env_rel_coeff));

  amt = clamp01(abs(formant_shift_semi) / 12);
  // v17 often vanished on short/transient-heavy sources because protection could
  // zero the whole effect. v18 protects the head, but never fully mutes max shift.
  protect = clamp01(transient_guard_s * (0.42 + 0.10 * trans_mode_mix) + clean_head_bus * 0.08 + room_head_bus * 0.06);
  amt *= (1 - protect * 0.72);

  amt > 0.0001 ? (
    // +/-12 now spans roughly half the six-band envelope, not barely one band.
    shift = (formant_shift_semi / 12) * 2.70;

    // Positive formant shift means the envelope moves upward: each high band
    // borrows the energy expectation that used to live lower on the log axis.
    target0 = formant_env_at(0 - shift);
    target1 = formant_env_at(1 - shift);
    target2 = formant_env_at(2 - shift);
    target3 = formant_env_at(3 - shift);
    target4 = formant_env_at(4 - shift);
    target5 = formant_env_at(5 - shift);

    g0 = formant_gain_from_ratio(form_env0, target0, amt, 0.72);
    g1 = formant_gain_from_ratio(form_env1, target1, amt, 1.00);
    g2 = formant_gain_from_ratio(form_env2, target2, amt, 1.12);
    g3 = formant_gain_from_ratio(form_env3, target3, amt, 1.12);
    g4 = formant_gain_from_ratio(form_env4, target4, amt, 1.00);
    g5 = formant_gain_from_ratio(form_env5, target5, amt, 0.78);

    // Static resonance-drive fallback: if the live envelope is flat/noisy, a pure
    // ratio warp can do almost nothing. This makes +/-12 unmistakable without a
    // full extra Color knob; it is shaped like body/mouth size, not a simple tilt.
    fs = clamp(formant_shift_semi / 12, -1, 1);
    drive_db = fs * (4.0 + 8.0 * amt);
    g0 *= db2amp(-0.92 * drive_db);
    g1 *= db2amp(-0.58 * drive_db);
    g2 *= db2amp(-0.12 * drive_db);
    g3 *= db2amp( 0.34 * drive_db);
    g4 *= db2amp( 0.70 * drive_db);
    g5 *= db2amp( 0.82 * drive_db);

    bump = abs(fs) * (1.8 + 4.2 * amt);
    fs >= 0 ? (
      g3 *= db2amp( bump * 0.65);
      g4 *= db2amp( bump * 0.52);
      g1 *= db2amp(-bump * 0.26);
    ) : (
      g1 *= db2amp( bump * 0.70);
      g2 *= db2amp( bump * 0.46);
      g4 *= db2amp(-bump * 0.30);
    );

    coeff = form_gain_coeff * (0.70 + 0.90 * amt);
    form_g0 += (g0 - form_g0) * coeff;
    form_g1 += (g1 - form_g1) * coeff;
    form_g2 += (g2 - form_g2) * coeff;
    form_g3 += (g3 - form_g3) * coeff;
    form_g4 += (g4 - form_g4) * coeff;
    form_g5 += (g5 - form_g5) * coeff;

    wetL = b0l * form_g0 + b1l * form_g1 + b2l * form_g2 + b3l * form_g3 + b4l * form_g4 + b5l * form_g5;
    wetR = b0r * form_g0 + b1r * form_g1 + b2r * form_g2 + b3r * form_g3 + b4r * form_g4 + b5r * form_g5;

    dryE = inL*inL + inR*inR + 0.000000000001;
    wetE = wetL*wetL + wetR*wetR + 0.000000000001;
    // Keep level sane, but do not normalize the audible formant contrast away.
    level = clamp(sqrt(dryE / wetE), 0.78, 1.22);
    form_level += (level - form_level) * form_level_coeff;
    abs(form_level - 1) < DENORM_CUT ? form_level = 1;
    wetL *= form_level;
    wetR *= form_level;

    wetmix = clamp01(0.20 + 0.80 * sqrt(amt));
    outL = lerp(inL, wetL, wetmix);
    outR = lerp(inR, wetR, wetmix);
  ) : (
    form_g0 += (1 - form_g0) * form_gain_coeff;
    form_g1 += (1 - form_g1) * form_gain_coeff;
    form_g2 += (1 - form_g2) * form_gain_coeff;
    form_g3 += (1 - form_g3) * form_gain_coeff;
    form_g4 += (1 - form_g4) * form_gain_coeff;
    form_g5 += (1 - form_g5) * form_gain_coeff;
    form_level += (1 - form_level) * form_level_coeff;
    abs(form_level - 1) < DENORM_CUT ? form_level = 1;
  );
);


function fpk_peakness(e center) local(p)
(
  // v32 Peak Pack Pro: high-threshold local-maximum detector for the narrow
  // resonance bank. Moderate settings stay sane; extremes become flattening or
  // resonant transformation.
  p = e <= 0.000000000001 ? 0 : max(0, e - center) / max(e + center * 0.22, 0.000000000001);
  clamp01((p * 3.15) ^ 0.82);
);


function fpk_band_freq(idx)
(
  idx == 0 ? 180
  : idx == 1 ? 280
  : idx == 2 ? 430
  : idx == 3 ? 660
  : idx == 4 ? 1000
  : idx == 5 ? 1550
  : idx == 6 ? 2400
  : idx == 7 ? 3700
  : idx == 8 ? 5900
  : idx == 9 ? 9200
  : idx == 10 ? 13500
  : 17500;
);

function fpk_bq_set_bandpass(slot freq q) local(base w0 sn cs alpha a0 b0 b1 b2 a1 a2)
(
  base = slot * FPK_BQ_STRIDE;
  freq = clamp(freq, 40, min(19000, srate * 0.49));
  q = clamp(q, 2.5, 32);
  w0 = 6.283185307179586 * freq / max(srate, 1);
  sn = sin(w0);
  cs = cos(w0);
  alpha = sn / max(0.000001, 2 * q);
  b0 = alpha;
  b1 = 0;
  b2 = -alpha;
  a0 = 1 + alpha;
  a1 = -2 * cs;
  a2 = 1 - alpha;
  fpk_bq_base[base + 0] = b0 / a0;
  fpk_bq_base[base + 1] = b1 / a0;
  fpk_bq_base[base + 2] = b2 / a0;
  fpk_bq_base[base + 3] = a1 / a0;
  fpk_bq_base[base + 4] = a2 / a0;
);

function fpk_bq_process_l(slot x) local(base y)
(
  base = slot * FPK_BQ_STRIDE;
  y = fpk_bq_base[base + 0] * x + fpk_bq_base[base + 5];
  fpk_bq_base[base + 5] = denorm_zap(fpk_bq_base[base + 1] * x - fpk_bq_base[base + 3] * y + fpk_bq_base[base + 6]);
  fpk_bq_base[base + 6] = denorm_zap(fpk_bq_base[base + 2] * x - fpk_bq_base[base + 4] * y);
  denorm_zap(y);
);

function fpk_bq_process_r(slot x) local(base y)
(
  base = slot * FPK_BQ_STRIDE;
  y = fpk_bq_base[base + 0] * x + fpk_bq_base[base + 7];
  fpk_bq_base[base + 7] = denorm_zap(fpk_bq_base[base + 1] * x - fpk_bq_base[base + 3] * y + fpk_bq_base[base + 8]);
  fpk_bq_base[base + 8] = denorm_zap(fpk_bq_base[base + 2] * x - fpk_bq_base[base + 4] * y);
  denorm_zap(y);
);

function fpk_update_coeffs() local(i freq q)
(
  i = 0;
  while (i < FPK_BANDS) (
    freq = fpk_band_freq(i);
    q = clamp(5.5 + i * 1.65, 4.8, 24);
    fpk_bq_set_bandpass(i, freq, q);
    i += 1;
  );
);

function apply_focus_peak_pack() local(
  inL inR i bl br e env avgE maxE neigh pk thresh active depth sign protect sane extreme coeff
  db g wetL wetR dryE wetE level wetmix sumActive
)
(
  // v32 Peak Pack Pro: sparse narrow-band peak processor. Negative values
  // suppress only standout resonances; positive values exaggerate them. This is
  // no longer broad Color/Focus behavior. It behaves closer to a dynamic bank of
  // tiny soothe/accent filters.
  inL = outL;
  inR = outR;
  depth = abs(clamp(focus_peak_amt, -1, 1));
  sign = focus_peak_amt >= 0 ? 1 : -1;

  denorm_near_silence(inL, inR) ? (
    reset_focus_peak_buffers();
    depth = 0;
  );

  protect = sign > 0 ? transient_guard_s * (0.30 + 0.10 * trans_mode_mix) : transient_guard_s * 0.02;
  depth *= 1 - clamp01(protect);

  depth > 0.0001 ? (
    sane = depth ^ 1.55;
    extreme = depth ^ 4.25;

    avgE = 0;
    maxE = 0;
    i = 0;
    while (i < FPK_BANDS) (
      bl = fpk_bq_process_l(i, inL);
      br = fpk_bq_process_r(i, inR);
      fpk_band_l_base[i] = bl;
      fpk_band_r_base[i] = br;
      e = bl*bl + br*br;
      env = fpk_env_base[i];
      env += (e - env) * (e > env ? fpk_env_att_coeff : fpk_env_rel_coeff);
      fpk_env_base[i] = denorm_zap(env);
      avgE += env;
      maxE = max(maxE, env);
      i += 1;
    );
    avgE = avgE / max(1, FPK_BANDS) + 0.000000000001;

    wetL = inL;
    wetR = inR;
    sumActive = 0;
    thresh = lerp(0.88, 0.58, extreme) - sane * 0.05;

    i = 0;
    while (i < FPK_BANDS) (
      env = fpk_env_base[i];
      neigh = 0;
      i > 0 ? neigh += fpk_env_base[i - 1] : neigh += avgE;
      i < FPK_BANDS - 1 ? neigh += fpk_env_base[i + 1] : neigh += avgE;
      neigh *= 0.5;

      pk = fpk_peakness(env, max(neigh * 1.32, avgE * 1.70));
      pk *= clamp01((env - avgE * 1.18) / max(env + avgE * 0.22, 0.000000000001));
      active = clamp01((pk - thresh) / max(0.0001, 1 - thresh));
      active = active ^ 1.48;
      sumActive += active;

      sign < 0 ? (
        db = -(sane * (3.0 + 18.0 * active) + extreme * (12.0 + 46.0 * active)) * active;
        db = clamp(db, -54, 0);
      ) : (
        db = (sane * (2.0 + 12.0 * active) + extreme * (6.0 + 34.0 * active)) * active;
        db = clamp(db, 0, 32);
      );

      coeff = fpk_gain_coeff * (0.82 + 1.20 * sane + 1.30 * extreme);
      fpk_gain_base[i] = denorm_zap(fpk_gain_base[i] + (db - fpk_gain_base[i]) * coeff);
      g = db2amp(fpk_gain_base[i]) - 1;
      wetL += fpk_band_l_base[i] * g;
      wetR += fpk_band_r_base[i] * g;
      i += 1;
    );

    dryE = inL*inL + inR*inR + 0.000000000001;
    wetE = wetL*wetL + wetR*wetR + 0.000000000001;
    level = sign > 0 ? clamp(sqrt(dryE / wetE), 0.40, 1.06) : clamp(sqrt(dryE / wetE), 0.58, 1.18);
    level = lerp(1, level, sign > 0 ? 0.72 : 0.52);
    fpk_level = denorm_zap(fpk_level + (level - fpk_level) * fpk_level_coeff);
    wetL *= fpk_level;
    wetR *= fpk_level;

    wetmix = clamp01(0.18 + 0.58 * sqrt(depth) + 0.22 * extreme);
    outL = lerp(inL, wetL, wetmix);
    outR = lerp(inR, wetR, wetmix);
  ) : (
    i = 0;
    while (i < FPK_BANDS) (
      fpk_gain_base[i] = denorm_zap(fpk_gain_base[i] + (0 - fpk_gain_base[i]) * fpk_gain_coeff);
      i += 1;
    );
    fpk_level = denorm_zap(fpk_level + (1 - fpk_level) * fpk_level_coeff);
  );
);

function reset_dynamics_expand_buffers()
(
  dynx_fast = 0;
  dynx_slow = 0;
  dynx_gain = 1;
  dynx_lim_gain = 1;
);

function apply_dynamics_expand() local(
  inL inR depth sane extreme det ratio low crest down_db up_db target_db target_gain
  coeff wetmix wetL wetR post lim_tgt protect gate_floor side mid side_boost body_keep
)
(
  // v41 DynExpand: hidden Shift+Dynamics processor. It is the useful opposite
  // of density compression: low-level bed gets pushed down, attacks and clear
  // crests can step forward. It is intentionally broad-band and transient-aware
  // so it behaves like a fast sound-design contrast macro, not a gate plugin.
  inL = outL;
  inR = outR;
  depth = clamp01(dynamics_expand_amt);

  denorm_near_silence(inL, inR) ? (
    reset_dynamics_expand_buffers();
    depth = 0;
  );

  depth > 0.0001 ? (
    sane = depth ^ 1.38;
    extreme = depth ^ 3.70;

    det = max(abs(inL), abs(inR));
    dynx_fast = denorm_zap(dynx_fast + (det - dynx_fast) * (det > dynx_fast ? dynx_fast_att_coeff : dynx_fast_rel_coeff));
    dynx_slow = denorm_zap(dynx_slow + (det - dynx_slow) * (det > dynx_slow ? dynx_slow_att_coeff : dynx_slow_rel_coeff));

    ratio = dynx_fast / max(dynx_slow, 0.00000001);

    // Downward expansion: remove low-level/sustained bed, but do not chop heads.
    low = clamp01(((0.94 - 0.10 * extreme) - ratio) / (0.70 - 0.18 * extreme));
    gate_floor = clamp01((dynx_slow - 0.000030) / 0.0060);
    low *= gate_floor;
    protect = clamp01(transient_guard_s * (0.72 + 0.18 * trans_mode_mix));
    low *= 1 - protect;

    // Upward expansion: accent actual crests. Extreme values make it obvious.
    crest = clamp01((ratio - (1.10 - 0.16 * extreme)) / (0.88 - 0.24 * extreme));
    crest = crest ^ lerp(1.55, 0.82, extreme);

    down_db = -(sane * (1.8 + 8.0 * low) + extreme * (7.5 + 26.0 * low)) * low;
    up_db   =  (sane * (1.2 + 5.4 * crest) + extreme * (3.5 + 14.0 * crest)) * crest;

    target_db = clamp(down_db + up_db, -36, 16);
    target_gain = db2amp(target_db);
    coeff = target_gain > dynx_gain ? dynx_gain_up_coeff : dynx_gain_down_coeff;
    dynx_gain = denorm_zap(dynx_gain + (target_gain - dynx_gain) * coeff);

    wetL = inL * dynx_gain;
    wetR = inR * dynx_gain;

    // Expansion can also separate width subtly: crests get a little wider, beds
    // get a little narrower. This keeps it sound-design useful without a panel.
    mid = 0.5 * (wetL + wetR);
    side = 0.5 * (wetL - wetR);
    side_boost = 1 + crest * (0.05 + 0.16 * sane + 0.12 * extreme) - low * (0.06 + 0.20 * sane);
    side_boost = clamp(side_boost, 0.62, 1.32);
    wetL = mid + side * side_boost;
    wetR = mid - side * side_boost;

    wetmix = clamp01(0.20 + 0.58 * sqrt(depth) + 0.18 * extreme);
    outL = lerp(inL, wetL, wetmix);
    outR = lerp(inR, wetR, wetmix);

    // Fail-safe limiter only catches expansion overs. It should be transparent
    // unless the hidden knob is pushed hard.
    post = max(abs(outL), abs(outR));
    lim_tgt = post > 1.02 ? 1.02 / post : 1;
    dynx_lim_gain = denorm_zap(dynx_lim_gain + (lim_tgt - dynx_lim_gain) * (lim_tgt < dynx_lim_gain ? dyn_lim_att_coeff : dyn_lim_rel_coeff));
    outL *= dynx_lim_gain;
    outR *= dynx_lim_gain;
  ) : (
    dynx_fast = denorm_zap(dynx_fast + (0 - dynx_fast) * dynx_fast_rel_coeff);
    dynx_slow = denorm_zap(dynx_slow + (0 - dynx_slow) * dynx_slow_rel_coeff);
    dynx_gain = denorm_zap(dynx_gain + (1 - dynx_gain) * dynx_gain_down_coeff);
    dynx_lim_gain = denorm_zap(dynx_lim_gain + (1 - dynx_lim_gain) * dyn_lim_rel_coeff);
  );
);



function reset_input_trigger_buffers()
(
  input_trig_fast = 0;
  input_trig_slow = 0;
  input_trig_floor = 0;
  input_trig_env = 0;
  input_trig_gate = 0;
  input_trig_silence = 0;
  input_trig_cooldown = 0;
  input_trig_norm = 0;
  input_trigger_was_armed = 0;
);


function group_hash_current_name() local(i n c h)
(
  // Cheap deterministic hash for track-name grouping. Kept numeric for gmem.
  // JSFX/EEL2 does not allow #string parameters in normal function arg lists,
  // so this hashes the global #group_name string directly.
  h = 5381;
  n = strlen(#group_name);
  i = 0;
  while (i < n) (
    c = str_getchar(#group_name, i);
    h = (h * 33 + c + 17) % 2147483647;
    i += 1;
  );
  h <= 0 ? h = 1;
  h;
);

function group_peer_base(idx)
(
  GROUP_PEER_BASE + idx * GROUP_PEER_STRIDE;
);

function group_init_memory() local(i b)
(
  (gmem[GROUP_MAGIC_SLOT] != GROUP_MAGIC_VALUE) ? (
    i = 0;
    while (i < GROUP_PEER_BASE + GROUP_MAX_PEERS * GROUP_PEER_STRIDE + 8) (
      gmem[i] = 0;
      i += 1;
    );
    gmem[GROUP_MAGIC_SLOT] = GROUP_MAGIC_VALUE;
    gmem[GROUP_COUNTER_SLOT] = 0;
    gmem[GROUP_CLOCK_SLOT] = 1;
    gmem[GROUP_EVENT_SLOT] = 1;
  );

  group_instance_id <= 0 ? (
    gmem[GROUP_COUNTER_SLOT] = max(gmem[GROUP_COUNTER_SLOT], 0) + 1;
    group_instance_id = gmem[GROUP_COUNTER_SLOT] | 0;
    group_instance_id <= 0 ? group_instance_id = floor(100000 + rand(1) * 900000);
  );
);

function group_poll_track_name(force) local(seq ok)
(
  seq = track_name_seq();
  (force || seq != group_track_seq || group_name_hash <= 0) ? (
    group_track_seq = seq;
    ok = track_name(#group_name);
    (ok <= 0 || strlen(#group_name) <= 0) ? sprintf(#group_name, "Sample");
    group_name_hash = group_hash_current_name();
    group_my_slot = -1;
  );
);

function group_find_slot_by_id(id) local(i b found)
(
  found = -1;
  i = 0;
  while (i < GROUP_MAX_PEERS && found < 0) (
    b = group_peer_base(i);
    (gmem[b + GROUP_F_ID] == id) ? found = i;
    i += 1;
  );
  found;
);

function group_find_free_slot() local(i b found oldest_idx oldest_clk clk)
(
  found = -1;
  oldest_idx = 0;
  oldest_clk = 1000000000000;
  clk = gmem[GROUP_CLOCK_SLOT];
  i = 0;
  while (i < GROUP_MAX_PEERS && found < 0) (
    b = group_peer_base(i);
    (gmem[b + GROUP_F_ID] <= 0 || (clk - gmem[b + GROUP_F_HEART]) > GROUP_STALE_TICKS) ? (
      found = i;
    ) : (
      gmem[b + GROUP_F_HEART] < oldest_clk ? (
        oldest_clk = gmem[b + GROUP_F_HEART];
        oldest_idx = i;
      );
    );
    i += 1;
  );
  found < 0 ? oldest_idx : found;
);

function group_ensure_slot() local(idx b)
(
  group_init_memory();
  group_poll_track_name(0);
  idx = group_find_slot_by_id(group_instance_id);
  idx < 0 ? idx = group_find_free_slot();
  group_my_slot = idx;
  b = group_peer_base(idx);
  gmem[b + GROUP_F_ID] = group_instance_id;
  gmem[b + GROUP_F_HASH] = group_name_hash;
  // Do not overwrite rank/mode command here; those are the shared order table.
  idx;
);

function group_write_heartbeat(active strength) local(idx b clk)
(
  group_enabled > 0 ? (
    idx = group_ensure_slot();
    b = group_peer_base(idx);
    clk = gmem[GROUP_CLOCK_SLOT] + 1;
    gmem[GROUP_CLOCK_SLOT] = clk;
    gmem[b + GROUP_F_ID] = group_instance_id;
    gmem[b + GROUP_F_HASH] = group_name_hash;
    gmem[b + GROUP_F_HEART] = clk;
    gmem[b + GROUP_F_ACTIVE] = active ? 1 : 0;
    gmem[b + GROUP_F_STRENGTH] = clamp01(strength);
    gmem[b + GROUP_F_TRACKSEQ] = group_track_seq;
  );
);

function group_refresh_state() local(i b clk id hash heart rank mode active peers leader strict)
(
  group_init_memory();
  group_poll_track_name(0);
  clk = gmem[GROUP_CLOCK_SLOT];
  peers = 0;
  leader = 0;
  strict = 0;
  group_my_rank = 0;
  group_my_mode = 0;

  i = 0;
  while (i < GROUP_MAX_PEERS) (
    b = group_peer_base(i);
    id = gmem[b + GROUP_F_ID] | 0;
    hash = gmem[b + GROUP_F_HASH] | 0;
    heart = gmem[b + GROUP_F_HEART];
    (id > 0 && hash == group_name_hash && (clk - heart) <= GROUP_STALE_TICKS) ? (
      peers += 1;
      (leader <= 0 || id < leader) ? leader = id;
      mode = gmem[b + GROUP_F_MODE] | 0;
      mode > 0 ? strict = 1;
      id == group_instance_id ? (
        group_my_rank = max(0, gmem[b + GROUP_F_RANK] | 0);
        group_my_mode = mode;
      );
    );
    i += 1;
  );

  group_peer_count = peers;
  group_leader_id = leader;
  group_is_leader = (leader == group_instance_id && leader > 0) ? 1 : 0;
  group_strict_active = strict;
);

function group_set_mode_for_group(mode) local(i b clk id hash heart)
(
  group_ensure_slot();
  clk = gmem[GROUP_CLOCK_SLOT];
  i = 0;
  while (i < GROUP_MAX_PEERS) (
    b = group_peer_base(i);
    id = gmem[b + GROUP_F_ID] | 0;
    hash = gmem[b + GROUP_F_HASH] | 0;
    heart = gmem[b + GROUP_F_HEART];
    (id > 0 && hash == group_name_hash && (clk - heart) <= GROUP_STALE_TICKS) ? (
      gmem[b + GROUP_F_MODE] = mode ? 1 : 0;
    );
    i += 1;
  );
  group_refresh_state();
);

function group_set_rank_for_id(id rank) local(i b clk hash heart)
(
  group_ensure_slot();
  clk = gmem[GROUP_CLOCK_SLOT];
  i = 0;
  while (i < GROUP_MAX_PEERS) (
    b = group_peer_base(i);
    (gmem[b + GROUP_F_ID] == id && gmem[b + GROUP_F_HASH] == group_name_hash && (clk - gmem[b + GROUP_F_HEART]) <= GROUP_STALE_TICKS) ? (
      gmem[b + GROUP_F_RANK] = clamp(rank | 0, 0, GROUP_MAX_RANK);
      rank > 0 ? gmem[b + GROUP_F_MODE] = 1;
    );
    i += 1;
  );
  group_refresh_state();
);

function group_report_onset(strength) local(idx b ev)
(
  group_enabled > 0 ? (
    idx = group_ensure_slot();
    b = group_peer_base(idx);
    ev = gmem[GROUP_EVENT_SLOT] + 1;
    gmem[GROUP_EVENT_SLOT] = ev;
    gmem[b + GROUP_F_ONSET] = ev;
    gmem[b + GROUP_F_STRENGTH] = clamp01(strength);
    gmem[b + GROUP_F_ACTIVE] = 1;
    group_last_onset_event = ev;
  );
);

function group_can_input_fire(env_amt) local(
  clk ev i b id hash heart rank lower_exists lower_fired lower_onset myrank timeout_samps
)
(
  group_enabled <= 0 ? 1 : (
    group_refresh_state();
    (group_strict_active <= 0 || group_my_rank <= 1) ? (
      1;
    ) : (
      myrank = group_my_rank;
      ev = gmem[GROUP_EVENT_SLOT];
      input_trig_wait <= 0 ? input_trig_wait_event = ev;
      lower_exists = 0;
      lower_fired = 0;
      clk = gmem[GROUP_CLOCK_SLOT];
      i = 0;
      while (i < GROUP_MAX_PEERS) (
        b = group_peer_base(i);
        id = gmem[b + GROUP_F_ID] | 0;
        hash = gmem[b + GROUP_F_HASH] | 0;
        heart = gmem[b + GROUP_F_HEART];
        (id > 0 && id != group_instance_id && hash == group_name_hash && (clk - heart) <= GROUP_STALE_TICKS) ? (
          rank = gmem[b + GROUP_F_RANK] | 0;
          (rank > 0 && rank < myrank) ? (
            lower_exists = 1;
            lower_onset = gmem[b + GROUP_F_ONSET];
            (lower_onset > input_trig_wait_event || (ev - lower_onset) <= GROUP_RECENT_EVENT_WINDOW) ? lower_fired = 1;
          );
        );
        i += 1;
      );
      timeout_samps = max(64, floor(srate * GROUP_WAIT_TIMEOUT_SEC));
      (!lower_exists || lower_fired || input_trig_wait >= timeout_samps) ? 1 : 0;
    );
  );
);

function denorm_flush_scalar_states()
(
  mix_fast = denorm_zap(mix_fast);
  mix_slow = denorm_zap(mix_slow);
  transient_guard_s = denorm_zap(transient_guard_s);
  tone_lp_l = denorm_zap(tone_lp_l); tone_lp_r = denorm_zap(tone_lp_r);
  focus_lp_l = denorm_zap(focus_lp_l); focus_lp_r = denorm_zap(focus_lp_r);
  dyn_env = denorm_zap(dyn_env);
  dynx_fast = denorm_zap(dynx_fast); dynx_slow = denorm_zap(dynx_slow); dynx_gain = denorm_zap(dynx_gain); dynx_lim_gain = denorm_zap(dynx_lim_gain);
  input_trig_fast = denorm_zap(input_trig_fast); input_trig_slow = denorm_zap(input_trig_slow); input_trig_floor = denorm_zap(input_trig_floor); input_trig_env = denorm_zap(input_trig_env);

  clean_lp1_l = denorm_zap(clean_lp1_l); clean_lp2_l = denorm_zap(clean_lp2_l); clean_lp3_l = denorm_zap(clean_lp3_l); clean_lp4_l = denorm_zap(clean_lp4_l);
  clean_lp1_r = denorm_zap(clean_lp1_r); clean_lp2_r = denorm_zap(clean_lp2_r); clean_lp3_r = denorm_zap(clean_lp3_r); clean_lp4_r = denorm_zap(clean_lp4_r);

  room_lp1_l = denorm_zap(room_lp1_l); room_lp2_l = denorm_zap(room_lp2_l); room_lp3_l = denorm_zap(room_lp3_l); room_lp4_l = denorm_zap(room_lp4_l);
  room_lp1_r = denorm_zap(room_lp1_r); room_lp2_r = denorm_zap(room_lp2_r); room_lp3_r = denorm_zap(room_lp3_r); room_lp4_r = denorm_zap(room_lp4_r);
  room_fast_env = denorm_zap(room_fast_env); room_slow_env = denorm_zap(room_slow_env);
  room_late_s = denorm_zap(room_late_s); room_diffuse_s = denorm_zap(room_diffuse_s); room_side_g = denorm_zap(room_side_g);
  room_b0_fast = denorm_zap(room_b0_fast); room_b1_fast = denorm_zap(room_b1_fast); room_b2_fast = denorm_zap(room_b2_fast); room_b3_fast = denorm_zap(room_b3_fast); room_b4_fast = denorm_zap(room_b4_fast);
  room_b0_slow = denorm_zap(room_b0_slow); room_b1_slow = denorm_zap(room_b1_slow); room_b2_slow = denorm_zap(room_b2_slow); room_b3_slow = denorm_zap(room_b3_slow); room_b4_slow = denorm_zap(room_b4_slow);

  form_lp1_l = denorm_zap(form_lp1_l); form_lp2_l = denorm_zap(form_lp2_l); form_lp3_l = denorm_zap(form_lp3_l); form_lp4_l = denorm_zap(form_lp4_l); form_lp5_l = denorm_zap(form_lp5_l);
  form_lp1_r = denorm_zap(form_lp1_r); form_lp2_r = denorm_zap(form_lp2_r); form_lp3_r = denorm_zap(form_lp3_r); form_lp4_r = denorm_zap(form_lp4_r); form_lp5_r = denorm_zap(form_lp5_r);
  form_env0 = denorm_zap(form_env0); form_env1 = denorm_zap(form_env1); form_env2 = denorm_zap(form_env2); form_env3 = denorm_zap(form_env3); form_env4 = denorm_zap(form_env4); form_env5 = denorm_zap(form_env5);

  push_m_lp15 = denorm_zap(push_m_lp15); push_m_lp32 = denorm_zap(push_m_lp32); push_m_lp55 = denorm_zap(push_m_lp55);
  push_s_lp15 = denorm_zap(push_s_lp15); push_s_lp32 = denorm_zap(push_s_lp32); push_s_lp55 = denorm_zap(push_s_lp55);
  push_bodyE = denorm_zap(push_bodyE); push_formE = denorm_zap(push_formE); push_edgeE = denorm_zap(push_edgeE); push_airE = denorm_zap(push_airE); push_srcE = denorm_zap(push_srcE);
  push_m_hiE = denorm_zap(push_m_hiE); push_s_hiE = denorm_zap(push_s_hiE); push_click_fastE = denorm_zap(push_click_fastE); push_click_slowE = denorm_zap(push_click_slowE);
);

function denorm_flush_silent_tail_state()
(
  reset_weight_buffers();
  reset_clean_buffers();
  reset_room_buffers();
  reset_push_buffers();
  reset_formant_buffers();
  reset_focus_peak_buffers();
  reset_dynamics_expand_buffers();
  reset_input_trigger_buffers();
  reset_processing_buffers();
  posteq_update_coeffs();
  fpk_update_coeffs();
  mix_fast = 0;
  mix_slow = 0;
  tone_lp_l = 0; tone_lp_r = 0;
  focus_lp_l = 0; focus_lp_r = 0;
  transient_guard_s = 0;
  dyn_env = 0;
  reset_dynamics_expand_buffers();
  reset_input_trigger_buffers();
);

function reset_bank_state() local(i)
(
  sample_count = 0;
  bank_selected_count = 0;
  bank_scan_count = 0;
  bank_skipped_count = 0;
  bank_cap_limited = 0;
  bank_memory_limited = 0;
  bank_pool_capacity = sample_pool_capacity;
  bank_pitchiness = 0;
  bank_brightness = 0;
  bank_brightness_spread = 0;
  bank_brightness_reliability = 0;
  bank_color_extreme = 0;
  bank_sharpness = 0;
  bank_sharpness_spread = 0;
  bank_sharpness_reliability = 0;
  bank_focus_extreme = 0;
  corpus_count = 0;
  corpus_best_idx = -1;
  corpus_best_sid = -1;
  next_audio = AUDIO_BASE;
  seq_cursor = 0;
  walk_last_sid = -1;
  walk_prev_sid = -1;
  walk_steps = 0;
  last_sid = -1;
  last_note = -1;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] = -1;
    i += 1;
  );
  reset_grain_histories();
  reset_voices();
  reset_note_gates();
  reset_weight_buffers();
  reset_clean_buffers();
  reset_room_buffers();
  reset_push_buffers();
  reset_formant_buffers();
  reset_focus_peak_buffers();
  reset_input_trigger_buffers();
  reset_processing_buffers();
  init_flow_model();
  corpus_dirty = 1;
  posteq_pre_silent = 0;
  posteq_post_silent = 0;
  posteq_filter_silent = 0;
  denorm_silence_samps = 0;
  denorm_flush_counter = 0;
  transient_guard_s = 0;
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
);

function load_one_pool_sample(sample_index) local(
  sid nch sr frames sm
)
(
  sid = sample_get(bank_pool, sample_index);
  sid > 0 && sample_count < sample_pool_capacity ? (
    nch = max(1, sample_channels(bank_pool, sid) | 0);
    sr = sample_srate(bank_pool, sid);
    frames = sample_len(bank_pool, sid) | 0;

    (nch > 0 && sr > 1000 && frames > 1) ? (
      sm = sample_meta_base + sample_count * SM_STRIDE;
      sm[SM_PTR]      = sid;
      sm[SM_NCH]      = nch;
      sm[SM_SR]       = sr;
      sm[SM_FRAMES]   = frames;
      sm[SM_LASTUSED] = -1000000;
      sm[SM_PEAK]     = sample_peak(bank_pool, sid);
      sm[SM_RMS]      = sample_rms(bank_pool, sid);
      analyze_sample(sm);
      sample_count += 1;
    );
  );
);

function refresh_bank_stats() local(
  i sm spread_step spread_root pitch_sum bright_sum bright2_sum sharp_sum sharp2_sum bright_mean bright_var sharp_mean sharp_var
)
(
  bank_pitchiness = 0;
  bank_brightness = 0;
  bank_brightness_spread = 0;
  bank_brightness_reliability = 0;
  bank_color_extreme = 0;
  bank_sharpness = 0;
  bank_sharpness_spread = 0;
  bank_sharpness_reliability = 0;
  bank_focus_extreme = 0;

  sample_count > 0 ? (
    spread_step = sample_count > 1 ? (ROOT_HIGH - ROOT_LOW) / (sample_count - 1) : 0;
    pitch_sum = 0;
    bright_sum = 0;
    bright2_sum = 0;
    sharp_sum = 0;
    sharp2_sum = 0;
    i = 0;
    while (i < sample_count) (
      sm = sample_meta_base + i * SM_STRIDE;
      spread_root = ROOT_LOW + i * spread_step;
      sm[SM_ROOT] = sm[SM_PITCHCONF] > 0.40 ? clamp(sm[SM_PITCHNOTE], 0, 127) : spread_root;
      update_sample_cluster(sm);
      pitch_sum += sm[SM_PITCHCONF];
      bright_sum += sm[SM_BRIGHT];
      bright2_sum += sm[SM_BRIGHT] * sm[SM_BRIGHT];
      sharp_sum += sm[SM_SHARP];
      sharp2_sum += sm[SM_SHARP] * sm[SM_SHARP];
      i += 1;
    );
    bank_pitchiness = clamp01(pitch_sum / sample_count);
    bright_mean = bright_sum / sample_count;
    bright_var = max(0, bright2_sum / sample_count - bright_mean * bright_mean);
    bank_brightness = clamp01(bright_mean);
    bank_brightness_spread = clamp(sqrt(bright_var), 0, 0.50);
    bank_brightness_reliability = clamp01(1 - bank_brightness_spread / 0.28);
    // Used by Color: extreme bright/dark banks get a stronger, more useful tilt.
    // Diverse banks get less automatic aggression because the average is less decisive.
    bank_color_extreme = clamp01(abs(bank_brightness - 0.50) / 0.32) * (0.55 + 0.45 * bank_brightness_reliability);

    sharp_mean = sharp_sum / sample_count;
    sharp_var = max(0, sharp2_sum / sample_count - sharp_mean * sharp_mean);
    bank_sharpness = clamp01(sharp_mean);
    bank_sharpness_spread = clamp(sqrt(sharp_var), 0, 0.50);
    bank_sharpness_reliability = clamp01(1 - bank_sharpness_spread / 0.30);
    // Used by Focus: sharp/dull banks get stronger corrective behavior,
    // but mixed banks avoid over-trusting the average.
    bank_focus_extreme = clamp01(abs(bank_sharpness - 0.50) / 0.32) * (0.55 + 0.45 * bank_sharpness_reliability);
  );

  sample_count > 0 ? (
    // v37 PerfGate: learned_flow_pick() is no longer called, so training the
    // tiny flow model was pure load-time overhead. The GrainCorpus is useful
    // only for Granular, so build it only when Granular is currently selected;
    // otherwise mark it dirty and build lazily on mode switch.
    init_flow_model();
    playback_mode == 3 ? (
      build_grain_corpus();
    ) : (
      corpus_count = 0;
      corpus_dirty = 1;
    );
  ) : (
    init_flow_model();
    corpus_count = 0;
    corpus_dirty = 0;
  );
  bank_loaded = sample_count > 0;
);

function reanalyze_bank() local(i sm)
(
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] = -1;
    i += 1;
  );
  reset_grain_histories();
  reset_weight_buffers();
  reset_clean_buffers();
  reset_room_buffers();
  reset_push_buffers();
  reset_formant_buffers();
  reset_focus_peak_buffers();
  transient_guard_s = 0;
  seq_cursor = 0;
  last_sid = -1;

  i = 0;
  while (i < sample_count) (
    sm = sample_meta_base + i * SM_STRIDE;
    analyze_sample(sm);
    i += 1;
  );

  refresh_bank_stats();
  rescan_flash = 1;
);

function configure_memory_layout(selected_count) local(cap) (
  cap = max(SAMPLE_POOL_MIN, selected_count | 0);
  cap > SAMPLE_POOL_HARD_MAX ? cap = SAMPLE_POOL_HARD_MAX;
  sample_pool_capacity = cap;

  sample_meta_base = 0;
  corpus_capacity = clamp(max(GRAIN_CORPUS_MIN, (selected_count | 0) * 64), GRAIN_CORPUS_MIN, GRAIN_CORPUS_HARD_MAX) | 0;
  grain_corpus_base = sample_meta_base + sample_pool_capacity * SM_STRIDE + 32;
  voice_base = grain_corpus_base + corpus_capacity * GC_STRIDE + 64;
  recent_base = voice_base + MAX_VOICES * VC_STRIDE;
  grain_hist_sid_base = recent_base + RECENT_LEN + 32;
  grain_hist_pos_base = grain_hist_sid_base + MAX_VOICES * GRAIN_HIST_LEN;
  grain_hist_phase_base = grain_hist_pos_base + MAX_VOICES * GRAIN_HIST_LEN;
  flow_model_base = grain_hist_phase_base + MAX_VOICES * GRAIN_HIST_LEN + 32;
  sig_scratch_base = flow_model_base + FLOW_WEIGHTS + 32;
  onset_raw_base = sig_scratch_base + SIG_PEEK_WORDS + 64;
  onset_smooth_base = onset_raw_base + ONSET_SCRATCH_MAX;

  m2e_cc_age_base = onset_smooth_base + ONSET_SCRATCH_MAX + 32;
  m2e_cc_val_base = m2e_cc_age_base + 128;

  note_gate_base = m2e_cc_val_base + 128 + 64;

  weight_ap1_l_base = note_gate_base + NOTE_GATE_CELLS + 64;
  weight_ap1_r_base = weight_ap1_l_base + AP_BUF_LEN;
  weight_ap2_l_base = weight_ap1_r_base + AP_BUF_LEN;
  weight_ap2_r_base = weight_ap2_l_base + AP_BUF_LEN;
  weight_er_l_base  = weight_ap2_r_base + AP_BUF_LEN;
  weight_er_r_base  = weight_er_l_base + ER_BUF_LEN;

  clean_env_base   = weight_er_r_base + ER_BUF_LEN + 256;
  clean_floor_base = clean_env_base + CLEAN_BANDS;
  clean_slow_base  = clean_floor_base + CLEAN_BANDS;
  clean_gain_base  = clean_slow_base + CLEAN_BANDS;

  posteq_spec_lp_base = clean_gain_base + CLEAN_BANDS + 32;
  posteq_spec_z2_base = posteq_spec_lp_base + POSTEQ_SPEC_BINS;
  posteq_spec_env_base = posteq_spec_z2_base + POSTEQ_SPEC_BINS;
  posteq_post_z1_base = posteq_spec_env_base + POSTEQ_SPEC_BINS;
  posteq_post_z2_base = posteq_post_z1_base + POSTEQ_SPEC_BINS;
  posteq_post_env_base = posteq_post_z2_base + POSTEQ_SPEC_BINS;
  posteq_spec_coeff_base = posteq_post_env_base + POSTEQ_SPEC_BINS;
  posteq_bq_base = posteq_spec_coeff_base + POSTEQ_SPEC_BINS * POSTEQ_SPEC_COEFFS + 32;
  fpk_env_base = posteq_bq_base + POSTEQ_BQ_COUNT * POSTEQ_BQ_STRIDE + 32;
  fpk_gain_base = fpk_env_base + FPK_BANDS;
  fpk_band_l_base = fpk_gain_base + FPK_BANDS;
  fpk_band_r_base = fpk_band_l_base + FPK_BANDS;
  fpk_bq_base = fpk_band_r_base + FPK_BANDS + 32;

  dc_inl_base = fpk_bq_base + FPK_BANDS * FPK_BQ_STRIDE + 256;
  dc_inr_base = dc_inl_base + DECRUST_RING;
  dc_outl_base = dc_inr_base + DECRUST_RING;
  dc_outr_base = dc_outl_base + DECRUST_RING;
  dc_fftl_base = dc_outr_base + DECRUST_RING;
  dc_fftr_base = dc_fftl_base + DECRUST_FFT * 2;
  dc_win_base = dc_fftr_base + DECRUST_FFT * 2;
  dc_syn_base = dc_win_base + DECRUST_FFT;
  dc_mag_base = dc_syn_base + DECRUST_FFT;
  dc_base_base = dc_mag_base + DECRUST_BINS;
  dc_prev_base = dc_base_base + DECRUST_BINS;
  dc_m1_base = dc_prev_base + DECRUST_BINS;
  dc_m2_base = dc_m1_base + DECRUST_BINS;
  dc_m3_base = dc_m2_base + DECRUST_BINS;
  dc_m4_base = dc_m3_base + DECRUST_BINS;
  dc_gain_base = dc_m4_base + DECRUST_BINS;

  AUDIO_BASE  = dc_gain_base + DECRUST_BINS + 256;
  MEM_LIMIT   = max(AUDIO_BASE + 1024, (__memtop() | 0) - 256);
);

function load_bank() local(
  selected loaded count i before_count
)
(
  sample_pool_set_mode(bank_pool, SAMPLE_MODE_RESIDENT);
  sample_pool_set_budget_mb(bank_pool, bank_budget_mb);
  sample_pool_commit(bank_pool);

  selected = max(0, sample_pool_selected(bank_pool) | 0);
  loaded = max(0, sample_pool_loaded(bank_pool) | 0);
  pool_state = sample_pool_state(bank_pool);
  pool_ram_mb = sample_pool_ram_mb(bank_pool);

  ((pool_state == SAMPLE_POOL_SCANNING || pool_state == SAMPLE_POOL_LOADING) && loaded <= 0 && sample_count > 0) ? (
    // Keep the previous generation playable while the worker builds the next one.
    bank_selected_count = selected;
    rescan_pending = 1;
  ) : (
    configure_memory_layout(max(selected, loaded));
    reset_bank_state();
    posteq_update_coeffs();
    fpk_update_coeffs();

    bank_selected_count = selected;
    bank_scan_count = loaded;
    bank_pool_capacity = sample_pool_capacity;
    bank_cap_limited = bank_selected_count > sample_pool_capacity ? 1 : 0;
    bank_memory_limited = sample_pool_failed(bank_pool) > 0 ? 1 : 0;

    count = min(sample_pool_capacity, loaded);
    i = 0;
    while (i < count) (
      before_count = sample_count;
      load_one_pool_sample(i);
      sample_count == before_count ? bank_skipped_count += 1;
      i += 1;
    );

    bank_skipped_count += max(0, selected - loaded);
    refresh_bank_stats();
    seq_cursor = 0;
    rescan_flash = 1;
    next_audio = AUDIO_BASE;
    freembuf(AUDIO_BASE);
  );
);

function compute_slot_signature() local(sig)
(
  sample_pool_set_mode(bank_pool, SAMPLE_MODE_RESIDENT);
  sample_pool_set_budget_mb(bank_pool, bank_budget_mb);
  sample_pool_commit(bank_pool);

  pool_state = sample_pool_state(bank_pool);
  pool_ram_mb = sample_pool_ram_mb(bank_pool);
  bank_selected_count = max(0, sample_pool_selected(bank_pool) | 0);

  sig = sample_pool_generation(bank_pool);
  sig += sample_pool_loaded(bank_pool) * 8191;
  sig += sample_pool_failed(bank_pool) * 131;
  sig += pool_state * 17;
  sig;
);

function schedule_rescan(sig force)
(
  pending_signature = sig;
  rescan_pending = 1;
  force ? rescan_force = 1;
);

function poll_slot(force) local(sig)
(
  sig = compute_slot_signature();
  force || sig != slot_signature_loaded ? schedule_rescan(sig, force);
);

function choose_sample(note velnorm) local(sid)
(
  sample_count <= 0 ? 0 : (
    selection_mode == 1 ? (
      sid = seq_cursor % max(sample_count, 1);
      seq_cursor = (seq_cursor + 1) % max(sample_count, 1);
      sid;
    ) : selection_mode == 2 ? (
      choose_walk_sample(note, velnorm);
    ) : (
      choose_random_sample(note, velnorm);
    );
  );
);

function choose_tail_donor(src_sid wideness) local(
  src sm i pick accum totalw score weight sid
  brighterr sharperr transerr lenerr pitcherr tailerr walkerr temp
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    temp = lerp(8.0, 2.4, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
        sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
        transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
        lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
        tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

        pitcherr = 0;
        (src[SM_PITCHCONF] > 0.38 && sm[SM_PITCHCONF] > 0.38) ? (
          pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
        );

        score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
        score += pitcherr * (0.20 + 0.70 * bank_pitchiness);
        walk_mode ? (
          walkerr = sample_descriptor_distance(src, sm, 1);
          score += walkerr * 0.22;
        );

        weight = 0.02 + exp(-score * temp);
        totalw += weight;
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.38 && sm[SM_PITCHCONF] > 0.38) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
          score += pitcherr * (0.20 + 0.70 * bank_pitchiness);
          walk_mode ? (
            walkerr = sample_descriptor_distance(src, sm, 1);
            score += walkerr * 0.22;
          );

          weight = 0.02 + exp(-score * temp);
          accum += weight;
          accum >= pick ? (
            sid = i;
            i = sample_count;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);


function alloc_voice() local(i v found best best_age)
(
  found = -1;
  best = 0;
  best_age = 100000000000;

  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] <= 0 ? (
      found = i;
      i = MAX_VOICES;
    ) : (
      v[VC_AGE] < best_age ? (
        best_age = v[VC_AGE];
        best = i;
      );
      i += 1;
    );
  );

  found >= 0 ? found : best;
);

function prepare_release_attack_bridge(note chan) local(
  i v env same_count any_count same_best any_best same_idx any_idx
  lo hi phase
)
(
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
  seam_bridge_note = note;
  seam_bridge_chan = chan;

  // Hybrid retrigger seam: if the previous sample is still in granular Release,
  // the next Attack begins from the equivalent envelope level instead of from 0.
  // Same-note releases are preferred; a single same-channel release can bridge too.
  (playback_mode >= 2 && granular_amt > 0.0001) ? (
    same_count = 0;
    any_count = 0;
    same_best = 0;
    any_best = 0;
    same_idx = -1;
    any_idx = -1;

    i = 0;
    while (i < MAX_VOICES) (
      v = voice_base + i * VC_STRIDE;
      (v[VC_ACTIVE] > 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_GMODE] > 0 && v[VC_GMIX] > 0.0001 && v[VC_CHAN] == chan) ? (
        env = clamp01(v[VC_ENV]);
        env > 0.0005 ? (
          (v[VC_NOTE] == note) ? (
            same_count += 1;
            env > same_best ? (
              same_best = env;
              same_idx = i;
            );
          ) : (
            any_count += 1;
            env > any_best ? (
              any_best = env;
              any_idx = i;
            );
          );
        );
      );
      i += 1;
    );

    same_count > 0 ? (
      seam_bridge_env = same_best;
      seam_bridge_idx = same_idx;
      seam_bridge_same_note = 1;
    ) : (any_count == 1 ? (
      seam_bridge_env = any_best;
      seam_bridge_idx = any_idx;
      seam_bridge_same_note = 0;
    ));

    seam_bridge_idx >= 0 ? (
      v = voice_base + seam_bridge_idx * VC_STRIDE;
      lo = max(0, floor(v[VC_BODYSTART]));
      hi = max(lo + 1, floor(v[VC_BODYEND]));
      phase = clamp01((v[VC_NEXTSRC] - lo) / max(1, hi - lo));
      seam_bridge_phase = phase;
    );
  );

  seam_bridge_env;
);

function apply_release_attack_bridge(skip_idx) local(i v use)
(
  seam_bridge_env > 0.0005 ? (
    i = 0;
    while (i < MAX_VOICES) (
      v = voice_base + i * VC_STRIDE;
      use = 0;
      (i != skip_idx && v[VC_ACTIVE] > 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_GMODE] > 0 && v[VC_GMIX] > 0.0001 && v[VC_CHAN] == seam_bridge_chan) ? (
        seam_bridge_same_note ? (
          v[VC_NOTE] == seam_bridge_note ? use = 1;
        ) : (
          i == seam_bridge_idx ? use = 1;
        );
      );

      use ? (
        // Handoff, not a hard kill: the old release keeps granular continuity but
        // fades on a short seam budget so the new Attack can take over smoothly.
        v[VC_RSTEP] = min(v[VC_RSTEP], seam_bridge_release_coef);
        v[VC_RHLEFT] = min(v[VC_RHLEFT], seam_bridge_samps);
        // Once this release has been consumed by a new Attack, do not let the
        // old voice spawn fresh body grains. Existing grains can fade, but this
        // prevents the old sample from sounding like a second retrigger.
        v[VC_CANSPAWN] = 0;
        v[VC_GTIMER] = max(v[VC_GTIMER], seam_bridge_samps);
        (!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = v[VC_ENV];
          v[VC_RLEN] = min(max(1, floor(v[VC_RLEN])), seam_bridge_samps);
        );
      );

      i += 1;
    );
  );
);

function fade_same_note_releases_for_retrigger(note chan skip_idx) local(i v)
(
  // Same-note retriggers should hand off; they should not leave an old Tape/Raw
  // release audibly trailing behind the new Attack. This is deliberately scoped
  // to already-releasing voices so normal polyphonic overlaps remain intact.
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (i != skip_idx && v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] <= 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_NOTE] == note && v[VC_CHAN] == chan) ? (
      v[VC_RSTEP] = min(v[VC_RSTEP], seam_bridge_release_coef);
      v[VC_RHLEFT] = min(v[VC_RHLEFT], seam_bridge_samps);
      v[VC_CANSPAWN] = 0;
      v[VC_GTIMER] = max(v[VC_GTIMER], seam_bridge_samps);
      (!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
        v[VC_EPHASE] = 0;
        v[VC_ESTART] = v[VC_ENV];
        v[VC_RLEN] = min(max(1, floor(v[VC_RLEN])), seam_bridge_samps);
      );
    );
    i += 1;
  );
);

function start_voice(note vel chan) local(
  velnorm sid sm donor donor_sm voice_idx v
  srcsr norm gain env0 lively playmode gran_voice ggrain_amt voice_stretch voice_stretch_norm
  driftcents raw_rate base_rate attack_rate pitch_protect pitch_abs head_hold_src head_hold_out
  transrich transprot translock hold_ms trans_hold_src trans_hold_out attack_preroll
  attack_norm pre_avail pre_keep align_guard align_jit
  j jmax pre startpos softskip gain_jit_db
  bodystart bodyend tailstart donor_tail min_body_span remain voice_hold_samps
  gesture_len gesture_depth
)
(
  sample_count <= 0 ? 0 : (
    velnorm = vel / 127;
    sid = choose_sample(note, velnorm);
    sm = sample_meta_base + sid * SM_STRIDE;

    prepare_release_attack_bridge(note, chan);

    voice_idx = alloc_voice();
    last_start_voice_idx = voice_idx;
    v = voice_base + voice_idx * VC_STRIDE;
    note_gate_forget_voice(v);

    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    grain_hist_clear_voice(voice_idx);

    note_counter += 1;
    last_note = note;
    last_sid = sid;

    lively = clamp01(slider9);
    playmode = playback_mode;
    gran_voice = playmode == 3 ? 1 : 0;
    ggrain_amt = gran_voice ? max(0.18, granular_amt) : granular_amt;
    playmode == 0 ? voice_stretch = 1 : voice_stretch = stretch_ratio;
    voice_stretch = max(1, voice_stretch);
    voice_stretch_norm = clamp01((voice_stretch - 1) / 3);

    srcsr = sm[SM_SR];
    norm  = sm[SM_NORM];
    gain  = (0.10 + 0.90 * (velnorm ^ 1.35)) * lerp(norm, 1, truth_mix);
    gain_jit_db = (rand(1) - 0.5) * lively * 0.8;
    gain *= db2amp(gain_jit_db);
    gain  = min(gain, 2.0);

    transrich = clamp01(sm[SM_FLAGS]);
    transprot = 0;
    transient_mode == 1 ? transprot = 1
    : transient_mode == 2 ? transprot = 0
    : transprot = clamp01((transrich - 0.38) / 0.44);
    translock = transprot >= 0.22 ? 1 : 0;

    driftcents = (rand(1) - 0.5) * (0.25 + lively * lively * 10.0);

    onset_mode_active ? (
      attack_norm = curve_norm(slider2, 0.1, 500, CURVE_TIME);
      pre_avail = max(0, sm[SM_ATTACK]);
      pre_keep = floor(pre_avail * attack_norm);

      translock ? (
        align_guard = min(pre_avail, max(0, floor(srcsr * (0.00020 + 0.00035 * transprot))));
        align_jit = floor(lively * (1 - transprot) * max(1, min(6, 1 + pre_avail * 0.035)));
        startpos = floor(sm[SM_ATTACK] - pre_keep - align_guard + (rand(1) - 0.5) * align_jit);
      ) : (
        pre  = min(pre_avail, floor(2 + attack_norm * min(64, 8 + pre_avail * 0.18)));
        jmax = floor((0.35 + lively * 2.05) * max(2, min(18, 2 + pre_avail * 0.08)));
        softskip = max(0, -slider7) * min(16, 2 + pre_avail * 0.06);
        startpos = floor(sm[SM_ATTACK] - max(pre_keep, pre) + (rand(1) - 0.5) * jmax + softskip);
      );
    ) : (
      translock ? (
        attack_preroll = min(sm[SM_ATTACK], max(0, floor(srcsr * (0.00035 + 0.00045 * transprot))));
        jmax = floor(lively * (1 - transprot) * min(4, 1 + sm[SM_ATTACK] * 0.02));
        startpos = floor(sm[SM_ATTACK] - attack_preroll + (rand(1) - 0.5) * jmax);
      ) : (
        pre  = min(sm[SM_ATTACK], 8 + lively * 8);
        jmax = floor((0.25 + lively * 1.75) * min(16, 2 + sm[SM_ATTACK] * 0.08));
        softskip = max(0, -slider7) * min(16, 2 + sm[SM_ATTACK] * 0.06);
        startpos = floor(sm[SM_ATTACK] - pre + (rand(1) - 0.5) * jmax + softskip);
      );
    );

    startpos = clamp(startpos, 0, max(0, sm[SM_FRAMES] - 2));
    raw_rate = (srcsr / srate) * midi_ratio(pitch_semi) * cents_ratio(driftcents);
    base_rate = raw_rate / voice_stretch;

    // v14 PitchSnap: transient-pinned attack rate. Stretch never slows the
    // protected head, and large pitch shifts are eased on transient-rich hits
    // so impacts keep their snap instead of becoming smeared clicks.
    pitch_abs = clamp01(abs(pitch_semi) / 12);
    pitch_protect = transient_mode == 2 ? 0 : clamp01(transprot * (0.28 + 0.72 * pitch_abs));
    transient_mode == 1 ? pitch_protect = clamp01(pitch_protect * 1.15 + transprot * 0.08);
    attack_rate = (srcsr / srate) * midi_ratio(pitch_semi * (1 - pitch_protect)) * cents_ratio(driftcents);

    hold_ms = translock ? (lerp(5.5, 15.5, transprot) + voice_stretch_norm * lerp(2.0, 9.5, transprot) + pitch_abs * transprot * 5.0) : 0;
    hold_ms = min(hold_ms, sm[SM_LENMS] * 0.30);
    trans_hold_src = translock ? min(max(0, sm[SM_FRAMES] - 2 - startpos), floor(srcsr * hold_ms * 0.001)) : 0;
    head_hold_src = translock ? clamp(sm[SM_HEADEND] - startpos + floor(srcsr * 0.0015), 0, max(0, sm[SM_FRAMES] - 2 - startpos)) : 0;
    head_hold_src = min(head_hold_src, floor(srcsr * lerp(0.010, 0.034, transprot)));
    trans_hold_src = max(trans_hold_src, head_hold_src);
    trans_hold_out = translock ? clamp(floor(trans_hold_src / max(abs(attack_rate), 0.000001)), 0, 8192) : 0;

    bodystart = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_FRAMES] - 2));
    tailstart = clamp(sm[SM_TAILSTART], bodystart + 1, max(bodystart + 1, sm[SM_FRAMES] - 2));
    remain = max(1, tailstart - bodystart);
    min_body_span = min(max(48, floor(max(srcsr * (0.020 + 0.016 * lively), hybrid_grain_samps * 0.85))), remain);
    remain < min_body_span ? (
      bodystart = max(sm[SM_HEADEND], tailstart - min_body_span);
      bodystart = clamp(bodystart, 0, max(0, tailstart - 1));
    );
    bodyend = max(bodystart + 1, tailstart);
    voice_hold_samps = max(0, hold_samps);

    donor = choose_region_donor(sid, 1, tail_borrow * (0.55 + 0.45 * lively), voice_idx);
    donor < 0 ? donor = sid;
    donor_sm = sample_meta_base + donor * SM_STRIDE;
    donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));

    v[VC_ACTIVE] = 1;
    v[VC_NOTE]   = note;
    v[VC_CHAN]   = chan;
    v[VC_SAMPLE] = sid;
    v[VC_POS]    = startpos;
    v[VC_RATE]   = base_rate;
    v[VC_BASE]   = gain * (gran_voice ? 1.55 : 1);
    env0 = (attack_samps <= 1 || (translock && attack_samps <= floor(0.010 * srate))) ? 1 : 0;
    (playmode >= 2 && ggrain_amt > 0.0001 && seam_bridge_env > 0.0005) ? (
      // Attack begins from the current Release level, matching the Phase Plant-style
      // release-point -> equivalent-attack-point retrigger behavior. This overrides
      // the usual fast Punch/Gaussian env=1 shortcut, except for a true 1-sample attack.
      env0 = attack_samps <= 1 ? 1 : min(0.985, seam_bridge_env);
    );
    v[VC_ENV]    = env0;
    v[VC_ASTEP]  = attack_coef;
    v[VC_DSTEP]  = decay_coef;
    v[VC_RSTEP]  = release_coef;
    v[VC_HLEFT]  = voice_hold_samps;
    v[VC_STAGE]  = env0 >= 1 ? (voice_hold_samps > 0 ? ENV_HOLD : ENV_DECAY) : ENV_ATTACK;
    v[VC_AGE]    = note_counter;
    v[VC_EPHASE] = 0;
    v[VC_ESTART] = env0;
    v[VC_ALEN]   = attack_samps;
    v[VC_DLEN]   = decay_samps;
    v[VC_RLEN]   = release_samps;
    v[VC_ACURVE] = attack_slope_pct;
    v[VC_DCURVE] = decay_slope_pct;
    v[VC_RCURVE] = release_slope_pct;
    (playmode >= 2 && ggrain_amt > 0.0001 && seam_bridge_env > 0.0005 && env0 < 1 && !env_slope_is_classic(attack_slope_pct, ENV_RISE)) ? (
      // For non-classic slopes, continue from the equivalent Attack curve point
      // instead of spending a full Attack time above the inherited Release level.
      v[VC_EPHASE] = env_slope_inv(env0, env_segment_slope(attack_slope_pct, ENV_RISE)) * max(1, attack_samps);
    );

    v[VC_GMODE]    = (playmode >= 2) ? 1 : 0;
    v[VC_OHOP]     = hybrid_hop_samps;
    v[VC_GSIZE]    = gran_voice ? max(hybrid_hop_samps + 1, floor(hybrid_grain_samps * lerp(1.0, 2.20, granular_event_stretch))) : hybrid_grain_samps;
    // Hybrid waits until transient protection clears because the direct head is audible.
    // Granular has no audible direct head, so its HybridCore grain layer starts immediately.
    v[VC_GTIMER]   = gran_voice ? (-floor(max(1, hybrid_hop_samps) * 3)) : max(1, trans_hold_out + 1);
    v[VC_NEXTSRC]  = max(bodystart, min(startpos, bodyend - 1));
    (playmode >= 2 && ggrain_amt > 0.0001 && seam_bridge_env > 0.0005 && seam_bridge_phase >= 0) ? (
      // The new Hybrid body cursor starts at the matching normalized body phase
      // of the releasing voice, while the direct head still uses Gaussian/onset alignment.
      v[VC_NEXTSRC] = clamp(bodystart + seam_bridge_phase * max(1, bodyend - bodystart - 1), bodystart, max(bodystart, bodyend - 1));
      v[VC_GTIMER] = min(v[VC_GTIMER], max(1, floor(hybrid_hop_samps * 0.25)));
    );
    v[VC_SRCHOP]   = max(0.25, abs(base_rate) * hybrid_hop_samps);
    v[VC_CANSPAWN] = (playmode >= 2 && ggrain_amt > 0.0001) ? 1 : 0;
    v[VC_TLEFT]    = gran_voice ? 0 : trans_hold_out;
    v[VC_TPROT]    = transprot;
    v[VC_DONOR]    = donor;
    v[VC_DONORPOS] = donor_tail;
    v[VC_BODYSTART]= bodystart;
    v[VC_TAILSTART]= tailstart;
    v[VC_BODYEND]  = bodyend;
    v[VC_GMIX]     = ggrain_amt;
    v[VC_TAILMIX]  = tail_borrow;
    v[VC_MODE]     = playmode;
    v[VC_STRETCH]  = voice_stretch;
    v[VC_THOLD]    = max(1, trans_hold_out);
    v[VC_RHLEFT]   = 0;
    v[VC_RHLEN]    = max(1, release_handoff_samps);
    v[VC_RAWRATE]  = raw_rate;
    v[VC_ATKRATE]  = attack_rate;
    v[VC_HEADSAFE] = sm[SM_HEADEND];
    v[VC_GENV]     = 0.36;
    v[VC_GENVDELTA]= 0;
    v[VC_AUDIOTRIG] = 0;
    v[VC_AUDIOENV]  = 1;
    v[VC_AUTOVEL]   = velnorm;

    gesture_len = floor(srate * lerp(0.22, 1.20, rand(1)) * lerp(0.82, 1.22, stretch_norm) * (gran_voice ? lerp(1.0, 2.75, granular_event_stretch) : 1));
    gesture_len = max(64, gesture_len);
    gesture_depth = lively * (0.38 + 0.62 * ggrain_amt) * (gran_voice ? 1.0 : 0.32);
    v[VC_GPHASE]  = rand(1);
    v[VC_GLEN]    = gesture_len;
    v[VC_GDEPTH]  = gesture_depth;
    v[VC_GACCENT] = rand(1);
    v[VC_LGSID]   = -1;
    v[VC_LGPOS]   = 0;
    v[VC_LGLO]    = 0;
    v[VC_LGHI]    = 1;
    v[VC_LGREG]   = -1;
    v[VC_LGRUN]   = 0;
    v[VC_LGCIDX]  = -1;

    apply_release_attack_bridge(voice_idx);
    fade_same_note_releases_for_retrigger(note, chan, voice_idx);

    sm[SM_LASTUSED] = note_counter;
    push_recent(sid);

    walk_prev_sid = walk_last_sid;
    walk_last_sid = sid;
    walk_steps += 1;
  );
);

function release_voice_internal(v) local(donor donor_sm donor_tail body_start body_end release_src sid sm auto_len rel_len rel_coef)
(
  (v[VC_ACTIVE] > 0 && v[VC_STAGE] != ENV_RELEASE) ? (
    sid = clamp(v[VC_SAMPLE] | 0, 0, max(0, sample_count - 1));
    sm = sample_meta_base + sid * SM_STRIDE;
    auto_len = max(1, floor(sm[SM_AUTOREL] * auto_release_amt * srate * 0.001));
    // Release knob remains the user's intent, but a hot/non-silent sample tail
    // is allowed to demand a longer minimum so note-off does not sound chopped.
    rel_len = max(release_samps, auto_len);
    rel_coef = exp(-6.90775527898214 / max(1, rel_len));

    rel_len <= 1 ? (
      v[VC_ENV] = 0;
      v[VC_STAGE] = ENV_OFF;
      v[VC_ACTIVE] = 0;
    ) : (
      v[VC_STAGE] = ENV_RELEASE;
      v[VC_RSTEP] = rel_coef;
      v[VC_HLEFT] = 0;
      v[VC_TLEFT] = 0;
      v[VC_EPHASE] = 0;
      v[VC_ESTART] = v[VC_ENV];
      v[VC_RLEN] = rel_len;
      v[VC_RCURVE] = release_slope_pct;
      (v[VC_GMODE] > 0) ? (
        // Release must continue from the current body/playback position, not
        // restart the body window. This prevents short one-shots from replaying
        // their body grain after the direct head has already finished.
        (v[VC_GMIX] > 0.0001) ? (
          body_start = max(0, floor(v[VC_BODYSTART]));
          body_end = max(body_start + 1, floor(v[VC_BODYEND]));
          release_src = clamp(max(v[VC_NEXTSRC], min(v[VC_POS], body_end - 1)), body_start, max(body_start, body_end - 1));
          v[VC_NEXTSRC] = release_src;
        );
        v[VC_CANSPAWN] = (v[VC_GMIX] > 0.0001 || v[VC_TAILMIX] > 0.0001) ? 1 : 0;
        v[VC_RHLEN] = max(1, release_handoff_samps);
        v[VC_RHLEFT] = v[VC_RHLEN];
        donor = v[VC_DONOR] | 0;
        donor_sm = sample_meta_base + donor * SM_STRIDE;
        donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));
        v[VC_DONORPOS] < donor_tail ? v[VC_DONORPOS] = donor_tail;
        v[VC_GTIMER] = min(v[VC_GTIMER], 1);
      ) : (
        v[VC_CANSPAWN] = 0;
        v[VC_RHLEFT] = 0;
      );
    );
  );
);

function release_oldest_held_note_voice(note chan) local(i v best_idx best_age)
(
  best_idx = -1;
  best_age = 100000000000;

  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] <= 0 && v[VC_NOTE] == note && v[VC_CHAN] == chan && v[VC_STAGE] != ENV_RELEASE) ? (
      v[VC_AGE] < best_age ? (
        best_age = v[VC_AGE];
        best_idx = i;
      );
    );
    i += 1;
  );

  best_idx >= 0 ? (
    v = voice_base + best_idx * VC_STRIDE;
    release_voice_internal(v);
    1;
  ) : 0;
);

function release_voice(note chan) local(target held guard idx)
(
  // Reconcile active held voices to the MIDI gate count for this note/channel.
  // This fixes stuck one-voice states: an extra Note Off with no matching Note On
  // drives the target to zero and releases every held orphan instead of only one.
  idx = note_gate_idx(note, chan);
  target = clamp(note_gate_base[idx], 0, MAX_VOICES);
  held = count_held_note_voices(note, chan);
  guard = 0;

  while (held > target && guard < MAX_VOICES) (
    release_oldest_held_note_voice(note, chan) ? (
      held -= 1;
    ) : (
      held = target;
    );
    guard += 1;
  );
);

function release_all_voices_transport(hard) local(i v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? (
      hard ? (
        v[VC_ENV] = 0;
        v[VC_STAGE] = ENV_OFF;
        v[VC_ACTIVE] = 0;
      ) : (
        release_voice_internal(v);
      );
    );
    i += 1;
  );

  reset_note_gates();

  hard ? (
    reset_weight_buffers();
    reset_clean_buffers();
    reset_room_buffers();
    reset_push_buffers();
    reset_formant_buffers();
    reset_focus_peak_buffers();
    reset_input_trigger_buffers();
  );
);


function count_audio_trigger_voices() local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] > 0) ? cnt += 1;
    i += 1;
  );
  cnt;
);

function update_audio_trigger_voice_envs(env_amt) local(i v e)
(
  e = clamp01(env_amt);
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] > 0) ? (
      v[VC_AUDIOENV] = e;
      v[VC_AUTOVEL] = max(v[VC_AUTOVEL], e);
    );
    i += 1;
  );
);

function release_audio_trigger_voices(hard) local(i v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_AUDIOTRIG] > 0) ? (
      hard ? (
        v[VC_ENV] = 0;
        v[VC_STAGE] = ENV_OFF;
        v[VC_ACTIVE] = 0;
        v[VC_AUDIOTRIG] = 0;
      ) : (
        release_voice_internal(v);
      );
    );
    i += 1;
  );
);

function start_audio_trigger_voice(env_amt) local(note vel v)
(
  // One input gate should own one texture voice. Do not retrigger while the
  // detector is still held; that produced double-hits on single input events.
  (bank_loaded && sample_count > 0 && playback_mode == 3 && count_audio_trigger_voices() <= 0) ? (
    note = last_note >= 0 ? last_note : 60;
    vel = clamp(floor(1 + 126 * (clamp01(env_amt) ^ 0.58)), 1, 127);
    last_start_voice_idx = -1;
    start_voice(note, vel, 0);
    (last_start_voice_idx >= 0 && last_start_voice_idx < MAX_VOICES) ? (
      v = voice_base + last_start_voice_idx * VC_STRIDE;
      v[VC_AUDIOTRIG] = 1;
      v[VC_AUDIOENV] = clamp01(env_amt);
      v[VC_AUTOVEL] = clamp01(env_amt);
      v[VC_MODE] = 3;
      v[VC_GMODE] = 1;
      v[VC_CANSPAWN] = 1;
      v[VC_GMIX] = max(v[VC_GMIX], max(0.18, granular_amt));
    );
  );
);

function process_granular_input_trigger(inL inR) local(
  det det_db floor_db knee_lo knee_hi knee_t env_norm on_env off_env noise_ok silence_target cooldown_samps
)
(
  det = max(abs(inL), abs(inR));
  det = det < 0.000000000000000001 ? 0 : det;

  input_trig_fast += (det - input_trig_fast) * (det > input_trig_fast ? input_trig_fast_att : input_trig_fast_rel);
  input_trig_slow += (det - input_trig_slow) * (det > input_trig_slow ? input_trig_slow_att : input_trig_slow_rel);
  input_trig_floor += (det - input_trig_floor) * (det > input_trig_floor ? input_trig_floor_up : input_trig_floor_down);

  input_trig_fast = denorm_zap(input_trig_fast);
  input_trig_slow = denorm_zap(input_trig_slow);
  input_trig_floor = denorm_zap(input_trig_floor);

  // v44 TextureInjection GateFix:
  // Use a dBFS soft knee aimed upward toward 0 dBFS. Quiet material produces
  // little/no texture, louder material scales proportionally, and one input
  // event cannot retrigger until it has actually released.
  det_db = 20 * log(max(input_trig_fast, 0.000000001)) * LOG10_INV;
  floor_db = 20 * log(max(input_trig_floor, 0.000000001)) * LOG10_INV;

  knee_lo = lerp(-42, -36, input_trigger_amt);
  knee_hi = lerp(-4, -2, input_trigger_amt);
  knee_t = clamp01((det_db - knee_lo) / max(0.001, knee_hi - knee_lo));
  // Smoothstep knee, then extra curvature so low-level input does not behave
  // like a hair-trigger. Extremes still reach full-scale texture injection.
  env_norm = knee_t * knee_t * (3 - 2 * knee_t);
  env_norm = env_norm ^ lerp(2.30, 1.58, input_trigger_amt);
  input_trig_norm = env_norm;
  input_trig_env += (env_norm - input_trig_env) * (env_norm > input_trig_env ? input_trig_env_att : input_trig_env_rel);
  input_trig_env = denorm_zap(input_trig_env);

  input_trig_cooldown > 0 ? input_trig_cooldown -= 1;
  silence_target = max(8, floor(srate * lerp(0.055, 0.150, input_trigger_amt)));
  cooldown_samps = max(8, floor(srate * lerp(0.080, 0.160, input_trigger_amt)));
  on_env = lerp(0.18, 0.115, input_trigger_amt);
  off_env = on_env * lerp(0.38, 0.25, input_trigger_amt);
  noise_ok = det_db > (floor_db + lerp(9.5, 6.5, input_trigger_amt));

  input_trig_gate <= 0 ? (
    (input_trig_env >= on_env && noise_ok && input_trig_cooldown <= 0 && count_audio_trigger_voices() <= 0) ? (
      group_can_input_fire(input_trig_env) ? (
        input_trig_gate = 1;
        input_trig_silence = 0;
        start_audio_trigger_voice(input_trig_env);
        group_report_onset(input_trig_env);
        input_trig_cooldown = cooldown_samps;
        input_trig_wait = 0;
      ) : (
        input_trig_wait += 1;
      );
    ) : (
      input_trig_wait = 0;
    );
  ) : (
    update_audio_trigger_voice_envs(input_trig_env);

    // Once held, follow the actual dBFS envelope. Do not let the adaptive
    // noise-floor tracker eat a sustained real input and prematurely release it.
    (input_trig_env <= off_env || det_db < -78) ? (
      input_trig_silence += 1;
    ) : (
      input_trig_silence = 0;
    );

    input_trig_silence >= silence_target ? (
      release_audio_trigger_voices(0);
      input_trig_gate = 0;
      input_trig_cooldown = cooldown_samps;
      input_trig_silence = 0;
      input_trig_wait = 0;
    );
  );
);

function ui_panel(x y w h) local(i t)
(
  gfx_r = 0.000; gfx_g = 0.000; gfx_b = 0.000; gfx_a = 0.34;
  gfx_rect(x + 3, y + 5, w, h, 1);

  i = 0;
  while (i < h) (
    t = i / max(1, h - 1);
    gfx_r = 0.045 + 0.020 * (1 - t);
    gfx_g = 0.058 + 0.024 * (1 - t);
    gfx_b = 0.078 + 0.030 * (1 - t);
    gfx_a = 1;
    gfx_line(x, y + i, x + w, y + i);
    i += 1;
  );

  gfx_r = 0.18; gfx_g = 0.25; gfx_b = 0.32; gfx_a = 0.96;
  gfx_rect(x, y, w, h, 0);
  gfx_r = 0.40; gfx_g = 0.66; gfx_b = 0.94; gfx_a = 0.15;
  gfx_line(x + 1, y + 1, x + w - 2, y + 1);
  gfx_r = 0.02; gfx_g = 0.025; gfx_b = 0.032; gfx_a = 0.80;
  gfx_line(x + 1, y + h - 1, x + w - 2, y + h - 1);

  // small screw-like corner marks, purely decorative
  gfx_r = 0.14; gfx_g = 0.19; gfx_b = 0.24; gfx_a = 0.85;
  gfx_circle(x + 7, y + 7, 2, 1);
  gfx_circle(x + w - 7, y + 7, 2, 1);
  gfx_circle(x + 7, y + h - 7, 2, 1);
  gfx_circle(x + w - 7, y + h - 7, 2, 1);
);

function ui_inner_panel(x y w h) local(i t)
(
  i = 0;
  while (i < h) (
    t = i / max(1, h - 1);
    gfx_r = 0.030 + 0.018 * (1 - t);
    gfx_g = 0.038 + 0.020 * (1 - t);
    gfx_b = 0.052 + 0.030 * (1 - t);
    gfx_a = 1;
    gfx_line(x, y + i, x + w, y + i);
    i += 1;
  );
  gfx_r = 0.11; gfx_g = 0.17; gfx_b = 0.22; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);
  gfx_r = 0.29; gfx_g = 0.56; gfx_b = 0.82; gfx_a = 0.13;
  gfx_line(x + 1, y + 1, x + w - 2, y + 1);
);

function ui_led(x y on cr cg cb) local(rr)
(
  rr = on ? 7 : 6;
  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.52;
  gfx_circle(x + 1, y + 1, rr + 2, 1);
  gfx_r = cr; gfx_g = cg; gfx_b = cb; gfx_a = on ? 0.24 : 0.10;
  gfx_circle(x, y, rr + 5, 1);
  gfx_r = on ? cr : 0.13;
  gfx_g = on ? cg : 0.16;
  gfx_b = on ? cb : 0.20;
  gfx_a = 1;
  gfx_circle(x, y, rr, 1);
  gfx_r = 1; gfx_g = 1; gfx_b = 1; gfx_a = on ? 0.42 : 0.10;
  gfx_circle(x - rr * 0.25, y - rr * 0.30, rr * 0.34, 1);
);

function ui_hmeter(x y w h val cr cg cb) local(v i t)
(
  v = clamp01(val);
  gfx_r = 0.030; gfx_g = 0.038; gfx_b = 0.052; gfx_a = 1;
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.11; gfx_g = 0.15; gfx_b = 0.18; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);
  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.28;
  gfx_rect(x + 1, y + 1, w - 2, h - 2, 1);
  i = 0;
  while (i < max(0, floor((w - 2) * v))) (
    t = i / max(1, w - 2);
    gfx_r = cr * (0.70 + 0.30 * t) + 0.10 * t;
    gfx_g = cg * (0.72 + 0.25 * t) + 0.12 * t;
    gfx_b = cb * (0.72 + 0.24 * t) + 0.16 * t;
    gfx_a = 0.96;
    gfx_line(x + 1 + i, y + 1, x + 1 + i, y + h - 2);
    i += 1;
  );
  gfx_r = cr; gfx_g = cg; gfx_b = cb; gfx_a = 0.34;
  gfx_rect(x + 1, y + 1, (w - 2) * v, h - 2, 0);
);

function ui_value_pill(x y w h) local(i t)
(
  i = 0;
  while (i < h) (
    t = i / max(1, h - 1);
    gfx_r = 0.030 + 0.020 * (1 - t);
    gfx_g = 0.040 + 0.025 * (1 - t);
    gfx_b = 0.055 + 0.035 * (1 - t);
    gfx_a = 1;
    gfx_line(x, y + i, x + w, y + i);
    i += 1;
  );
  gfx_r = 0.13; gfx_g = 0.21; gfx_b = 0.28; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);
);

function ui_draw_header_logo(cx cy s) local(i xx h)
(
  gfx_r = 0.02; gfx_g = 0.03; gfx_b = 0.04; gfx_a = 0.92;
  gfx_circle(cx, cy, s * 1.05, 1);
  gfx_r = 0.12; gfx_g = 0.18; gfx_b = 0.23; gfx_a = 1;
  gfx_circle(cx, cy, s * 1.05, 0);
  gfx_r = 0.24; gfx_g = 0.62; gfx_b = 0.96; gfx_a = 0.25;
  gfx_circle(cx, cy, s * 1.25, 0);

  i = -3;
  while (i <= 3) (
    xx = cx + i * s * 0.22;
    h = s * (0.22 + 0.18 * (3 - abs(i)));
    i == 0 ? h = s * 0.72;
    gfx_r = 0.46; gfx_g = 0.82; gfx_b = 1.0; gfx_a = 0.90;
    gfx_line(xx, cy - h, xx, cy + h);
    i += 1;
  );
);

function ui_button(id x y w h) local(hot clicked i t)
(
  clicked = 0;
  hot = pt_in(x, y, w, h);

  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_pressed && hot && ui_active < 0 ? ui_active = id;
  ui_active == id ? (
    !mouse_down ? (
      hot ? clicked = 1;
      ui_active = -1;
    );
  );

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.35;
  gfx_rect(x + 1, y + 2, w, h, 1);
  i = 0;
  while (i < h) (
    t = i / max(1, h - 1);
    gfx_r = (hot || ui_active == id) ? (0.115 - t * 0.030) : (0.085 - t * 0.022);
    gfx_g = (hot || ui_active == id) ? (0.160 - t * 0.035) : (0.115 - t * 0.025);
    gfx_b = (hot || ui_active == id) ? (0.220 - t * 0.045) : (0.155 - t * 0.030);
    gfx_a = 1;
    gfx_line(x, y + i, x + w, y + i);
    i += 1;
  );
  gfx_r = (hot || ui_active == id) ? 0.35 : 0.17;
  gfx_g = (hot || ui_active == id) ? 0.62 : 0.25;
  gfx_b = (hot || ui_active == id) ? 0.90 : 0.34;
  gfx_a = (hot || ui_active == id) ? 1 : 0.95;
  gfx_rect(x, y, w, h, 0);
  gfx_r = 0.55; gfx_g = 0.80; gfx_b = 1.00; gfx_a = (hot || ui_active == id) ? 0.40 : 0.12;
  gfx_line(x + 2, y + 1, x + w - 3, y + 1);
  gfx_r = 0.02; gfx_g = 0.03; gfx_b = 0.04; gfx_a = 0.70;
  gfx_line(x + 2, y + h - 1, x + w - 3, y + h - 1);

  clicked;
);

function ui_knob(id x y r val vmin vmax defval wheel_step) local(hot norm ang px py vv dbl step_amt i a rr x1 y1 x2 y2 tickn active_n)
(
  hot = ((mouse_x - x) * (mouse_x - x) + (mouse_y - y) * (mouse_y - y)) <= r * r;
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    abs(val - defval) > 0.0000001 ? (
      val = defval;
      ui_value_changed = 1;
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
      ui_active = -1;
    ) : (
      ui_active = id;
      ui_down_y = mouse_y;
      ui_down_val = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 && !ui_shift ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(ui_down_val - (mouse_y - ui_down_y) / 150);
      vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
      abs(vv - val) > 0.0000001 ? (
        val = vv;
        ui_value_changed = 1;
      );
    ) : (
      ui_active = -1;
    );
  );

  norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.48;
  gfx_circle(x + 2, y + 3, r + 5, 1);
  gfx_r = 0.020; gfx_g = 0.026; gfx_b = 0.034; gfx_a = 1;
  gfx_circle(x, y, r + 4, 1);
  gfx_r = 0.11; gfx_g = 0.15; gfx_b = 0.19; gfx_a = 1;
  gfx_circle(x, y, r + 3, 0);

  tickn = 32;
  i = 0;
  while (i <= tickn) (
    a = (-0.76 + (i / tickn) * 1.52) * 3.14159265358979;
    rr = (i % 4 == 0) ? r + 3 : r + 2;
    x1 = x + cos(a) * rr;
    y1 = y + sin(a) * rr;
    x2 = x + cos(a) * (rr + ((i % 4 == 0) ? 4 : 2));
    y2 = y + sin(a) * (rr + ((i % 4 == 0) ? 4 : 2));
    gfx_r = 0.21; gfx_g = 0.28; gfx_b = 0.35; gfx_a = 0.70;
    gfx_line(x1, y1, x2, y2);
    i += 1;
  );

  active_n = floor(norm * tickn);
  i = 0;
  while (i <= active_n) (
    a = (-0.76 + (i / tickn) * 1.52) * 3.14159265358979;
    x1 = x + cos(a) * (r + 2);
    y1 = y + sin(a) * (r + 2);
    x2 = x + cos(a) * (r + 7);
    y2 = y + sin(a) * (r + 7);
    gfx_r = 0.05 + 0.23 * norm; gfx_g = 0.50 + 0.32 * norm; gfx_b = 1.00; gfx_a = 0.96;
    gfx_line(x1, y1, x2, y2);
    i += 1;
  );

  gfx_r = 0.045; gfx_g = 0.055; gfx_b = 0.070; gfx_a = 1;
  gfx_circle(x, y, r, 1);
  gfx_r = 0.18; gfx_g = 0.22; gfx_b = 0.27; gfx_a = 1;
  gfx_circle(x - 1, y - 1, r * 0.76, 1);
  gfx_r = 0.045; gfx_g = 0.050; gfx_b = 0.060; gfx_a = 0.88;
  gfx_circle(x + 1, y + 2, r * 0.62, 1);
  gfx_r = 0.32; gfx_g = 0.44; gfx_b = 0.54; gfx_a = 0.64;
  gfx_circle(x - r * 0.25, y - r * 0.34, r * 0.22, 1);

  ang = (-0.75 + norm * 1.5) * 3.14159265358979;
  px = x + cos(ang) * (r - 5);
  py = y + sin(ang) * (r - 5);
  gfx_r = hot || ui_active == id ? 0.85 : 0.50;
  gfx_g = hot || ui_active == id ? 0.95 : 0.76;
  gfx_b = 1.00;
  gfx_a = 1;
  gfx_line(x, y, px, py);
  gfx_circle(px, py, 2, 1);

  (hot || ui_active == id) ? (
    gfx_r = 0.22; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.36;
    gfx_circle(x, y, r + 10, 0);
  );

  val;
);

function ui_vslider(id x y w h val vmin vmax curve_mode defval wheel_step) local(hot norm py vv fillh dbl step_amt i t tickn)
(
  hot = pt_in(x, y, w, h);
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    (id == 204 && ui_shift) ? (
      auto_release_amt = 1;
      ui_value_changed = 1;
      ui_alt_release_drag = 0;
    ) : (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      (id == 204 && ui_shift) ? (
        auto_release_amt = 1;
        ui_value_changed = 1;
      ) : (
        abs(val - defval) > 0.0000001 ? (
          val = defval;
          ui_value_changed = 1;
        );
      );
      ui_alt_release_drag = 0;
      ui_active = -1;
    ) : (
      ui_active = id;
      ui_alt_release_drag = (id == 204 && ui_shift) ? 1 : 0;
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 && !ui_shift ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, curve_mode);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, curve_mode);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(1 - ((mouse_y - y) / max(h, 1)));
      (id == 204 && ui_alt_release_drag) ? (
        abs(norm - auto_release_amt) > 0.0000001 ? (
          auto_release_amt = norm;
          ui_value_changed = 1;
        );
      ) : (
        vv = curve_denorm(norm, vmin, vmax, curve_mode);
        abs(vv - val) > 0.0000001 ? (
          val = vv;
          ui_value_changed = 1;
        );
      );
    ) : (
      ui_active = -1;
      ui_alt_release_drag = 0;
    );
  );

  norm = curve_norm(val, vmin, vmax, curve_mode);
  fillh = clamp01(norm) * h;

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.40;
  gfx_rect(x + 2, y + 2, w, h, 1);
  ui_inner_panel(x, y, w, h);

  tickn = 12;
  i = 1;
  while (i < tickn) (
    t = y + h - (i / tickn) * h;
    gfx_r = 0.24; gfx_g = 0.31; gfx_b = 0.38; gfx_a = 0.42;
    gfx_line(x - 8, t, x - 2, t);
    gfx_line(x + w + 2, t, x + w + 8, t);
    i += 1;
  );

  gfx_r = 0.02; gfx_g = 0.10; gfx_b = 0.18; gfx_a = 0.65;
  gfx_rect(x + 3, y + 3, w - 6, h - 6, 1);
  gfx_r = 0.00; gfx_g = 0.43; gfx_b = 0.96; gfx_a = 0.24;
  gfx_rect(x + 4, y + h - fillh + 2, w - 8, max(0, fillh - 4), 1);
  gfx_r = 0.04; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.92;
  gfx_rect(x + 6, y + h - fillh + 4, w - 12, max(0, fillh - 8), 1);

  py = y + h - norm * h;
  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.45;
  gfx_rect(x - 6, py - 3, w + 12, 8, 1);
  gfx_r = 0.78; gfx_g = 0.88; gfx_b = 0.98; gfx_a = 1;
  gfx_rect(x - 5, py - 4, w + 10, 7, 1);
  gfx_r = 0.30; gfx_g = 0.52; gfx_b = 0.70; gfx_a = 1;
  gfx_rect(x - 5, py - 4, w + 10, 7, 0);
  gfx_r = 1; gfx_g = 1; gfx_b = 1; gfx_a = 0.52;
  gfx_line(x - 3, py - 3, x + w + 3, py - 3);

  hot || ui_active == id ? (
    gfx_r = 0.25; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.55;
    gfx_rect(x - 4, y - 4, w + 8, h + 8, 0);
  );

  val;
);

function ui_shift_wheel_slope(id val defval) local(step_amt)
(
  (ui_hover_id == id && ui_shift && !ui_wheel_used && abs(ui_wheel) >= 1) ? (
    step_amt = 5 * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    val = clamp(val + (ui_wheel > 0 ? step_amt : -step_amt), -100, 100);
    ui_wheel_used = 1;
    ui_value_changed = 1;
  );

  val;
);

function draw_curve_line(x1 y1 x2 y2 mode) local(i steps t u px py nx ny)
(
  steps = 24;
  px = x1;
  py = y1;
  i = 1;
  while (i <= steps) (
    t = i / steps;
    u = env_slope_shape(t, mode);
    nx = x1 + (x2 - x1) * t;
    ny = y1 + (y2 - y1) * u;
    gfx_line(px, py, nx, ny);
    px = nx;
    py = ny;
    i += 1;
  );
);

function draw_center_buf(x y w) local(tw th)
(
  gfx_measurestr(#ui_buf, tw, th);
  gfx_x = x + max(0, (w - tw) * 0.5);
  gfx_y = y;
  gfx_drawstr(#ui_buf);
);


function ui_tab_button(id x y w h active) local(hot clicked i t)
(
  clicked = 0;
  hot = pt_in(x, y, w, h);
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_pressed && hot && ui_active < 0 ? ui_active = id;
  ui_active == id ? (
    !mouse_down ? (
      hot ? clicked = 1;
      ui_active = -1;
    );
  );

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.34;
  gfx_rect(x + 1, y + 2, w, h, 1);
  i = 0;
  while (i < h) (
    t = i / max(1, h - 1);
    active ? (
      gfx_r = 0.155 - t * 0.035;
      gfx_g = 0.214 - t * 0.046;
      gfx_b = 0.292 - t * 0.050;
    ) : (
      gfx_r = (hot || ui_active == id) ? (0.095 - t * 0.026) : (0.055 - t * 0.016);
      gfx_g = (hot || ui_active == id) ? (0.128 - t * 0.030) : (0.074 - t * 0.020);
      gfx_b = (hot || ui_active == id) ? (0.172 - t * 0.036) : (0.100 - t * 0.024);
    );
    gfx_a = 1;
    gfx_line(x, y + i, x + w, y + i);
    i += 1;
  );
  gfx_r = active ? 0.82 : ((hot || ui_active == id) ? 0.35 : 0.16);
  gfx_g = active ? 0.66 : ((hot || ui_active == id) ? 0.62 : 0.25);
  gfx_b = active ? 0.22 : ((hot || ui_active == id) ? 0.90 : 0.34);
  gfx_a = 1;
  gfx_rect(x, y, w, h, 0);
  active ? (
    gfx_r = 0.96; gfx_g = 0.72; gfx_b = 0.18; gfx_a = 0.95;
    gfx_rect(x + 2, y + h - 4, w - 4, 2, 1);
  );

  clicked;
);

function proc_freq_x(freq x w) local(n)
(
  n = (log(max(20, min(20000, freq))) - log(20)) / (log(20000) - log(20));
  x + clamp01(n) * w;
);

function proc_x_freq(mx x w) local(n)
(
  n = clamp01((mx - x) / max(w, 1));
  exp(log(20) + n * (log(20000) - log(20)));
);

function proc_db_y(db y h) local(n)
(
  n = (18 - clamp(db, -18, 18)) / 36;
  y + clamp01(n) * h;
);

function proc_y_db(my y h) local(n)
(
  n = clamp01((my - y) / max(h, 1));
  clamp(18 - n * 36, -18, 18);
);

function proc_band_resp(freq cf q gain_db) local(
  A w0 sn cs alpha a0 b0 b1 b2 a1 a2
  w c1 s1 c2 s2 nre nim dre dim mag2
)
(
  // Match the DSP peaking biquad instead of drawing an over-wide Gaussian.
  // The old graph made Q0.75 look like it affected nearly the entire spectrum.
  abs(gain_db) < 0.000001 ? 0 : (
    cf = clamp(cf, 20, min(20000, srate * 0.49));
    q = clamp(q, 0.35, 8);
    A = exp(gain_db * 0.05756462732485114); // 10^(dB/40)
    w0 = 6.283185307179586 * cf / max(srate, 1);
    sn = sin(w0);
    cs = cos(w0);
    alpha = sn / max(0.000001, 2 * q);

    b0 = 1 + alpha * A;
    b1 = -2 * cs;
    b2 = 1 - alpha * A;
    a0 = 1 + alpha / A;
    a1 = -2 * cs;
    a2 = 1 - alpha / A;

    b0 /= a0; b1 /= a0; b2 /= a0; a1 /= a0; a2 /= a0;

    w = 6.283185307179586 * clamp(freq, 20, min(20000, srate * 0.49)) / max(srate, 1);
    c1 = cos(w); s1 = sin(w);
    c2 = cos(2 * w); s2 = sin(2 * w);

    nre = b0 + b1 * c1 + b2 * c2;
    nim = -(b1 * s1 + b2 * s2);
    dre = 1 + a1 * c1 + a2 * c2;
    dim = -(a1 * s1 + a2 * s2);

    mag2 = (nre * nre + nim * nim) / max(0.000000000001, dre * dre + dim * dim);
    10 * log(max(0.000000000001, mag2)) * LOG10_INV;
  );
);

function proc_cut_slope_db(idx)
(
  idx <= 0 ? 6 : idx * 12;
);

function proc_eq_resp_db(freq) local(resp hpfhz lpfhz slope r octv)
(
  // UI response reads sliders directly so graph movement is immediate.
  resp = 0;
  resp += proc_band_resp(freq, clamp(slider35, 20, 20000), clamp(slider40, 0.35, 8), clamp(slider32, -18, 18));
  resp += proc_band_resp(freq, clamp(slider36, 20, 20000), clamp(slider41, 0.35, 8), clamp(slider33, -18, 18));
  resp += proc_band_resp(freq, clamp(slider37, 20, 20000), clamp(slider42, 0.35, 8), clamp(slider34, -18, 18));

  hpfhz = clamp(slider38, 20, 1000);
  hpfhz > 22 ? (
    resp += posteq_cut_res_resp_db(freq, hpfhz, slider45);
    freq < hpfhz ? (
      slope = proc_cut_slope_db(clamp(slider43 | 0, 0, 4));
      octv = log(hpfhz / max(freq, 1)) / log(2);
      resp -= slope * octv;
    );
  );

  lpfhz = clamp(slider39, 1000, 20000);
  lpfhz < min(19000, srate * 0.47) ? (
    resp += posteq_cut_res_resp_db(freq, lpfhz, slider46);
    freq > lpfhz ? (
      slope = proc_cut_slope_db(clamp(slider44 | 0, 0, 4));
      octv = log(max(freq, 1) / lpfhz) / log(2);
      resp -= slope * octv;
    );
  );

  clamp(resp, -42, 18);
);

function proc_draw_node(cx cy r hot active label_id) local(tw th)
(
  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.42;
  gfx_circle(cx + 1, cy + 2, r + 3, 1);
  gfx_r = active ? 0.96 : (hot ? 0.34 : 0.08);
  gfx_g = active ? 0.72 : (hot ? 0.62 : 0.22);
  gfx_b = active ? 0.18 : (hot ? 0.96 : 0.36);
  gfx_a = 1;
  gfx_circle(cx, cy, r + 1, 1);
  gfx_r = 0.030; gfx_g = 0.040; gfx_b = 0.055; gfx_a = 1;
  gfx_circle(cx, cy, r - 1, 1);
  gfx_r = active ? 1.0 : 0.74;
  gfx_g = active ? 0.86 : 0.88;
  gfx_b = active ? 0.34 : 1.0;
  gfx_a = 1;
  gfx_setfont(1, "Arial", 9, 0);
  label_id == 0 ? sprintf(#ui_buf, "HP")
  : label_id == 1 ? sprintf(#ui_buf, "1")
  : label_id == 2 ? sprintf(#ui_buf, "2")
  : label_id == 3 ? sprintf(#ui_buf, "3")
  : label_id == 4 ? sprintf(#ui_buf, "LP")
  : sprintf(#ui_buf, "?");
  gfx_measurestr(#ui_buf, tw, th);
  gfx_x = cx - tw * 0.5;
  gfx_y = cy - th * 0.5;
  gfx_drawstr(#ui_buf);
);

function draw_tooltip_box() local(tw1 th1 tw2 th2 tw th pad bx by bw bh)
(
  strlen(#tip_title) > 0 ? (
    pad = 10;

    gfx_setfont(1, "Arial", 13, 0);
    gfx_measurestr(#tip_title, tw1, th1);
    gfx_setfont(1, "Arial", 12, 0);
    gfx_measurestr(#tip_body, tw2, th2);

    tw = max(tw1, tw2);
    th = th1 + th2 + 7;
    bw = tw + pad * 2;
    bh = th + pad * 2;

    bx = clamp(mouse_x + 18, 8, gfx_w - bw - 8);
    by = clamp(mouse_y + 18, 8, gfx_h - bh - 8);

    gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.55;
    gfx_rect(bx + 3, by + 5, bw, bh, 1);
    ui_inner_panel(bx, by, bw, bh);
    gfx_r = 0.36; gfx_g = 0.68; gfx_b = 1.0; gfx_a = 0.55;
    gfx_rect(bx, by, bw, bh, 0);

    gfx_setfont(1, "Arial", 13, 0);
    gfx_r = 0.92; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad - 1;
    gfx_drawstr(#tip_title);

    gfx_setfont(1, "Arial", 12, 0);
    gfx_r = 0.70; gfx_g = 0.80; gfx_b = 0.92; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad + th1 + 4;
    gfx_drawstr(#tip_body);
  );
);

