@serialize
file_var(0, slope_schema);
file_var(0, formant_shift_semi);
file_var(0, auto_release_amt);
file_var(0, posteq_q_schema);
file_var(0, focus_peak_amt);
file_var(0, dynamics_expand_amt);
file_var(0, input_trigger_amt);
file_var(0, clean_decrust_amt);

@slider
attack_samps = max(1, floor(slider2 * srate * 0.001));
decay_samps = max(1, floor(slider3 * srate * 0.001));
sustain_level = clamp01(slider4);
release_samps = max(1, floor(slider5 * srate * 0.001));
hold_samps = max(0, floor(slider20 * srate * 0.001));
mono_source = (slider21 | 0) ? 1 : 0;
dynamics_amt = clamp01(slider22);
dynamics_expand_amt = clamp01(dynamics_expand_amt);
input_trigger_amt = clamp01(input_trigger_amt);
clean_amt = clamp01(slider25);
clean_decrust_amt = clamp01(clean_decrust_amt);
(clean_decrust_amt <= 0.0001 && clean_decrust_active_prev > 0) ? (
  decrust_clear_state();
);
(clean_decrust_amt > 0.0001 && clean_decrust_active_prev <= 0) ? (
  decrust_update_params();
  decrust_clear_state();
);
clean_decrust_active_prev = clean_decrust_amt > 0.0001 ? 1 : 0;
room_amt = clamp01(slider26);
push_amt = clamp01(slider27 / 100);
(slope_schema < 0.5) ? (
  slider28 = env_migrate_old_slope(slider28, ENV_RISE);
  slider29 = env_migrate_old_slope(slider29, ENV_FALL);
  slider30 = env_migrate_old_slope(slider30, ENV_FALL);
  slope_schema = 1;
  sliderchange(MASK_S28 + MASK_S29 + MASK_S30);
);
(posteq_q_schema < 0.5) ? (
  // v25 migration: the old Band Q default was 0.75 and the UI graph overstated
  // its width. If a band is still at that untouched default, move it to the new
  // generous-but-controlled default. User-edited Q values are preserved.
  posteq_q_mask = 0;
  abs(slider40 - 0.75) < 0.0001 ? (slider40 = 1.15; posteq_q_mask += MASK_S40;);
  abs(slider41 - 0.75) < 0.0001 ? (slider41 = 1.15; posteq_q_mask += MASK_S41;);
  abs(slider42 - 0.75) < 0.0001 ? (slider42 = 1.15; posteq_q_mask += MASK_S42;);
  posteq_q_schema = 1;
  posteq_q_mask ? sliderchange(posteq_q_mask);
);
posteq_clamp_mask = 0;
slider40 != clamp(slider40, 0.35, 8) ? (slider40 = clamp(slider40, 0.35, 8); posteq_clamp_mask += MASK_S40;);
slider41 != clamp(slider41, 0.35, 8) ? (slider41 = clamp(slider41, 0.35, 8); posteq_clamp_mask += MASK_S41;);
slider42 != clamp(slider42, 0.35, 8) ? (slider42 = clamp(slider42, 0.35, 8); posteq_clamp_mask += MASK_S42;);
posteq_clamp_mask ? sliderchange(posteq_clamp_mask);

attack_slope_pct = clamp(slider28, -100, 100);
decay_slope_pct = clamp(slider29, -100, 100);
release_slope_pct = clamp(slider30, -100, 100);
(clean_amt <= 0.0001 && clean_active_prev > 0) ? reset_clean_buffers();
(room_amt <= 0.0001 && room_active_prev > 0) ? reset_room_buffers();
(push_amt <= 0.0001 && push_active_prev > 0) ? reset_push_buffers();
clean_active_prev = clean_amt > 0.0001 ? 1 : 0;
room_active_prev = room_amt > 0.0001 ? 1 : 0;
push_active_prev = push_amt > 0.0001 ? 1 : 0;
onset_mode_target = clamp(slider23 | 0, 0, 1);
bank_budget_mb = max(0, slider24);
attack_coef = attack_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / attack_samps));
decay_coef = decay_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / decay_samps));
release_coef = release_samps <= 1 ? 0 : exp(-6.90775527898214 / release_samps);
truth_mix = clamp01(slider10);
out_trim = db2amp(slider11);
pitch_semi = clamp(slider12, -24, 24);
formant_shift_semi = clamp(formant_shift_semi, -12, 12);
focus_peak_amt = clamp(focus_peak_amt, -1, 1);
auto_release_amt = clamp(auto_release_amt, 0, 1);
proc_eq_band1_db = clamp(slider32, -18, 18);
proc_eq_band2_db = clamp(slider33, -18, 18);
proc_eq_band3_db = clamp(slider34, -18, 18);
proc_eq_band1_hz = clamp(slider35, 20, 20000);
proc_eq_band2_hz = clamp(slider36, 20, 20000);
proc_eq_band3_hz = clamp(slider37, 20, 20000);
proc_hpf_hz = clamp(slider38, 20, 1000);
proc_lpf_hz = clamp(slider39, 1000, 20000);
proc_eq_band1_q = clamp(slider40, 0.35, 8);
proc_eq_band2_q = clamp(slider41, 0.35, 8);
proc_eq_band3_q = clamp(slider42, 0.35, 8);
proc_hpf_slope_idx = clamp(slider43 | 0, 0, 4);
proc_lpf_slope_idx = clamp(slider44 | 0, 0, 4);
proc_hpf_q = clamp(slider45, 0.35, 4.0);
proc_lpf_q = clamp(slider46, 0.35, 4.0);
selection_mode = clamp(slider13 | 0, 0, 2);
sequence_mode = selection_mode == 1 ? 1 : 0;
walk_mode = selection_mode == 2 ? 1 : 0;
stretch_ratio = clamp(slider14, 1, 4);
stretch_norm = clamp01((stretch_ratio - 1) / 3);
// v36: in Granular only, Stretch becomes an event-scale control. Smoothstep
// keeps 1x identical and most of the range sane, with the slow coherent behavior
// arriving progressively toward 4x.
granular_event_stretch = stretch_norm * stretch_norm * (3 - 2 * stretch_norm);
weight_amt = clamp01(slider15);
transient_mode = clamp(slider16 | 0, 0, 2);
playback_mode = clamp(slider17 | 0, 0, 3);
// v37 PerfGate: switching to Granular after a bank was loaded in Raw/Tape/Hybrid
// builds the corpus here, not per-block and not inside Raw/Tape/Hybrid playback.
(playback_mode == 3 && corpus_dirty > 0 && sample_count > 0) ? build_grain_corpus();
granular_amt = clamp01(slider18);
tail_borrow = clamp01(slider19);
poll_interval_samps = max(1024, floor(0.35 * srate));

stretch_grain_samps = clamp(floor(srate * lerp(0.024, 0.070, stretch_norm)), 192, 4096);
stretch_hop_samps = max(24, floor(stretch_grain_samps * lerp(0.34, 0.22, stretch_norm)));
hybrid_grain_samps = clamp(floor(srate * lerp(0.028, 0.090, granular_amt) * lerp(1.0, 1.30, stretch_norm)), 160, 4096);
hybrid_grain_samps = max(160, 4 * floor(hybrid_grain_samps / 4));
hybrid_hop_samps = max(20, floor(hybrid_grain_samps * 0.25));
hybrid_body_jitter = max(6, floor(hybrid_grain_samps * (0.04 + 0.18 * slider9)));
hybrid_tail_jitter = max(24, floor(hybrid_grain_samps * (0.16 + 0.28 * tail_borrow + 0.10 * slider9)));
release_handoff_samps = clamp(floor(min(release_samps * 0.30, max(srate * 0.020, hybrid_grain_samps * 0.70))), 32, floor(srate * 0.090));
seam_bridge_samps = clamp(
  floor(max(attack_samps * 0.85, min(release_samps * 0.30, srate * 0.18))),
  max(8, floor(srate * 0.012)),
  max(16, floor(srate * 0.420))
);
seam_bridge_release_coef = exp(-6.90775527898214 / max(1, seam_bridge_samps));

weight_scale = 1 + stretch_norm * 1.8;
weight_ap1_len = clamp(floor(srate * (0.0032 * weight_scale)), 16, AP_BUF_LEN - 1);
weight_ap2_len = clamp(floor(srate * (0.0066 * weight_scale)), 24, AP_BUF_LEN - 1);
weight_tap1 = clamp(floor(srate * (0.0085 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap2 = clamp(floor(srate * (0.0135 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap3 = clamp(floor(srate * (0.0205 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap4 = clamp(floor(srate * (0.0315 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap5 = clamp(floor(srate * (0.0470 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap6 = clamp(floor(srate * (0.0680 * weight_scale)), 1, ER_BUF_LEN - 1);

weight_mix = weight_amt * (0.10 + 0.42 * max(stretch_norm, 0.35));
weight_body = weight_amt * (0.02 + 0.10 * max(stretch_norm, 0.25));
weight_sat = weight_amt * (0.01 + 0.05 * stretch_norm);
weight_ap_g1 = clamp(0.10 + weight_amt * (0.28 + 0.10 * stretch_norm), 0, 0.72);
weight_ap_g2 = clamp(0.08 + weight_amt * (0.25 + 0.14 * stretch_norm), 0, 0.72);
weight_in_coeff = clamp((1400 - 700 * stretch_norm) / max(srate, 1), 0.002, 0.12);
weight_wet_coeff = clamp((900 - 350 * stretch_norm) / max(srate, 1), 0.001, 0.08);

tone_lp_coeff = clamp(1900 / max(srate, 1), 0.005, 0.18);
focus_lp_coeff = clamp(4400 / max(srate, 1), 0.01, 0.40);
env_att_coeff = clamp(1200 / max(srate, 1), 0.02, 0.5);
env_rel_coeff = clamp(60 / max(srate, 1), 0.001, 0.12);
m2e_smooth_coeff = clamp(42 / max(srate, 1), 0.0006, 0.02);
m2e_mode_coeff = clamp(24 / max(srate, 1), 0.0004, 0.02);
m2e_detect_window_samps = max(1024, floor(0.75 * srate));
m2e_timeout_samps = max(2048, floor(1.7 * srate));
input_trig_fast_att = 1 - exp(-6.90775527898214 / max(1, floor(0.0035 * srate)));
input_trig_fast_rel = 1 - exp(-6.90775527898214 / max(1, floor(0.055 * srate)));
input_trig_slow_att = 1 - exp(-6.90775527898214 / max(1, floor(0.060 * srate)));
input_trig_slow_rel = 1 - exp(-6.90775527898214 / max(1, floor(0.420 * srate)));
input_trig_floor_up = 1 - exp(-6.90775527898214 / max(1, floor(3.5 * srate)));
input_trig_floor_down = 1 - exp(-6.90775527898214 / max(1, floor(0.220 * srate)));
input_trig_env_att = 1 - exp(-6.90775527898214 / max(1, floor(0.009 * srate)));
input_trig_env_rel = 1 - exp(-6.90775527898214 / max(1, floor(0.095 * srate)));

dyn_drive = 1 + dynamics_amt * 2.6;
dyn_thresh = lerp(0.98, 0.42, dynamics_amt);
dyn_ratio = lerp(1, 6.5, dynamics_amt);
dyn_makeup = 1 + dynamics_amt * 0.75;
dyn_sat_mix = dynamics_amt * (0.08 + 0.30 * dynamics_amt);
dyn_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.006 * srate)));
dyn_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.160 * srate)));
dyn_gain_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.004 * srate)));
dyn_gain_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.120 * srate)));
dyn_lim_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0015 * srate)));
dyn_lim_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.070 * srate)));
dyn_ceiling = 0.985 - 0.01 * dynamics_amt;
dynx_fast_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0025 * srate)));
dynx_fast_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.060 * srate)));
dynx_slow_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.110 * srate)));
dynx_slow_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.620 * srate)));
dynx_gain_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0040 * srate)));
dynx_gain_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.038 * srate)));

clean_lp_c1 = clamp(1 - exp(-6.283185307179586 * 180 / max(srate, 1)), 0.0001, 0.60);
clean_lp_c2 = clamp(1 - exp(-6.283185307179586 * 720 / max(srate, 1)), 0.0002, 0.72);
clean_lp_c3 = clamp(1 - exp(-6.283185307179586 * 2600 / max(srate, 1)), 0.0005, 0.86);
clean_lp_c4 = clamp(1 - exp(-6.283185307179586 * 7800 / max(srate, 1)), 0.0010, 0.94);
clean_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0045 * srate)));
clean_env_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.220 + 0.360 * (1 - clean_amt)) * srate)));
clean_slow_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.360 + 1.450 * (1 - clean_amt)) * srate)));
clean_slow_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.160 + 0.460 * (1 - clean_amt)) * srate)));
clean_floor_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor((1.150 + 3.200 * (1 - clean_amt)) * srate)));
clean_floor_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.090 + 0.220 * (1 - clean_amt)) * srate)));
clean_gain_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.010 + 0.018 * (1 - clean_amt)) * srate)));
clean_gain_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.075 + 0.180 * (1 - clean_amt)) * srate)));
clean_gain_protect_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.005 * srate)));
clean_thresh_floor = 1.05 + clean_amt * 5.80;
clean_thresh_env = 0.0020 + clean_amt * 0.034;
clean_abs_floor = 0.00000018 + clean_amt * 0.0000022;
clean_expand_pow = 0.72 + clean_amt * 3.30;
clean_min_gain = db2amp(-(3.0 + 27.0 * (clean_amt ^ 1.18)));

room_lp_c1 = clamp(1 - exp(-6.283185307179586 * 220 / max(srate, 1)), 0.0001, 0.62);
room_lp_c2 = clamp(1 - exp(-6.283185307179586 * 950 / max(srate, 1)), 0.0002, 0.76);
room_lp_c3 = clamp(1 - exp(-6.283185307179586 * 3800 / max(srate, 1)), 0.0005, 0.88);
room_lp_c4 = clamp(1 - exp(-6.283185307179586 * 9000 / max(srate, 1)), 0.0010, 0.95);
room_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.010 * srate)));
room_env_fast_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.085 * srate)));
room_env_slow_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.180 * srate)));
room_env_slow_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.850 * srate)));
room_band_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.006 * srate)));
room_band_fast_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.060 * srate)));
room_band_slow_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.190 * srate)));
room_band_slow_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.900 * srate)));
room_late_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.035 * srate)));
room_late_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.260 * srate)));
room_gain_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.011 + 0.012 * (1 - room_amt)) * srate)));
room_gain_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.180 + 0.260 * room_amt) * srate)));
room_min_gain0 = db2amp(-(0.6 + 3.2 * room_amt));
room_min_gain1 = db2amp(-(2.2 + 17.0 * room_amt));
room_min_gain2 = db2amp(-(1.8 + 14.5 * room_amt));
room_min_gain3 = db2amp(-(0.9 + 9.0 * room_amt));
room_min_gain4 = db2amp(-(0.4 + 5.0 * room_amt));

push_lp15_c = clamp(1 - exp(-6.283185307179586 * min(1500, srate * 0.49) / max(srate, 1)), 0.0001, 0.80);
push_lp32_c = clamp(1 - exp(-6.283185307179586 * min(3200, srate * 0.49) / max(srate, 1)), 0.0002, 0.88);
push_lp55_c = clamp(1 - exp(-6.283185307179586 * min(5500, srate * 0.49) / max(srate, 1)), 0.0003, 0.93);
push_a_lev = 1 - exp(-1 / max(1, floor(0.110 * srate)));
push_a_src = 1 - exp(-1 / max(1, floor(0.160 * srate)));
push_a_fast = 1 - exp(-1 / max(1, floor(0.020 * srate)));
push_a_slow = 1 - exp(-1 / max(1, floor(0.520 * srate)));
push_preserve = clamp(0.82 - 0.52 * push_amt, 0.22, 0.82);
push_trans_w = (0.08 + 1.15 * push_amt) * (0.70 + 0.30 * (1 - push_preserve));
push_side_w = (0.45 + 0.90 * push_amt) * (1 - 0.35 * push_preserve);
push_max_common_dB = 18.0 * (push_amt ^ 1.10);
push_max_side_dB = 12.0 * (push_amt ^ 1.20);
push_broad_static_dB = 7.0 * push_amt * push_amt;
push_common_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.070 + 0.045 * (1 - push_amt)) * srate)));
push_common_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.750 + 1.650 * push_amt) * srate)));
push_side_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.110 + 0.060 * (1 - push_amt)) * srate)));
push_side_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.900 + 1.900 * push_amt) * srate)));

proc_hpf_coeff = clamp(1 - exp(-6.283185307179586 * min(proc_hpf_hz, srate * 0.49) / max(srate, 1)), 0.00002, 0.72);
proc_lpf_coeff = clamp(1 - exp(-6.283185307179586 * min(proc_lpf_hz, srate * 0.49) / max(srate, 1)), 0.00010, 0.96);
posteq_spec_stride = POSTEQ_SPEC_STRIDE;
posteq_spec_att_coeff = 1 - exp(-posteq_spec_stride / max(1, floor(0.010 * srate)));
posteq_spec_rel_coeff = 1 - exp(-posteq_spec_stride / max(1, floor(0.145 * srate)));
posteq_update_coeffs();

form_lp_c1 = clamp(1 - exp(-6.283185307179586 * min(190, srate * 0.49) / max(srate, 1)), 0.0001, 0.72);
form_lp_c2 = clamp(1 - exp(-6.283185307179586 * min(520, srate * 0.49) / max(srate, 1)), 0.0002, 0.78);
form_lp_c3 = clamp(1 - exp(-6.283185307179586 * min(1250, srate * 0.49) / max(srate, 1)), 0.0003, 0.84);
form_lp_c4 = clamp(1 - exp(-6.283185307179586 * min(3000, srate * 0.49) / max(srate, 1)), 0.0005, 0.90);
form_lp_c5 = clamp(1 - exp(-6.283185307179586 * min(7200, srate * 0.49) / max(srate, 1)), 0.0010, 0.95);
form_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.010 * srate)));
form_env_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.135 * srate)));
form_gain_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.018 * srate)));
form_level_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.045 * srate)));
fpk_lp_c1 = clamp(1 - exp(-6.283185307179586 * min(320, srate * 0.49) / max(srate, 1)), 0.0001, 0.74);
fpk_lp_c2 = clamp(1 - exp(-6.283185307179586 * min(980, srate * 0.49) / max(srate, 1)), 0.0002, 0.82);
fpk_lp_c3 = clamp(1 - exp(-6.283185307179586 * min(2900, srate * 0.49) / max(srate, 1)), 0.0004, 0.90);
fpk_lp_c4 = clamp(1 - exp(-6.283185307179586 * min(8200, srate * 0.49) / max(srate, 1)), 0.0010, 0.96);
fpk_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0045 * srate)));
fpk_env_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.105 * srate)));
fpk_gain_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.014 * srate)));
fpk_level_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.040 * srate)));
fpk_update_coeffs();

(onset_mode_target != onset_mode_active) ? (
  onset_mode_active = onset_mode_target;
  sample_count > 0 ? (
    release_all_voices_transport(1);
    reanalyze_bank();
  );
);

((slider1 | 0) > 0) ? (
  force_rescan_flag = 1;
  slider1 = 0;
  sliderchange(MASK_S1);
);

@block
m2e_clock_samps += samplesblock;

group_poll_counter += samplesblock;
(group_poll_counter >= group_poll_interval_samps || group_poll_counter < 0) ? (
  group_poll_counter = 0;
  group_poll_track_name(0);
  group_write_heartbeat(count_active_voices() > 0 || input_trig_gate > 0, max(input_trig_env, mix_fast));
  group_refresh_state();
);

// Transport panic/seek reconciliation. REAPER does not guarantee MIDI note-offs
// when playback is paused, stopped, or the edit cursor jumps while a note is
// sounding. Treat those discontinuities as an all-notes-off and hard-clear the
// sampler voices so held Hybrid/Tape notes cannot become orphaned.
transport_running = (play_state & 1) ? 1 : 0;
transport_paused = (play_state & 2) ? 1 : 0;
transport_stopped = play_state == 0;
transport_discontinuity = 0;

transport_play_state_prev < 0 ? (
  transport_play_state_prev = play_state;
  transport_playpos_prev = play_position;
);

transport_running && transport_playpos_prev >= 0 ? (
  transport_expected_pos = transport_playpos_prev + samplesblock / max(srate, 1);
  transport_seek_tol = max(0.050, 3 * samplesblock / max(srate, 1));
  abs(play_position - transport_expected_pos) > transport_seek_tol ? transport_discontinuity = 1;
);

((transport_paused || transport_stopped) && transport_running_prev) ? (
  transport_discontinuity = 1;
);

transport_discontinuity ? (
  release_all_voices_transport(1);
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
);

transport_running ? (
  transport_running_prev = 1;
  transport_playpos_prev = play_position;
) : (
  transport_running_prev = 0;
  transport_playpos_prev = -1;
);

transport_play_state_prev = play_state;

force_rescan_flag ? (
  poll_slot(1);
  force_rescan_flag = 0;
  poll_counter = 0;
);

poll_counter += samplesblock;
while (poll_counter >= poll_interval_samps) (
  poll_counter -= poll_interval_samps;
  poll_slot(0);
);

while (midirecv(offset, msg1, msg23)) (
  status = msg1 & 240;
  chan   = msg1 & 15;
  note   = msg23 & 127;
  vel    = (msg23 / 256) & 127;

  status == 176 ? (
    (chan == M2E_CHAN) ? (
      ccnum = note;
      ccval = vel;

      (ccnum >= M2E_BASE_FIXED && ccnum < (M2E_BASE_FIXED + M2E_LANE_COUNT)) ? (
        m2e_cc_age_base[ccnum] = m2e_clock_samps;
        m2e_cc_val_base[ccnum] = ccval;
        m2e_last_any_cc_samps = m2e_clock_samps;

        m2e_base = M2E_BASE_FIXED;
        m2e_last_msg_samps = m2e_clock_samps;
        m2e_apply_cc(m2e_base, ccnum, ccval);
      );
    );

    bank_loaded && (note == 120 || note == 123) ? (
      reset_note_gates();
      release_all_voices_transport(note == 120);
    );

    midisend(offset, msg1, msg23);
  ) : (
    (status == 144 && vel > 0) ? (
      bank_loaded ? (
        note_gate_on(note, chan);
        start_voice(note, vel, chan);
        group_report_onset(vel / 127);
      ) : midisend(offset, msg1, msg23);
    ) : (
      (status == 128 || (status == 144 && vel == 0)) ? (
        bank_loaded ? (
          note_gate_off(note, chan);
          release_voice(note, chan);
        ) : midisend(offset, msg1, msg23);
      ) : (
        midisend(offset, msg1, msg23);
      );
    );
  );
);

cand_base = m2e_detect_base(m2e_clock_samps);
cand_base >= 0 ? (
  m2e_base = M2E_BASE_FIXED;
  m2e_decode_snapshot(m2e_base);
  m2e_active = 1;
);

(m2e_active && ((m2e_clock_samps - m2e_last_msg_samps) > m2e_timeout_samps)) ? (
  m2e_active = 0;
);

m2e_target = m2e_active ? 1 : 0;

rescan_pending ? (
  (!voices_busy() || rescan_force) ? (
    load_bank();
    slot_signature_loaded = pending_signature;
    rescan_pending = 0;
    rescan_force = 0;
  );
);

@sample
dry_in_l = spl0;
dry_in_r = spl1;
input_detect_l = dry_in_l;
input_detect_r = dry_in_r;
input_trigger_armed = (playback_mode == 3 && input_trigger_amt > 0.0001 && bank_loaded) ? 1 : 0;
input_trigger_armed ? (
  input_trigger_was_armed = 1;
  // Texture-injection mode: the incoming audio is never processed or muted here.
  // It passes through dry, while its dBFS envelope triggers/scales only Granular.
  process_granular_input_trigger(input_detect_l, input_detect_r);
) : (
  input_trigger_was_armed ? (
    (input_trig_gate > 0 || count_audio_trigger_voices() > 0) ? release_audio_trigger_voices(0);
    input_trigger_was_armed = 0;
  );
  input_trig_gate = 0;
  input_trig_silence = 0;
  input_trig_env += (0 - input_trig_env) * input_trig_env_rel;
  input_trig_fast += (0 - input_trig_fast) * input_trig_fast_rel;
  input_trig_slow += (0 - input_trig_slow) * input_trig_slow_rel;
);

outL = 0;
outR = 0;
active_voice_seen = 0;
punch_bus = 0;
clean_head_bus = 0;
clean_tail_bus = 0;
room_head_bus = 0;
room_tail_bus = 0;
denorm_guard = denorm_guard_tick();

i = 0;
while (i < MAX_VOICES) (
  v = voice_base + i * VC_STRIDE;

  v[VC_ACTIVE] > 0 ? (
    active_voice_seen = 1;
    sid = v[VC_SAMPLE] | 0;
    sm  = sample_meta_base + sid * SM_STRIDE;
    frames = sm[SM_FRAMES] | 0;
    ptr = sm[SM_PTR] | 0;
    nch = max(1, sm[SM_NCH] | 0);

    stage = v[VC_STAGE] | 0;
    tleft = max(0, floor(v[VC_TLEFT]));
    rel_handoff_left = max(0, floor(v[VC_RHLEFT]));
    rel_handoff_len = max(1, floor(v[VC_RHLEN]));
    rel_handoff_mix = 1 - rel_handoff_left / rel_handoff_len;
    body_start = max(0, floor(v[VC_BODYSTART]));
    tailstart = clamp(floor(v[VC_TAILSTART]), body_start, max(body_start, frames - 2));
    body_end = clamp(floor(v[VC_BODYEND]), body_start + 1, max(body_start + 1, frames - 2));
    granular_voice = (v[VC_MODE] == 3) ? 1 : 0;
    grain_slot_limit = granular_voice ? NUM_GRAINS : HYBRID_GRAINS;
    gesture_arc = 0;
    gesture_drive = 0;
    v[VC_GMODE] > 0 ? (
      gphase = v[VC_GPHASE] + 1 / max(1, v[VC_GLEN]);
      gphase >= 1 ? (
        gphase -= floor(gphase);
        v[VC_GLEN] = max(64, floor(srate * lerp(0.24, 1.35, rand(1)) * lerp(0.82, 1.18, stretch_norm) * (granular_voice ? lerp(1.0, 2.75, granular_event_stretch) : 1)));
        v[VC_GACCENT] = rand(1);
      );
      v[VC_GPHASE] = gphase;
      gesture_arc = sin(gphase * 3.141592653589793);
      gesture_arc = gesture_arc * gesture_arc;
      gesture_drive = clamp01(v[VC_GDEPTH] * gesture_arc);
    );

    hybrid_body_release = (v[VC_GMODE] > 0 && stage == ENV_RELEASE && v[VC_GMIX] > 0.0001) ? 1 : 0;
    hybrid_tail_release = (stage == ENV_RELEASE && !hybrid_body_release && v[VC_TAILMIX] > 0.0001) ? 1 : 0;

    // In Hybrid granular release, keep the body-grain engine running and let the
    // Release envelope do the fade. Only force the tail path when there is no
    // granular body layer available and Tail Borrow is acting as the release source.
    (v[VC_GMODE] > 0 && stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
      v[VC_POS] < tailstart ? v[VC_POS] = tailstart;
      v[VC_NEXTSRC] < tailstart ? v[VC_NEXTSRC] = tailstart;
    );

    rawL = 0;
    rawR = 0;
    grainL = 0;
    grainR = 0;
    got_raw = 0;
    got_grain = 0;
    direct_alive = 0;
    activeg = 0;

    // Hybrid: direct playback carries the head and core identity.
    // Granular: the same path remains as a silent timing/source-exhaustion clock.
    pos = v[VC_POS];
    held_body_only = (v[VC_GMODE] > 0 && (stage != ENV_RELEASE || hybrid_body_release));
    body_cutoff = max(body_start + 1, tailstart);
    held_body_only && pos >= body_cutoff ? (
      pos = body_cutoff;
      v[VC_POS] = pos;
    ) : (
      ip = pos | 0;
      ip < (frames - 1) ? (
        got_raw = sample_frame2(ptr, nch, pos);
        rawL = readL;
        rawR = readR;
        direct_alive = got_raw;

        // v19: source-end guard. If a file ends hot, fade the final source
        // window before EOF instead of letting playback vanish on the last frame.
        endfade_src = max(2, floor(sm[SM_ENDFADE] * auto_release_amt * sm[SM_SR] * 0.001));
        endfade_src = min(endfade_src, max(2, floor(frames * 0.42)));
        rem_src = max(0, frames - 1 - pos);
        source_end_fade = clamp01(rem_src / max(1, endfade_src));
        source_end_fade = source_end_fade * source_end_fade * (3 - 2 * source_end_fade);
        rawL *= source_end_fade;
        rawR *= source_end_fade;
        source_end_fade <= 0.0003 ? direct_alive = 0;

        play_rate = v[VC_RATE];
        voice_stretch = max(1, v[VC_STRETCH]);
        (tleft > 0 && v[VC_TPROT] > 0) ? (
          holdn = clamp01(tleft / max(1, v[VC_THOLD]));
          // Smoothstep crossfade from protected transient rate to stretched / pitched body rate.
          holdn = holdn * holdn * (3 - 2 * holdn);
          play_rate = lerp(play_rate, v[VC_ATKRATE], holdn * v[VC_TPROT]);
        );

        pos += play_rate;
        held_body_only && pos >= body_cutoff ? (
          pos = body_cutoff;
          direct_alive = 0;
        );
        v[VC_POS] = pos;
        pos >= (frames - 1) ? direct_alive = 0;
      );
    );

    granular_voice ? (
      got_raw = 0;
      rawL = 0;
      rawR = 0;
    );

    tleft > 0 ? (
      tleft -= 1;
      v[VC_TLEFT] = tleft;
    );

    // Hybrid overlays granular body/tail material after the protected head.
    // Granular reuses this same conservative core with the direct path muted.
    hybrid_release_only = hybrid_tail_release;
    (v[VC_GMODE] > 0 && (v[VC_GMIX] > 0.0001 || hybrid_release_only)) ? (
      (stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
        v[VC_NEXTSRC] < tailstart ? v[VC_NEXTSRC] = tailstart;
      );

      gran_hold_guard = (!granular_voice && (stage == ENV_ATTACK || stage == ENV_HOLD) && direct_alive) ? 1 : 0;
      (tleft <= 0 && !gran_hold_guard) ? (
        hop = max(1, floor(v[VC_OHOP]));
        gsize = max(hop + 1, floor(v[VC_GSIZE]));
        gran_hop_floor = 1;
        granular_voice ? (
          gran_hop_floor = max(floor(srate * 0.0055), floor(gsize * 0.115));
          hop = max(gran_hop_floor, floor(hop * (1 - gesture_drive * 0.20)));
        );
        timer = floor(v[VC_GTIMER]) - 1;
        schedule_prefill = granular_voice ? max(0, -timer) : 0;
        spawn_guard = 0;

        while (timer <= 0 && spawn_guard < grain_slot_limit && v[VC_CANSPAWN] > 0) (
          schedule_prefill = granular_voice ? max(0, -timer) : 0;
          gslot = -1;
          oldest = 0;
          oldest_age = -1;

          gk = 0;
          while (gk < grain_slot_limit) (
            gb = v + VC_GBASE + gk * VG_STRIDE;
            gb[VG_ACTIVE] <= 0 ? (
              gslot = gk;
              gk = grain_slot_limit;
            ) : (
              gb[VG_AGE] > oldest_age ? (
                oldest_age = gb[VG_AGE];
                oldest = gk;
              );
              gk += 1;
            );
          );

          gslot < 0 ? gslot = oldest;
          gb = v + VC_GBASE + gslot * VG_STRIDE;

          source_exhausted = !direct_alive && !(stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left > 0);
          gsid = sid;
          gsm = sm;
          gframes = frames;
          gsrc = body_start;
          grate = v[VC_RATE];
          ggain = 1;
          ghist_lo = body_start;
          ghist_hi = max(body_start + 1, body_end);

          (stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
            donor_blend = clamp01(v[VC_TAILMIX]);
            self_lo = tailstart;
            self_hi = max(self_lo + 1, frames - 2);
            self_span = max(1, self_hi - self_lo);

            donor = v[VC_DONOR] | 0;
            donor < 0 ? donor = sid;
            donor_sm = sample_meta_base + donor * SM_STRIDE;
            donor_frames = donor_sm[SM_FRAMES] | 0;
            donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_frames - 2));
            donor_hi = max(donor_tail + 1, donor_frames - 2);
            donor_phase = clamp01((max(v[VC_DONORPOS], donor_tail) - donor_tail) / max(1, donor_hi - donor_tail));
            self_phase = clamp01((max(v[VC_POS], tailstart) - tailstart) / max(1, self_hi - self_lo));
            tail_phase01 = max(self_phase, donor_phase);

            self_pos = choose_region_pos(i, sid, 1, tail_phase01, 0.28 + 0.46 * donor_blend + 0.14 * slider9);
            self_pen = grain_hist_penalty(i, sid, self_pos, self_lo, self_hi);

            alt_sid = donor_blend > 0.001 ? choose_region_donor(sid, 1, clamp01(donor_blend * 0.55 + self_pen * 0.10 + 0.18), i) : sid;
            alt_sid != sid ? (
              alt_pos = choose_region_pos(i, alt_sid, 1, tail_phase01, 0.42 + 0.46 * donor_blend + 0.18 * slider9);
              alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
              alt_lo = clamp(alt_sm[SM_TAILSTART], 0, max(0, alt_sm[SM_FRAMES] - 2));
              alt_hi = max(alt_lo + 1, alt_sm[SM_FRAMES] - 2);
              alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

              (alt_pen > self_pen + 0.55 && sample_count > 2) ? (
                alt_sid2 = choose_region_donor(sid, 1, 1, i);
                (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                  alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                  alt_lo2 = clamp(alt_sm2[SM_TAILSTART], 0, max(0, alt_sm2[SM_FRAMES] - 2));
                  alt_hi2 = max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2);
                  alt_pos2 = choose_region_pos(i, alt_sid2, 1, tail_phase01, 0.55 + 0.22 * slider9);
                  alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                  alt_pen2 < alt_pen ? (
                    alt_sid = alt_sid2;
                    alt_sm = alt_sm2;
                    alt_lo = alt_lo2;
                    alt_hi = alt_hi2;
                    alt_pos = alt_pos2;
                    alt_pen = alt_pen2;
                  );
                );
              );

              use_alt = (alt_pen + 0.12 < self_pen) || (rand(1) < donor_blend * (0.42 + 0.14 * clamp01(self_pen * 0.30) + 0.12 * source_exhausted));
              granular_voice ? (
                use_alt = use_alt && (source_exhausted || self_pen > 2.90 || rand(1) < donor_blend * (0.16 + 0.14 * slider9));
              );
            ) : (
              use_alt = 0;
            );

            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.90 + 0.10 * tail_phase01;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
              v[VC_DONOR] = alt_sid;
              v[VC_DONORPOS] = min(max(alt_lo, alt_pos + hop * abs(grate) * (0.78 + 0.44 * rand(1))), max(alt_lo, alt_hi - 1));
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = self_lo;
              ghist_hi = self_hi;
              v[VC_DONOR] = sid;
              v[VC_DONORPOS] = min(max(self_lo, self_pos + hop * abs(grate) * (0.72 + 0.36 * rand(1))), max(self_lo, self_hi - 1));
            );
          ) : (
            grow_lo = body_start;
            grow_hi = min(max(grow_lo + 1, body_end), max(grow_lo + 1, frames - 2));
            grow_span = max(1, grow_hi - grow_lo);

            hybrid_body_release ? (
              // Release is one-way through the body window. Do not wrap back to
              // the start and do not widen to body donors; both can sound like a
              // second hit after a short one-shot has already finished.
              grow_cursor = clamp(v[VC_NEXTSRC], grow_lo, max(grow_lo, grow_hi - 1));
              grow_phase01 = clamp01((grow_cursor - grow_lo) / max(1, grow_span - 1));
              advance = v[VC_SRCHOP] * (0.72 + 0.22 * rand(1));
              nextsrc = grow_cursor + advance;
              wrapped = nextsrc >= grow_hi;
              wrapped ? (
                nextsrc = max(grow_lo, grow_hi - 1);
                v[VC_CANSPAWN] = 0;
              );
              v[VC_NEXTSRC] = nextsrc;
              source_exhausted = 0;

              release_jitter = min(max(2, floor(v[VC_GSIZE] * 0.08)), max(2, floor(grow_span * 0.10)));
              self_pos = clamp(grow_cursor + (rand(1) - 0.5) * release_jitter, grow_lo, max(grow_lo, grow_hi - 1));
              self_pen = 0;
            ) : (
              grow_cursor = wrap_in_range(v[VC_NEXTSRC], grow_lo, grow_hi);
              grow_phase01 = clamp01((grow_cursor - grow_lo) / max(1, grow_span - 1));
              grow_phase_pick = grow_phase01;
              granular_voice ? (
                // Crescendo motion pulls the grain cursor toward earlier body/head color,
                // not raw attack retriggering. Hybrid itself remains unchanged.
                phase_pull = gesture_drive * (0.055 + 0.105 * slider9 + 0.045 * v[VC_TAILMIX]);
                stage == ENV_ATTACK || stage == ENV_HOLD ? phase_pull *= 0.18;
                stage == ENV_RELEASE ? phase_pull *= 0.35;
                grow_phase_pick = clamp01(grow_phase01 - phase_pull);
                cont_phase = grain_follow_phase(v, 0);
                cont_phase >= 0 ? (
                  cont_strength = grain_follow_strength(v, slider9, truth_mix, v[VC_TAILMIX]);
                  grow_phase_pick = phase_lerp_region(grow_phase_pick, cont_phase, cont_strength * 0.55, 0);
                );
              );
              advance = v[VC_SRCHOP] * (0.80 + 0.65 * rand(1));
              nextsrc = grow_cursor + advance;
              wrapped = nextsrc >= grow_hi;
              granular_voice && wrapped ? (
                // v13: grain-only learned flow should not restart the same body
                // window. Hold the silent anchor at the boundary and let learned
                // cross-flow select the next sample event.
                nextsrc = max(grow_lo, grow_hi - 1);
              ) : (
                nextsrc = wrap_in_range(nextsrc, grow_lo, grow_hi);
              );
              source_exhausted ? (
                granular_voice ? (
                  nextsrc = max(grow_lo, grow_hi - 1);
                ) : (
                  nextsrc = wrap_in_range(nextsrc + (rand(1) - 0.5) * grow_span * 0.30, grow_lo, grow_hi);
                );
              );
              v[VC_NEXTSRC] = nextsrc;

              self_pos = choose_region_pos(i, sid, 0, granular_voice ? grow_phase_pick : grow_phase01, 0.18 + 0.48 * slider9 + 0.22 * source_exhausted + (granular_voice ? gesture_drive * 0.10 : 0));
              self_pen = grain_hist_penalty(i, sid, self_pos, grow_lo, grow_hi);
            );

            need_alt = (!hybrid_body_release) && (source_exhausted || wrapped || (self_pen > 2.35) || (grow_span < max(64, floor(v[VC_GSIZE] * 0.55))));
            granular_voice ? (
              // In grain-only mode, the silent direct clock exhausting should
              // not by itself cause donor hopping. Switch only on a boundary,
              // bad repeat pressure, short source span, or Spice-authorized relief.
              need_alt = (!hybrid_body_release) && (
                wrapped
                || (self_pen > (3.15 + 0.65 * (1 - v[VC_TAILMIX])))
                || (grow_span < max(64, floor(v[VC_GSIZE] * 0.55)))
                || (source_exhausted && self_pen > 2.10 && rand(1) < (0.06 + 0.28 * v[VC_TAILMIX]))
              );
            );
            alt_sid = sid;
            alt_pen = 1000000000;

            need_alt && sample_count > 1 ? (
              alt_sid = choose_region_donor(sid, 0, clamp01(0.16 + 0.40 * source_exhausted + 0.20 * wrapped + 0.10 * slider9 + 0.08 * clamp01((self_pen - 1.2) * 0.6)), i);
              alt_sid != sid ? (
                alt_pos = choose_region_pos(i, alt_sid, 0, granular_voice ? grow_phase_pick : grow_phase01, 0.26 + 0.56 * slider9 + 0.24 * source_exhausted + (granular_voice ? gesture_drive * 0.08 : 0));
                alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
                alt_lo = clamp(alt_sm[SM_HEADEND], 0, max(0, alt_sm[SM_TAILSTART] - 1));
                alt_hi = clamp(alt_sm[SM_TAILSTART], alt_lo + 1, max(alt_lo + 1, alt_sm[SM_FRAMES] - 2));
                alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

                (alt_pen > self_pen + 0.65 && sample_count > 2) ? (
                  alt_sid2 = choose_region_donor(sid, 0, 1, i);
                  (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                    alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                    alt_lo2 = clamp(alt_sm2[SM_HEADEND], 0, max(0, alt_sm2[SM_TAILSTART] - 1));
                    alt_hi2 = clamp(alt_sm2[SM_TAILSTART], alt_lo2 + 1, max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2));
                    alt_pos2 = choose_region_pos(i, alt_sid2, 0, grow_phase01, 0.44 + 0.26 * slider9);
                    alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                    alt_pen2 < alt_pen ? (
                      alt_sid = alt_sid2;
                      alt_sm = alt_sm2;
                      alt_lo = alt_lo2;
                      alt_hi = alt_hi2;
                      alt_pos = alt_pos2;
                      alt_pen = alt_pen2;
                    );
                  );
                );
              );
            );

            use_alt = (!hybrid_body_release) && (alt_sid != sid) && (source_exhausted || (alt_pen + 0.18 < self_pen) || (wrapped && rand(1) < 0.65));
            granular_voice ? (
              use_alt = (!hybrid_body_release) && (alt_sid != sid) && (
                (wrapped && rand(1) < (0.72 + 0.20 * slider9))
                || ((self_pen > 2.85) && (alt_pen + 0.58 < self_pen))
                || (source_exhausted && alt_pen + 0.24 < self_pen && rand(1) < (0.10 + 0.40 * v[VC_TAILMIX]))
                || (rand(1) < v[VC_TAILMIX] * slider9 * 0.055 && alt_pen + 0.28 < self_pen)
              );
            );
            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.95;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = grow_lo;
              ghist_hi = grow_hi;
            );
          );

          cur_region_mode = (stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? 1 : 0;
          granular_voice ? (
            follow_phase = hybrid_body_release ? -1 : grain_follow_phase(v, cur_region_mode);
            follow_phase >= 0 ? (
              follow_strength = grain_follow_strength(v, slider9, truth_mix, v[VC_TAILMIX]);
              follow_limit = grain_run_limit(slider9, truth_mix, v[VC_TAILMIX]);
              follow_sid = v[VC_LGSID] | 0;
              follow_can_reuse = (follow_sid >= 0 && follow_sid < sample_count && (v[VC_LGRUN] < follow_limit || gsid == follow_sid)) ? 1 : 0;

              follow_can_reuse && rand(1) < follow_strength ? (
                follow_lo = grain_region_lo(follow_sid, cur_region_mode);
                follow_hi = grain_region_hi(follow_sid, cur_region_mode);
                follow_span = max(1, follow_hi - follow_lo);
                follow_span > max(32, floor(gsize * 0.42)) ? (
                  follow_pos = choose_region_pos(i, follow_sid, cur_region_mode, follow_phase, 0.07 + 0.18 * slider9 + 0.07 * gesture_drive);
                  follow_pen = grain_hist_penalty(i, follow_sid, follow_pos, follow_lo, follow_hi);
                  cur_pen = grain_hist_penalty(i, gsid, gsrc, ghist_lo, ghist_hi);

                  follow_pen <= cur_pen + 1.65 + 0.65 * (1 - v[VC_TAILMIX]) ? (
                    gsid = follow_sid;
                    gsm = sample_meta_base + gsid * SM_STRIDE;
                    gframes = gsm[SM_FRAMES] | 0;
                    gsrc = follow_pos;
                    grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
                    ggain *= gsid == sid ? 1.0 : 0.96;
                    ghist_lo = follow_lo;
                    ghist_hi = follow_hi;
                  ) : (
                    cur_phase = clamp01((gsrc - ghist_lo) / max(1, ghist_hi - ghist_lo - 1));
                    blended_phase = phase_lerp_region(cur_phase, follow_phase, follow_strength * 0.42, cur_region_mode);
                    gsrc = choose_region_pos(i, gsid, cur_region_mode, blended_phase, 0.08 + 0.22 * slider9 + 0.05 * gesture_drive);
                  );
                );
              ) : (
                cur_phase = clamp01((gsrc - ghist_lo) / max(1, ghist_hi - ghist_lo - 1));
                blended_phase = phase_lerp_region(cur_phase, follow_phase, follow_strength * 0.35, cur_region_mode);
                gsrc = choose_region_pos(i, gsid, cur_region_mode, blended_phase, 0.10 + 0.24 * slider9 + 0.05 * gesture_drive);
              );
            );
          );

          gcorpus_idx = -1;
          granular_voice ? (
            // v37 PerfGate: the expensive corpus selector is called only for
