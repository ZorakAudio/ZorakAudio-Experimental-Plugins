            role_cycle = (v[VC_LGRUN] + spawn_guard) % 5;
            corpus_pick_role = (role_cycle == 1 || role_cycle == 3) ? 1 : 0;
            (slider9 > 0.58 && v[VC_TAILMIX] > 0.18 && rand(1) < (0.010 + 0.060 * slider9 * v[VC_TAILMIX] * (0.35 + 0.65 * gesture_arc))) ? corpus_pick_role = 2;
            corpus_pick_grain(i, v, corpus_want_region, gsid, gsrc, ghist_lo, ghist_hi, gsize, slider9, truth_mix, v[VC_TAILMIX], stage);
            corpus_best_idx >= 0 && corpus_best_sid >= 0 && corpus_best_sid < sample_count ? (
              prev_pick_sid = gsid;
              gsid = corpus_best_sid;
              gsrc = corpus_best_pos;
              ghist_lo = corpus_best_lo;
              ghist_hi = corpus_best_hi;
              gcorpus_idx = corpus_best_idx;
              (gsid != prev_pick_sid) ? ggain *= 0.975;
              gsm = sample_meta_base + gsid * SM_STRIDE;
              gframes = gsm[SM_FRAMES] | 0;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
            );
          );

          gsrc_follow_store = gsrc;
          spawn_gsize = gsize;
          gran_slow_glue = 0;
          gran_cbright = gsm[SM_BRIGHT];
          gran_cedge = gsm[SM_EDGE];
          gran_crms = 0.22;
          gran_mscont = 0;
          gran_mstrans = 0;
          gran_evtfrac = 0;
          gran_xcont = 0;
          gran_region = corpus_want_region;
          gpan = 0;
          gxpand = 0;
          genv_dir = 0;
          genv_peak = 0;
          genv_amt = 0;
          genv_level = 0.36;
          prefill_age = 0;
          prefill_src = gsrc;
          gcorpus_idx >= 0 ? (
            gran_gc = grain_corpus_base + gcorpus_idx * GC_STRIDE;
            gran_cbright = gran_gc[GC_BRIGHT];
            gran_cedge = gran_gc[GC_EDGE];
            gran_crms = gran_gc[GC_RMS];
            genv_dir = gran_gc[GC_EDIR];
            genv_peak = gran_gc[GC_EPEAK];
            genv_level = gran_gc[GC_ELEVEL];
            gran_mscont = gran_gc[GC_MSCONT];
            gran_mstrans = gran_gc[GC_MSTRANS];
            gran_evtfrac = gran_gc[GC_EVTFRAC];
            gran_xcont = gran_gc[GC_XCONT];
            gran_region = gran_gc[GC_REGION] | 0;
          );
          // Slow, dark, low-edge material exposes grain boundaries. Give it
          // longer grains, tighter overlap, and less micro-jitter. Bright/HF
          // squelch remains short and lively because it masks edges naturally.
          gran_slow_glue = clamp01((0.70 - gran_cbright) / 0.56) * clamp01((0.42 - gran_cedge) / 0.38);
          // v34: multi-scale continuity is a stronger signal than brightness alone.
          gran_slow_glue = max(gran_slow_glue, max(gran_mscont * 0.92 - gran_mstrans * 0.22, gran_xcont * 0.98 - gran_mstrans * 0.12));
          gran_slow_glue *= clamp01(0.35 + 0.65 * (1 - truth_mix));
          gran_crms < 0.055 ? gran_slow_glue *= 0.55;
          // v36 GranStretch: higher Stretch in Granular favors coherent event
          // playback, but only when the corpus analysis says the material can
          // support it. Bright/transient grains stay fast and purposeful.
          gran_stretch_glue = granular_event_stretch * clamp01(0.14 + 0.36 * gran_mscont + 0.58 * gran_xcont + 0.26 * gran_slow_glue - 0.38 * gran_mstrans);
          gran_slow_glue = clamp01(gran_slow_glue + gran_stretch_glue * (0.42 + 0.26 * (1 - truth_mix)));

          granular_voice ? (
            gran_tail_region = cur_region_mode;

            src_phase_jit = source_phase_jitter_samples(gsid, gran_tail_region, slider9, truth_mix, v[VC_TAILMIX]) * (1 - 0.90 * gran_slow_glue) * (1 - 0.70 * granular_event_stretch);
            gran_tail_region ? (
              gsrc = clamp(gsrc + src_phase_jit, ghist_lo, max(ghist_lo, ghist_hi - 1));
            ) : (
              gsrc = wrap_in_range(gsrc + src_phase_jit, ghist_lo, ghist_hi);
            );

            pitch_jit_cents = (rand(1) - 0.5) * 2 * slider9 * (0.85 + 3.20 * (1 - truth_mix)) * lerp(1.00, 0.45, clamp01(gsm[SM_PITCHCONF] * bank_pitchiness)) * (1 - 0.72 * gran_slow_glue) * (1 - 0.64 * granular_event_stretch);
            grate *= cents_ratio(pitch_jit_cents);

            len_jit = 1 + (rand(1) - 0.5) * slider9 * (0.08 + 0.10 * (1 - truth_mix) + 0.04 * gesture_arc) * (1 - 0.66 * gran_slow_glue) * (1 - 0.62 * max(gran_mscont, gran_xcont)) * (1 - 0.58 * granular_event_stretch);
            spawn_gsize = clamp(
              floor(gsize * len_jit * (1 + gran_slow_glue * (0.70 + 0.62 * (1 - slider9)) + gran_mscont * 0.42 + gran_xcont * 1.10 + gran_stretch_glue * (1.10 + 1.10 * gran_mscont + 2.30 * gran_xcont))),
              max(hop + 1, floor(gsize * 0.72)),
              max(hop + 1, floor(gsize * (1.42 + 2.20 * gran_slow_glue + 0.76 * gran_mscont + 3.20 * gran_xcont + granular_event_stretch * (1.80 + 2.60 * gran_mscont + 4.80 * gran_xcont))))
            );
            gcorpus_idx >= 0 && corpus_best_len > 0 ? (
              corpus_out_len = corpus_best_len / max(0.05, abs(grate));
              gran_len_scale = max(gran_slow_glue, gran_xcont);
              gran_max_ms_base = gran_region == GC_REGION_ATTACK ? 0.125 : (gran_region == GC_REGION_TAIL ? lerp(0.420, 1.250, gran_len_scale) : lerp(0.520, 1.120, gran_len_scale));
              gran_max_ms_slow = gran_region == GC_REGION_ATTACK ? 0.180 : (gran_region == GC_REGION_TAIL ? lerp(0.760, 2.350, gran_len_scale) : lerp(0.820, 2.050, gran_len_scale));
              gran_max_ms = lerp(gran_max_ms_base, gran_max_ms_slow, granular_event_stretch * clamp01(0.22 + 0.78 * gran_len_scale));
              gran_len_amt = clamp01(0.38 + 0.26 * gran_mscont + 0.40 * gran_xcont + 0.22 * (1 - truth_mix) - 0.20 * gran_mstrans + granular_event_stretch * (0.14 + 0.30 * gran_mscont + 0.42 * gran_xcont));
              spawn_gsize = clamp(
                floor(lerp(spawn_gsize, corpus_out_len * (1 + 0.62 * gran_slow_glue + 0.34 * gran_mscont + 0.68 * gran_xcont + granular_event_stretch * (0.42 + 0.92 * gran_mscont + 1.80 * gran_xcont)), gran_len_amt)),
                max(hop + 1, floor(gsize * 0.62)),
                max(hop + 1, min(floor(srate * gran_max_ms), floor(gsize * (1.80 + 6.50 * gran_slow_glue + 2.20 * gran_mscont + 4.80 * gran_xcont + granular_event_stretch * (3.20 + 3.60 * gran_mscont + 7.80 * gran_xcont)))))
              );
            );

            reverse_grain = gran_tail_region && slider9 > 0.55 && v[VC_TAILMIX] > 0.25 && rand(1) < (0.006 + 0.030 * slider9 * v[VC_TAILMIX] * gesture_arc);
            reverse_grain ? (
              rev_span = min(max(1, ghist_hi - ghist_lo - 2), (spawn_gsize - 1) * abs(grate));
              gsrc = clamp(gsrc + rev_span, ghist_lo + rev_span, max(ghist_lo + rev_span, ghist_hi - 1));
              grate = -abs(grate);
              ggain *= 0.92;
            );

            norm_match = clamp(gsm[SM_NORM] / max(sm[SM_NORM], 0.000001), 0.45, 2.10);
            ggain *= lerp(norm_match, 1, truth_mix);
            ggain *= 1 + gesture_drive * (0.08 + 0.10 * v[VC_GMIX]);

            // v33 EnvTrajectory: preserve learned corpus prosody. Previous
            // versions normalized grain gains away in the OLA sum, making wet
            // grains sound monotonic. This macro gain is intentionally moderate;
            // the per-grain shape below carries the motion.
            genv_amt = clamp01((0.30 + 0.34 * slider9 + 0.24 * (1 - truth_mix) + 0.18 * gesture_arc) * (0.72 + 0.28 * v[VC_GMIX]));
            genv_level = clamp01(genv_level);
            v[VC_GENV] <= 0 ? ( v[VC_GENV] = genv_level; );
            v[VC_GENV] = lerp(v[VC_GENV], genv_level, 0.16 + 0.18 * slider9 + 0.12 * gesture_arc);
            v[VC_GENVDELTA] = lerp(v[VC_GENVDELTA], genv_dir, 0.12 + 0.18 * slider9);
            genv_macro = clamp((0.58 + 1.30 * v[VC_GENV]) / 1.02, 0.55, 1.72);
            ggain *= lerp(1, genv_macro, genv_amt * 0.74);

            amp_jit_db = (rand(1) - 0.5) * 2 * slider9 * (0.22 + 0.78 * (1 - truth_mix)) * (1 - 0.58 * gran_slow_glue) * (1 - 0.55 * granular_event_stretch);
            ggain *= db2amp(amp_jit_db);
            gpan = (rand(1) - 0.5) * slider8 * slider9 * (0.10 + 0.30 * gesture_arc) * (1 - 0.65 * gran_slow_glue) * (1 - 0.50 * granular_event_stretch);
            // Adaptive per-grain downward expansion: useful for noisy/bright grains,
            // harmful for slow bassy grains. So it is disabled by slow glue.
            gxpand = clamp01((gran_cedge - 0.24) / 0.44) * clamp01((gran_cbright - 0.34) / 0.50);
            corpus_pick_role == 2 ? gxpand *= 1.25;
            gxpand *= slider9 * (0.10 + 0.38 * v[VC_TAILMIX] + 0.18 * gesture_arc) * (1 - 0.88 * gran_slow_glue);
            gxpand = clamp01(gxpand);

            prefill_age = floor(spawn_gsize * (slider9 * (0.015 + 0.075 * gesture_arc) + gran_slow_glue * 0.110 + gran_mscont * 0.060 + gran_stretch_glue * 0.075) * rand(1));
            schedule_prefill > 0 ? prefill_age = max(prefill_age, min(max(0, spawn_gsize - 2), floor(schedule_prefill)));
            prefill_src = gsrc - prefill_age * grate;
            gran_tail_region ? (
              prefill_src = clamp(prefill_src, ghist_lo, max(ghist_lo, ghist_hi - 1));
            ) : (
              prefill_src = wrap_in_range(prefill_src, ghist_lo, ghist_hi);
            );
          );

          gb[VG_ACTIVE] = 1;
          gb[VG_AGE] = prefill_age;
          gb[VG_SRC] = prefill_src;
          gb[VG_SID] = gsid;
          gb[VG_RATE] = grate;
          gb[VG_GAIN] = ggain;
          gb[VG_PAN] = gpan;
          gb[VG_SIZE] = spawn_gsize;
          gb[VG_XPAND] = gxpand;
          gb[VG_EDIR] = genv_dir;
          gb[VG_EPEAK] = genv_peak;
          gb[VG_EAMT] = genv_amt;
          gb[VG_LIFE] = 0;
          grain_hist_push(i, gsid, gsrc, ghist_lo, ghist_hi);
          granular_voice ? (
            prev_lgsid = v[VC_LGSID] | 0;
            prev_lgreg = v[VC_LGREG] | 0;
            v[VC_LGRUN] = (prev_lgsid == gsid && prev_lgreg == cur_region_mode) ? min(999, v[VC_LGRUN] + 1) : 1;
            v[VC_LGSID] = gsid;
            // Store the logical source before micro-decorrelation so jitter does
            // not become the path itself.
            v[VC_LGPOS] = gsrc_follow_store;
            v[VC_LGLO] = ghist_lo;
            v[VC_LGHI] = ghist_hi;
            v[VC_LGREG] = cur_region_mode;
            v[VC_LGCIDX] = gcorpus_idx;
          );

          spawn_hop = hop;
          granular_voice ? (
            // v30: hop follows the actual spawned grain length, not the old
            // HybridCore base length. This prevents audible empty gaps when the
            // corpus chooses shorter local grains.
            gran_hop_scale = max(gran_slow_glue, max(gran_mscont, gran_xcont));
            gran_hop_scale = clamp01(gran_hop_scale + granular_event_stretch * (0.18 + 0.42 * gran_hop_scale));
            spawn_hop_base = max(floor(srate * lerp(0.0048, 0.0028, gran_hop_scale)), floor(spawn_gsize * lerp(lerp(0.19, 0.135, slider9), lerp(0.112, 0.070, slider9), gran_hop_scale)));
            spawn_hop_base = floor(spawn_hop_base * lerp(1.0, 1.72, gran_stretch_glue));
            hop_jit = floor(spawn_hop_base * slider9 * (0.05 + 0.11 * (1 - truth_mix)) * (1 - 0.72 * gran_slow_glue) * (1 - 0.65 * max(gran_mscont, gran_xcont)) * (1 - 0.58 * granular_event_stretch) * ((rand(1) - 0.5) * 2));
            gran_min_hop = floor(srate * lerp(lerp(0.0046, 0.0026, gran_hop_scale), lerp(0.0100, 0.0064, gran_hop_scale), granular_event_stretch));
            gran_max_hop_ratio = lerp(lerp(0.285, 0.118, gran_hop_scale), lerp(0.360, 0.220, gran_hop_scale), granular_event_stretch);
            spawn_hop = clamp(spawn_hop_base + hop_jit, max(1, gran_min_hop), max(1, floor(spawn_gsize * gran_max_hop_ratio)));
          );
          timer += spawn_hop;
          spawn_guard += 1;
        );

        v[VC_GTIMER] = timer;

        sumL = 0;
        sumR = 0;
        sumW = 0;
        activeg = 0;

        gk = 0;
        while (gk < grain_slot_limit) (
          gb = v + VC_GBASE + gk * VG_STRIDE;

          gb[VG_ACTIVE] > 0 ? (
            gsid = gb[VG_SID] | 0;
            gsm = sample_meta_base + gsid * SM_STRIDE;
            gptr = gsm[SM_PTR] | 0;
            gnch = max(1, gsm[SM_NCH] | 0);
            gframes = gsm[SM_FRAMES] | 0;
            age = gb[VG_AGE];
            glife = max(0, floor(gb[VG_LIFE]));
            gsize = max(1, floor(gb[VG_SIZE]));
            gsize <= 1 ? gsize = max(1, floor(v[VC_GSIZE]));

            age < gsize ? (
              srcp = gb[VG_SRC] + age * gb[VG_RATE];

              (srcp >= 0 && srcp < (gframes - 1)) ? (
                sample_frame2(gptr, gnch, srcp);
                gl = readL;
                gr = readR;

                gpan = gb[VG_PAN];
                abs(gpan) > 0.000001 ? (
                  gm = 0.5 * (gl + gr);
                  gs = 0.5 * (gl - gr);
                  gl = gm + gs + gm * gpan;
                  gr = gm - gs - gm * gpan;
                );

                gxpand = gb[VG_XPAND];
                gxpand > 0.0001 ? (
                  gdet = max(abs(gl), abs(gr));
                  gref = max(0.000001, gsm[SM_RMS] * (0.78 + 0.52 * gxpand));
                  ggate = clamp01(gdet / gref);
                  ggate = max(0.22, ggate ^ (1.20 + 2.35 * gxpand));
                  gl *= lerp(1, ggate, gxpand);
                  gr *= lerp(1, ggate, gxpand);
                );

                // v33 EnvTrajectory: learned intra-grain energy motion. Rising
                // grains lean later, falling grains lean earlier, and crest
                // grains receive a small natural mid-arc. This restores prosody
                // without adding a visible control.
                genv_amt_play = gb[VG_EAMT];
                genv_amt_play > 0.0001 ? (
                  gn = clamp01(age / max(1, gsize - 1));
                  edir = clamp(gb[VG_EDIR], -1, 1);
                  epeak = clamp01(gb[VG_EPEAK]);
                  eshape = edir * (gn - 0.5) * 1.08 + epeak * (sin(gn * 3.141592653589793) - 0.60) * 0.72;
                  eshape = exp(clamp(eshape * genv_amt_play, -0.62, 0.76));
                  gl *= eshape;
                  gr *= eshape;
                );

                // Also fade grains that run into source boundaries. Otherwise a
                // tail grain can deactivate mid-window and expose a hard edge.
                gendfade_src = max(2, floor(gsm[SM_ENDFADE] * auto_release_amt * gsm[SM_SR] * 0.001));
                gendfade_src = min(gendfade_src, max(2, floor(gframes * 0.42)));
                grem_src = gb[VG_RATE] < 0 ? max(0, srcp) : max(0, gframes - 1 - srcp);
                gsource_end_fade = clamp01(grem_src / max(1, gendfade_src));
                gsource_end_fade = gsource_end_fade * gsource_end_fade * (3 - 2 * gsource_end_fade);

                // v35: prefilled grains used to enter mid-window at nonzero
                // amplitude, which could click. Every Granular grain now gets a
                // short real-time entry ramp independent of its logical window age.
                entry_fade = 1;
                granular_voice ? (
                  entry_len = clamp(floor(gsize * 0.10), max(2, floor(srate * 0.0025)), max(3, floor(srate * 0.030)));
                  entry_fade = clamp01(glife / max(1, entry_len));
                  entry_fade = entry_fade * entry_fade * (3 - 2 * entry_fade);
                );

                win_flat = granular_voice ? clamp01((gsize - srate * 0.140) / max(1, srate * 0.720) + granular_event_stretch * 0.42 * clamp01((gsize - srate * 0.060) / max(1, srate * 0.620))) : 0;
                w = (granular_voice ? stretch_window_morph(age, gsize, win_flat) : stretch_window(age, gsize)) * gsource_end_fade * entry_fade;
                gw = w * gb[VG_GAIN];
                sumL += gl * gw;
                sumR += gr * gw;
                // v33: in pure Granular, normalize by the window overlap, not
                // by gain-weighted overlap. Otherwise learned envelope/gain
                // motion is mathematically erased by OLA normalization.
                granular_voice ? ( sumW += w; ) : ( sumW += gw; );
              );

              age += 1;
              glife += 1;
              gb[VG_AGE] = age;
              gb[VG_LIFE] = glife;
              ((age >= gsize) || (srcp < 0) || (srcp >= (gframes - 1))) ? (
                gb[VG_ACTIVE] = 0;
              ) : (
                activeg += 1;
              );
            ) : (
              gb[VG_ACTIVE] = 0;
            );
          );

          gk += 1;
        );

        sumW > 0 ? (
          // Do not normalize by the instantaneous overlap sum. That cancels the
          // window fade whenever only one grain is active and makes seams obvious.
          // Instead, target the COLA sum for a periodic Hann window at 25%% hop.
          // v32: pure Granular should not leave audible level holes when slow/
          // low-motion sources expose OLA underlap. Use a lower floor than
          // Hybrid while still guarding against tiny-window blowups.
          target_ola_norm = granular_voice ? max(0.54, sumW) : max(2.0, sumW);
          granular_voice ? (
            v[VC_GOLA] <= 0 ? v[VC_GOLA] = target_ola_norm;
            ola_coeff = target_ola_norm > v[VC_GOLA] ? 0.24 : 0.075;
            v[VC_GOLA] += (target_ola_norm - v[VC_GOLA]) * ola_coeff;
            ola_norm = max(0.42, v[VC_GOLA]);
          ) : (
            ola_norm = target_ola_norm;
          );
          grainL = sumL / ola_norm;
          grainR = sumR / ola_norm;
          got_grain = 1;
        );
      );
    );

    stage = v[VC_STAGE] | 0;
    env = v[VC_ENV];

    stage == ENV_ATTACK ? (
      (env_slope_is_classic(v[VC_ACURVE], ENV_RISE)) ? (
        env += (1 - env) * v[VC_ASTEP];
        env >= 0.999 ? (
          env = 1;
          stage = (v[VC_HLEFT] > 0) ? ENV_HOLD : ENV_DECAY;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_ALEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] + (1 - v[VC_ESTART]) * env_slope_shape(env_n, env_segment_slope(v[VC_ACURVE], ENV_RISE));
        v[VC_EPHASE] = env_phase;
        (env_phase >= env_len || env >= 0.999) ? (
          env = 1;
          stage = (v[VC_HLEFT] > 0) ? ENV_HOLD : ENV_DECAY;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      );
    );

    stage == ENV_HOLD ? (
      env = 1;
      hleft = max(0, floor(v[VC_HLEFT]) - 1);
      v[VC_HLEFT] = hleft;
      hleft <= 0 ? (
        stage = ENV_DECAY;
        v[VC_EPHASE] = 0;
        v[VC_ESTART] = env;
      );
    );

    stage == ENV_DECAY ? (
      (env_slope_is_classic(v[VC_DCURVE], ENV_FALL)) ? (
        env += (sustain_level - env) * v[VC_DSTEP];
        abs(env - sustain_level) <= 0.0005 ? (
          env = sustain_level;
          stage = ENV_SUSTAIN;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_DLEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] + (sustain_level - v[VC_ESTART]) * env_slope_shape(env_n, env_segment_slope(v[VC_DCURVE], ENV_FALL));
        v[VC_EPHASE] = env_phase;
        (env_phase >= env_len || abs(env - sustain_level) <= 0.0005) ? (
          env = sustain_level;
          stage = ENV_SUSTAIN;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      );
    );

    stage == ENV_SUSTAIN ? (
      env = sustain_level;
    );

    stage == ENV_RELEASE ? (
      rel_handoff_left > 0 ? (
        rel_handoff_left -= 1;
        v[VC_RHLEFT] = rel_handoff_left;
        rel_handoff_mix = 1 - rel_handoff_left / rel_handoff_len;
      );
      (env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
        env *= v[VC_RSTEP];
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_RLEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] * (1 - env_slope_shape(env_n, env_segment_slope(v[VC_RCURVE], ENV_FALL)));
        v[VC_EPHASE] = env_phase;
      );
      (env <= 0.00005 || ((!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) && v[VC_EPHASE] >= max(1, floor(v[VC_RLEN])))) ? (
        env = 0;
        v[VC_ACTIVE] = 0;
        stage = ENV_OFF;
      );
    );

    v[VC_STAGE] = stage;
    v[VC_ENV] = env;

    got_sig = 0;
    mix = 0;
    got_raw && got_grain ? (
      tail_phase = clamp01((v[VC_POS] - tailstart) / max(1, frames - tailstart));
      prebody_mix = (stage == ENV_ATTACK || stage == ENV_HOLD) ? 0 : 1;
      mix = clamp(v[VC_GMIX] * prebody_mix * (0.18 + 0.18 * tail_phase + (stage == ENV_RELEASE ? 0.40 : 0)), 0, 0.90);
      stage == ENV_RELEASE ? (
        rel_release_mix = hybrid_body_release ? clamp01(0.32 + 0.46 * v[VC_GMIX] + 0.12 * slider9) : clamp01(0.10 + 0.22 * rel_handoff_mix + 0.68 * v[VC_TAILMIX]);
        mix = max(mix, rel_release_mix);
      );
      l = lerp(rawL, grainL, mix);
      r = lerp(rawR, grainR, mix);
      got_sig = 1;
    ) : got_raw ? (
      l = rawL;
      r = rawR;
      got_sig = 1;
    ) : got_grain ? (
      l = grainL;
      r = grainR;
      got_sig = 1;
    );

    g = v[VC_BASE] * env;
    v[VC_AUDIOTRIG] > 0 ? (
      aud_env = clamp01(v[VC_AUDIOENV]);
      aud_env = aud_env * aud_env * (3 - 2 * aud_env);
      // Envelope -> Input Envelope: the normal AHDSR still shapes the voice,
      // then the dry input's dBFS amplitude envelope scales the Granular layer.
      // No threshold-relative makeup is added here; use Grain/Output for amount.
      g *= lerp(1, aud_env, input_trigger_amt);
    );
    keepalive = direct_alive || got_grain || activeg > 0 || (v[VC_GMODE] > 0 && stage != ENV_OFF && (stage != ENV_RELEASE || v[VC_CANSPAWN] > 0));

    (g > 0 && got_sig) ? (
      outL += l * g;
      outR += r * g;
      (v[VC_TLEFT] > 0) ? (
        punch_bus = max(punch_bus, v[VC_TPROT]);
        clean_head_bus = max(clean_head_bus, v[VC_TPROT]);
        room_head_bus = max(room_head_bus, v[VC_TPROT]);
      );
      (stage == ENV_HOLD && hold_samps > 0) ? (
        punch_bus = max(punch_bus, (0.18 + 0.32 * clamp01(v[VC_HLEFT] / max(1, hold_samps))) * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
        clean_head_bus = max(clean_head_bus, 0.22 * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
        room_head_bus = max(room_head_bus, 0.36 * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
      );
      clean_tail_score = 0;
      stage == ENV_RELEASE ? clean_tail_score = max(clean_tail_score, 0.82 + 0.18 * clamp01(v[VC_TAILMIX]));
      (v[VC_POS] >= tailstart && stage != ENV_ATTACK && stage != ENV_HOLD) ? clean_tail_score = max(clean_tail_score, 0.45);
      clean_tail_bus = max(clean_tail_bus, clean_tail_score * clamp01(env * 1.35));
      room_tail_bus = max(room_tail_bus, clean_tail_score * clamp01(env * 1.20));
    ) : (
      (!keepalive || stage == ENV_OFF) ? v[VC_ACTIVE] = 0;
    );
  );

  i += 1;
);

outL += denorm_guard;
outR -= denorm_guard;

midm = abs(0.5 * (outL + outR));
mix_fast = denorm_zap(mix_fast + (midm - mix_fast) * (midm > mix_fast ? env_att_coeff : env_rel_coeff));
mix_slow = denorm_zap(mix_slow + (midm - mix_slow) * env_rel_coeff);
mix_fast = denorm_zap(mix_fast);
mix_slow = denorm_zap(mix_slow);
transient = clamp01((mix_fast - mix_slow) * 10);
transient_guard = clamp01(max(punch_bus, transient * (0.72 + 0.28 * punch_bus)));
transient_guard_s = denorm_zap(transient_guard_s + (transient_guard - transient_guard_s) * (transient_guard > transient_guard_s ? 0.12 : 0.02));
transient_guard_s = denorm_zap(transient_guard_s);

m2e_mix = denorm_zap(m2e_mix + (m2e_target - m2e_mix) * m2e_mode_coeff);
m2e_env_s += (m2e_env_raw - m2e_env_s) * m2e_smooth_coeff;
m2e_rigid_s = denorm_zap(m2e_rigid_s + (m2e_rigid_raw - m2e_rigid_s) * m2e_smooth_coeff);
m2e_impact_s = denorm_zap(m2e_impact_s + (m2e_impact_raw - m2e_impact_s) * m2e_smooth_coeff);
m2e_pan_s += (m2e_pan_raw - m2e_pan_s) * m2e_smooth_coeff;
m2e_entropy_s = denorm_zap(m2e_entropy_s + (m2e_entropy_raw - m2e_entropy_s) * m2e_smooth_coeff);
m2e_axis_v_s = denorm_zap(m2e_axis_v_s + (m2e_axis_v_raw - m2e_axis_v_s) * m2e_smooth_coeff);
m2e_axis_acc_s = denorm_zap(m2e_axis_acc_s + (m2e_axis_acc_raw - m2e_axis_acc_s) * m2e_smooth_coeff);
m2e_lat_v_s = denorm_zap(m2e_lat_v_s + (m2e_lat_v_raw - m2e_lat_v_s) * m2e_smooth_coeff);
m2e_lat_amp_s = denorm_zap(m2e_lat_amp_s + (m2e_lat_amp_raw - m2e_lat_amp_s) * m2e_smooth_coeff);
m2e_micro_s = denorm_zap(m2e_micro_s + (m2e_micro_raw - m2e_micro_s) * m2e_smooth_coeff);
m2e_meso_s = denorm_zap(m2e_meso_s + (m2e_meso_raw - m2e_meso_s) * m2e_smooth_coeff);
m2e_macro_s = denorm_zap(m2e_macro_s + (m2e_macro_raw - m2e_macro_s) * m2e_smooth_coeff);
m2e_excite_s = denorm_zap(m2e_excite_s + (m2e_excite_raw - m2e_excite_s) * m2e_smooth_coeff);
m2e_activity_s += (m2e_activity_raw - m2e_activity_s) * m2e_smooth_coeff;

m2e_depth = m2e_mix * (0.22 + 0.78 * max(0.18, slider9));
m2e_depth *= (1 - 0.35 * m2e_rigid_s);
(playback_mode >= 2) ? m2e_depth *= (0.94 - 0.12 * granular_amt * (0.55 + 0.45 * tail_borrow));
m2e_depth = clamp01(m2e_depth);
m2e_activity_hi = clamp01((m2e_activity_s - 1) / 3);

m2e_tone_bias =
  ((m2e_excite_s - 0.5) * 0.18
  + (m2e_micro_s - 0.5) * 0.10
  + (m2e_meso_s - 0.5) * 0.05
  - (m2e_macro_s - 0.5) * 0.12
  + (m2e_env_s - 0.5) * 0.06) * m2e_depth;

m2e_focus_bias =
  (m2e_impact_s * 0.22
  + abs(m2e_axis_acc_s) * 0.10
  + abs(m2e_axis_v_s) * 0.04
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.06) * m2e_depth;

m2e_width_bias =
  (m2e_lat_amp_s * 0.24
  + m2e_activity_hi * 0.12
  + m2e_excite_s * 0.10
  - m2e_rigid_s * 0.08
  - m2e_entropy_s * 0.04) * m2e_depth;

m2e_pan_bias =
  (((m2e_pan_s - 0.5) * 2) * 0.20
  + m2e_lat_v_s * 0.08
  + m2e_axis_v_s * 0.04) * m2e_depth;

m2e_body_bias =
  ((m2e_env_s - 0.5) * 0.10
  + m2e_impact_s * 0.08
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.04) * m2e_depth;

m2e_sat_mix =
  (m2e_impact_s * 0.26
  + m2e_excite_s * 0.18
  + abs(m2e_axis_acc_s) * 0.08
  + m2e_meso_s * 0.06) * m2e_depth;
m2e_sat_mix = min(clamp01(m2e_sat_mix), 0.22);

trans_mode_mix = 0.6;
transient_mode == 1 ? trans_mode_mix = 1
: transient_mode == 2 ? trans_mode_mix = 0;
m2e_transient_damp = clamp(1 - transient_guard_s * (0.52 + 0.28 * trans_mode_mix), 0.12, 1);
m2e_tone_bias *= 0.48 + 0.52 * m2e_transient_damp;
m2e_focus_bias *= 0.18 + 0.82 * m2e_transient_damp * m2e_transient_damp;
m2e_width_bias *= 0.62 + 0.38 * m2e_transient_damp;
m2e_pan_bias *= 0.30 + 0.70 * m2e_transient_damp;
m2e_body_bias *= 0.56 + 0.44 * m2e_transient_damp;
m2e_sat_mix *= 0.16 + 0.84 * m2e_transient_damp * m2e_transient_damp;

clean_amt > 0.0001 ? apply_cleaner();
clean_decrust_amt > 0.0001 ? apply_clean_decrust();
room_amt > 0.0001 ? apply_room_tame();
abs(formant_shift_semi) > 0.0001 ? apply_formant_shift();

tone_lp_l = denorm_zap(tone_lp_l + (outL - tone_lp_l) * tone_lp_coeff);
tone_lp_r = denorm_zap(tone_lp_r + (outR - tone_lp_r) * tone_lp_coeff);
focus_lp_l = denorm_zap(focus_lp_l + (outL - focus_lp_l) * focus_lp_coeff);
focus_lp_r = denorm_zap(focus_lp_r + (outR - focus_lp_r) * focus_lp_coeff);

tone_hp_l = outL - tone_lp_l;
tone_hp_r = outR - tone_lp_r;
focus_hp_l = outL - focus_lp_l;
focus_hp_r = outR - focus_lp_r;

bank_bright_dev = bank_brightness - 0.50;
color_corrective = ((slider6 < 0 && bank_bright_dev > 0) || (slider6 > 0 && bank_bright_dev < 0)) ? 1 : 0.35;
color_drive = 1 + bank_color_extreme * (0.30 + 0.42 * color_corrective + 0.18 * abs(slider6));
tone_amt = clamp(slider6 * color_drive + m2e_tone_bias, -1, 1);

// Average Attack Focus now calibrates the Focus macro. Corrective moves get
// stronger; exaggerating an already sharp/dull bank is deliberately restrained.
bank_focus_dev = bank_sharpness - 0.50;
focus_corrective = ((slider7 < 0 && bank_focus_dev > 0) || (slider7 > 0 && bank_focus_dev < 0)) ? 1 : 0;
focus_exaggerating = ((slider7 > 0 && bank_focus_dev > 0) || (slider7 < 0 && bank_focus_dev < 0)) ? 1 : 0;
focus_drive = focus_corrective ? (
  1 + bank_focus_extreme * (0.32 + 0.54 * abs(slider7))
) : (
  focus_exaggerating ? (
    1 - bank_focus_extreme * (0.12 + 0.24 * abs(slider7))
  ) : 1
);
focus_drive = clamp(focus_drive, 0.58, 1.86);
focus_amt = clamp(slider7 * focus_drive + m2e_focus_bias * (1 - 0.10 * bank_focus_extreme * focus_exaggerating), -1, 1);
width_amt = clamp(slider8 + m2e_width_bias, 0, 1);

tone_hi_w = 0.17 * (1 + bank_color_extreme * (0.18 + 0.28 * abs(tone_amt)));
tone_lo_w = 0.035 * (1 + bank_color_extreme * (0.20 + 0.34 * abs(tone_amt)));
outL += tone_amt * (tone_hp_l * tone_hi_w - tone_lp_l * tone_lo_w);
outR += tone_amt * (tone_hp_r * tone_hi_w - tone_lp_r * tone_lo_w);

focus_base_mix = 0.05 + transient * (0.11 + 0.08 * m2e_impact_s * m2e_depth);
focus_corrective_boost = 1 + bank_focus_extreme * focus_corrective * (0.18 + 0.24 * abs(focus_amt));
focus_exaggerate_guard = focus_exaggerating ? (
  1 - bank_focus_extreme * (0.10 + 0.24 * abs(focus_amt) + 0.14 * max(0, bank_focus_dev) + 0.06 * max(0, -bank_focus_dev))
) : 1;
focus_exaggerate_guard = clamp(focus_exaggerate_guard, 0.56, 1);
focus_mix = focus_amt * focus_base_mix * focus_corrective_boost * focus_exaggerate_guard;
outL += focus_hp_l * focus_mix;
outR += focus_hp_r * focus_mix;
abs(focus_peak_amt) > 0.0001 ? apply_focus_peak_pack();

mid = 0.5 * (outL + outR);
side = 0.5 * (outL - outR);
side *= 1 + width_amt * 0.22;
side += mid * m2e_pan_bias * 0.45;
mid *= 1 + m2e_body_bias;
outL = mid + side;
outR = mid - side;

satL = outL - (outL * outL * outL) * 0.1666666667;
satR = outR - (outR * outR * outR) * 0.1666666667;
outL = lerp(outL, satL, m2e_sat_mix);
outR = lerp(outR, satR, m2e_sat_mix);

weight_amt > 0.0001 ? (
  wmid = 0.5 * (outL + outR);
  wside = 0.5 * (outL - outR);

  weight_in_src_l = outL * 0.74 + wmid * 0.42 - wside * 0.06;
  weight_in_src_r = outR * 0.74 + wmid * 0.42 + wside * 0.06;

  weight_in_lp_l = denorm_zap(weight_in_lp_l + (weight_in_src_l - weight_in_lp_l) * weight_in_coeff);
  weight_in_lp_r = denorm_zap(weight_in_lp_r + (weight_in_src_r - weight_in_lp_r) * weight_in_coeff);

  ap_idx = weight_ap1_pos;
  ap_del = weight_ap1_l_base[ap_idx];
  ap1L = -weight_ap_g1 * weight_in_lp_l + ap_del;
  weight_ap1_l_base[ap_idx] = denorm_zap(weight_in_lp_l + weight_ap_g1 * ap1L);
  ap_del = weight_ap1_r_base[ap_idx];
  ap1R = -weight_ap_g1 * weight_in_lp_r + ap_del;
  weight_ap1_r_base[ap_idx] = denorm_zap(weight_in_lp_r + weight_ap_g1 * ap1R);
  weight_ap1_pos += 1;
  weight_ap1_pos >= weight_ap1_len ? weight_ap1_pos = 0;

  ap_idx = weight_ap2_pos;
  ap_del = weight_ap2_l_base[ap_idx];
  ap2L = -weight_ap_g2 * ap1L + ap_del;
  weight_ap2_l_base[ap_idx] = denorm_zap(ap1L + weight_ap_g2 * ap2L);
  ap_del = weight_ap2_r_base[ap_idx];
  ap2R = -weight_ap_g2 * ap1R + ap_del;
  weight_ap2_r_base[ap_idx] = denorm_zap(ap1R + weight_ap_g2 * ap2R);
  weight_ap2_pos += 1;
  weight_ap2_pos >= weight_ap2_len ? weight_ap2_pos = 0;

  er_idx = weight_er_pos;
  weight_er_l_base[er_idx] = denorm_zap(ap2L);
  weight_er_r_base[er_idx] = denorm_zap(ap2R);

  rd1 = er_idx - weight_tap1; rd1 < 0 ? rd1 += ER_BUF_LEN;
  rd2 = er_idx - weight_tap2; rd2 < 0 ? rd2 += ER_BUF_LEN;
  rd3 = er_idx - weight_tap3; rd3 < 0 ? rd3 += ER_BUF_LEN;
  rd4 = er_idx - weight_tap4; rd4 < 0 ? rd4 += ER_BUF_LEN;
  rd5 = er_idx - weight_tap5; rd5 < 0 ? rd5 += ER_BUF_LEN;
  rd6 = er_idx - weight_tap6; rd6 < 0 ? rd6 += ER_BUF_LEN;

  dl1 = weight_er_l_base[rd1]; dr1 = weight_er_r_base[rd1];
  dl2 = weight_er_l_base[rd2]; dr2 = weight_er_r_base[rd2];
  dl3 = weight_er_l_base[rd3]; dr3 = weight_er_r_base[rd3];
  dl4 = weight_er_l_base[rd4]; dr4 = weight_er_r_base[rd4];
  dl5 = weight_er_l_base[rd5]; dr5 = weight_er_r_base[rd5];
  dl6 = weight_er_l_base[rd6]; dr6 = weight_er_r_base[rd6];

  dm3 = 0.5 * (dl3 + dr3);
  dm6 = 0.5 * (dl6 + dr6);

  wetL = dl1 * 0.29 + dr2 * 0.22 + dm3 * 0.19 + dl4 * 0.14 + dr5 * 0.10 + dm6 * 0.07;
  wetR = dr1 * 0.29 + dl2 * 0.22 + dm3 * 0.19 + dr4 * 0.14 + dl5 * 0.10 + dm6 * 0.07;

  weight_er_pos += 1;
  weight_er_pos >= ER_BUF_LEN ? weight_er_pos = 0;

  weight_wet_lp_l = denorm_zap(weight_wet_lp_l + (wetL - weight_wet_lp_l) * weight_wet_coeff);
  weight_wet_lp_r = denorm_zap(weight_wet_lp_r + (wetR - weight_wet_lp_r) * weight_wet_coeff);

  wet_damp = 0.52 + 0.22 * stretch_norm;
  wetL = lerp(wetL, weight_wet_lp_l, wet_damp);
  wetR = lerp(wetR, weight_wet_lp_r, wet_damp);

  weight_duck = clamp(1 - transient_guard_s * (0.64 + 0.20 * trans_mode_mix + 0.08 * weight_amt), 0.14, 1);
  bloom = 0.5 * (weight_wet_lp_l + weight_wet_lp_r) * weight_body * (0.42 + 0.58 * weight_duck);
  outL += wetL * weight_mix * weight_duck + bloom;
  outR += wetR * weight_mix * weight_duck + bloom;

  heavySatL = outL - (outL * outL * outL) * 0.11;
  heavySatR = outR - (outR * outR * outR) * 0.11;
  outL = lerp(outL, heavySatL, weight_sat * (0.42 + 0.58 * weight_duck));
  outR = lerp(outR, heavySatR, weight_sat * (0.42 + 0.58 * weight_duck));
);

dynamics_amt > 0.0001 ? (
  dynL = outL * dyn_drive;
  dynR = outR * dyn_drive;

  dyn_det = max(abs(dynL), abs(dynR));
  dyn_env = denorm_zap(dyn_env + (dyn_det - dyn_env) * (dyn_det > dyn_env ? dyn_att_coeff : dyn_rel_coeff));

  dyn_over = max(0, dyn_env - dyn_thresh);
  dyn_target_gain = dyn_over > 0 ? (dyn_thresh + dyn_over / dyn_ratio) / max(dyn_env, 0.000001) : 1;
  dyn_comp_gain = denorm_zap(dyn_comp_gain + (dyn_target_gain - dyn_comp_gain) * (dyn_target_gain < dyn_comp_gain ? dyn_gain_att_coeff : dyn_gain_rel_coeff));

  dynL *= dyn_comp_gain;
  dynR *= dyn_comp_gain;

  dynSatL = dynL / (1 + abs(dynL));
  dynSatR = dynR / (1 + abs(dynR));
  dynL = lerp(dynL, dynSatL * 1.16, dyn_sat_mix);
  dynR = lerp(dynR, dynSatR * 1.16, dyn_sat_mix);

  dynL *= dyn_makeup;
  dynR *= dyn_makeup;

  dyn_post = max(abs(dynL), abs(dynR));
  dyn_lim_tgt = dyn_post > dyn_ceiling ? dyn_ceiling / dyn_post : 1;
  dyn_lim_gain = denorm_zap(dyn_lim_gain + (dyn_lim_tgt - dyn_lim_gain) * (dyn_lim_tgt < dyn_lim_gain ? dyn_lim_att_coeff : dyn_lim_rel_coeff));

  outL = dynL * dyn_lim_gain;
  outR = dynR * dyn_lim_gain;
) : (
  dyn_env = denorm_zap(dyn_env + (0 - dyn_env) * dyn_rel_coeff);
  dyn_comp_gain = denorm_zap(dyn_comp_gain + (1 - dyn_comp_gain) * dyn_gain_rel_coeff);
  dyn_lim_gain = denorm_zap(dyn_lim_gain + (1 - dyn_lim_gain) * dyn_lim_rel_coeff);
);

// Hidden Shift+Dynamics expansion runs after the normal density/guard stage so
// it can restore contrast when desired. It is fully bypassed at zero.
dynamics_expand_amt > 0.0001 ? (
  apply_dynamics_expand();
) : (
  dynx_fast = denorm_zap(dynx_fast + (0 - dynx_fast) * dynx_fast_rel_coeff);
  dynx_slow = denorm_zap(dynx_slow + (0 - dynx_slow) * dynx_slow_rel_coeff);
  dynx_gain = denorm_zap(dynx_gain + (1 - dynx_gain) * dynx_gain_down_coeff);
  dynx_lim_gain = denorm_zap(dynx_lim_gain + (1 - dynx_lim_gain) * dyn_lim_rel_coeff);
);

push_amt > 0.0001 ? apply_push();

// v38: PostEQ spectrum is visual-only. Running two 96-band analyzers every
// audio sample across several instances can look like a stall even when audio
// CPU meters stay modest, so analyze every 4th sample with compensated envelope
// coefficients. Audio EQ processing is unchanged.
posteq_spec_tick += 1;
posteq_spec_do = posteq_spec_tick >= posteq_spec_stride ? 1 : 0;
posteq_spec_do ? (
  posteq_spec_tick = 0;
  posteq_analyze_spectrum(outL, outR);
);
apply_processing_strip();
posteq_spec_do ? posteq_analyze_post_spectrum(outL, outR);

denorm_flush_counter += 1;
denorm_flush_counter >= DENORM_FLUSH_INTERVAL ? (
  denorm_flush_scalar_states();
  denorm_flush_counter = 0;
);

(!active_voice_seen && denorm_near_silence(outL, outR)) ? (
  denorm_silence_samps += 1;
  denorm_silence_samps == DENORM_SILENCE_RESET_SAMPS ? denorm_flush_silent_tail_state();
  denorm_silence_samps > DENORM_SILENCE_RESET_SAMPS ? denorm_silence_samps = DENORM_SILENCE_RESET_SAMPS;
) : (
  denorm_silence_samps = 0;
);

outL = denorm_zap(outL);
outR = denorm_zap(outR);
// Texture-injection guarantee: dry input is restored exactly and bypasses all
// sampler processing, Output trim, PostEQ, Clean/Room/Push, etc.
spl0 = dry_in_l + outL * out_trim;
spl1 = dry_in_r + outR * out_trim;

@gfx 1380 760
gfx_getchar();
mouse_down = mouse_cap & 1;
mouse_rdown = mouse_cap & 2;
ui_shift = (mouse_cap & 8) ? 1 : 0;
ui_ctrl = (mouse_cap & 4) ? 1 : 0;
(!mouse_down || !ui_ctrl) ? posteq_solo_target = 0;
mouse_pressed = mouse_down && !ui_prev_down;
mouse_rpressed = mouse_rdown && !ui_prev_rdown;
ui_now = time_precise();
ui_wheel = mouse_wheel;
mouse_wheel = 0;
ui_wheel_used = 0;
ui_value_changed = 0;
ui_hover_id = -1;
gfx_slider_mask = 0;
sprintf(#tip_title, "");
sprintf(#tip_body, "");

// UI-side safety net: when REAPER stops/pause-freezes processing, @gfx can
// still run. Clear orphaned transport voices here too, but only after a prior
// running transport state, so live MIDI use while stopped is not affected.
gfx_transport_running = (play_state & 1) ? 1 : 0;
gfx_transport_paused = (play_state & 2) ? 1 : 0;
gfx_transport_stopped = play_state == 0;
((gfx_transport_paused || gfx_transport_stopped) && transport_running_prev) ? (
  // Inline hard panic for @gfx. Some JSFX builds do not resolve audio helper
  // functions from @gfx during compile, so keep this side-effect-only clear local.
  panic_i = 0;
  while (panic_i < MAX_VOICES) (
    panic_v = voice_base + panic_i * VC_STRIDE;
    panic_v[VC_ENV] = 0;
    panic_v[VC_STAGE] = ENV_OFF;
    panic_v[VC_ACTIVE] = 0;
    panic_i += 1;
  );

  panic_i = 0;
  while (panic_i < NOTE_GATE_CELLS) (
    note_gate_base[panic_i] = 0;
    panic_i += 1;
  );

  weight_ap1_pos = 0;
  weight_ap2_pos = 0;
  weight_er_pos = 0;
  weight_in_lp_l = 0;
  weight_in_lp_r = 0;
  weight_wet_lp_l = 0;
  weight_wet_lp_r = 0;
  panic_i = 0;
  while (panic_i < AP_BUF_LEN) (
    weight_ap1_l_base[panic_i] = 0;
    weight_ap1_r_base[panic_i] = 0;
    weight_ap2_l_base[panic_i] = 0;
    weight_ap2_r_base[panic_i] = 0;
    panic_i += 1;
  );
  panic_i = 0;
  while (panic_i < ER_BUF_LEN) (
    weight_er_l_base[panic_i] = 0;
    weight_er_r_base[panic_i] = 0;
    panic_i += 1;
  );

  clean_lp1_l = 0;
  clean_lp2_l = 0;
  clean_lp3_l = 0;
  clean_lp4_l = 0;
  clean_lp1_r = 0;
  clean_lp2_r = 0;
  clean_lp3_r = 0;
  clean_lp4_r = 0;
  clean_head_bus = 0;
  clean_tail_bus = 0;
  panic_i = 0;
  while (panic_i < CLEAN_BANDS) (
    clean_env_base[panic_i] = 0;
    clean_floor_base[panic_i] = 0;
    clean_slow_base[panic_i] = 0;
    clean_gain_base[panic_i] = 1;
    panic_i += 1;
  );

  room_lp1_l = 0;
  room_lp2_l = 0;
  room_lp3_l = 0;
  room_lp4_l = 0;
  room_lp1_r = 0;
  room_lp2_r = 0;
  room_lp3_r = 0;
  room_lp4_r = 0;
  room_fast_env = 0;
  room_slow_env = 0;
  room_g0 = 1;
  room_g1 = 1;
  room_g2 = 1;
  room_g3 = 1;
  room_g4 = 1;
  room_head_bus = 0;
  room_tail_bus = 0;

  push_m_lp15 = 0;
  push_m_lp32 = 0;
  push_m_lp55 = 0;
  push_s_lp15 = 0;
  push_s_lp32 = 0;
  push_s_lp55 = 0;
  push_bodyE = 0;
  push_formE = 0;
  push_edgeE = 0;
  push_airE = 0;
  push_srcE = 0;
  push_m_hiE = 0;
  push_s_hiE = 0;
  push_click_fastE = 0;
  push_click_slowE = 0;
  push_common_dB = 0;
  push_side_dB = 0;
  push_hot_dB = -150;
  push_click_dB = 0;
  push_side_rel_dB = -150;

  proc_hpf1_l = 0; proc_hpf2_l = 0;
  proc_hpf1_r = 0; proc_hpf2_r = 0;
  proc_lpf1_l = 0; proc_lpf2_l = 0;
  proc_lpf1_r = 0; proc_lpf2_r = 0;
  posteq_solo_target = 0;
  posteq_solo_mode_latched = 0;
  posteq_solo_mix = 0;
  posteq_solo_zero();
  panic_i = 0;
  while (panic_i < POSTEQ_SPEC_BINS) (
    posteq_spec_lp_base[panic_i] = 0;
    posteq_spec_z2_base[panic_i] = 0;
    posteq_spec_env_base[panic_i] = 0;
    posteq_post_z1_base[panic_i] = 0;
    posteq_post_z2_base[panic_i] = 0;
    posteq_post_env_base[panic_i] = 0;
    panic_i += 1;
  );
  panic_i = 0;
  while (panic_i < POSTEQ_BQ_COUNT) (
    posteq_bq_base[panic_i * POSTEQ_BQ_STRIDE + 5] = 0;
    posteq_bq_base[panic_i * POSTEQ_BQ_STRIDE + 6] = 0;
    posteq_bq_base[panic_i * POSTEQ_BQ_STRIDE + 7] = 0;
    posteq_bq_base[panic_i * POSTEQ_BQ_STRIDE + 8] = 0;
    panic_i += 1;
  );

  transient_guard_s = 0;
  dyn_env = 0;
  dyn_comp_gain = 1;
  dyn_lim_gain = 1;
  mix_fast = 0;
  mix_slow = 0;

  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
  transport_running_prev = 0;
  transport_playpos_prev = -1;
  transport_play_state_prev = play_state;
);

// Flagship dark-metal visual pass
bg_i = 0;
while (bg_i < gfx_h) (
  bg_t = bg_i / max(1, gfx_h - 1);
  gfx_r = 0.014 + 0.028 * (1 - bg_t);
  gfx_g = 0.018 + 0.034 * (1 - bg_t);
  gfx_b = 0.026 + 0.050 * (1 - bg_t);
  gfx_a = 1;
  gfx_line(0, bg_i, gfx_w, bg_i);
  bg_i += 1;
);

// Header
x0 = 10; y0 = 10;
header_h = 84;
ui_panel(x0, y0, gfx_w - 20, header_h);

ui_draw_header_logo(x0 + 44, y0 + 42, 23);

gfx_setfont(1, "Arial", 25, 0);
gfx_x = x0 + 88; gfx_y = y0 + 19;
gfx_r = 0.92; gfx_g = 0.97; gfx_b = 1.0; gfx_a = 1;
gfx_drawstr("LOAD-AND-GO");
gfx_setfont(1, "Arial", 17, 0);
gfx_x = x0 + 286; gfx_y = y0 + 25;
gfx_r = 0.50; gfx_g = 0.64; gfx_b = 0.78; gfx_a = 1;
gfx_drawstr("MULTISAMPLER");
pt_in(x0, y0, gfx_w - 20, header_h) ? ui_hover_id = 1001;

gfx_setfont(1, "Arial", 14, 0);
gfx_x = x0 + 88; gfx_y = y0 + 55;
gfx_r = 0.63; gfx_g = 0.72; gfx_b = 0.84; gfx_a = 1;
gfx_drawstr("Auto-polls slot 0, rescans on change, bank-wide triggering.");

lamp_x = gfx_w - 238;
lamp_y = y0 + 27;
status_on = bank_loaded ? 1 : 0;
bank_partial = bank_loaded && bank_selected_count > 0 && sample_count < bank_selected_count;
ui_led(lamp_x, lamp_y + 11, status_on && !bank_partial, bank_partial ? 0.95 : 0.18, bank_partial ? 0.68 : 0.90, bank_partial ? 0.20 : 0.44);
gfx_setfont(1, "Arial", 14, 0);
gfx_r = 0.86; gfx_g = 0.92; gfx_b = 0.98; gfx_a = 1;
gfx_x = lamp_x + 22; gfx_y = lamp_y + 1;
bank_partial ? sprintf(#ui_buf, "Bank partial") : (bank_loaded ? sprintf(#ui_buf, "Bank ready") : sprintf(#ui_buf, "No bank"));
gfx_drawstr(#ui_buf);

gfx_r = 0.62; gfx_g = 0.70; gfx_b = 0.82; gfx_a = 1;
gfx_x = lamp_x + 22; gfx_y = lamp_y + 25;
bank_partial ? (
  bank_memory_limited ? sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, bank_selected_count, pool_ram_mb) : (
    bank_cap_limited ? sprintf(#ui_buf, "Loaded %d/%d | pool max %d", sample_count, bank_selected_count, sample_pool_capacity) : sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, bank_selected_count, pool_ram_mb)
  )
) : (
  bank_loaded ? sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, max(bank_selected_count, sample_count), pool_ram_mb) : (
    rescan_pending ? (
      rescan_force ? sprintf(#ui_buf, "Rescan now") : sprintf(#ui_buf, "Rescan queued")
    ) : sprintf(#ui_buf, "Auto-rescan live")
  )
);
gfx_drawstr(#ui_buf);

m2e_lamp_x = gfx_w - 456;
m2e_lamp_y = y0 + 27;
m2e_recent = (m2e_clock_samps - m2e_last_any_cc_samps) <= m2e_detect_window_samps ? 1 : 0;
m2e_on = m2e_mix > 0.02 ? 1 : 0;
ui_led(m2e_lamp_x, m2e_lamp_y + 11, m2e_on, m2e_on ? 0.48 : (m2e_recent ? 0.82 : 0.18), m2e_on ? 0.62 : (m2e_recent ? 0.52 : 0.20), m2e_on ? 1.00 : (m2e_recent ? 0.24 : 0.24));
gfx_setfont(1, "Arial", 14, 0);
gfx_r = 0.84; gfx_g = 0.90; gfx_b = 0.98; gfx_a = 1;
gfx_x = m2e_lamp_x + 22; gfx_y = m2e_lamp_y + 1;
m2e_on ? sprintf(#ui_buf, "FluxBridge live") : (m2e_recent ? sprintf(#ui_buf, "FluxBridge detect") : sprintf(#ui_buf, "FluxBridge idle"));
gfx_drawstr(#ui_buf);
gfx_r = 0.62; gfx_g = 0.70; gfx_b = 0.82; gfx_a = 1;
gfx_x = m2e_lamp_x + 22; gfx_y = m2e_lamp_y + 25;
sprintf(#ui_buf, "Auto-detect");
gfx_drawstr(#ui_buf);

pt_in(m2e_lamp_x - 8, m2e_lamp_y - 2, 170, 48) ? ui_hover_id = 1003;
pt_in(lamp_x - 8, lamp_y - 2, 180, 48) ? ui_hover_id = 1002;

group_poll_track_name(0);
group_write_heartbeat(count_active_voices() > 0 || input_trig_gate > 0, max(input_trig_env, mix_fast));
group_refresh_state();
grp_btn_x = x0 + 420;
grp_btn_y = y0 + 18;
grp_btn_w = max(260, min(380, gfx_w - grp_btn_x - 500));
grp_btn_w > 0 ? (
  ui_button(GROUP_UI_BTN_ID, grp_btn_x, grp_btn_y, grp_btn_w, 34) ? group_popup_open = 1 - group_popup_open;
  gfx_setfont(1, "Arial", 11, 0);
  gfx_r = 0.58; gfx_g = 0.68; gfx_b = 0.80; gfx_a = 1;
  gfx_x = grp_btn_x + 12; gfx_y = grp_btn_y + 6;
  gfx_drawstr("GROUP");
  gfx_r = 0.90; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
  gfx_x = grp_btn_x + 58; gfx_y = grp_btn_y + 6;
  strlen(#group_name) > 0 ? gfx_drawstr(#group_name) : (sprintf(#ui_buf, "Sample"); gfx_drawstr(#ui_buf););
  gfx_r = group_strict_active ? 0.98 : 0.60; gfx_g = group_strict_active ? 0.76 : 0.72; gfx_b = group_strict_active ? 0.24 : 0.82; gfx_a = 1;
  gfx_x = grp_btn_x + 12; gfx_y = grp_btn_y + 21;
  group_strict_active ? sprintf(#ui_buf, "ORDER Strict | ID %d | Lead %d | Peers %d", group_instance_id, group_leader_id, group_peer_count) : sprintf(#ui_buf, "ORDER Unordered | ID %d | Lead %d | Peers %d", group_instance_id, group_leader_id, group_peer_count);
  gfx_drawstr(#ui_buf);
  pt_in(grp_btn_x, grp_btn_y, grp_btn_w, 34) ? ui_hover_id = GROUP_UI_BTN_ID;
);

// Panels - responsive layout
panel_gap = 10;
panel_total_w = gfx_w - 20;
panel_total_h = gfx_h - 112;

left_x = 10; left_y = 104;
left_w = clamp(floor(panel_total_w * 0.19), 215, 290);
mid_w  = clamp(floor(panel_total_w * 0.27), 300, 410);
proc_w = clamp(floor(panel_total_w * 0.24), 250, 360);
right_w = panel_total_w - left_w - mid_w - proc_w - panel_gap * 3;
right_min_w = 330;
proc_min_w = 235;

right_w < right_min_w ? (
  deficit = right_min_w - right_w;
  take_proc = min(deficit * 0.55, max(0, proc_w - proc_min_w));
  proc_w -= take_proc;
  deficit -= take_proc;
  take_mid = min(deficit * 0.70, max(0, mid_w - 260));
  mid_w -= take_mid;
  deficit -= take_mid;
  take_left = min(deficit, max(0, left_w - 190));
  left_w -= take_left;
  right_w = panel_total_w - left_w - mid_w - proc_w - panel_gap * 3;
);

right_w > 410 ? (
  excess = right_w - 410;
  proc_w += min(excess, max(0, 360 - proc_w));
  right_w = panel_total_w - left_w - mid_w - proc_w - panel_gap * 3;
);

mid_x = left_x + left_w + panel_gap; mid_y = left_y;
right_x = mid_x + mid_w + panel_gap; right_y = left_y;
proc_x = right_x + right_w + panel_gap; proc_y = left_y;
left_h = panel_total_h;
mid_h = panel_total_h;
right_h = panel_total_h;
proc_h = panel_total_h;

ui_panel(left_x, left_y, left_w, left_h);
ui_panel(mid_x, mid_y, mid_w, mid_h);
ui_panel(right_x, right_y, right_w, right_h);
ui_panel(proc_x, proc_y, proc_w, proc_h);

// Left panel: bank overview
gfx_setfont(1, "Arial", 16, 0);
gfx_r = 0.88; gfx_g = 0.94; gfx_b = 1.0; gfx_a = 1;
gfx_x = left_x + 18; gfx_y = left_y + 16;
gfx_drawstr("BANK OVERVIEW");
gfx_r = 0.10; gfx_g = 0.58; gfx_b = 1.0; gfx_a = 0.90; gfx_circle(left_x + 10, left_y + 25, 4, 1);
gfx_r = 0.26; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.35; gfx_line(left_x + 18, left_y + 39, left_x + left_w - 18, left_y + 39);

gfx_setfont(1, "Arial", 14, 0);
bank_selected_count > 0 && sample_count < bank_selected_count ? sprintf(#ui_buf, "%d/%d samples loaded", sample_count, bank_selected_count) : sprintf(#ui_buf, "%d samples loaded", sample_count);
gfx_x = left_x + 14; gfx_y = left_y + 42; gfx_r = bank_partial ? 0.95 : 0.70; gfx_g = bank_partial ? 0.76 : 0.78; gfx_b = bank_partial ? 0.42 : 0.88;
gfx_drawstr(#ui_buf);

sprintf(#ui_buf, "%d voices active", count_active_voices());
gfx_x = left_x + 14; gfx_y = left_y + 62; gfx_drawstr(#ui_buf);

(last_sid >= 0) ? (
  selection_mode == 2 ? sprintf(#ui_buf, "Last sample %d | Walk", last_sid + 1) : (
    sequence_mode ? sprintf(#ui_buf, "Last sample %d | Seq", last_sid + 1) : sprintf(#ui_buf, "Last sample %d | Random", last_sid + 1)
  );
) : (
  selection_mode == 2 ? sprintf(#ui_buf, "Last sample -- | Walk") : (
    sequence_mode ? sprintf(#ui_buf, "Last sample -- | Seq") : sprintf(#ui_buf, "Last sample -- | Random")
  );
);
gfx_x = left_x + 14; gfx_y = left_y + 82; gfx_drawstr(#ui_buf);
pt_in(left_x + 10, left_y + 8, left_w - 20, 84) ? ui_hover_id = 1100;

meter_x = left_x + 14; meter_y = left_y + 122; meter_w = left_w - 28; meter_h = 12;
ui_hmeter(meter_x, meter_y, meter_w, meter_h, bank_pitchiness, 0.16, 0.62, 1.00);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y - 20;
gfx_drawstr("Pitch confidence");
pt_in(meter_x, meter_y - 22, meter_w, meter_h + 26) ? ui_hover_id = 1101;

meter_y2 = meter_y + 52;
ui_hmeter(meter_x, meter_y2, meter_w, meter_h, bank_brightness, 0.20, 0.86, 0.58);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y2 - 20;
gfx_drawstr("Average brightness");
pt_in(meter_x, meter_y2 - 22, meter_w, meter_h + 26) ? ui_hover_id = 1102;

meter_y3 = meter_y2 + 52;
ui_hmeter(meter_x, meter_y3, meter_w, meter_h, bank_sharpness, 0.64, 0.40, 1.00);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y3 - 20;
gfx_drawstr("Average attack focus");
pt_in(meter_x, meter_y3 - 22, meter_w, meter_h + 26) ? ui_hover_id = 1103;

map_x = left_x + 14; map_y = left_y + 250; map_w = left_w - 28; map_h = max(80, left_h - 266);
ui_inner_panel(map_x, map_y, map_w, map_h);
gfx_x = map_x; gfx_y = map_y - 22; gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88;
gfx_drawstr("Sample map");
pt_in(map_x, map_y, map_w, map_h) ? (
  sample_count > 0 ? (
    hov_bw = map_w / max(sample_count, 1);
    hov_sid = clamp(floor((mouse_x - map_x) / max(hov_bw, 0.000001)), 0, sample_count - 1);
    ui_hover_id = 5000 + hov_sid;
  ) : ui_hover_id = 1200;
);

sample_count > 0 ? (
  bw = map_w / max(sample_count, 1);
  i = 0;
  while (i < sample_count) (
    sm = sample_meta_base + i * SM_STRIDE;
    rootn = clamp01((sm[SM_ROOT] - ROOT_LOW) / max(ROOT_HIGH - ROOT_LOW, 1));
    bright = sm[SM_BRIGHT];
    sharp = sm[SM_SHARP];
    bh = 10 + (map_h - 20) * clamp01(0.15 + bright * 0.85);
    bx = map_x + i * bw;
    by = map_y + map_h - bh - 4;
    gfx_r = lerp(0.10, 0.95, rootn);
    gfx_g = lerp(0.78, 0.48, rootn) * (0.78 + 0.22 * sharp);
    gfx_b = lerp(0.35, 0.05, rootn) * (0.80 + 0.20 * (1 - bright));
    gfx_a = (i == last_sid) ? 1 : 0.82;
    gfx_rect(bx + 1, by, max(1, bw - 2), bh, 1);
    i += 1;
  );
) : (
  gfx_r = 0.48; gfx_g = 0.54; gfx_b = 0.62; gfx_a = 1;
  gfx_x = map_x + 12; gfx_y = map_y + 12;
  gfx_drawstr("Drop a multi-file selection onto slot 0.");
);

// Mid panel: AHDSR graph and controls
gfx_setfont(1, "Arial", 16, 0);
gfx_r = 0.88; gfx_g = 0.94; gfx_b = 1.0; gfx_a = 1;
