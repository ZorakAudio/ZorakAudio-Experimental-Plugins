);
ui_hover_id == 1400 ? (
  sprintf(#tip_title, "Playback controls");
  sprintf(#tip_body, "Pitch is now independent of MIDI note. The rest stay restrained and mix-safe rather than exaggerated.");
);
ui_hover_id == 1401 ? (
  sprintf(#tip_title, "Hidden stock sliders");
  sprintf(#tip_body, "Every mapped parameter still lives on a normal JSFX slider for automation and state recall. Random hits the whole bank, Sequence walks it deterministically.");
);
ui_hover_id == 201 ? (
  sprintf(#tip_title, "Attack");
  sprintf(#tip_body, "Current %.1f ms. Log-scaled time control with curved rise. Wheel adjusts; right-click or double-click resets.", slider2);
);
ui_hover_id == 202 ? (
  sprintf(#tip_title, "Decay");
  sprintf(#tip_body, "Current %.0f ms. Log-scaled time control with curved fall to Sustain. Wheel adjusts; right-click or double-click resets.", slider3);
);
ui_hover_id == 203 ? (
  sprintf(#tip_title, "Sustain");
  sprintf(#tip_body, "Current %.0f%%. Perceptually curved sustain level. Wheel adjusts; right-click or double-click resets.", slider4 * 100);
);
ui_hover_id == 204 ? (
  sprintf(#tip_title, "Release");
  sprintf(#tip_body, "Current %.0f ms. Log-scaled time control with curved fade-out. Wheel adjusts; right-click or double-click resets.", slider5);
);
ui_hover_id == 301 ? (
  sprintf(#tip_title, "Color");
  sprintf(#tip_body, "Current %.2f. Gentle spectral tilt: negative warms, positive brightens. Wheel adjusts; right-click or double-click resets.", slider6);
);
ui_hover_id == 302 ? (
  sprintf(#tip_title, "Focus");
  sprintf(#tip_body, "Current %.2f. Negative softens, positive adds clarity. Wheel adjusts; right-click or double-click resets.", slider7);
);
ui_hover_id == 303 ? (
  sprintf(#tip_title, "Width");
  sprintf(#tip_body, "Current %.2f. Mild mid/side spread kept intentionally mono-safe. Wheel adjusts; right-click or double-click resets.", slider8);
);
ui_hover_id == 304 ? (
  sprintf(#tip_title, "Liveliness");
  sprintf(#tip_body, "Current %.2f. Controls start-position jitter, tiny detune drift, gain micro-variation, and how adventurous Random mode becomes. Wheel adjusts; right-click or double-click resets.", slider9);
);
ui_hover_id == 305 ? (
  sprintf(#tip_title, "Truth");
  sprintf(#tip_body, "Current %.2f. 0 favors matched playback, 1 preserves raw sample behavior. Wheel adjusts; right-click or double-click resets.", slider10);
);
ui_hover_id == 306 ? (
  sprintf(#tip_title, "Output");
  sprintf(#tip_body, "Current %.1f dB. Final output trim after the macro stage. Wheel adjusts; right-click or double-click resets.", slider11);
);
ui_hover_id == 307 ? (
  sprintf(#tip_title, "Pitch");
  sprintf(#tip_body, "Current %+.1f semitones. This is the global transpose now; incoming MIDI note no longer decides which bank entry can play.", slider12);
);
ui_hover_id == 401 ? (
  sprintf(#tip_title, "Random / Sequence");
  (slider13 | 0) ? (
    sprintf(#tip_body, "Sequence mode walks through every loaded file in order, one trigger at a time.");
