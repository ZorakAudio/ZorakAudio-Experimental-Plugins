knob_panel_top = btn_y3 + btn_h + 18;
knob_panel_bottom = right_y + right_h - 18;
knob_area_h = max(140, knob_panel_bottom - knob_panel_top);
knob_count = 15;
knob_cols = right_inner_w >= 270 ? 3 : 2;
knob_rows = floor((knob_count + knob_cols - 1) / knob_cols);
knob_col_gap = clamp(floor(right_inner_w * 0.016), 10, 16);
knob_row_gap = 16;
cell_w = (right_inner_w - knob_col_gap * max(0, knob_cols - 1)) / knob_cols;
cell_h = floor((knob_area_h - knob_row_gap * max(0, knob_rows - 1)) / max(1, knob_rows));
cell_h = min(cell_h, 112);
kb_r = clamp(min(cell_w * 0.18, cell_h * 0.24), 18, knob_cols >= 6 ? 24 : 22);

// Pitch / hidden Formant shift
// Shift+drag or Shift+wheel this knob to adjust formant/resonance shift without adding a visible control.
grid_idx = 0;
cell_x = right_inner_x + (grid_idx % knob_cols) * (cell_w + knob_col_gap);
cell_y = knob_panel_top + floor(grid_idx / knob_cols) * (cell_h + knob_row_gap);
kc = cell_x + cell_w * 0.5; ky = cell_y + kb_r + 6; label_y = min(cell_y + cell_h - 12, ky + kb_r + 12);
pitch_hot = ((mouse_x - kc) * (mouse_x - kc) + (mouse_y - ky) * (mouse_y - ky)) <= kb_r * kb_r;
(mouse_pressed && pitch_hot) ? pitch_alt_active = ui_shift ? 1 : 0;
(ui_active != 317 && !mouse_down) ? pitch_alt_active = 0;
focus_peak_alt_active = 0;
pitch_alt_use = pitch_alt_active || (ui_shift && (pitch_hot || ui_active == 317));
pitch_alt_use ? (
  nv = ui_knob(317, kc, ky, kb_r, formant_shift_semi, -12, 12, 0, 0.021);
  abs(nv - formant_shift_semi) > 0.0000001 ? (
    formant_shift_semi = clamp(nv, -12, 12);
    ui_value_changed = 1;
  );
  pitch_hot && ui_shift && !ui_wheel_used && abs(ui_wheel) >= 1 ? (
    formant_shift_semi = clamp(formant_shift_semi + (ui_wheel > 0 ? 0.25 : -0.25) * max(1, floor(abs(ui_wheel) / 120 + 0.5)), -12, 12);
    ui_wheel_used = 1;
    ui_value_changed = 1;
  );
) : (
  nv = ui_knob(307, kc, ky, kb_r, slider12, -24, 24, 0, 0.021);
  abs(nv - slider12) > 0.0000001 ? (slider12 = nv; gfx_slider_mask |= MASK_S12;);
);
