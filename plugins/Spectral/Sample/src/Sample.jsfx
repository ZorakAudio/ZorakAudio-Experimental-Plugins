nv = ui_knob(311, kc, ky, kb_r, slider19, 0, 1, 0.35, 0.018); abs(nv - slider19) > 0.0000001 ? (slider19 = nv; gfx_slider_mask |= MASK_S19;);
gfx_setfont(1, "Arial", 10, 0); gfx_r = 0.88; gfx_g = 0.93; gfx_b = 0.98; gfx_a = 1;
