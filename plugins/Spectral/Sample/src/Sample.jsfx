cell_y = knob_panel_top + floor(grid_idx / knob_cols) * (cell_h + knob_row_gap);
kc = cell_x + cell_w * 0.5; ky = cell_y + kb_r + 6; label_y = min(cell_y + cell_h - 12, ky + kb_r + 12);
grain_hot = ((mouse_x - kc) * (mouse_x - kc) + (mouse_y - ky) * (mouse_y - ky)) <= kb_r * kb_r;
(mouse_pressed && grain_hot) ? grain_input_alt_active = ui_shift ? 1 : 0;
(!mouse_down && ui_active != 320) ? grain_input_alt_active = 0;
grain_input_alt_use = grain_input_alt_active || (ui_shift && (grain_hot || ui_active == 320));
grain_input_alt_use ? (
  nv = ui_knob(320, kc, ky, kb_r, input_trigger_amt, 0, 1, 0, 0.018);
