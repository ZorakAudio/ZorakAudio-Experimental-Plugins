// Post-Processing panel: free-band spectrum EQ
PROC_EQ_HPF_ID = 530;
PROC_EQ_B1_ID = 531;
PROC_EQ_B2_ID = 532;
PROC_EQ_B3_ID = 533;
PROC_EQ_LPF_ID = 534;

// Dynamics remains the output density/guard tool; this panel is final EQ only.
post_hot = pt_in(proc_x, proc_y, proc_w, proc_h);
post_hot ? ui_hover_id = 1500;
gfx_setfont(1, "Arial", 16, 0);
gfx_r = 0.88; gfx_g = 0.94; gfx_b = 1.0; gfx_a = 1;
gfx_x = proc_x + 18; gfx_y = proc_y + 16;
gfx_drawstr("POST-PROCESSING");
gfx_r = 0.10; gfx_g = 0.58; gfx_b = 1.0; gfx_a = 0.90; gfx_circle(proc_x + 10, proc_y + 25, 4, 1);
gfx_r = 0.26; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.35; gfx_line(proc_x + 18, proc_y + 39, proc_x + proc_w - 18, proc_y + 39);

proc_inner_x = proc_x + 12;
proc_inner_w = max(150, proc_w - 24);

gfx_setfont(1, "Arial", 11, 0);
gfx_r = 0.62; gfx_g = 0.72; gfx_b = 0.84; gfx_a = 1;
gfx_x = proc_inner_x + 8; gfx_y = proc_y + 45;
gfx_drawstr("Pre/Post spectrum  |  drag bands  |  Ctrl+drag solo  |  wheel Q  |  Shift+wheel slope");
(posteq_solo_target > 0 || posteq_solo_mix > 0.001) ? (
  gfx_r = 1.00; gfx_g = 0.78; gfx_b = 0.20; gfx_a = 0.95;
  gfx_x = proc_inner_x + proc_inner_w - 100; gfx_y = proc_y + 45;
  gfx_drawstr("SOLO");
);

proc_graph_x = proc_inner_x + 8;
proc_graph_y = proc_y + 66;
proc_graph_w = max(100, proc_inner_w - 16);
proc_graph_h = max(260, min(430, proc_h - 172));
proc_cards_y = proc_graph_y + proc_graph_h + 12;
proc_cards_h = max(58, proc_y + proc_h - proc_cards_y - 16);

ui_inner_panel(proc_graph_x, proc_graph_y, proc_graph_w, proc_graph_h);
pt_in(proc_graph_x, proc_graph_y, proc_graph_w, proc_graph_h) ? ui_hover_id = 1501;

// Node positions from sliders.
hpf_x = proc_freq_x(slider38, proc_graph_x, proc_graph_w);
lpf_x = proc_freq_x(slider39, proc_graph_x, proc_graph_w);
b1_x = proc_freq_x(slider35, proc_graph_x, proc_graph_w);
b2_x = proc_freq_x(slider36, proc_graph_x, proc_graph_w);
b3_x = proc_freq_x(slider37, proc_graph_x, proc_graph_w);
hpf_y = proc_db_y(posteq_cut_res_gain_db(slider45), proc_graph_y, proc_graph_h);
lpf_y = proc_db_y(posteq_cut_res_gain_db(slider46), proc_graph_y, proc_graph_h);
b1_y = proc_db_y(slider32, proc_graph_y, proc_graph_h);
b2_y = proc_db_y(slider33, proc_graph_y, proc_graph_h);
b3_y = proc_db_y(slider34, proc_graph_y, proc_graph_h);
node_r = 11;

hot_hpf = ((mouse_x - hpf_x) * (mouse_x - hpf_x) + (mouse_y - hpf_y) * (mouse_y - hpf_y)) <= node_r * node_r * 1.8;
hot_lpf = ((mouse_x - lpf_x) * (mouse_x - lpf_x) + (mouse_y - lpf_y) * (mouse_y - lpf_y)) <= node_r * node_r * 1.8;
hot_b1 = ((mouse_x - b1_x) * (mouse_x - b1_x) + (mouse_y - b1_y) * (mouse_y - b1_y)) <= node_r * node_r * 1.8;
hot_b2 = ((mouse_x - b2_x) * (mouse_x - b2_x) + (mouse_y - b2_y) * (mouse_y - b2_y)) <= node_r * node_r * 1.8;
hot_b3 = ((mouse_x - b3_x) * (mouse_x - b3_x) + (mouse_y - b3_y) * (mouse_y - b3_y)) <= node_r * node_r * 1.8;

// Cards are also valid wheel/reset targets. This makes Q/slope editing usable
// even when the cutoff node is visually parked near the edge of the graph.
pre_card_gap = 5;
pre_card_w = (proc_inner_w - pre_card_gap * 4) / 5;
pre_card_y = proc_cards_y;
pre_card_h = min(64, proc_cards_h);
hot_hpf_ctl = hot_hpf || pt_in(proc_inner_x, pre_card_y, pre_card_w, pre_card_h);
hot_b1_ctl = hot_b1 || pt_in(proc_inner_x + 1 * (pre_card_w + pre_card_gap), pre_card_y, pre_card_w, pre_card_h);
hot_b2_ctl = hot_b2 || pt_in(proc_inner_x + 2 * (pre_card_w + pre_card_gap), pre_card_y, pre_card_w, pre_card_h);
hot_b3_ctl = hot_b3 || pt_in(proc_inner_x + 3 * (pre_card_w + pre_card_gap), pre_card_y, pre_card_w, pre_card_h);
hot_lpf_ctl = hot_lpf || pt_in(proc_inner_x + 4 * (pre_card_w + pre_card_gap), pre_card_y, pre_card_w, pre_card_h);

// Right-click reset.
mouse_rpressed && hot_hpf_ctl ? (slider38 = 20; slider43 = 1; slider45 = 0.707; gfx_slider_mask |= MASK_S38 + MASK_S43 + MASK_S45;);
mouse_rpressed && hot_lpf_ctl ? (slider39 = 20000; slider44 = 1; slider46 = 0.707; gfx_slider_mask |= MASK_S39 + MASK_S44 + MASK_S46;);
mouse_rpressed && hot_b1_ctl ? (slider35 = 120; slider32 = 0; slider40 = 1.15; gfx_slider_mask |= MASK_S35 + MASK_S32 + MASK_S40;);
mouse_rpressed && hot_b2_ctl ? (slider36 = 950; slider33 = 0; slider41 = 1.15; gfx_slider_mask |= MASK_S36 + MASK_S33 + MASK_S41;);
mouse_rpressed && hot_b3_ctl ? (slider37 = 6500; slider34 = 0; slider42 = 1.15; gfx_slider_mask |= MASK_S37 + MASK_S34 + MASK_S42;);

// Wheel: Q for all nodes. Shift+Wheel: cutoff slope for HPF/LPF.
(!ui_wheel_used && abs(ui_wheel) >= 1) ? (
  wdir = ui_wheel > 0 ? 1 : -1;
  wsteps = max(1, floor(abs(ui_wheel) / 120 + 0.5));
  hot_b1_ctl ? (
    slider40 = clamp(slider40 * exp(wdir * wsteps * 0.085), 0.35, 8);
    gfx_slider_mask |= MASK_S40; ui_wheel_used = 1;
  ) : hot_b2_ctl ? (
    slider41 = clamp(slider41 * exp(wdir * wsteps * 0.085), 0.35, 8);
    gfx_slider_mask |= MASK_S41; ui_wheel_used = 1;
  ) : hot_b3_ctl ? (
    slider42 = clamp(slider42 * exp(wdir * wsteps * 0.085), 0.35, 8);
    gfx_slider_mask |= MASK_S42; ui_wheel_used = 1;
  ) : hot_hpf_ctl ? (
    ui_shift ? (
      slider43 = clamp((slider43 | 0) + wdir * wsteps, 0, 4);
      gfx_slider_mask |= MASK_S43;
    ) : (
      slider45 = clamp(slider45 * exp(wdir * wsteps * 0.105), 0.35, 4.0);
      gfx_slider_mask |= MASK_S45;
    );
    ui_wheel_used = 1;
  ) : hot_lpf_ctl ? (
    ui_shift ? (
      slider44 = clamp((slider44 | 0) + wdir * wsteps, 0, 4);
      gfx_slider_mask |= MASK_S44;
    ) : (
      slider46 = clamp(slider46 * exp(wdir * wsteps * 0.105), 0.35, 4.0);
      gfx_slider_mask |= MASK_S46;
    );
    ui_wheel_used = 1;
  );
);

mouse_pressed && ui_active < 0 ? (
  hot_hpf ? (ui_active = PROC_EQ_HPF_ID; ui_ctrl ? posteq_solo_target = 1;);
  hot_b1 ? (ui_active = PROC_EQ_B1_ID; ui_ctrl ? posteq_solo_target = 2;);
  hot_b2 ? (ui_active = PROC_EQ_B2_ID; ui_ctrl ? posteq_solo_target = 3;);
  hot_b3 ? (ui_active = PROC_EQ_B3_ID; ui_ctrl ? posteq_solo_target = 4;);
  hot_lpf ? (ui_active = PROC_EQ_LPF_ID; ui_ctrl ? posteq_solo_target = 5;);
);

ui_active >= PROC_EQ_HPF_ID && ui_active <= PROC_EQ_LPF_ID ? (
  mouse_down ? (
    ui_ctrl ? (
      posteq_solo_target = ui_active == PROC_EQ_HPF_ID ? 1
      : ui_active == PROC_EQ_B1_ID ? 2
      : ui_active == PROC_EQ_B2_ID ? 3
      : ui_active == PROC_EQ_B3_ID ? 4
      : ui_active == PROC_EQ_LPF_ID ? 5
      : 0;
    );
    fine = ui_shift ? 0.22 : 1;
    ui_active == PROC_EQ_HPF_ID ? (
      nv = proc_x_freq(mouse_x, proc_graph_x, proc_graph_w);
      nv = clamp(nv, 20, min(1000, slider39 * 0.72));
      slider38 = slider38 + (nv - slider38) * fine;
      gfx_slider_mask |= MASK_S38;
    );
    ui_active == PROC_EQ_LPF_ID ? (
      nv = proc_x_freq(mouse_x, proc_graph_x, proc_graph_w);
      nv = clamp(nv, max(1000, slider38 * 1.38), 20000);
      slider39 = slider39 + (nv - slider39) * fine;
      gfx_slider_mask |= MASK_S39;
    );
    ui_active == PROC_EQ_B1_ID ? (
      nvf = proc_x_freq(mouse_x, proc_graph_x, proc_graph_w);
      nvg = proc_y_db(mouse_y, proc_graph_y, proc_graph_h);
      slider35 = slider35 + (clamp(nvf, 20, 20000) - slider35) * fine;
      slider32 = slider32 + (clamp(nvg, -18, 18) - slider32) * fine;
      gfx_slider_mask |= MASK_S35 + MASK_S32;
    );
    ui_active == PROC_EQ_B2_ID ? (
      nvf = proc_x_freq(mouse_x, proc_graph_x, proc_graph_w);
      nvg = proc_y_db(mouse_y, proc_graph_y, proc_graph_h);
      slider36 = slider36 + (clamp(nvf, 20, 20000) - slider36) * fine;
      slider33 = slider33 + (clamp(nvg, -18, 18) - slider33) * fine;
      gfx_slider_mask |= MASK_S36 + MASK_S33;
    );
    ui_active == PROC_EQ_B3_ID ? (
      nvf = proc_x_freq(mouse_x, proc_graph_x, proc_graph_w);
      nvg = proc_y_db(mouse_y, proc_graph_y, proc_graph_h);
      slider37 = slider37 + (clamp(nvf, 20, 20000) - slider37) * fine;
      slider34 = slider34 + (clamp(nvg, -18, 18) - slider34) * fine;
      gfx_slider_mask |= MASK_S37 + MASK_S34;
    );
  ) : (
    ui_active = -1;
  );
);

// Recompute after interaction so graph moves immediately.
hpf_x = proc_freq_x(slider38, proc_graph_x, proc_graph_w);
lpf_x = proc_freq_x(slider39, proc_graph_x, proc_graph_w);
b1_x = proc_freq_x(slider35, proc_graph_x, proc_graph_w);
b2_x = proc_freq_x(slider36, proc_graph_x, proc_graph_w);
b3_x = proc_freq_x(slider37, proc_graph_x, proc_graph_w);
hpf_y = proc_db_y(posteq_cut_res_gain_db(slider45), proc_graph_y, proc_graph_h);
lpf_y = proc_db_y(posteq_cut_res_gain_db(slider46), proc_graph_y, proc_graph_h);
b1_y = proc_db_y(slider32, proc_graph_y, proc_graph_h);
b2_y = proc_db_y(slider33, proc_graph_y, proc_graph_h);
b3_y = proc_db_y(slider34, proc_graph_y, proc_graph_h);

// Spectrum underlay first. v28: shared-scale pre/post spectrum.
// Pre is a cool blue ghost. Post is a brighter cyan trace. Both use the same
// visual floor/range so EQ moves show as real spectral movement, not two
// independently normalized curves.
spec_base_y = proc_graph_y + proc_graph_h - 5;
spec_peak_db = -150;
spec_sum_db = 0;
spec_i = 0;
while (spec_i < POSTEQ_SPEC_BINS) (
  spec_pre_db = 20 * log(max(posteq_spec_env_base[spec_i], 0.000000001)) * LOG10_INV;
  spec_post_db = 20 * log(max(posteq_post_env_base[spec_i], 0.000000001)) * LOG10_INV;
  spec_peak_db = max(spec_peak_db, max(spec_pre_db, spec_post_db));
  spec_sum_db += spec_pre_db + spec_post_db;
  spec_i += 1;
);
spec_mean_db = spec_sum_db / max(1, POSTEQ_SPEC_BINS * 2);
spec_active = clamp01((spec_peak_db + 112) / 30);
spec_floor_db = max(-112, min(spec_peak_db - 44, spec_mean_db - 11));
spec_range_db = max(30, spec_peak_db - spec_floor_db);

// Pre-EQ spectrum ghost.
spec_i = 0;
prevx = proc_graph_x;
prevy = spec_base_y;
while (spec_i < POSTEQ_SPEC_BINS) (
  spec_norm = spec_i / max(1, POSTEQ_SPEC_BINS - 1);
  spec_freq = exp(log(32) + spec_norm * (log(19000) - log(32)));
  spec_x = proc_freq_x(spec_freq, proc_graph_x, proc_graph_w);
  spec_db = 20 * log(max(posteq_spec_env_base[spec_i], 0.000000001)) * LOG10_INV;
  spec_n = clamp01((spec_db - spec_floor_db) / spec_range_db);
  spec_n = spec_n ^ 0.90;
  spec_y = spec_base_y - spec_n * (proc_graph_h * 0.82);
  spec_i > 0 ? (
    gfx_r = 0.05; gfx_g = 0.24; gfx_b = 0.58; gfx_a = (0.12 + 0.24 * spec_n) * spec_active;
    gfx_line(prevx, prevy, spec_x, spec_y);
    spec_stem_y = spec_y + (spec_base_y - spec_y) * 0.72;
    gfx_r = 0.04; gfx_g = 0.18; gfx_b = 0.42; gfx_a = (0.025 + 0.070 * spec_n) * spec_active;
    gfx_line(spec_x, spec_stem_y, spec_x, spec_y);
  );
  prevx = spec_x;
  prevy = spec_y;
  spec_i += 1;
);

// Post-EQ spectrum trace.
spec_i = 0;
prevx = proc_graph_x;
prevy = spec_base_y;
while (spec_i < POSTEQ_SPEC_BINS) (
  spec_norm = spec_i / max(1, POSTEQ_SPEC_BINS - 1);
  spec_freq = exp(log(32) + spec_norm * (log(19000) - log(32)));
  spec_x = proc_freq_x(spec_freq, proc_graph_x, proc_graph_w);
  spec_db = 20 * log(max(posteq_post_env_base[spec_i], 0.000000001)) * LOG10_INV;
  spec_n = clamp01((spec_db - spec_floor_db) / spec_range_db);
  spec_n = spec_n ^ 0.82;
  spec_y = spec_base_y - spec_n * (proc_graph_h * 0.86);
  spec_i > 0 ? (
    spec_stem_y = spec_y + (spec_base_y - spec_y) * 0.60;
    gfx_r = 0.08; gfx_g = 0.58; gfx_b = 1.00; gfx_a = (0.040 + 0.125 * spec_n) * spec_active;
    gfx_line(spec_x, spec_stem_y, spec_x, spec_y);

    gfx_r = 0.20; gfx_g = 0.78; gfx_b = 1.00; gfx_a = (0.62 + 0.30 * spec_n) * spec_active;
    gfx_line(prevx, prevy, spec_x, spec_y);

    gfx_r = 0.82; gfx_g = 0.98; gfx_b = 1.00; gfx_a = (0.14 + 0.28 * spec_n) * spec_active;
    gfx_line(prevx, prevy - 1, spec_x, spec_y - 1);
  );
  prevx = spec_x;
  prevy = spec_y;
  spec_i += 1;
);

// EQ grid.
grid_i = 0;
while (grid_i < 8) (
  gf = grid_i == 0 ? 50 : grid_i == 1 ? 100 : grid_i == 2 ? 200 : grid_i == 3 ? 500 : grid_i == 4 ? 1000 : grid_i == 5 ? 2000 : grid_i == 6 ? 5000 : 10000;
  gxv = proc_freq_x(gf, proc_graph_x, proc_graph_w);
  gfx_r = 0.16; gfx_g = 0.26; gfx_b = 0.34; gfx_a = 0.34;
  gfx_line(gxv, proc_graph_y + 8, gxv, proc_graph_y + proc_graph_h - 8);
  gfx_setfont(1, "Arial", 9, 0);
  gfx_r = 0.48; gfx_g = 0.56; gfx_b = 0.64; gfx_a = 0.92;
  gf >= 1000 ? sprintf(#ui_buf, "%dk", floor(gf / 1000)) : sprintf(#ui_buf, "%.0f", gf);
  gfx_measurestr(#ui_buf, tw, th);
  gfx_x = gxv - tw * 0.5; gfx_y = proc_graph_y + 4;
  gfx_drawstr(#ui_buf);
  grid_i += 1;
);

grid_i = -18;
while (grid_i <= 18) (
  gyv = proc_db_y(grid_i, proc_graph_y, proc_graph_h);
  gfx_r = grid_i == 0 ? 0.38 : 0.16; gfx_g = grid_i == 0 ? 0.48 : 0.26; gfx_b = grid_i == 0 ? 0.56 : 0.34; gfx_a = grid_i == 0 ? 0.62 : 0.26;
  gfx_line(proc_graph_x + 8, gyv, proc_graph_x + proc_graph_w - 8, gyv);
  gfx_setfont(1, "Arial", 9, 0);
  gfx_r = 0.48; gfx_g = 0.56; gfx_b = 0.64; gfx_a = 0.92;
  (grid_i % 6 == 0) ? (
    sprintf(#ui_buf, "%+d", grid_i);
    gfx_x = proc_graph_x + 4; gfx_y = gyv - 5;
    gfx_drawstr(#ui_buf);
  );
  grid_i += 3;
);

// Pre/Post legend.
gfx_setfont(1, "Arial", 9, 0);
gfx_r = 0.20; gfx_g = 0.36; gfx_b = 0.78; gfx_a = 0.95;
gfx_x = proc_graph_x + proc_graph_w - 72; gfx_y = proc_graph_y + 22;
gfx_drawstr("pre");
gfx_r = 0.25; gfx_g = 0.86; gfx_b = 1.00; gfx_a = 0.98;
gfx_x = proc_graph_x + proc_graph_w - 44; gfx_y = proc_graph_y + 22;
gfx_drawstr("post");

// EQ response curve.
ci = 0;
prevx = proc_graph_x;
prevy = proc_db_y(proc_eq_resp_db(20), proc_graph_y, proc_graph_h);
while (ci <= 128) (
  cn = ci / 128;
  cf = exp(log(20) + cn * (log(20000) - log(20)));
  cxv = proc_graph_x + cn * proc_graph_w;
  cyv = proc_db_y(proc_eq_resp_db(cf), proc_graph_y, proc_graph_h);
  gfx_r = 0.05; gfx_g = 0.03; gfx_b = 0.01; gfx_a = 0.65;
  gfx_line(prevx, prevy + 1, cxv, cyv + 1);
  gfx_r = 0.98; gfx_g = 0.72; gfx_b = 0.19; gfx_a = 0.98;
  gfx_line(prevx, prevy, cxv, cyv);
  prevx = cxv; prevy = cyv;
  ci += 1;
);

// Cutoff guide lines.
gfx_r = 0.82; gfx_g = 0.64; gfx_b = 0.24; gfx_a = slider38 > 22 ? 0.58 : 0.18;
gfx_line(hpf_x, proc_graph_y + 20, hpf_x, proc_graph_y + proc_graph_h - 20);
gfx_r = 0.82; gfx_g = 0.64; gfx_b = 0.24; gfx_a = slider39 < 19000 ? 0.58 : 0.18;
gfx_line(lpf_x, proc_graph_y + 20, lpf_x, proc_graph_y + proc_graph_h - 20);

proc_draw_node(hpf_x, hpf_y, node_r, hot_hpf, ui_active == PROC_EQ_HPF_ID, 0);
proc_draw_node(b1_x, b1_y, node_r, hot_b1, ui_active == PROC_EQ_B1_ID, 1);
proc_draw_node(b2_x, b2_y, node_r, hot_b2, ui_active == PROC_EQ_B2_ID, 2);
proc_draw_node(b3_x, b3_y, node_r, hot_b3, ui_active == PROC_EQ_B3_ID, 3);
proc_draw_node(lpf_x, lpf_y, node_r, hot_lpf, ui_active == PROC_EQ_LPF_ID, 4);

// Specific node hover IDs for clear tooltips.
hot_hpf_ctl || ui_active == PROC_EQ_HPF_ID ? ui_hover_id = PROC_EQ_HPF_ID;
hot_b1_ctl || ui_active == PROC_EQ_B1_ID ? ui_hover_id = PROC_EQ_B1_ID;
hot_b2_ctl || ui_active == PROC_EQ_B2_ID ? ui_hover_id = PROC_EQ_B2_ID;
hot_b3_ctl || ui_active == PROC_EQ_B3_ID ? ui_hover_id = PROC_EQ_B3_ID;
hot_lpf_ctl || ui_active == PROC_EQ_LPF_ID ? ui_hover_id = PROC_EQ_LPF_ID;

// Bottom cards.
card_gap = 5;
card_w = (proc_inner_w - card_gap * 4) / 5;
card_y = proc_cards_y;
card_h = min(64, proc_cards_h);
ci = 0;
while (ci < 5) (
  cxv = proc_inner_x + ci * (card_w + card_gap);
  ui_value_pill(cxv, card_y, card_w, card_h);
  card_id = ci == 0 ? PROC_EQ_HPF_ID : ci == 1 ? PROC_EQ_B1_ID : ci == 2 ? PROC_EQ_B2_ID : ci == 3 ? PROC_EQ_B3_ID : PROC_EQ_LPF_ID;
  pt_in(cxv, card_y, card_w, card_h) ? ui_hover_id = card_id;
  gfx_setfont(1, "Arial", 9, 0);
  gfx_r = 0.54; gfx_g = 0.64; gfx_b = 0.74; gfx_a = 1;
  ci == 0 ? sprintf(#ui_buf, "HPF") : ci == 1 ? sprintf(#ui_buf, "BAND 1") : ci == 2 ? sprintf(#ui_buf, "BAND 2") : ci == 3 ? sprintf(#ui_buf, "BAND 3") : sprintf(#ui_buf, "LPF");
  draw_center_buf(cxv, card_y + 7, card_w);
  gfx_setfont(1, "Arial", 9, 0);
  gfx_r = 0.88; gfx_g = 0.94; gfx_b = 1.0; gfx_a = 1;
  ci == 0 ? (slider38 <= 22 ? sprintf(#ui_buf, "off") : sprintf(#ui_buf, "%.0f Hz", slider38))
  : ci == 1 ? sprintf(#ui_buf, "%.0fHz %+.1f", slider35, slider32)
  : ci == 2 ? sprintf(#ui_buf, "%.0fHz %+.1f", slider36, slider33)
  : ci == 3 ? sprintf(#ui_buf, "%.0fHz %+.1f", slider37, slider34)
  : (slider39 >= 19000 ? sprintf(#ui_buf, "off") : sprintf(#ui_buf, "%.0f Hz", slider39));
  draw_center_buf(cxv, card_y + 27, card_w);
  gfx_r = 0.62; gfx_g = 0.72; gfx_b = 0.84; gfx_a = 1;
  ci == 0 ? sprintf(#ui_buf, "Q%.2f +%.1fdB", slider45, posteq_cut_res_gain_db(slider45))
  : ci == 1 ? sprintf(#ui_buf, "Q %.2f", slider40)
  : ci == 2 ? sprintf(#ui_buf, "Q %.2f", slider41)
  : ci == 3 ? sprintf(#ui_buf, "Q %.2f", slider42)
  : sprintf(#ui_buf, "Q%.2f +%.1fdB", slider46, posteq_cut_res_gain_db(slider46));
  draw_center_buf(cxv, card_y + 45, card_w);
  ci += 1;
);


// GroupSync strict-order popup. This is intentionally lightweight: peers are
// numeric IDs in the same Auto Track Name group; drag rows to numbered ranks.
group_popup_open ? (
  pop_w = min(560, max(420, gfx_w - 80));
  pop_h = min(520, max(360, gfx_h - 110));
  pop_x = max(20, gfx_w - pop_w - 24);
  pop_y = 96;

  gfx_r = 0; gfx_g = 0; gfx_b = 0; gfx_a = 0.58;
  gfx_rect(pop_x + 5, pop_y + 8, pop_w, pop_h, 1);
  ui_panel(pop_x, pop_y, pop_w, pop_h);

  gfx_setfont(1, "Arial", 17, 0);
  gfx_r = 0.92; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
  gfx_x = pop_x + 18; gfx_y = pop_y + 14;
  gfx_drawstr("GROUP ORDER");
  gfx_setfont(1, "Arial", 12, 0);
  gfx_r = 0.64; gfx_g = 0.74; gfx_b = 0.85; gfx_a = 1;
  gfx_x = pop_x + 18; gfx_y = pop_y + 38;
  gfx_drawstr(#group_name);
  gfx_x = pop_x + 18; gfx_y = pop_y + 52;
  sprintf(#ui_buf, "this ID %d | leader %d", group_instance_id, group_leader_id);
  gfx_drawstr(#ui_buf);

  mode_y = pop_y + 62;
  mode_w = floor((pop_w - 48) / 2);
  ui_button(GROUP_UI_MODE_STRICT_ID, pop_x + 16, mode_y, mode_w, 26) ? group_set_mode_for_group(1);
  ui_button(GROUP_UI_MODE_FREE_ID, pop_x + 24 + mode_w, mode_y, mode_w, 26) ? group_set_mode_for_group(0);
  gfx_setfont(1, "Arial", 11, 0);
  gfx_r = group_strict_active ? 1.0 : 0.58; gfx_g = group_strict_active ? 0.78 : 0.70; gfx_b = group_strict_active ? 0.24 : 0.82; gfx_a = 1;
  sprintf(#ui_buf, "STRICT"); draw_center_buf(pop_x + 16, mode_y + 8, mode_w);
  gfx_r = group_strict_active ? 0.58 : 1.0; gfx_g = group_strict_active ? 0.70 : 0.78; gfx_b = group_strict_active ? 0.82 : 0.24; gfx_a = 1;
  sprintf(#ui_buf, "UNORDERED"); draw_center_buf(pop_x + 24 + mode_w, mode_y + 8, mode_w);

  hint_y = mode_y + 36;
  ui_inner_panel(pop_x + 16, hint_y, pop_w - 32, 42);
  gfx_setfont(1, "Arial", 11, 0);
  gfx_r = 0.70; gfx_g = 0.80; gfx_b = 0.90; gfx_a = 1;
  gfx_x = pop_x + 28; gfx_y = hint_y + 8;
  gfx_drawstr("Drag rows into Step lanes. Same lane = parallel. Drag to Unordered to remove strict rank.");
  gfx_x = pop_x + 28; gfx_y = hint_y + 24;
  gfx_drawstr("Strict order currently gates Granular Input Env texture triggers.");

  // Drop zones.
  unordered_x = pop_x + 16;
  unordered_y = hint_y + 58;
  unordered_w = pop_w - 32;
  unordered_h = 70;
  ui_inner_panel(unordered_x, unordered_y, unordered_w, unordered_h);
  gfx_setfont(1, "Arial", 12, 0);
  gfx_r = 0.60; gfx_g = 0.70; gfx_b = 0.82; gfx_a = 1;
  gfx_x = unordered_x + 10; gfx_y = unordered_y + 8;
  gfx_drawstr("UNORDERED");
  pt_in(unordered_x, unordered_y, unordered_w, unordered_h) ? ui_hover_id = GROUP_UI_UNORDERED_DROP_ID;

  lanes_x = pop_x + 16;
  lanes_y = unordered_y + unordered_h + 14;
  lane_gap = 8;
  lane_h = 56;
  lane_w = unordered_w;
  rank_i = 1;
  while (rank_i <= 4) (
    ly = lanes_y + (rank_i - 1) * (lane_h + lane_gap);
    ui_inner_panel(lanes_x, ly, lane_w, lane_h);
    gfx_setfont(1, "Arial", 11, 0);
    gfx_r = 0.96; gfx_g = 0.74; gfx_b = 0.22; gfx_a = 1;
    gfx_x = lanes_x + 10; gfx_y = ly + 8;
    sprintf(#ui_buf, "STEP %d", rank_i); gfx_drawstr(#ui_buf);
    pt_in(lanes_x, ly, lane_w, lane_h) ? ui_hover_id = GROUP_UI_RANK_DROP_BASE + rank_i;
    rank_i += 1;
  );

  // Draw peer rows into either unordered strip or strict rank lanes.
  clk = gmem[GROUP_CLOCK_SLOT];
  unordered_count = 0;
  lane_count1 = 0; lane_count2 = 0; lane_count3 = 0; lane_count4 = 0;
  peer_i = 0;
  while (peer_i < GROUP_MAX_PEERS) (
    pb = group_peer_base(peer_i);
    pid = gmem[pb + GROUP_F_ID] | 0;
    phash = gmem[pb + GROUP_F_HASH] | 0;
    pheart = gmem[pb + GROUP_F_HEART];
    (pid > 0 && phash == group_name_hash && (clk - pheart) <= GROUP_STALE_TICKS) ? (
      prank = clamp(gmem[pb + GROUP_F_RANK] | 0, 0, 4);
      pact = gmem[pb + GROUP_F_ACTIVE] > 0 ? 1 : 0;
      pstr = gmem[pb + GROUP_F_STRENGTH];
      prank <= 0 ? (
        row_x = unordered_x + 12 + unordered_count * 126;
        row_y = unordered_y + 30;
        row_w = min(118, unordered_w - 24);
        unordered_count += 1;
      ) : (
        ly = lanes_y + (prank - 1) * (lane_h + lane_gap);
        prank == 1 ? (idx_in_lane = lane_count1; lane_count1 += 1;)
        : prank == 2 ? (idx_in_lane = lane_count2; lane_count2 += 1;)
        : prank == 3 ? (idx_in_lane = lane_count3; lane_count3 += 1;)
        : (idx_in_lane = lane_count4; lane_count4 += 1;);
        row_x = lanes_x + 74 + idx_in_lane * 126;
        row_y = ly + 26;
        row_w = min(118, lane_w - 88);
      );
      row_h = 22;
      row_w > 36 ? (
        is_drag = group_drag_id == pid ? 1 : 0;
        gfx_r = pid == group_leader_id ? 0.45 : (is_drag ? 0.18 : 0.10);
        gfx_g = pid == group_leader_id ? 0.35 : (is_drag ? 0.42 : 0.18);
        gfx_b = pid == group_leader_id ? 0.10 : (is_drag ? 0.64 : 0.25);
        gfx_a = 0.95;
        gfx_rect(row_x, row_y, row_w, row_h, 1);
        gfx_r = pid == group_leader_id ? 0.95 : 0.28; gfx_g = pid == group_leader_id ? 0.70 : 0.58; gfx_b = pid == group_leader_id ? 0.22 : 0.90; gfx_a = 1;
        gfx_rect(row_x, row_y, row_w, row_h, 0);
        gfx_setfont(1, "Arial", 10, 0);
        gfx_x = row_x + 5; gfx_y = row_y + 5;
        gfx_r = 0.86; gfx_g = 0.92; gfx_b = 1.0; gfx_a = 1;
        sprintf(#ui_buf, "≡ %d", pid); gfx_drawstr(#ui_buf);
        pact ? (
          gfx_r = 0.30; gfx_g = 1.0; gfx_b = 0.55; gfx_a = 1;
          gfx_circle(row_x + row_w - 12, row_y + 11, 3, 1);
        );
        (mouse_pressed && pt_in(row_x, row_y, row_w, row_h) && ui_active < 0) ? (
          group_drag_id = pid;
          group_drag_slot = peer_i;
          ui_active = GROUP_UI_ROW_BASE + peer_i;
        );
        mouse_rpressed && pt_in(row_x, row_y, row_w, row_h) ? group_set_rank_for_id(pid, 0);
        pt_in(row_x, row_y, row_w, row_h) ? ui_hover_id = GROUP_UI_ROW_BASE + peer_i;
      );
    );
    peer_i += 1;
  );

  // Commit drag release to a drop zone.
  group_drag_id > 0 ? (
    !mouse_down ? (
      drop_rank = -1;
      pt_in(unordered_x, unordered_y, unordered_w, unordered_h) ? drop_rank = 0;
      rank_i = 1;
      while (rank_i <= 4) (
        ly = lanes_y + (rank_i - 1) * (lane_h + lane_gap);
        pt_in(lanes_x, ly, lane_w, lane_h) ? drop_rank = rank_i;
        rank_i += 1;
      );
      drop_rank >= 0 ? group_set_rank_for_id(group_drag_id, drop_rank);
      ui_active >= GROUP_UI_ROW_BASE && ui_active < GROUP_UI_ROW_BASE + GROUP_MAX_PEERS ? ui_active = -1;
      group_drag_id = -1;
      group_drag_slot = -1;
    ) : (
      gfx_r = 1.0; gfx_g = 0.78; gfx_b = 0.25; gfx_a = 0.95;
      gfx_circle(mouse_x, mouse_y, 5, 1);
    );
  );
);

rescan_flash > 0 ? rescan_flash = max(0, rescan_flash - 0.035);
rescan_flash > 0 ? (
  gfx_r = 0.35; gfx_g = 0.74; gfx_b = 0.98; gfx_a = rescan_flash * 0.65;
  gfx_circle(lamp_x, lamp_y + 12, 11 + rescan_flash * 10, 0);
  gfx_a = rescan_flash * 0.22;
  gfx_rect(x0, y0, gfx_w - 36, header_h, 0);
);

