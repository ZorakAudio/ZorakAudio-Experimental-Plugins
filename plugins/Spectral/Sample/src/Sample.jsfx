grid_i = 1;
while (grid_i < 8) (
  gfx_r = 0.12; gfx_g = 0.27; gfx_b = 0.38; gfx_a = 0.22;
  gfx_line(graph_x + (graph_w * grid_i / 8), graph_y + 8, graph_x + (graph_w * grid_i / 8), graph_y + graph_h - 8);
  grid_i += 1;
);
grid_i = 1;
while (grid_i < 5) (
  gfx_r = 0.12; gfx_g = 0.27; gfx_b = 0.38; gfx_a = 0.20;
  gfx_line(graph_x + 8, graph_y + (graph_h * grid_i / 5), graph_x + graph_w - 8, graph_y + (graph_h * grid_i / 5));
  grid_i += 1;
);

an = curve_norm(slider2, 0.1, 500, CURVE_TIME);
hn = slider20 <= 0.5 ? 0 : curve_norm(max(slider20, 1), 1, 2000, CURVE_TIME);
dn = curve_norm(slider3, 1, 5000, CURVE_TIME);
rn = curve_norm(slider5, 5, 5000, CURVE_TIME);
susn = 0.18;
sumw = an * 0.72 + hn * 0.55 + dn * 0.88 + susn + rn * 1.05 + 0.2;
p0x = graph_x + 14; p0y = graph_y + graph_h - 18;
p1x = p0x + (graph_w - 28) * (an * 0.72) / sumw; p1y = graph_y + 18;
p2x = p1x + (graph_w - 28) * (hn * 0.55) / sumw; p2y = p1y;
p3x = p2x + (graph_w - 28) * (dn * 0.88) / sumw; p3y = graph_y + graph_h - 18 - (graph_h - 36) * sustain_level;
p4x = p3x + (graph_w - 28) * susn / sumw; p4y = p3y;
p5x = graph_x + graph_w - 14; p5y = graph_y + graph_h - 18;

gfx_r = 0.18; gfx_g = 0.22; gfx_b = 0.28; gfx_a = 1;
gfx_line(graph_x + 14, graph_y + graph_h - 18, graph_x + graph_w - 14, graph_y + graph_h - 18);
gfx_line(graph_x + 14, graph_y + 18, graph_x + 14, graph_y + graph_h - 18);

gfx_r = 0.05; gfx_g = 0.45; gfx_b = 1.00; gfx_a = 0.25;
draw_curve_line(p0x - 1, p0y, p1x - 1, p1y, env_segment_slope(attack_slope_pct, ENV_RISE));
gfx_line(p1x - 1, p1y, p2x - 1, p2y);
draw_curve_line(p2x - 1, p2y, p3x - 1, p3y, env_segment_slope(decay_slope_pct, ENV_FALL));
gfx_line(p3x - 1, p3y, p4x - 1, p4y);
draw_curve_line(p4x - 1, p4y, p5x - 1, p5y, env_segment_slope(release_slope_pct, ENV_FALL));
gfx_r = 0.36; gfx_g = 0.78; gfx_b = 1.00; gfx_a = 1;
draw_curve_line(p0x, p0y, p1x, p1y, env_segment_slope(attack_slope_pct, ENV_RISE));
gfx_line(p1x, p1y, p2x, p2y);
draw_curve_line(p2x, p2y, p3x, p3y, env_segment_slope(decay_slope_pct, ENV_FALL));
gfx_line(p3x, p3y, p4x, p4y);
draw_curve_line(p4x, p4y, p5x, p5y, env_segment_slope(release_slope_pct, ENV_FALL));
gfx_circle(p1x, p1y, 3, 1); gfx_circle(p3x, p3y, 3, 1); gfx_circle(p5x, p5y, 3, 1);

for_y = graph_y + graph_h - 18 - (graph_h - 36) * sustain_level;
gfx_r = 0.26; gfx_g = 0.52; gfx_b = 0.74; gfx_a = 0.6;
gfx_line(graph_x + 14, for_y, graph_x + graph_w - 14, for_y);

gfx_setfont(1, "Arial", 14, 0);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
sprintf(#ui_buf, "A %.1f ms   H %.0f ms   D %.0f ms   S %.0f%%   R %.0f ms", slider2, slider20, slider3, slider4 * 100, slider5);
gfx_x = graph_x; gfx_y = graph_y + graph_h + 8;
gfx_drawstr(#ui_buf);
pt_in(graph_x, graph_y, graph_w, graph_h) ? ui_hover_id = 1301;

adsr_y = mid_y + 290;
adsr_h = max(120, mid_h - 310);
track_count = 5;
adsr_inner_w = mid_w - 40;
track_w = clamp(floor((adsr_inner_w - 14 * (track_count - 1)) / track_count), 20, 28);
track_gap = max(10, (adsr_inner_w - track_w * track_count) / max(1, track_count - 1));
track_x = mid_x + 20;

nv = ui_vslider(201, track_x, adsr_y, track_w, adsr_h, slider2, 0.1, 500, CURVE_TIME, 3, 0.020); abs(nv - slider2) > 0.0000001 ? (slider2 = nv; gfx_slider_mask |= MASK_S2;);
nv = ui_shift_wheel_slope(201, slider28, 100); abs(nv - slider28) > 0.0000001 ? (slider28 = nv; gfx_slider_mask |= MASK_S28;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("A");
sprintf(#ui_buf, "%.1f", slider2); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(205, track_x, adsr_y, track_w, adsr_h, slider20, 0, 2000, CURVE_LINEAR, 20, 0.015); abs(nv - slider20) > 0.0000001 ? (slider20 = nv; gfx_slider_mask |= MASK_S20;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("H");
sprintf(#ui_buf, "%.0f", slider20); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(202, track_x, adsr_y, track_w, adsr_h, slider3, 1, 5000, CURVE_TIME, 110, 0.020); abs(nv - slider3) > 0.0000001 ? (slider3 = nv; gfx_slider_mask |= MASK_S3;);
nv = ui_shift_wheel_slope(202, slider29, -100); abs(nv - slider29) > 0.0000001 ? (slider29 = nv; gfx_slider_mask |= MASK_S29;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("D");
sprintf(#ui_buf, "%.0f", slider3); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(203, track_x, adsr_y, track_w, adsr_h, slider4, 0, 1, CURVE_SUSTAIN, 0.82, 0.018); abs(nv - slider4) > 0.0000001 ? (slider4 = nv; gfx_slider_mask |= MASK_S4;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("S");
sprintf(#ui_buf, "%.0f%%", slider4 * 100); gfx_x = track_x + (track_w - 28) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(204, track_x, adsr_y, track_w, adsr_h, slider5, 5, 5000, CURVE_TIME, 180, 0.020); abs(nv - slider5) > 0.0000001 ? (slider5 = nv; gfx_slider_mask |= MASK_S5;);
nv = ui_shift_wheel_slope(204, slider30, -100); abs(nv - slider30) > 0.0000001 ? (slider30 = nv; gfx_slider_mask |= MASK_S30;);
